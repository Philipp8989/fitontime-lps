---
// Gemeinsames Layout für die 3 Stoffwechsel-Ergebnis-Pages (staemmig, soft, zierlich).
// Identische Struktur und Styling, nur Inhalt kommt aus Props.
import CookieBanner from '../components/CookieBanner.astro';

export interface Props {
  typ: 'staemmig' | 'soft' | 'zierlich';
  label: string;        // z.B. "Langsamer Stoffwechsel"
  title: string;        // z.B. "Der Speichertyp"
  summary: string;      // Profil-Zusammenfassung
  food: string;
  move: string;
  time: string;
  mistake: string;
  videoId: string;      // Wistia-ID für diesen Typ
  bodyColor?: string;   // optionaler Tint pro Typ (default accent)
}

const { typ, label, title, summary, food, move, time, mistake, videoId } = Astro.props;
const impressumUrl = 'https://fitontime.ch/impressum-datenschutz';
const datenschutzUrl = 'https://fitontime.ch/impressum-datenschutz';

const imageSrc = `/images/bodytypes/${typ}.png`;
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#1d73d3" />
  <title>Dein Ergebnis: {title} | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --card: #ffffff;
      --border: #e8e4da;
      --accent: #1d73d3;
      --accent-dark: #155aa8;
      --accent-soft: #eaf2fc;
      --green: #16a34a;
      --amber: #f59e0b;
      --red: #dc2626;
      --text: #0f172a;
      --text-2: #475569;
      --text-3: #94a3b8;
      --r: 16px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
      --shadow-sm: 0 2px 8px rgba(15,23,42,0.04);
      --shadow-md: 0 6px 20px rgba(29,115,211,0.14);
      --shadow-lg: 0 12px 28px rgba(29,115,211,0.22);
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    button:focus-visible, a:focus-visible { outline: 3px solid var(--accent); outline-offset: 3px; border-radius: 6px; }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; scroll-behavior: auto !important; }
    }

    .wrap { max-width: 760px; margin: 0 auto; padding: 0 20px; }

    /* Header */
    .top-bar { position: sticky; top: 0; background: rgba(255,255,255,0.94); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); z-index: 50; }
    .top-inner { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; max-width: 1040px; margin: 0 auto; }
    .top-inner img { height: 32px; }
    .top-inner .done-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: var(--green); background: #ecfdf5; padding: 5px 10px; border-radius: 20px; }

    /* Hero */
    .result-hero { text-align: center; padding: 32px 0 24px; }
    .rh-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--accent); color: #fff; font-size: 11px; font-weight: 800; padding: 7px 16px; border-radius: 20px; margin-bottom: 16px; letter-spacing: 0.6px; text-transform: uppercase; box-shadow: var(--shadow-md); }
    .rh-visual { display: flex; align-items: center; justify-content: center; gap: 20px; margin: 8px 0 18px; }
    .rh-visual .silhouette { width: 180px; height: 180px; display: flex; align-items: center; justify-content: center; background: #fff; border-radius: 20px; position: relative; overflow: hidden; box-shadow: var(--shadow-md); flex-shrink: 0; padding: 10px; }
    .rh-visual .silhouette img { width: 100%; height: 100%; object-fit: contain; mix-blend-mode: multiply; }
    .rh-meta { text-align: left; }
    .rh-meta .r-label { font-size: 12px; color: var(--text-3); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .rh-meta h1 { font-size: 28px; font-weight: 900; line-height: 1.15; letter-spacing: -0.5px; color: var(--accent); margin-bottom: 8px; }
    .rh-meta .r-greet { font-size: 14px; color: var(--text-2); font-weight: 500; }
    .rh-meta .r-greet b { color: var(--text); }
    @media (max-width: 540px) {
      .rh-visual { flex-direction: column; gap: 12px; }
      .rh-meta { text-align: center; }
      .rh-visual .silhouette { width: 160px; height: 160px; }
    }

    .r-summary { font-size: 15px; color: var(--text-2); line-height: 1.6; max-width: 560px; margin: 0 auto; text-align: center; }

    /* Video */
    .video-wrap { margin: 26px 0; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-lg); background: #000; aspect-ratio: 16/9; max-width: 760px; margin-left: auto; margin-right: auto; }

    /* Pillars */
    .pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 22px 0; }
    .pillar { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 16px; box-shadow: var(--shadow-sm); }
    .pillar .p-ic { font-size: 24px; margin-bottom: 8px; }
    .pillar h4 { font-size: 14px; font-weight: 800; margin-bottom: 6px; color: var(--text); }
    .pillar p { font-size: 13px; color: var(--text-2); line-height: 1.5; }

    /* Scarcity */
    .scarcity { background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412; padding: 14px 16px; border-radius: 12px; font-size: 13px; font-weight: 600; margin: 18px 0; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .scarcity b { color: #7c2d12; font-weight: 800; }

    /* CTA-Block */
    .cta-block { background: linear-gradient(135deg, var(--accent) 0%, #3b92f0 100%); border-radius: var(--r); padding: 26px 22px; color: #fff; text-align: center; margin: 22px 0; box-shadow: var(--shadow-lg); }
    .cta-block h3 { color: #fff; font-size: 22px; font-weight: 900; margin-bottom: 8px; letter-spacing: -0.3px; }
    .cta-block p { color: rgba(255,255,255,0.95); font-size: 15px; margin-bottom: 16px; line-height: 1.5; }
    .cta-btn { background: #fff; color: var(--accent); font-family: var(--font); font-size: 17px; font-weight: 800; padding: 18px 28px; border: none; border-radius: 12px; cursor: pointer; display: inline-block; width: 100%; max-width: 360px; text-decoration: none; text-align: center; transition: all 0.2s; box-shadow: 0 4px 14px rgba(0,0,0,0.2); }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }
    .cta-block .c-sub { font-size: 12px; color: rgba(255,255,255,0.8); margin-top: 10px; }

    /* Booking */
    .booking-wrap { margin: 22px 0; min-height: 420px; background: var(--card); border: 1px solid var(--border); border-radius: var(--r); padding: 14px; box-shadow: var(--shadow-sm); }
    .booking-wrap h3 { font-size: 17px; font-weight: 800; text-align: center; margin-bottom: 12px; }

    /* Was-du-bekommst Liste */
    .want-section { background: var(--card); border: 1px solid var(--border); border-radius: var(--r); padding: 20px; margin: 22px 0; box-shadow: var(--shadow-sm); }
    .want-section h3 { font-size: 18px; font-weight: 800; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .want-list { list-style: none; }
    .want-list li { font-size: 14px; color: var(--text-2); padding: 8px 0; display: flex; align-items: flex-start; gap: 12px; line-height: 1.5; border-bottom: 1px solid var(--border); }
    .want-list li:last-child { border-bottom: none; }
    .want-list li::before { content: '✓'; color: var(--green); font-weight: 800; flex-shrink: 0; font-size: 16px; background: #ecfdf5; width: 22px; height: 22px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-top: 1px; }

    /* Trust-Row */
    .trust-row { display: flex; align-items: center; justify-content: center; gap: 18px; flex-wrap: wrap; padding: 14px 0; font-size: 12px; color: var(--text-3); }
    .trust-row .t-item { display: inline-flex; align-items: center; gap: 6px; }
    .trust-row b { color: var(--text-2); font-weight: 700; }

    footer { text-align: center; padding: 24px 20px 32px; font-size: 11px; color: var(--text-3); }
    footer a { color: var(--text-3); text-decoration: none; }

    @media (min-width: 640px) {
      .rh-meta h1 { font-size: 36px; }
      .pillars { grid-template-columns: 1fr 1fr 1fr 1fr; }
    }
  </style>
</head>
<body>

  <header class="top-bar">
    <div class="top-inner">
      <img src="/images/logo.png" alt="Fit on Time" />
      <span class="done-tag">✓ Dein Ergebnis</span>
    </div>
  </header>

  <main class="wrap">

    <!-- Hero mit Silhouette + Profil -->
    <section class="result-hero">
      <div class="rh-badge">⚡ Dein Stoffwechsel-Typ</div>
      <div class="rh-visual">
        <div class="silhouette">
          <img src={imageSrc} alt="" />
        </div>
        <div class="rh-meta">
          <div class="r-label">{label}</div>
          <h1>{title}</h1>
          <div class="r-greet" id="greet">Dein persönliches Profil ist fertig.</div>
        </div>
      </div>
      <p class="r-summary" id="rSummary">{summary}</p>
    </section>

    <!-- Video -->
    <div class="video-wrap" id="videoWrap">
      <div class={`wistia_embed wistia_async_${videoId}`} style="width:100%;height:100%;"></div>
    </div>

    <!-- 4 Pillars -->
    <div class="pillars">
      <div class="pillar"><div class="p-ic">🍽️</div><h4>Ernährung</h4><p>{food}</p></div>
      <div class="pillar"><div class="p-ic">💪</div><h4>Bewegung</h4><p>{move}</p></div>
      <div class="pillar"><div class="p-ic">⏱️</div><h4>Timing</h4><p>{time}</p></div>
      <div class="pillar"><div class="p-ic">⚠️</div><h4>Dein Fehler</h4><p>{mistake}</p></div>
    </div>

    <!-- Scarcity -->
    <div class="scarcity">🔥 <span>Nur <b id="spots">7</b> freie Termine diese Woche &middot; Rückmeldung in 24h</span></div>

    <!-- CTA -->
    <div class="cta-block">
      <h3>Kostenlose Standortbestimmung</h3>
      <p>Wir gehen gemeinsam durch dein Profil und zeigen dir den nächsten Schritt, individuell für dich.</p>
      <a href="#booking" class="cta-btn" onclick="document.getElementById('booking').scrollIntoView({behavior:'smooth'}); return false;">Termin sichern →</a>
      <div class="c-sub">100% kostenlos · unverbindlich · in 15 Minuten</div>
    </div>

    <!-- Booking -->
    <div class="booking-wrap" id="booking">
      <h3>Termin auswählen</h3>
      <div id="ycbm-container"></div>
    </div>

    <!-- Was du bekommst -->
    <div class="want-section">
      <h3>📝 Das bekommst du im Gespräch</h3>
      <ul class="want-list">
        <li>Einen individuellen Fahrplan für die nächsten 6 Wochen, passend zu deinem Körper.</li>
        <li>Wie du ohne Kalorienzählen oder Disziplinkampf abnimmst.</li>
        <li>Wie du an den typischen <slot name="problem-zonen">Problemzonen</slot> gezielt Fett verlierst.</li>
        <li>Wie du langfristig schlank bleibst, ohne Jojo-Effekt.</li>
      </ul>
    </div>

    <div class="trust-row">
      <span class="t-item">🔒 <b>SSL-verschlüsselt</b></span>
      <span class="t-item">⭐⭐⭐⭐⭐ <b>5.000+</b> Teilnehmerinnen</span>
      <span class="t-item">🇨🇭 aus der <b>Schweiz</b></span>
    </div>

    <footer>
      <a href={impressumUrl} target="_blank" rel="noopener">Impressum</a> &middot;
      <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutzerklärung</a>
    </footer>

  </main>

  <script is:inline>
    // Begrüssung personalisieren, wenn wir Daten aus dem Quiz haben
    try {
      var raw = sessionStorage.getItem('fot_result');
      if (raw) {
        var data = JSON.parse(raw);
        if (data && data.name) {
          var g = document.getElementById('greet');
          if (g) g.innerHTML = '<b>' + data.name + '</b>, dein persönliches Profil ist fertig.';
        }
        if (data && data.problem) {
          // Problem-spezifische Summary-Verlängerung
          var extra = '';
          if (data.problem === 'hunger') extra = ' Dein Heisshunger deutet auf schwankenden Blutzucker hin, das lösen wir mit dem richtigen Mahlzeiten-Timing.';
          else if (data.problem === 'jojo') extra = ' Der Jojo-Effekt zeigt: Bisherige Ansätze haben deinen Typ ignoriert. Unser Ansatz setzt genau da an.';
          else if (data.problem === 'sport') extra = ' Wenn Sport nicht wirkt, stimmt das Verhältnis zwischen Training und Ernährung nicht, genau das optimieren wir.';
          else if (data.problem === 'moti') extra = ' Die Motivation bricht ein, wenn dein Plan zu viel von dir will. Deiner wird an deinen Alltag angepasst.';
          if (extra) {
            var s = document.getElementById('rSummary');
            if (s) s.textContent = s.textContent + extra;
          }
        }
      }
    } catch (e) {}

    // Scarcity leicht variieren
    (function(){
      var s = document.getElementById('spots');
      if (s) s.textContent = 5 + Math.floor(Math.random() * 4);
    })();

    // Wistia laden
    (function(){
      var ws = document.createElement('script');
      ws.src = 'https://fast.wistia.com/assets/external/E-v1.js';
      ws.async = true;
      document.head.appendChild(ws);
    })();

    // YCBM-Kalender
    (function(){
      var ys = document.createElement('script');
      ys.src = 'https://embed.ycb.me';
      ys.async = true;
      ys.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
      ys.setAttribute('data-displaymode', 'auto');
      document.getElementById('ycbm-container').appendChild(ys);
    })();

    // Tracking: result_shown (LP-Machine Pattern)
    (function(){
      var tries = 0;
      function fire(){
        if (window.__lp) {
          window.__lp.track('result_shown', { page: 'stoffwechsel-result', typ: document.body.dataset.typ }, 'fot', 'Stoffwechsel Result');
        } else if (tries++ < 40) setTimeout(fire, 50);
      }
      fire();
    })();
  </script>

  {/* Hyros essential */}
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <CookieBanner
    metaPixelId="1349136525891811"
    consentKey="fot_stoffwechsel_consent"
    impressumUrl={impressumUrl}
    datenschutzUrl={datenschutzUrl}
  />

  <script is:inline define:vars={{ typ }}>
    document.body.dataset.typ = typ;
  </script>
</body>
</html>
