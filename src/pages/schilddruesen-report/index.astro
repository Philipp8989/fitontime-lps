---
// Schilddrüsen-Report Funnel — Landing Page + Quiz + Lead-Formular
// Feminines, stilvolles Dark-Theme mit Conversion-Optimierungen
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Schilddrüsen-Report | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Meta Pixel -->
  <script is:inline define:vars={{ pixelId: import.meta.env.PUBLIC_META_PIXEL_ID || '' }}>
    if (pixelId) {
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', pixelId);
      fbq('track', 'PageView');
    }
  </script>

  <style is:global>
    /* === RESET & BASE === */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg-primary: #0c0a13;
      --bg-card: #16131f;
      --bg-card-hover: #1e1a2a;
      --accent: #c9899a;
      --accent-light: #e4b4c2;
      --accent-glow: rgba(201, 137, 154, 0.3);
      --gold: #d4a574;
      --text: #e8e4ef;
      --text-muted: #9a95a8;
      --border: rgba(201, 137, 154, 0.15);
      --radius: 16px;
      --font-serif: 'Playfair Display', Georgia, serif;
      --font-sans: 'Inter', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-sans);
      background: var(--bg-primary);
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    /* === HINTERGRUND-EFFEKT === */
    body::before {
      content: '';
      position: fixed;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(ellipse at 30% 20%, rgba(201,137,154,0.06) 0%, transparent 50%),
                  radial-gradient(ellipse at 70% 80%, rgba(212,165,116,0.04) 0%, transparent 50%);
      z-index: -1;
    }

    /* === CONTAINER === */
    .container { max-width: 720px; margin: 0 auto; padding: 0 1.25rem; }

    /* === LOGO === */
    .logo-bar {
      text-align: center;
      padding: 1.25rem 0;
    }
    .logo-bar img {
      height: 48px;
      width: auto;
      filter: brightness(1.1);
    }

    /* === HERO === */
    .hero {
      text-align: center;
      padding: 2rem 0 2.5rem;
    }
    .hero-badge {
      display: inline-block;
      background: linear-gradient(135deg, var(--accent), var(--gold));
      color: #0c0a13;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      padding: 0.4rem 1.2rem;
      border-radius: 50px;
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-family: var(--font-serif);
      font-size: clamp(1.75rem, 5vw, 2.5rem);
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #fff 40%, var(--accent-light));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero p {
      font-size: 1.1rem;
      color: var(--text-muted);
      max-width: 560px;
      margin: 0 auto 2rem;
    }

    /* === GESCHLECHTS-AUSWAHL === */
    .gender-label {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1.25rem;
      color: var(--text);
    }
    .gender-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      max-width: 440px;
      margin: 0 auto 1.5rem;
    }
    .gender-card {
      position: relative;
      border-radius: var(--radius);
      overflow: hidden;
      cursor: pointer;
      border: 2px solid var(--border);
      transition: all 0.3s ease;
      background: var(--bg-card);
    }
    .gender-card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
      box-shadow: 0 8px 30px var(--accent-glow);
    }
    .gender-card img {
      width: 100%;
      aspect-ratio: 3/4;
      object-fit: cover;
      display: block;
    }
    .gender-card .label {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1rem;
      background: linear-gradient(transparent, rgba(12,10,19,0.9));
      font-weight: 600;
      font-size: 1.1rem;
      text-align: center;
    }

    /* === SOCIAL PROOF === */
    .social-proof {
      text-align: center;
      margin: 0.75rem 0 1rem;
    }
    .social-proof .count {
      font-weight: 600;
      color: var(--accent-light);
    }
    .social-proof .badge {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      margin-top: 0.35rem;
      color: var(--text-muted);
      font-size: 0.85rem;
    }
    .social-proof .badge svg {
      width: 14px;
      height: 14px;
      color: var(--gold);
    }

    /* === CONTENT-SEKTIONEN === */
    .section {
      padding: 3rem 0;
    }
    .section-divider {
      width: 60px;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--gold));
      margin: 0 auto 2rem;
      border-radius: 2px;
    }
    .section-tag {
      display: inline-block;
      color: var(--accent);
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      margin-bottom: 0.75rem;
    }
    .section h2 {
      font-family: var(--font-serif);
      font-size: clamp(1.4rem, 4vw, 1.9rem);
      font-weight: 700;
      margin-bottom: 1rem;
      line-height: 1.3;
    }
    .section p {
      color: var(--text-muted);
      margin-bottom: 1rem;
    }

    /* === WARNUNG-KARTEN === */
    .warning-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin-bottom: 1.25rem;
    }
    .warning-card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 0.75rem;
      color: #e8a0a0;
    }
    .warning-card ul {
      list-style: none;
      padding: 0;
    }
    .warning-card ul li {
      padding: 0.4rem 0;
      padding-left: 1.5rem;
      position: relative;
      color: var(--text-muted);
      font-size: 0.95rem;
    }
    .warning-card ul li::before {
      content: '×';
      position: absolute;
      left: 0;
      color: #e8a0a0;
      font-weight: 700;
    }

    /* === POSITIV-KARTEN === */
    .benefit-card {
      background: var(--bg-card);
      border: 1px solid rgba(201,137,154,0.2);
      border-radius: var(--radius);
      padding: 1.5rem;
      margin-bottom: 1rem;
    }
    .benefit-card h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--accent-light);
    }
    .benefit-card p {
      font-size: 0.92rem;
      line-height: 1.5;
    }

    /* === URGENCY-SEKTION === */
    .urgency {
      background: linear-gradient(135deg, rgba(201,137,154,0.08), rgba(212,165,116,0.05));
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 2rem;
      text-align: center;
      margin: 1rem 0;
    }
    .urgency h3 {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }
    .urgency-items {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      margin: 1rem 0 1.5rem;
    }
    .urgency-item {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.95rem;
      color: var(--text-muted);
    }
    .urgency-item .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }

    /* === CTA BUTTON === */
    .cta-wrap { text-align: center; margin: 1.5rem 0; }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: linear-gradient(135deg, var(--accent), #b07585);
      color: #fff;
      font-size: 1.1rem;
      font-weight: 600;
      padding: 1rem 2.5rem;
      border: none;
      border-radius: 60px;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px var(--accent-glow);
      text-decoration: none;
    }
    .cta-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 35px rgba(201,137,154,0.4);
    }

    /* === WHY-SEKTION === */
    .why-section {
      text-align: center;
      padding: 2.5rem 0 3rem;
      border-top: 1px solid var(--border);
    }
    .why-section .gold { color: var(--gold); font-weight: 700; }

    /* === FOOTER === */
    footer {
      text-align: center;
      padding: 2rem 0;
      border-top: 1px solid var(--border);
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    footer a { color: var(--text-muted); text-decoration: none; }
    footer a:hover { color: var(--text); }

    /* ============================================
       QUIZ-OVERLAY
       ============================================ */
    .quiz-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--bg-primary);
      z-index: 1000;
      overflow-y: auto;
    }
    .quiz-overlay.active { display: flex; flex-direction: column; }

    .quiz-header {
      padding: 1rem 1.25rem;
      text-align: center;
      border-bottom: 1px solid var(--border);
    }
    .quiz-header img { height: 36px; }

    /* Fortschrittsbalken */
    .progress-wrap {
      padding: 0 1.25rem;
      max-width: 720px;
      margin: 1rem auto 0;
      width: 100%;
    }
    .progress-bar {
      height: 6px;
      background: rgba(201,137,154,0.15);
      border-radius: 3px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--gold));
      border-radius: 3px;
      transition: width 0.5s ease;
      width: 0%;
    }
    .progress-text {
      text-align: right;
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-top: 0.4rem;
    }

    /* Quiz-Content */
    .quiz-body {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.25rem;
    }
    .quiz-step {
      display: none;
      max-width: 640px;
      width: 100%;
      text-align: center;
      animation: fadeUp 0.4s ease;
    }
    .quiz-step.active { display: block; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .quiz-step h2 {
      font-family: var(--font-serif);
      font-size: clamp(1.3rem, 4vw, 1.7rem);
      font-weight: 700;
      margin-bottom: 2rem;
      line-height: 1.3;
    }

    .quiz-options {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    @media (max-width: 480px) {
      .quiz-options { grid-template-columns: 1fr; }
    }

    .quiz-option {
      background: var(--bg-card);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 1.1rem 1.25rem;
      text-align: left;
      font-size: 1rem;
      font-weight: 500;
      color: var(--text);
      cursor: pointer;
      transition: all 0.25s ease;
      font-family: var(--font-sans);
    }
    .quiz-option:hover {
      border-color: var(--accent);
      background: var(--bg-card-hover);
      transform: translateY(-2px);
      box-shadow: 0 4px 15px var(--accent-glow);
    }

    /* === LOADING-SCREEN === */
    .loading-screen {
      text-align: center;
    }
    .spinner {
      width: 72px;
      height: 72px;
      border: 3px solid rgba(201,137,154,0.15);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 0 auto 1.5rem;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-screen h2 {
      font-family: var(--font-serif);
      font-size: 1.4rem;
      margin-bottom: 0.5rem;
    }
    .loading-screen p { color: var(--text-muted); }
    .loading-checks {
      margin-top: 1.5rem;
      text-align: left;
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }
    .loading-check {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 0;
      font-size: 0.9rem;
      color: var(--text-muted);
      opacity: 0;
      transition: opacity 0.4s ease;
    }
    .loading-check.show { opacity: 1; }
    .loading-check .check {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      color: #fff;
      flex-shrink: 0;
    }

    /* === LEAD-FORMULAR === */
    .lead-form {
      text-align: center;
    }
    .lead-form h2 {
      font-family: var(--font-serif);
      font-size: clamp(1.3rem, 4vw, 1.7rem);
      margin-bottom: 0.5rem;
    }
    .lead-form .subtitle {
      color: var(--text-muted);
      margin-bottom: 2rem;
      font-size: 0.95rem;
    }
    .lead-form .subtitle strong {
      color: var(--accent-light);
    }
    .form-fields {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      max-width: 400px;
      margin: 0 auto 1.5rem;
    }
    .form-field {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: var(--bg-card);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 0 1rem;
      transition: border-color 0.3s;
    }
    .form-field:focus-within {
      border-color: var(--accent);
    }
    .form-field .icon { font-size: 1.1rem; flex-shrink: 0; }
    .form-field input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-family: var(--font-sans);
      font-size: 1rem;
      padding: 0.9rem 0;
    }
    .form-field input::placeholder { color: var(--text-muted); }

    .phone-prefix {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--text-muted);
      font-size: 0.95rem;
      flex-shrink: 0;
    }

    .checkbox-row {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      max-width: 400px;
      margin: 0 auto 1.25rem;
      text-align: left;
    }
    .checkbox-row input[type="checkbox"] {
      margin-top: 3px;
      accent-color: var(--accent);
      width: 16px;
      height: 16px;
      flex-shrink: 0;
    }
    .checkbox-row label {
      font-size: 0.8rem;
      color: var(--text-muted);
      line-height: 1.4;
    }
    .checkbox-row label a { color: var(--accent-light); text-decoration: underline; }

    .submit-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: linear-gradient(135deg, var(--accent), #b07585);
      color: #fff;
      font-size: 1.15rem;
      font-weight: 700;
      padding: 1.1rem 3rem;
      border: none;
      border-radius: 60px;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px var(--accent-glow);
      font-family: var(--font-sans);
      width: 100%;
      max-width: 400px;
      justify-content: center;
    }
    .submit-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 35px rgba(201,137,154,0.4);
    }
    .submit-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    .form-trust {
      margin-top: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      color: var(--text-muted);
    }
    .form-trust svg { width: 12px; height: 12px; color: var(--gold); }

    /* === DANKE-SEITE === */
    .thank-you {
      text-align: center;
    }
    .thank-you .emoji { font-size: 3rem; margin-bottom: 1rem; }
    .thank-you h2 {
      font-family: var(--font-serif);
      font-size: 1.7rem;
      margin-bottom: 0.75rem;
    }
    .thank-you p { color: var(--text-muted); max-width: 400px; margin: 0 auto; }

    /* === RESPONSIVE === */
    @media (max-width: 600px) {
      .gender-grid { max-width: 100%; }
      .urgency { padding: 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- ===== LANDING PAGE ===== -->
  <div id="landing-page">
    <div class="container">
      <!-- Logo -->
      <div class="logo-bar">
        <img src="/images/logo.png" alt="Fit on Time" />
      </div>

      <!-- Hero -->
      <section class="hero">
        <div class="hero-badge">Kostenloser Schilddrüsen-Check</div>
        <h1>Hält deine Schilddrüse dich vom Abnehmen ab?</h1>
        <p>Erhalte in 2 Minuten deinen persönlichen Schilddrüsen-Report und einen Plan, um sofort bis zu 100g Fett pro Tag abzubauen.</p>

        <div class="gender-label">Verrate uns vorab dein Geschlecht:</div>
        <div class="gender-grid">
          <div class="gender-card" onclick="startQuiz('frau')">
            <img src="https://images.unsplash.com/photo-1594744803329-e58b31de8bf5?w=400&h=530&fit=crop&crop=face" alt="Frau" loading="lazy" />
            <div class="label">Frau</div>
          </div>
          <div class="gender-card" onclick="startQuiz('mann')">
            <img src="https://images.unsplash.com/photo-1594672830234-ba4cfe1202dc?w=400&h=530&fit=crop&crop=face" alt="Mann" loading="lazy" />
            <div class="label">Mann</div>
          </div>
        </div>

        <div class="social-proof">
          <div class="count">Über 3.357 Frauen haben ihren Report bereits erhalten!</div>
          <div class="badge">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
            Von Ernährungsexperten entwickelt
          </div>
        </div>
      </section>

      <!-- Warnung: Kurz- und Langzeitfolgen -->
      <section class="section">
        <div class="section-divider"></div>
        <div class="section-tag">Wichtig zu wissen</div>
        <h2>Was passiert, wenn du deine Schilddrüsenfunktion nicht optimierst?</h2>

        <div class="warning-card">
          <h3>Scheiternde Abnehmversuche</h3>
          <ul>
            <li>Du verbrennst weniger Kalorien im Ruhezustand</li>
            <li>Wassereinlagerungen & aufgeschwemmtes Gefühl</li>
            <li>Müdigkeit & Antriebslosigkeit</li>
            <li>Insulinresistenz & Blutzuckerprobleme</li>
          </ul>
        </div>

        <div class="warning-card">
          <h3>Gesundheitliche Langzeitfolgen</h3>
          <ul>
            <li>Erhöhte Blutfette & Herz-Kreislauf-Risiko</li>
            <li>Depressive Verstimmungen</li>
            <li>Haarausfall & brüchige Nägel</li>
            <li>Kognitive Probleme & Konzentrationsschwäche</li>
            <li>Libidoverlust</li>
          </ul>
        </div>

        <p style="color: var(--text-muted); font-size: 0.92rem; margin-top: 1rem;">
          Das Abnehmen wird trotz Diät und Training wesentlich schwieriger oder stagniert komplett.
          Dein Körper kann dauerhaft im Energiesparmodus bleiben.
        </p>
      </section>

      <!-- CTA Wiederholung -->
      <div class="cta-wrap">
        <button class="cta-btn" onclick="document.querySelector('.hero').scrollIntoView({behavior:'smooth'})">
          Jetzt Report erhalten
          <span>→</span>
        </button>
      </div>

      <!-- Positiv: Doch es kann auch anders kommen -->
      <section class="section">
        <div class="section-divider"></div>
        <div class="section-tag">Doch es kann auch anders kommen</div>
        <h2>Deine Schilddrüse arbeitet gegen dich — aber das lässt sich ändern.</h2>

        <div class="benefit-card">
          <h3>Abnehmen ohne Kampf</h3>
          <p>Deine Abnehmversuche funktionieren endlich so, wie du es bei anderen siehst. Ohne Stress, ohne übermässigen Aufwand.</p>
        </div>

        <div class="benefit-card">
          <h3>Deine Gesundheit dankt es dir</h3>
          <p>Durch eine optimierte Schilddrüse, die für dich arbeitet, beugst du vielen Krankheitserscheinungen vor — jetzt und im Alter.</p>
        </div>

        <div class="benefit-card">
          <h3>Mehr Energie für dein Leben</h3>
          <p>Mit einem funktionierenden Stoffwechsel wirst du die Powerfrau, die du mal warst oder immer sein wolltest.</p>
        </div>
      </section>

      <!-- Urgency -->
      <section class="section">
        <div class="urgency">
          <h3>Der richtige Zeitpunkt ist genau jetzt</h3>
          <p style="color: var(--text-muted); font-size: 0.92rem; margin-bottom: 1rem;">
            Wenn deine Schilddrüse bereits abbaut, sendet dir dein Körper Warnsignale:
          </p>
          <div class="urgency-items">
            <div class="urgency-item"><span class="dot"></span> Ständige Müdigkeit</div>
            <div class="urgency-item"><span class="dot"></span> Heisshungerattacken</div>
            <div class="urgency-item"><span class="dot"></span> Stagnierendes oder steigendes Gewicht</div>
          </div>
          <button class="cta-btn" onclick="document.querySelector('.hero').scrollIntoView({behavior:'smooth'})">
            Kostenlos testen — Report erhalten
            <span>→</span>
          </button>
        </div>
      </section>

      <!-- Wieso wir das machen -->
      <section class="why-section">
        <div class="section-tag">Wieso wir das machen</div>
        <h2>Was du hier bekommst, ist <span class="gold" style="color: var(--gold);">Gold wert</span></h2>
        <p style="color: var(--text-muted); max-width: 520px; margin: 0 auto 1rem;">
          Wir bieten dir eine kostenlose Analyse anhand deiner Antworten.
          Jeder sollte seinen individuellen Weg zu einem gesunden Körper kostenfrei erhalten.
        </p>
        <p style="color: var(--text-muted); max-width: 520px; margin: 0 auto; font-size: 0.9rem;">
          Nach deinem Report bist du bereit, auf eigene Faust loszulegen.
          <strong style="color: var(--accent-light);">Aber du musst es nicht allein tun</strong> —
          wir helfen dir, die empfohlenen Schritte schnell und effektiv umzusetzen.
        </p>
      </section>

      <!-- Footer -->
      <footer>
        <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener">Impressum</a> ·
        <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener">Datenschutzerklärung</a>
      </footer>
    </div>
  </div>

  <!-- ===== QUIZ OVERLAY ===== -->
  <div id="quiz-overlay" class="quiz-overlay">
    <div class="quiz-header">
      <img src="/images/logo.png" alt="Fit on Time" />
    </div>
    <div class="progress-wrap">
      <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
      <div class="progress-text" id="progress-text">Frage 1 von 9</div>
    </div>
    <div class="quiz-body">
      <!-- Frage 1 -->
      <div class="quiz-step active" data-step="1">
        <h2>Wie schwer fällt es dir aktuell, Gewicht zu verlieren, obwohl du auf deine Ernährung achtest?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(1)">Extrem schwer</button>
          <button class="quiz-option" onclick="nextStep(1)">Es geht so</button>
          <button class="quiz-option" onclick="nextStep(1)">Gar nicht schwer</button>
          <button class="quiz-option" onclick="nextStep(1)">Weiss ich nicht</button>
        </div>
      </div>

      <!-- Frage 2 -->
      <div class="quiz-step" data-step="2">
        <h2>Wie reagiert dein Körper auf Kälte (z.B. kalte Hände oder Füsse)?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(2)">Friere ständig</button>
          <button class="quiz-option" onclick="nextStep(2)">Mir ist eher warm</button>
          <button class="quiz-option" onclick="nextStep(2)">Habe oft kalte Füsse</button>
          <button class="quiz-option" onclick="nextStep(2)">Nur im Winter</button>
        </div>
      </div>

      <!-- Frage 3 -->
      <div class="quiz-step" data-step="3">
        <h2>Wie oft fühlst du dich tagsüber erschöpft oder antriebslos?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(3)">Fast immer</button>
          <button class="quiz-option" onclick="nextStep(3)">Oft nachmittags</button>
          <button class="quiz-option" onclick="nextStep(3)">Nur nach Stress</button>
          <button class="quiz-option" onclick="nextStep(3)">Selten</button>
        </div>
      </div>

      <!-- Frage 4 -->
      <div class="quiz-step" data-step="4">
        <h2>Hast du Probleme mit Wassereinlagerungen (z.B. geschwollenes Gesicht)?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(4)">Eigentlich nie</button>
          <button class="quiz-option" onclick="nextStep(4)">Ja, sehr oft</button>
          <button class="quiz-option" onclick="nextStep(4)">Gelegentlich</button>
          <button class="quiz-option" onclick="nextStep(4)">Nur bei Hitze</button>
        </div>
      </div>

      <!-- Frage 5 -->
      <div class="quiz-step" data-step="5">
        <h2>Wie würdest du den Zustand deiner Haare und Nägel beschreiben?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(5)">Eher trocken</button>
          <button class="quiz-option" onclick="nextStep(5)">Ganz normal</button>
          <button class="quiz-option" onclick="nextStep(5)">Wachsen sehr schnell</button>
          <button class="quiz-option" onclick="nextStep(5)">Brüchig / Haarausfall</button>
        </div>
      </div>

      <!-- Frage 6 -->
      <div class="quiz-step" data-step="6">
        <h2>Leidest du unter Konzentrationsproblemen oder Brain Fog?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(6)">Nein, bin fokussiert</button>
          <button class="quiz-option" onclick="nextStep(6)">Ja, regelmässig</button>
          <button class="quiz-option" onclick="nextStep(6)">Nur bei wenig Schlaf</button>
          <button class="quiz-option" onclick="nextStep(6)">Ab und zu</button>
        </div>
      </div>

      <!-- Frage 7 -->
      <div class="quiz-step" data-step="7">
        <h2>Wie ist deine Verdauung meistens eingestellt?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(7)">Ganz normal</button>
          <button class="quiz-option" onclick="nextStep(7)">Eher träge</button>
          <button class="quiz-option" onclick="nextStep(7)">Wechselhaft</button>
          <button class="quiz-option" onclick="nextStep(7)">Weiss ich nicht</button>
        </div>
      </div>

      <!-- Frage 8 -->
      <div class="quiz-step" data-step="8">
        <h2>Welche Aussage beschreibt deine Ernährung am besten?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(8)">Ich esse gesund und ausgewogen</button>
          <button class="quiz-option" onclick="nextStep(8)">Ich achte nicht auf meine Ernährung</button>
          <button class="quiz-option" onclick="nextStep(8)">Ich achte auf Kalorien</button>
          <button class="quiz-option" onclick="nextStep(8)">Unsicher was mir gut tut</button>
        </div>
      </div>

      <!-- Frage 9 -->
      <div class="quiz-step" data-step="9">
        <h2>Was ist dein wichtigstes Ziel in den nächsten 3 Monaten?</h2>
        <div class="quiz-options">
          <button class="quiz-option" onclick="nextStep(9)">Gewicht reduzieren</button>
          <button class="quiz-option" onclick="nextStep(9)">Mehr Energie im Alltag</button>
          <button class="quiz-option" onclick="nextStep(9)">Hormonbalance und Wohlbefinden</button>
          <button class="quiz-option" onclick="nextStep(9)">Selbstbewusst auftreten</button>
        </div>
      </div>

      <!-- Loading -->
      <div class="quiz-step loading-screen" data-step="loading">
        <div class="spinner"></div>
        <h2>Deine Antworten werden ausgewertet...</h2>
        <p>Das dauert nur einen Moment</p>
        <div class="loading-checks">
          <div class="loading-check" id="lc1"><span class="check">&#10003;</span> Symptome analysiert</div>
          <div class="loading-check" id="lc2"><span class="check">&#10003;</span> Schilddrüsen-Profil erstellt</div>
          <div class="loading-check" id="lc3"><span class="check">&#10003;</span> Persönlicher Plan generiert</div>
        </div>
      </div>

      <!-- Lead-Formular -->
      <div class="quiz-step lead-form" data-step="form">
        <p style="color: var(--gold); font-weight: 600; margin-bottom: 0.5rem;">Geschafft!</p>
        <h2>Dein Report steht bereit</h2>
        <p class="subtitle">Erhalte <strong>kostenlos</strong> dein Ergebnis und deine persönliche Strategie.</p>

        <div class="form-fields">
          <div class="form-field">
            <span class="icon">&#128075;</span>
            <input type="text" id="fname" placeholder="Dein Vorname" required />
          </div>
          <div class="form-field">
            <span class="icon">&#128075;</span>
            <input type="text" id="lname" placeholder="Dein Nachname" required />
          </div>
          <div class="form-field">
            <span class="icon">&#128231;</span>
            <input type="email" id="email" placeholder="Deine E-Mail" required />
          </div>
          <div class="form-field">
            <span class="icon">&#128222;</span>
            <div class="phone-prefix">
              <span>&#127464;&#127469;</span>
              <span>+41</span>
            </div>
            <input type="tel" id="phone" placeholder="Deine Telefonnummer" />
          </div>
        </div>

        <div class="checkbox-row">
          <input type="checkbox" id="privacy" />
          <label for="privacy">Ich akzeptiere die <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener">Datenschutzbestimmungen</a></label>
        </div>

        <button class="submit-btn" id="submit-btn" onclick="submitLead()" disabled>
          Jetzt Ergebnis erfahren
          <span>&#10024;</span>
        </button>

        <div class="form-trust">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/></svg>
          100% kostenlos & unverbindlich
        </div>
      </div>

      <!-- Danke -->
      <div class="quiz-step thank-you" data-step="thanks">
        <div class="emoji">&#127881;</div>
        <h2>Vielen Dank!</h2>
        <p>Dein persönlicher Schilddrüsen-Report wird gerade erstellt. Du erhältst ihn in Kürze per E-Mail.</p>
      </div>
    </div>
  </div>

  <script is:inline>
    // === Tracking-Helfer ===
    function track(event, data = {}) {
      fetch('/api/track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ event, page: 'schilddruesen-report', ...data }),
      }).catch(() => {});

      // Meta Pixel Events
      if (typeof fbq !== 'undefined') {
        if (event === 'quiz_start') fbq('track', 'ViewContent', { content_name: 'Quiz Start' });
        if (event === 'quiz_complete') fbq('track', 'CompleteRegistration');
        if (event === 'lead_submit') fbq('track', 'Lead');
      }
    }

    // Seitenaufruf tracken
    track('page_view');

    const totalSteps = 9;
    let currentStep = 0;

    // Quiz starten
    function startQuiz(gender) {
      track('quiz_start', { detail: gender });
      document.getElementById('landing-page').style.display = 'none';
      document.getElementById('quiz-overlay').classList.add('active');
      updateProgress(1);
    }

    // Nächste Frage
    function nextStep(step) {
      track('quiz_answer', { detail: `q${step}` });

      const current = document.querySelector(`.quiz-step[data-step="${step}"]`);
      current.classList.remove('active');

      if (step < totalSteps) {
        const next = document.querySelector(`.quiz-step[data-step="${step + 1}"]`);
        next.classList.add('active');
        updateProgress(step + 1);
      } else {
        // Quiz fertig — Loading anzeigen
        track('quiz_complete');
        showLoading();
      }
    }

    // Fortschrittsbalken aktualisieren
    function updateProgress(step) {
      const pct = Math.round((step / totalSteps) * 100);
      document.getElementById('progress-fill').style.width = pct + '%';
      document.getElementById('progress-text').textContent = `Frage ${step} von ${totalSteps}`;
    }

    // Loading-Animation
    function showLoading() {
      const loading = document.querySelector('.quiz-step[data-step="loading"]');
      loading.classList.add('active');
      document.getElementById('progress-fill').style.width = '100%';
      document.getElementById('progress-text').textContent = 'Auswertung...';

      // Checks nacheinander einblenden
      setTimeout(() => document.getElementById('lc1').classList.add('show'), 800);
      setTimeout(() => document.getElementById('lc2').classList.add('show'), 1800);
      setTimeout(() => document.getElementById('lc3').classList.add('show'), 2800);

      // Zum Formular wechseln
      setTimeout(() => {
        loading.classList.remove('active');
        const form = document.querySelector('.quiz-step[data-step="form"]');
        form.classList.add('active');
        document.getElementById('progress-text').textContent = 'Fast geschafft!';
      }, 4000);
    }

    // Checkbox → Button aktivieren
    document.getElementById('privacy').addEventListener('change', function() {
      document.getElementById('submit-btn').disabled = !this.checked;
    });

    // Lead absenden
    function submitLead() {
      const fname = document.getElementById('fname').value.trim();
      const lname = document.getElementById('lname').value.trim();
      const email = document.getElementById('email').value.trim();
      const phone = document.getElementById('phone').value.trim();

      if (!fname || !email) {
        // Felder markieren
        if (!fname) document.getElementById('fname').parentElement.style.borderColor = '#e8a0a0';
        if (!email) document.getElementById('email').parentElement.style.borderColor = '#e8a0a0';
        return;
      }

      document.getElementById('submit-btn').disabled = true;
      document.getElementById('submit-btn').textContent = 'Wird gesendet...';

      track('lead_submit', { detail: `${fname} ${lname}` });

      // Danke-Seite anzeigen
      setTimeout(() => {
        document.querySelector('.quiz-step[data-step="form"]').classList.remove('active');
        document.querySelector('.quiz-step[data-step="thanks"]').classList.add('active');
        document.getElementById('progress-text').textContent = 'Fertig!';
      }, 1000);
    }
  </script>
</body>
</html>
