---
// Schilddrüsen-Report Funnel v2 — Mobile-First, Senior Design, Conversion-Optimiert
const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL || 'https://calendly.com/fitontime';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Kostenloser Schilddrüsen-Check | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Meta Pixel -->
  <script is:inline define:vars={{ pixelId: import.meta.env.PUBLIC_META_PIXEL_ID || '' }}>
    if (pixelId) {
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', pixelId); fbq('track', 'PageView');
    }
  </script>

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0b0b0f;
      --surface: #151519;
      --surface-2: #1c1c22;
      --accent: #c4697a;
      --accent-soft: #d4949f;
      --green: #4ade80;
      --text: #f0eff2;
      --text-2: #a09cac;
      --text-3: #6b6778;
      --r: 14px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
    }

    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* === LAYOUT === */
    .wrap { max-width: 440px; margin: 0 auto; padding: 0 20px; }

    /* === LOGO === */
    .logo { text-align: center; padding: 16px 0 8px; }
    .logo img { height: 40px; }

    /* === HERO === */
    .hero { text-align: center; padding: 20px 0 24px; }
    .hero h1 {
      font-size: 24px;
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: -0.3px;
      margin-bottom: 10px;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--accent);
    }
    .hero p {
      font-size: 15px;
      color: var(--text-2);
      margin-bottom: 20px;
    }
    .hero p strong { color: var(--text); font-weight: 600; }

    /* === GENDER === */
    .gender-q {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-2);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 14px;
    }
    .gender-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }
    .g-card {
      position: relative;
      border-radius: var(--r);
      overflow: hidden;
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.2s, transform 0.2s;
      -webkit-tap-highlight-color: transparent;
    }
    .g-card:active { transform: scale(0.97); }
    .g-card img {
      width: 100%;
      aspect-ratio: 4/5;
      object-fit: cover;
      display: block;
    }
    .g-card span {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 10px;
      background: linear-gradient(transparent, rgba(0,0,0,.7));
      font-size: 15px;
      font-weight: 600;
      text-align: center;
    }

    /* === PROOF === */
    .proof {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-3);
    }
    .proof b { color: var(--text-2); }

    /* === MINI-SEKTIONEN (nur 2-3 kurze) === */
    .divider {
      width: 40px; height: 1px;
      background: var(--accent);
      margin: 28px auto;
      opacity: 0.4;
    }
    .mini {
      text-align: center;
      padding: 0 0 8px;
    }
    .mini h2 {
      font-size: 20px;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 14px;
      letter-spacing: -0.2px;
    }

    /* === RISK-LISTE === */
    .risks {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 20px;
      text-align: left;
    }
    .risks li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--text-2);
      background: var(--surface);
      padding: 12px 14px;
      border-radius: 10px;
    }
    .risks li .ic {
      flex-shrink: 0;
      width: 20px; height: 20px;
      border-radius: 50%;
      background: rgba(196,105,122,0.15);
      color: var(--accent);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      margin-top: 1px;
    }

    /* === BENEFIT-LISTE === */
    .benefits {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 20px;
      text-align: left;
    }
    .benefits li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--text-2);
      background: var(--surface);
      padding: 12px 14px;
      border-radius: 10px;
    }
    .benefits li .ic {
      flex-shrink: 0;
      width: 20px; height: 20px;
      border-radius: 50%;
      background: rgba(74,222,128,0.12);
      color: var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      margin-top: 1px;
    }

    /* === CTA === */
    .cta-wrap { text-align: center; padding: 4px 0 20px; }
    .cta {
      display: block;
      width: 100%;
      background: var(--accent);
      color: #fff;
      font-family: var(--font);
      font-size: 16px;
      font-weight: 700;
      padding: 16px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: opacity 0.2s;
      -webkit-tap-highlight-color: transparent;
    }
    .cta:active { opacity: 0.85; }
    .cta-sub {
      font-size: 11px;
      color: var(--text-3);
      margin-top: 8px;
    }

    /* === URGENCY BOX === */
    .urg {
      background: var(--surface);
      border: 1px solid rgba(196,105,122,0.2);
      border-radius: var(--r);
      padding: 20px;
      text-align: center;
      margin-bottom: 28px;
    }
    .urg h3 {
      font-size: 17px;
      font-weight: 700;
      margin-bottom: 6px;
    }
    .urg p { font-size: 13px; color: var(--text-2); margin-bottom: 16px; }
    .urg .signals {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 16px;
    }
    .urg .sig {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--text-2);
    }
    .urg .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }

    /* === FOOTER === */
    footer {
      text-align: center;
      padding: 20px;
      font-size: 11px;
      color: var(--text-3);
      border-top: 1px solid var(--surface-2);
    }
    footer a { color: var(--text-3); text-decoration: none; }

    /* ================================
       QUIZ OVERLAY
       ================================ */
    #quiz {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--bg);
      z-index: 100;
      flex-direction: column;
    }
    #quiz.on { display: flex; }

    .q-head {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 14px 20px;
      border-bottom: 1px solid var(--surface-2);
    }
    .q-head img { height: 32px; }

    .q-progress {
      padding: 12px 20px 0;
      max-width: 440px;
      margin: 0 auto;
      width: 100%;
    }
    .q-bar {
      height: 4px;
      background: var(--surface-2);
      border-radius: 2px;
      overflow: hidden;
    }
    .q-fill {
      height: 100%;
      background: var(--accent);
      border-radius: 2px;
      transition: width 0.4s ease;
      width: 11%;
    }
    .q-num {
      font-size: 11px;
      color: var(--text-3);
      text-align: right;
      margin-top: 4px;
    }

    .q-body {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .step {
      display: none;
      max-width: 440px;
      width: 100%;
      animation: up 0.3s ease;
    }
    .step.on { display: block; }
    @keyframes up {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .step h2 {
      font-size: 20px;
      font-weight: 700;
      text-align: center;
      margin-bottom: 24px;
      line-height: 1.3;
      letter-spacing: -0.2px;
    }

    .opts {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .opt {
      background: var(--surface);
      border: 1.5px solid var(--surface-2);
      border-radius: 12px;
      padding: 16px 18px;
      font-size: 15px;
      font-weight: 500;
      color: var(--text);
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      font-family: var(--font);
      -webkit-tap-highlight-color: transparent;
      text-align: left;
    }
    .opt:active {
      border-color: var(--accent);
      background: var(--surface-2);
    }

    /* === LOADING === */
    .ld { text-align: center; }
    .spinner {
      width: 48px; height: 48px;
      border: 3px solid var(--surface-2);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 20px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ld h2 { font-size: 18px; margin-bottom: 6px; }
    .ld p { font-size: 14px; color: var(--text-2); margin-bottom: 20px; }
    .checks { text-align: left; max-width: 260px; margin: 0 auto; }
    .chk {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 6px 0;
      font-size: 13px;
      color: var(--text-2);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .chk.show { opacity: 1; }
    .chk i {
      width: 18px; height: 18px;
      border-radius: 50%;
      background: var(--green);
      color: #0b0b0f;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
      font-style: normal;
      font-weight: 700;
      flex-shrink: 0;
    }

    /* === LEAD FORM === */
    .form { text-align: center; }
    .form .tag {
      font-size: 13px;
      font-weight: 600;
      color: var(--green);
      margin-bottom: 6px;
    }
    .form h2 { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
    .form .sub {
      font-size: 14px;
      color: var(--text-2);
      margin-bottom: 24px;
    }
    .fields {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 14px;
    }
    .field {
      background: var(--surface);
      border: 1.5px solid var(--surface-2);
      border-radius: 12px;
      padding: 0 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: border-color 0.2s;
    }
    .field:focus-within { border-color: var(--accent); }
    .field .ic { font-size: 16px; flex-shrink: 0; opacity: 0.5; }
    .field input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      padding: 14px 0;
    }
    .field input::placeholder { color: var(--text-3); }
    .field .pre {
      font-size: 14px;
      color: var(--text-3);
      flex-shrink: 0;
    }

    .cb-row {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 16px;
      text-align: left;
    }
    .cb-row input[type="checkbox"] {
      accent-color: var(--accent);
      width: 16px; height: 16px;
      margin-top: 2px;
      flex-shrink: 0;
    }
    .cb-row label {
      font-size: 11px;
      color: var(--text-3);
      line-height: 1.4;
    }
    .cb-row label a { color: var(--text-2); }

    .submit {
      display: block;
      width: 100%;
      background: var(--accent);
      color: #fff;
      font-family: var(--font);
      font-size: 16px;
      font-weight: 700;
      padding: 16px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .submit:disabled { opacity: 0.4; cursor: not-allowed; }
    .submit:not(:disabled):active { opacity: 0.85; }
    .form-trust {
      font-size: 11px;
      color: var(--text-3);
      margin-top: 10px;
    }

    /* === DANKE-SEITE === */
    .thanks { text-align: center; }
    .thanks .check-big {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: rgba(74,222,128,0.12);
      color: var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin: 0 auto 16px;
    }
    .thanks h2 { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
    .thanks .info {
      font-size: 14px;
      color: var(--text-2);
      margin-bottom: 24px;
      line-height: 1.5;
    }
    .thanks .book-box {
      background: var(--surface);
      border: 1px solid rgba(196,105,122,0.25);
      border-radius: var(--r);
      padding: 20px;
      margin-bottom: 16px;
    }
    .thanks .book-box h3 {
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .thanks .book-box p {
      font-size: 13px;
      color: var(--text-2);
      margin-bottom: 14px;
    }
    .thanks .book-btn {
      display: block;
      width: 100%;
      background: var(--accent);
      color: #fff;
      font-family: var(--font);
      font-size: 15px;
      font-weight: 700;
      padding: 14px;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      text-decoration: none;
      text-align: center;
    }
    .thanks .book-btn:active { opacity: 0.85; }
    .thanks .book-hint {
      font-size: 11px;
      color: var(--text-3);
      margin-top: 8px;
      font-style: italic;
    }
    .thanks .alt {
      font-size: 12px;
      color: var(--text-3);
      margin-top: 16px;
    }

    /* === DESKTOP ADJUST === */
    @media (min-width: 600px) {
      .hero h1 { font-size: 30px; }
      .mini h2 { font-size: 24px; }
      .step h2 { font-size: 24px; }
      .opts {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</head>
<body>

  <!-- ===== LANDING ===== -->
  <div id="lp">
    <div class="wrap">
      <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

      <section class="hero">
        <h1>Blockiert deine Schilddrüse <em>deinen Fettabbau?</em></h1>
        <p>Finde es in <strong>90 Sekunden</strong> heraus — und erhalte deinen persönlichen Abnehm-Plan. Kostenlos.</p>

        <div class="gender-q">Ich bin:</div>
        <div class="gender-row">
          <div class="g-card" onclick="go('frau')">
            <img src="https://images.unsplash.com/photo-1594744803329-e58b31de8bf5?w=400&h=500&fit=crop&crop=face&q=80" alt="Frau" />
            <span>Frau</span>
          </div>
          <div class="g-card" onclick="go('mann')">
            <img src="https://images.unsplash.com/photo-1594672830234-ba4cfe1202dc?w=400&h=500&fit=crop&crop=face&q=80" alt="Mann" />
            <span>Mann</span>
          </div>
        </div>
        <div class="proof"><b>3.357+</b> Analysen durchgeführt</div>
      </section>

      <div class="divider"></div>

      <!-- Risiko — kurz & knackig -->
      <section class="mini">
        <h2>Was passiert, wenn du nichts tust</h2>
        <ul class="risks">
          <li><span class="ic">!</span>Dein Stoffwechsel bleibt im Sparmodus — jede Diät scheitert</li>
          <li><span class="ic">!</span>Müdigkeit, Heisshunger & Gewichtszunahme werden schlimmer</li>
          <li><span class="ic">!</span>Langfristig: Herz-Kreislauf-Risiko, Haarausfall, Depression</li>
        </ul>
      </section>

      <div class="divider"></div>

      <!-- Lösung — kurz -->
      <section class="mini">
        <h2>Das muss nicht so bleiben</h2>
        <ul class="benefits">
          <li><span class="ic">&#10003;</span>Verstehe, warum dein Körper Fett festhält</li>
          <li><span class="ic">&#10003;</span>Bekomme einen Plan, der auf dich zugeschnitten ist</li>
          <li><span class="ic">&#10003;</span>Starte mit Klarheit statt Frust</li>
        </ul>
      </section>

      <!-- Urgency CTA -->
      <div class="urg">
        <h3>Dein Körper sendet dir Signale</h3>
        <p>Je früher du handelst, desto einfacher wird es.</p>
        <div class="signals">
          <div class="sig"><span class="dot"></span>Ständige Müdigkeit trotz genug Schlaf</div>
          <div class="sig"><span class="dot"></span>Gewicht stagniert oder steigt ohne Grund</div>
          <div class="sig"><span class="dot"></span>Heisshunger, den du nicht kontrollieren kannst</div>
        </div>
        <button class="cta" onclick="document.querySelector('.hero').scrollIntoView({behavior:'smooth'})">Jetzt kostenlosen Check starten</button>
        <div class="cta-sub">Dauert 90 Sekunden · 100% kostenlos</div>
      </div>

      <footer>
        <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener">Impressum</a> ·
        <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener">Datenschutz</a>
      </footer>
    </div>
  </div>

  <!-- ===== QUIZ ===== -->
  <div id="quiz">
    <div class="q-head"><img src="/images/logo.png" alt="Fit on Time" /></div>
    <div class="q-progress"><div class="q-bar"><div class="q-fill" id="qf"></div></div><div class="q-num" id="qn">1 / 9</div></div>
    <div class="q-body">

      <div class="step on" data-s="1">
        <h2>Wie schwer fällt dir Abnehmen — obwohl du auf deine Ernährung achtest?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(1)">Extrem schwer</button>
          <button class="opt" onclick="nxt(1)">Es geht so</button>
          <button class="opt" onclick="nxt(1)">Gar nicht schwer</button>
          <button class="opt" onclick="nxt(1)">Weiss ich nicht</button>
        </div>
      </div>

      <div class="step" data-s="2">
        <h2>Frierst du oft — z.B. kalte Hände oder Füsse?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(2)">Ja, ständig</button>
          <button class="opt" onclick="nxt(2)">Mir ist eher warm</button>
          <button class="opt" onclick="nxt(2)">Oft kalte Füsse</button>
          <button class="opt" onclick="nxt(2)">Nur im Winter</button>
        </div>
      </div>

      <div class="step" data-s="3">
        <h2>Wie oft fühlst du dich tagsüber erschöpft?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(3)">Fast immer</button>
          <button class="opt" onclick="nxt(3)">Oft nachmittags</button>
          <button class="opt" onclick="nxt(3)">Nur nach Stress</button>
          <button class="opt" onclick="nxt(3)">Selten</button>
        </div>
      </div>

      <div class="step" data-s="4">
        <h2>Hast du Wassereinlagerungen — z.B. geschwollenes Gesicht?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(4)">Ja, sehr oft</button>
          <button class="opt" onclick="nxt(4)">Gelegentlich</button>
          <button class="opt" onclick="nxt(4)">Eigentlich nie</button>
          <button class="opt" onclick="nxt(4)">Nur bei Hitze</button>
        </div>
      </div>

      <div class="step" data-s="5">
        <h2>Wie sind deine Haare & Nägel?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(5)">Trocken / dünn</button>
          <button class="opt" onclick="nxt(5)">Ganz normal</button>
          <button class="opt" onclick="nxt(5)">Brüchig / Haarausfall</button>
          <button class="opt" onclick="nxt(5)">Wachsen gut</button>
        </div>
      </div>

      <div class="step" data-s="6">
        <h2>Hast du oft Brain Fog oder Konzentrationsprobleme?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(6)">Ja, regelmässig</button>
          <button class="opt" onclick="nxt(6)">Ab und zu</button>
          <button class="opt" onclick="nxt(6)">Nur bei wenig Schlaf</button>
          <button class="opt" onclick="nxt(6)">Nein, bin fokussiert</button>
        </div>
      </div>

      <div class="step" data-s="7">
        <h2>Wie ist deine Verdauung?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(7)">Eher träge</button>
          <button class="opt" onclick="nxt(7)">Wechselhaft</button>
          <button class="opt" onclick="nxt(7)">Ganz normal</button>
          <button class="opt" onclick="nxt(7)">Weiss nicht</button>
        </div>
      </div>

      <div class="step" data-s="8">
        <h2>Wie ernährst du dich?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(8)">Gesund & ausgewogen</button>
          <button class="opt" onclick="nxt(8)">Achte auf Kalorien</button>
          <button class="opt" onclick="nxt(8)">Achte nicht gross drauf</button>
          <button class="opt" onclick="nxt(8)">Unsicher was mir gut tut</button>
        </div>
      </div>

      <div class="step" data-s="9">
        <h2>Was ist dein Ziel in den nächsten 3 Monaten?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(9)">Gewicht verlieren</button>
          <button class="opt" onclick="nxt(9)">Mehr Energie</button>
          <button class="opt" onclick="nxt(9)">Hormone in Balance</button>
          <button class="opt" onclick="nxt(9)">Wieder wohlfühlen</button>
        </div>
      </div>

      <!-- Loading -->
      <div class="step ld" data-s="ld">
        <div class="spinner"></div>
        <h2>Wird ausgewertet...</h2>
        <p>Dein persönlicher Report wird erstellt</p>
        <div class="checks">
          <div class="chk" id="c1"><i>&#10003;</i>Symptome analysiert</div>
          <div class="chk" id="c2"><i>&#10003;</i>Schilddrüsen-Profil erstellt</div>
          <div class="chk" id="c3"><i>&#10003;</i>Abnehm-Plan generiert</div>
        </div>
      </div>

      <!-- Formular -->
      <div class="step form" data-s="form">
        <div class="tag">&#10003; Analyse abgeschlossen</div>
        <h2>Dein Report ist fertig</h2>
        <p class="sub">Wohin sollen wir ihn schicken?</p>
        <div class="fields">
          <div class="field"><span class="ic">&#128100;</span><input type="text" id="fn" placeholder="Vorname" /></div>
          <div class="field"><span class="ic">&#128100;</span><input type="text" id="ln" placeholder="Nachname" /></div>
          <div class="field"><span class="ic">&#9993;</span><input type="email" id="em" placeholder="E-Mail Adresse" /></div>
          <div class="field"><span class="ic">&#128222;</span><span class="pre">+41</span><input type="tel" id="ph" placeholder="Telefonnummer" /></div>
        </div>
        <div class="cb-row">
          <input type="checkbox" id="ds" />
          <label for="ds">Ich akzeptiere die <a href="https://fitontime.ch/impressum-datenschutz" target="_blank">Datenschutzbestimmungen</a></label>
        </div>
        <button class="submit" id="sbtn" disabled onclick="send()">Report kostenlos erhalten</button>
        <div class="form-trust">&#128274; Deine Daten sind sicher & werden nicht weitergegeben</div>
      </div>

      <!-- Danke -->
      <div class="step thanks" data-s="thx">
        <div class="check-big">&#10003;</div>
        <h2>Dein Report ist unterwegs!</h2>
        <p class="info">Du erhältst ihn in wenigen Minuten per E-Mail.<br/>Jetzt kommt der wichtigste Schritt:</p>

        <div class="book-box">
          <h3>Ergebnis persönlich besprechen</h3>
          <p>Lass dir deinen Report erklären — individuell auf dich zugeschnitten. Kostenlos & unverbindlich.</p>
          <a class="book-btn" id="cal-link" href="#" target="_blank" rel="noopener">Termin wählen</a>
          <div class="book-hint">Begrenzte Plätze — nur wer bucht, bekommt die persönliche Analyse.</div>
        </div>
        <div class="alt">Kein Termin? Du erhältst deinen Report trotzdem per E-Mail.</div>
      </div>

    </div>
  </div>

  <script is:inline define:vars={{ calendlyUrl }}>
    document.getElementById('cal-link').href = calendlyUrl;
  </script>
  <script is:inline>
    // === Tracking ===
    function tk(e, d) {
      fetch('/api/track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ event: e, page: 'schilddruesen-report', ...d }),
      }).catch(function(){});
      if (typeof fbq !== 'undefined') {
        if (e === 'quiz_start') fbq('track', 'ViewContent');
        if (e === 'quiz_complete') fbq('track', 'CompleteRegistration');
        if (e === 'lead_submit') fbq('track', 'Lead');
      }
    }
    tk('page_view');

    // === Quiz starten ===
    function go(g) {
      tk('quiz_start', { detail: g });
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
    }

    // === Nächste Frage ===
    function nxt(s) {
      tk('quiz_answer', { detail: 'q' + s });
      document.querySelector('.step[data-s="' + s + '"]').classList.remove('on');
      if (s < 9) {
        document.querySelector('.step[data-s="' + (s + 1) + '"]').classList.add('on');
        var p = Math.round(((s + 1) / 9) * 100);
        document.getElementById('qf').style.width = p + '%';
        document.getElementById('qn').textContent = (s + 1) + ' / 9';
      } else {
        tk('quiz_complete');
        load();
      }
    }

    // === Loading ===
    function load() {
      var ld = document.querySelector('.step[data-s="ld"]');
      ld.classList.add('on');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qn').textContent = 'Auswertung...';
      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 600);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1400);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2200);
      setTimeout(function(){
        ld.classList.remove('on');
        document.querySelector('.step[data-s="form"]').classList.add('on');
        document.getElementById('qn').textContent = 'Fast fertig';
      }, 3200);
    }

    // === Checkbox ===
    document.getElementById('ds').addEventListener('change', function() {
      document.getElementById('sbtn').disabled = !this.checked;
    });

    // === Absenden ===
    function send() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      if (!fn || !em) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--accent)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--accent)';
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird gesendet...';
      tk('lead_submit', { detail: fn });
      setTimeout(function(){
        document.querySelector('.step[data-s="form"]').classList.remove('on');
        document.querySelector('.step[data-s="thx"]').classList.add('on');
        document.getElementById('qn').textContent = 'Fertig!';
      }, 800);
    }
  </script>
</body>
</html>
