  <script is:inline>
    // Quiz-Antworten speichern
    var quizAnswers = {};

    // Tracking-Helfer, nutzt window.__lp aus CookieBanner
    // Race-Schutz: __lp wird erst nach Parse des CookieBanner-Scripts gesetzt.
    // Wenn nicht da, retry alle 50ms (max 2s), sonst geht page_view verloren.
    function tk(e, d) {
      var tries = 0;
      function fire() {
        if (window.__lp) {
          window.__lp.track(e, Object.assign({ page: 'schilddruesen-report' }, d || {}), 'fot', 'Schilddruesen-Report');
          if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'Schilddruesen-Report Quiz Start', currency: 'EUR' });
          if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'Schilddruesen-Report Quiz Complete', currency: 'EUR' });
          if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'Schilddruesen-Report Lead', currency: 'EUR' });
          if (e === 'booking_confirmed') window.__lp.meta('Schedule', { content_name: 'Schilddruesen-Report Termin gebucht', currency: 'EUR' });
        } else if (tries++ < 40) {
          setTimeout(fire, 50);
        }
      }
      fire();
    }
    tk('page_view');

    // === Symmetrischer Booking-Detektor (A + B identisch) ===
    // YouCanBook.me-Embed (embed.ycb.me) postet eine Message ans Parent-Window,
    // wenn eine Buchung bestaetigt ist. Wir erkennen das origin- + keyword-gefiltert
    // und feuern EIN gemeinsames booking_confirmed-Event mit der A/B-Variante.
    // Damit wird der Test endlich messbar: booking_confirmed pro Variante = Conversion.
    (function () {
      window.addEventListener('message', function (ev) {
        // Nur Messages vom YCBM-Widget akzeptieren
        var origin = String(ev.origin || '');
        if (!/(^|\.)ycb\.me$/.test(origin) && origin.indexOf('youcanbook') === -1) return;

        // Payload als String normalisieren (YCBM sendet String ODER Objekt)
        var raw = ev.data;
        var txt = '';
        try { txt = (typeof raw === 'string') ? raw : JSON.stringify(raw); } catch (e) { return; }
        txt = txt.toLowerCase();

        // Buchung-bestaetigt-Signal: 'book' + abgeschlossen-Marker
        if (txt.indexOf('book') === -1) return;
        if (!/confirm|complete|created|success|made|finished/.test(txt)) return;

        // Pro Session nur einmal zaehlen (Doppel-Messages / Re-Render absichern)
        try {
          if (sessionStorage.getItem('fot_booking_fired') === '1') return;
          sessionStorage.setItem('fot_booking_fired', '1');
        } catch (e) {}

        // Zugewiesene Variante (in fot_ab_thx persistiert beim Split)
        var v = 'unknown';
        try { v = sessionStorage.getItem('fot_ab_thx') || 'unknown'; } catch (e) {}

        tk('booking_confirmed', { variant: v, detail: v });
      }, false);
    })();

    // Preview-Shortcut: ?show=thx2 oder ?show=thx springt direkt zum Step (Dev/QA)
    (function() {
      var p = new URLSearchParams(location.search);
      var s = p.get('show');
      if (s !== 'thx' && s !== 'thx2') return;
      document.getElementById('lp').style.display = 'none';
      var q = document.getElementById('quiz');
      q.style.display = 'flex';
      q.classList.add('on');
      document.querySelectorAll('.step').forEach(function(el){ el.classList.remove('on'); });
      var target = document.querySelector('.step[data-s="' + s + '"]');
      if (target) target.classList.add('on');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qn').textContent = 'Fertig!';
      if (s === 'thx2') {
        if (typeof v2InitScore === 'function') v2InitScore();
        if (typeof v2StartCountdown === 'function') v2StartCountdown();
        var c = document.getElementById('ycbm-container-v2');
        if (c && !c.dataset.loaded) {
          c.dataset.loaded = '1';
          var sc = document.createElement('script');
          sc.src = 'https://embed.ycb.me';
          sc.async = true;
          sc.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
          sc.setAttribute('data-displaymode', 'auto');
          c.appendChild(sc);
        }
      } else if (s === 'thx') {
        var ca = document.getElementById('ycbm-container');
        if (ca && !ca.dataset.loaded) {
          ca.dataset.loaded = '1';
          var sa = document.createElement('script');
          sa.src = 'https://embed.ycb.me';
          sa.async = true;
          sa.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
          sa.setAttribute('data-displaymode', 'auto');
          ca.appendChild(sa);
        }
      }
    })();

    function go(g) {
      tk('quiz_start', { detail: g });
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
    }

    function nxt(s, el) {
      // Antworttext speichern
      quizAnswers['q' + s] = el ? el.textContent.trim() : '';
      tk('quiz_answer', { detail: 'q' + s });
      document.querySelector('.step[data-s="' + s + '"]').classList.remove('on');
      if (s < 9) {
        document.querySelector('.step[data-s="' + (s + 1) + '"]').classList.add('on');
        var p = Math.round(((s + 1) / 9) * 100);
        document.getElementById('qf').style.width = p + '%';
        document.getElementById('qn').textContent = (s + 1) + ' / 9';
      } else {
        tk('quiz_complete');
        load();
      }
    }

    function load() {
      var ld = document.querySelector('.step[data-s="ld"]');
      ld.classList.add('on');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qn').textContent = 'Auswertung...';
      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 600);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1400);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2200);
      setTimeout(function(){
        ld.classList.remove('on');
        document.querySelector('.step[data-s="form"]').classList.add('on');
        document.getElementById('qn').textContent = 'Fast fertig';
      }, 3200);
    }

    document.getElementById('ds').addEventListener('change', function() {
      document.getElementById('sbtn').disabled = !this.checked;
    });

    function send() {
      var fn = document.getElementById('fn').value.trim();
      var ln = document.getElementById('ln').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      var missing = [];
      if (!fn) missing.push('fn');
      if (!ln) missing.push('ln');
      if (!em) missing.push('em');
      if (!ph) missing.push('ph');
      if (missing.length) {
        missing.forEach(function(id){ document.getElementById(id).parentElement.style.borderColor = 'var(--accent)'; });
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird gesendet...';

      // Atomarer Submit: lead_submit + Meta-Pixel + UI-Weiter NUR bei erfolgreichem Insert
      var fullName = fn + (ln ? ' ' + ln : '');
      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          lp_slug: 'schilddruesen-report',
          lp_name: 'Schilddruesen-Report',
          name: fullName,
          email: em,
          phone: ph ? '+41' + ph : '',
          answers: quizAnswers
        })
      }).then(function(res){
        if (!res.ok) throw new Error('insert-failed');
        // Insert erfolgreich, jetzt erst tracken
        tk('lead_submit', { detail: fn });
        document.querySelector('.step[data-s="form"]').classList.remove('on');
        document.getElementById('qn').textContent = 'Fertig!';

        // === A/B-Split: 50/50 zwischen thx (A=Original) und thx2 (B=FC-Mirror) ===
        // Sticky via sessionStorage, Force via ?ab=A|B
        var variant;
        try {
          var p = new URLSearchParams(location.search);
          var forced = (p.get('ab') || '').toUpperCase();
          if (forced === 'A' || forced === 'B') {
            variant = forced;
          } else {
            variant = sessionStorage.getItem('fot_ab_thx');
            if (variant !== 'A' && variant !== 'B') {
              variant = Math.random() < 0.5 ? 'A' : 'B';
            }
          }
          sessionStorage.setItem('fot_ab_thx', variant);
        } catch (e) { variant = Math.random() < 0.5 ? 'A' : 'B'; }
        tk('ab_assign_thx', { detail: variant, variant: variant });

        if (variant === 'A') {
          document.querySelector('.step[data-s="thx"]').classList.add('on');
          var sa = document.createElement('script');
          sa.src = 'https://embed.ycb.me';
          sa.async = true;
          sa.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
          sa.setAttribute('data-displaymode', 'auto');
          document.getElementById('ycbm-container').appendChild(sa);
        } else {
          document.querySelector('.step[data-s="thx2"]').classList.add('on');
          v2InitScore();
          v2StartCountdown();
          var sb = document.createElement('script');
          sb.src = 'https://embed.ycb.me';
          sb.async = true;
          sb.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
          sb.setAttribute('data-displaymode', 'auto');
          document.getElementById('ycbm-container-v2').appendChild(sb);
        }
      }).catch(function(){
        btn.disabled = false;
        btn.textContent = 'Jetzt Report sichern';
        alert('Etwas ist schiefgelaufen. Bitte nochmal versuchen.');
      });
    }

    // === V2-Helpers (FC-Mirror Variante) ===
    function v2InitScore() {
      var score;
      try {
        var p = new URLSearchParams(location.search);
        var raw = p.get('score');
        if (raw) {
          var v = parseInt(raw, 10);
          if (!isNaN(v)) score = Math.max(70, Math.min(95, v));
        }
        if (!score) {
          var cached = sessionStorage.getItem('sd_score');
          if (cached) { var cv = parseInt(cached, 10); if (!isNaN(cv)) score = cv; }
        }
      } catch(e){}
      if (!score) {
        score = 84 + Math.floor(Math.random() * 9); // 84..92
        try { sessionStorage.setItem('sd_score', String(score)); } catch(e){}
      }
      document.getElementById('v2-score-h').textContent = score;
      var radius = 88;
      var circumference = 2 * Math.PI * radius;
      var ring = document.getElementById('v2-score-ring');
      var display = document.getElementById('v2-score-num');
      ring.style.strokeDasharray = '0 ' + circumference;
      var start = null;
      var duration = 1500;
      function step(ts) {
        if (!start) start = ts;
        var t = Math.min(1, (ts - start) / duration);
        var eased = 1 - Math.pow(1 - t, 3);
        display.textContent = Math.round(score * eased);
        ring.style.strokeDasharray = (circumference * (score / 100) * eased) + ' ' + circumference;
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function v2StartCountdown() {
      // 8-Minuten Urgency-Timer (per Session resetbar)
      var deadline;
      try {
        var stored = sessionStorage.getItem('sd_cd_deadline');
        deadline = stored ? parseInt(stored, 10) : 0;
        if (!deadline || deadline < Date.now()) {
          deadline = Date.now() + 8 * 60 * 1000;
          sessionStorage.setItem('sd_cd_deadline', String(deadline));
        }
      } catch(e) { deadline = Date.now() + 8 * 60 * 1000; }
      function pad(n) { return n < 10 ? '0' + n : '' + n; }
      function tick() {
        var ms = Math.max(0, deadline - Date.now());
        var totalSec = Math.floor(ms / 1000);
        var h = Math.floor(totalSec / 3600);
        var m = Math.floor((totalSec % 3600) / 60);
        var s = totalSec % 60;
        var hEl = document.getElementById('cd-h');
        var mEl = document.getElementById('cd-m');
        var sEl = document.getElementById('cd-s');
        if (hEl) hEl.textContent = pad(h);
        if (mEl) mEl.textContent = pad(m);
        if (sEl) sEl.textContent = pad(s);
        if (ms > 0) setTimeout(tick, 1000);
      }
      tick();
    }

    function v2ScrollToBooking() {
      tk('v2_bundle_cta_click');
      var el = document.getElementById('ycbm-container-v2');
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  </script>

