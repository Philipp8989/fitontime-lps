          <button class="opt" onclick="nxt(10,this,'woche',8)"><div><strong>Mehrmals pro Woche</strong><span>Ich frage mich, was los ist.</span></div></button>
          <button class="opt" onclick="nxt(10,this,'spiegel',5)"><div><strong>Gelegentlich</strong><span>Wenn ich mich im Spiegel sehe.</span></div></button>
          <button class="opt" onclick="nxt(10,this,'proaktiv',3)"><div><strong>Kaum</strong><span>Ich will proaktiv vorgehen.</span></div></button>
        </div>
      </div>

      <!-- F11: Alltag — MULTI -->
      <div class="step" data-s="11">
        <div class="step-eyebrow">Dein Alltag</div>
        <h2>Wie sieht dein Alltag gerade aus?</h2>
        <p class="multi-note">Mehrfachauswahl möglich</p>
        <div class="opts" id="m11">
          <button class="opt" data-v="vollzeit" onclick="mtoggle(this)"><div><strong>Vollzeit berufstätig</strong></div><div class="chk-mark"></div></button>
          <button class="opt" data-v="kinder" onclick="mtoggle(this)"><div><strong>Kinder zuhause</strong></div><div class="chk-mark"></div></button>
          <button class="opt" data-v="fuehrung" onclick="mtoggle(this)"><div><strong>Beruflich sehr eingespannt / Führungsposition</strong></div><div class="chk-mark"></div></button>
          <button class="opt" data-v="selbst" onclick="mtoggle(this)"><div><strong>Selbstständig</strong></div><div class="chk-mark"></div></button>
          <button class="opt" data-v="teilzeit" onclick="mtoggle(this)"><div><strong>Teilzeit oder reduziert</strong></div><div class="chk-mark"></div></button>
          <button class="opt" data-v="umbruch" onclick="mtoggle(this)"><div><strong>Aktuell in einer Umbruchphase</strong><span>Umzug, Jobwechsel, Trennung…</span></div><div class="chk-mark"></div></button>
        </div>
        <button class="multi-submit" id="m11sub" disabled onclick="msubmit(11)">Weiter →</button>
      </div>

      <!-- F12: Ziel-Freitext -->
      <div class="step" data-s="12">
        <div class="step-eyebrow">Letzte Frage</div>
        <h2>Was würde sich in deinem Leben ändern, wenn dein Körper wieder mit dir zusammenarbeitet?</h2>
        <p class="step-sub">Deine Antwort sieht nur unser Coaching-Team. Sie hilft uns, dich nicht mit Standard-Tipps abzuspeisen.</p>
        <textarea id="goal" class="textarea-field" placeholder="Kurz in deinen eigenen Worten…" minlength="10" maxlength="500" required></textarea>
        <p style="font-size:11px;color:var(--text-3);margin-top:8px;text-align:right;"><span id="goalCnt">0</span> / 500</p>
        <button class="multi-submit" id="goalSub" disabled onclick="goalSubmit()" style="margin-top:18px;">Auswertung starten →</button>
      </div>

      <!-- Loading -->
      <div class="step ld" data-s="ld">
        <div class="spinner"></div>
        <h2>Dein MSM-Profil wird erstellt</h2>
        <p>Wir analysieren deine Antworten. Einen Moment…</p>
        <div class="checks">
          <div class="chk" id="c1"><i>✓</i>Antworten analysiert</div>
          <div class="chk" id="c2"><i>✓</i>Score berechnet</div>
          <div class="chk" id="c3"><i>✓</i>Kritische Dimension erkannt</div>
          <div class="chk" id="c4"><i>✓</i>Team wird benachrichtigt</div>
        </div>
      </div>

      <!-- Exit-Screen unter 35 -->
      <div class="step exit" data-s="exit">
        <h2>Der MSM-Test ist für Frauen ab 35.</h2>
        <p>Für deine Altersgruppe haben wir einen besser passenden Test.<br>Die MSM-Muster entstehen typischerweise ab der Perimenopause.</p>
        <a href="/stoffwechsel-test/">Zum passenden Test für dich →</a>
      </div>

    </div>
  </div>

  <script is:inline>
    var quizAnswers = {};
    // Reihenfolge der Fragen (nicht-linear wegen Lead-Gate)
    var FLOW = ['1','2','3','4','5','6','7','8','9','gate','10','11','12'];
    var TOTAL = 12;
    var qHistory = ['1'];
    var scoreAccum = 0;

    // Sticky CTA
    (function stickyCta(){
      var sticky = document.getElementById('stickyCta');
      if (!sticky) return;
      window.addEventListener('scroll', function(){
        var quizOn = document.getElementById('quiz').classList.contains('on');
        if (quizOn) { sticky.classList.remove('show'); return; }
        sticky.classList.toggle('show', window.scrollY > 600);
      }, { passive: true });
    })();

    // Live-Counter, organische Drift (langsam, +/- 1-2, bounded 6-15)
    (function liveCounter(){
      var el = document.getElementById('liveCnt');
      if (!el) return;
      var n = 8 + Math.floor(Math.random() * 4);
      el.textContent = n;
      function tick(){
        var step = Math.random() < 0.5 ? -1 : 1;
        if (Math.random() < 0.25) step *= 2;
        n = Math.max(6, Math.min(15, n + step));
        el.textContent = n;
        setTimeout(tick, 25000 + Math.floor(Math.random() * 35000));
      }
      setTimeout(tick, 18000 + Math.floor(Math.random() * 12000));
    })();

    // Tracking
    function tk(e, d) {
      var tries = 0;
      function fire() {
        if (window.__lp) {
          window.__lp.track(e, Object.assign({ page: 'msm' }, d || {}), 'fot', 'MSM Test');
          if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'MSM Test Quiz Start', currency: 'EUR' });
          if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'MSM Test Quiz Complete', currency: 'EUR' });
          if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'MSM Test Lead', currency: 'EUR' });
        } else if (tries++ < 40) {
          setTimeout(fire, 50);
        }
      }
      fire();
    }
    tk('page_view');

    // Reveal-on-Scroll via IntersectionObserver
    (function reveal(){
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el){ el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el){ io.observe(el); });
    })();

    function startQuiz() {
      tk('quiz_start');
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0, 0);
    }

    function stepIndex(key) {
      return FLOW.indexOf(key);
    }

    function progressPos(key) {
      // Visueller Fortschritt: Lead-Gate zählt als Position 9.5
      if (key === 'gate') return 9.5;
      if (key === 'ld' || key === 'exit') return 12;
      var n = parseInt(key, 10);
      return isNaN(n) ? 0 : n;
    }

    function setProgress(key) {
      var pos = progressPos(key);
      var p = Math.round((pos / TOTAL) * 100);
      document.getElementById('qf').style.width = p + '%';
      var bar = document.getElementById('qbar');
      if (bar) bar.setAttribute('aria-valuenow', p);
      if (key === 'gate') {
        document.getElementById('qr').textContent = '—';
        document.getElementById('qp').textContent = 'Kontakt für Rückruf';
      } else if (!isNaN(parseInt(key, 10))) {
        document.getElementById('qr').textContent = key + '/12';
        document.getElementById('qp').textContent = 'Frage ' + key + ' von 12';
      }
      var left = Math.max(10, Math.round((TOTAL - pos) * 14));
      document.getElementById('qt').textContent = '⏱ ~' + left + ' Sek.';
      document.getElementById('qback').classList.toggle('hidden', qHistory.length <= 1);
    }

    function show(key) {
      document.querySelectorAll('.step').forEach(function(el){ el.classList.remove('on'); });
      var target = document.querySelector('.step[data-s="' + key + '"]');
      if (target) target.classList.add('on');
      setProgress(key);
    }

    function nxt(s, el, val, pts) {
      quizAnswers['q' + s] = el ? (el.querySelector('strong') ? el.querySelector('strong').textContent.trim() : el.textContent.trim()) : '';
      quizAnswers['q' + s + '_val'] = val;
      quizAnswers['q' + s + '_pts'] = pts || 0;

      // F1 Exit: Unter 35
      if (s === 1 && val === 'u35') {
        setTimeout(function(){ show('exit'); }, 200);
        return;
      }

      scoreAccum += (pts || 0);
      tk('quiz_answer', { detail: 'q' + s + '_' + val });
      if (el) el.classList.add('selected');

      setTimeout(function(){
        var currentKey = String(s);
        var idx = stepIndex(currentKey);
        var next = FLOW[idx + 1];
        if (!next) { finalize(); return; }
        qHistory.push(next);
        show(next);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, 180);
    }

    // Multi-Select-Fragen (F9, F11)
    function mtoggle(el) {
      el.classList.toggle('chk-sel');
      var parent = el.parentElement;
      var any = parent.querySelectorAll('.chk-sel').length > 0;
      var subId = parent.id === 'm9' ? 'm9sub' : 'm11sub';
      document.getElementById(subId).disabled = !any;
    }

    function msubmit(s) {
      var parent = document.getElementById('m' + s);
      var selected = Array.from(parent.querySelectorAll('.chk-sel')).map(function(el){ return el.getAttribute('data-v'); });
      quizAnswers['q' + s] = selected.join(',');
      quizAnswers['q' + s + '_val'] = selected;

      if (s === 9) {
        var pts = selected.length >= 4 ? 12 : selected.length >= 2 ? 7 : 3;
        // Sonderregel: reines "nichts" → 3 Pkt
        if (selected.length === 1 && selected[0] === 'nichts') pts = 3;
        quizAnswers.q9_pts = pts;
        quizAnswers.glp1_used = selected.indexOf('glp1') !== -1;
        scoreAccum += pts;
      }

      tk('quiz_answer', { detail: 'q' + s + '_multi' });
      setTimeout(function(){
        var idx = stepIndex(String(s));
        var next = FLOW[idx + 1];
        qHistory.push(next);
        show(next);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, 180);
    }

    // F12: Freitext
    var goalEl = document.getElementById('goal');
    var goalCnt = document.getElementById('goalCnt');
    var goalSub = document.getElementById('goalSub');
    goalEl.addEventListener('input', function(){
      var len = goalEl.value.trim().length;
      goalCnt.textContent = len;
      goalSub.disabled = len < 10;
    });
    function goalSubmit() {
      var t = goalEl.value.trim();
      if (t.length < 10) return;
      quizAnswers.q12 = t;
      finalize();
    }

    // Lead-Gate
    document.getElementById('ds').addEventListener('change', function(){
      document.getElementById('gbtn').disabled = !this.checked;
    });

    function gateSubmit() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      quizAnswers.gate_name = fn;
      quizAnswers.gate_email = em;
      quizAnswers.gate_phone = '+41' + ph;
      tk('quiz_lead_gate_submitted', { detail: fn });

      // Weiter zur F10
      var idx = stepIndex('gate');
      var next = FLOW[idx + 1];
      qHistory.push(next);
      show(next);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function back() {
      if (qHistory.length <= 1) return;
      qHistory.pop();
      var prev = qHistory[qHistory.length - 1];
      show(prev);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // SCORING: berechne finalen Score + Stufe + kritische Dimension
    function computeResult() {
      var MAX = 139;
      var score = Math.min(100, Math.round((scoreAccum / MAX) * 100));

      var stufe = 1, stufeName = 'Frühwarnung';
      if (score >= 86) { stufe = 4; stufeName = 'Vollbild-MSM'; }
      else if (score >= 61) { stufe = 3; stufeName = 'Cascade-Phase'; }
      else if (score >= 31) { stufe = 2; stufeName = 'Aktive Signalphase'; }

      // Dimensionen: Prozentsatz der erreichten Punkte pro Dimension
      var dims = {
        muskel: { pts: quizAnswers.q5_pts || 0, max: 15, label: 'Muskel & Kraft' },
        gelenk: { pts: quizAnswers.q4_pts || 0, max: 15, label: 'Gelenk & Struktur' },
        fett: { pts: quizAnswers.q3_pts || 0, max: 15, label: 'Fettverteilung' },
        schlaf: { pts: quizAnswers.q6_pts || 0, max: 12, label: 'Schlaf & Regeneration' },
        energie: { pts: quizAnswers.q7_pts || 0, max: 15, label: 'Energie & Stoffwechsel' },
        stress: { pts: quizAnswers.q8_pts || 0, max: 10, label: 'Stress & Nervensystem' },
        historie: { pts: quizAnswers.q9_pts || 0, max: 12, label: 'Frustration & Historie' }
      };
      var critKey = 'muskel', critPct = 0;
      Object.keys(dims).forEach(function(k){
        var pct = Math.round((dims[k].pts / dims[k].max) * 100);
        dims[k].pct = pct;
        if (pct > critPct) { critPct = pct; critKey = k; }
      });
      return {
        score: score,
        stufe: stufe,
        stufeName: stufeName,
        critDim: critKey,
        critDimLabel: dims[critKey].label,
        critPct: critPct,
        dims: dims,
        glp1Used: !!quizAnswers.glp1_used
      };
    }

    function finalize() {
      tk('quiz_complete');
      show('ld');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qback').classList.add('hidden');

      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 500);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1200);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 1900);
      setTimeout(function(){ document.getElementById('c4').classList.add('show'); }, 2600);
      setTimeout(function(){
        var result = computeResult();
        submitLead(result);
      }, 3400);
    }

    function submitLead(result) {
      var payload = {
        name: quizAnswers.gate_name,
        email: quizAnswers.gate_email,
        phone: quizAnswers.gate_phone,
        lp_slug: 'msm',
        lp_name: 'MSM-Test',
        answers: Object.assign({}, quizAnswers, {
          msm_score: result.score,
          msm_stufe: result.stufe,
          msm_stufe_name: result.stufeName,
          msm_crit_dim: result.critDim,
          msm_crit_dim_label: result.critDimLabel,
          msm_crit_pct: result.critPct,
          msm_glp1: result.glp1Used
        })
      };

      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).then(function(res){
        if (!res.ok) throw new Error('insert-failed');
        tk('lead_submit', { detail: quizAnswers.gate_name + ' · Score ' + result.score + ' · Stufe ' + result.stufe });
        try {
          sessionStorage.setItem('fot_msm_result', JSON.stringify({
            name: (quizAnswers.gate_name || '').split(' ')[0],
            score: result.score,
            stufe: result.stufe,
            stufeName: result.stufeName,
            critDim: result.critDim,
            critDimLabel: result.critDimLabel,
            critPct: result.critPct,
            glp1: result.glp1Used,
            phone: quizAnswers.gate_phone,
            ts: Date.now()
          }));
        } catch (e) {}
        window.location.href = '/msm/ergebnis/';
      }).catch(function(){
        // Fallback: trotzdem weiterleiten, damit Kundin ihren Score sieht
        try {
          sessionStorage.setItem('fot_msm_result', JSON.stringify({
            name: (quizAnswers.gate_name || '').split(' ')[0],
            score: result.score,
            stufe: result.stufe,
            stufeName: result.stufeName,
            critDim: result.critDim,
            critDimLabel: result.critDimLabel,
            critPct: result.critPct,
            glp1: result.glp1Used,
            phone: quizAnswers.gate_phone,
            ts: Date.now()
          }));
        } catch (e) {}
        window.location.href = '/msm/ergebnis/';
      });
    }
  </script>

  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

