---
// MSM-Test  —  Musculoskeletal Syndrome of Menopause Quiz
// 12 Fragen · adaptiv · Lead-Gate bei F10 · Score 0-100 · Stufe 1-4 · kritischste Dimension
import CookieBanner from '../../components/CookieBanner.astro';
const impressumUrl = 'https://fitontime.ch/impressum-datenschutz';
const datenschutzUrl = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#1d73d3" />
  <title>MSM-Test — Das Muster der Wechseljahre, das fast niemand kennt | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preload" as="image" href="/images/logo.png" fetchpriority="high" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --bg-soft: #f3ede1;
      --card: #ffffff;
      --border: #e8e4da;
      --accent: #1d73d3;
      --accent-dark: #155aa8;
      --accent-soft: #eaf2fc;
      --green: #16a34a;
      --amber: #f59e0b;
      --red: #dc2626;
      --text: #0f172a;
      --text-2: #475569;
      --text-3: #94a3b8;
      --r: 16px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
      --shadow-sm: 0 2px 8px rgba(15,23,42,0.04);
      --shadow-md: 0 6px 20px rgba(29,115,211,0.14);
      --shadow-lg: 0 12px 28px rgba(29,115,211,0.22);
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    button:focus-visible, a:focus-visible, input:focus-visible, label:focus-visible { outline: 3px solid var(--accent); outline-offset: 3px; border-radius: 6px; }
    .opt:focus-visible, .cta-btn:focus-visible, .submit:focus-visible { outline-offset: 4px; }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; scroll-behavior: auto !important; }
    }

    /* ===== Reveal-on-Scroll System (IntersectionObserver) ===== */
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.7s cubic-bezier(0.2, 0.9, 0.3, 1), transform 0.7s cubic-bezier(0.2, 0.9, 0.3, 1); }
    .reveal.in { opacity: 1; transform: translateY(0); }
    .reveal-stagger > * { opacity: 0; transform: translateY(18px); transition: opacity 0.55s cubic-bezier(0.2, 0.9, 0.3, 1), transform 0.55s cubic-bezier(0.2, 0.9, 0.3, 1); }
    .reveal-stagger.in > *:nth-child(1) { opacity: 1; transform: translateY(0); transition-delay: 0.05s; }
    .reveal-stagger.in > *:nth-child(2) { opacity: 1; transform: translateY(0); transition-delay: 0.12s; }
    .reveal-stagger.in > *:nth-child(3) { opacity: 1; transform: translateY(0); transition-delay: 0.19s; }
    .reveal-stagger.in > *:nth-child(4) { opacity: 1; transform: translateY(0); transition-delay: 0.26s; }
    .reveal-stagger.in > *:nth-child(5) { opacity: 1; transform: translateY(0); transition-delay: 0.33s; }
    .reveal-stagger.in > *:nth-child(6) { opacity: 1; transform: translateY(0); transition-delay: 0.4s; }

    /* ===== Hero-Polish ===== */
    .hero h1 em::after { animation: highlight-grow 1.1s cubic-bezier(0.2, 0.9, 0.3, 1) 0.3s both; transform-origin: left center; }
    @keyframes highlight-grow { from { transform: scaleX(0) skewX(-4deg); } to { transform: scaleX(1) skewX(-4deg); } }
    .hero h1 { animation: hero-fade 0.6s cubic-bezier(0.2, 0.9, 0.3, 1) both; }
    .hero .sub { animation: hero-fade 0.6s cubic-bezier(0.2, 0.9, 0.3, 1) 0.15s both; }
    .hero .badge { animation: hero-fade 0.6s cubic-bezier(0.2, 0.9, 0.3, 1) 0.05s both; }
    .hero .cta-wrap { animation: hero-fade 0.6s cubic-bezier(0.2, 0.9, 0.3, 1) 0.3s both; }
    .hero .proof-bar { animation: hero-fade 0.6s cubic-bezier(0.2, 0.9, 0.3, 1) 0.45s both; }
    @keyframes hero-fade { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    /* CTA Button Glow-Pulse (idle attention) */
    .cta-btn { position: relative; overflow: hidden; }
    .cta-btn::before { content: ''; position: absolute; top: 0; left: -120%; width: 60%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.35), transparent); animation: cta-shine 3.2s ease-in-out infinite; pointer-events: none; }
    @keyframes cta-shine { 0%, 75%, 100% { left: -120%; } 85% { left: 220%; } }

    /* Sticky CTA — sanftere Show-Anim */
    .sticky-cta { transition: transform 0.45s cubic-bezier(0.2, 0.9, 0.3, 1), opacity 0.3s; opacity: 0; }
    .sticky-cta.show { opacity: 1; }

    /* Dimension-Cards — Hover-Lift */
    .dim { transition: transform 0.25s cubic-bezier(0.2, 0.9, 0.3, 1), box-shadow 0.25s; cursor: default; }
    .dim:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
    .dim .d-ic { transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); display: inline-block; }
    .dim:hover .d-ic { transform: scale(1.15) rotate(-4deg); }

    /* 3-Schritte-Cards — Hover */
    .stp { transition: transform 0.25s cubic-bezier(0.2, 0.9, 0.3, 1), box-shadow 0.25s, border-color 0.25s; }
    .stp:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--accent-soft); }
    .stp .n { transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .stp:hover .n { transform: scale(1.1); }

    /* Transformations — Reveal-In bei Hover */
    .trans-grid img { transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.3, 1), filter 0.3s; }
    .trans-grid img:hover { transform: scale(1.04); filter: brightness(1.06); }

    /* Quiz-Polish */
    .opt { position: relative; }
    .opt:active { transform: scale(0.97); }
    .opt.selected { animation: opt-confirm 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @keyframes opt-confirm { 0% { transform: scale(1); } 40% { transform: scale(1.03); box-shadow: 0 0 0 8px rgba(29, 115, 211, 0.12); } 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(29, 115, 211, 0); } }
    .opt.chk-sel .chk-mark { animation: chk-pop 0.32s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @keyframes chk-pop { 0% { transform: scale(0.6); } 60% { transform: scale(1.18); } 100% { transform: scale(1); } }

    /* Quiz Progress-Bar Glow */
    .q-fill { position: relative; }
    .q-fill::after { content: ''; position: absolute; top: 0; right: 0; width: 22px; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.7)); border-radius: 0 3px 3px 0; opacity: 0.7; }

    /* Loading-Checks — bounce-in */
    .chk { transition: opacity 0.4s, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .chk.show i { animation: tick-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
    @keyframes tick-pop { 0% { transform: scale(0.4); } 60% { transform: scale(1.18); } 100% { transform: scale(1); } }
    .spinner { animation: spin 0.9s linear infinite, spinner-glow 2s ease-in-out infinite; }
    @keyframes spinner-glow { 0%, 100% { box-shadow: 0 0 0 0 rgba(29, 115, 211, 0); } 50% { box-shadow: 0 0 0 12px rgba(29, 115, 211, 0.08); } }

    /* Benefit-Items Hover */
    .benefit { transition: transform 0.2s, border-color 0.2s; }
    .benefit:hover { transform: translateX(3px); border-color: var(--accent-soft); }

    .wrap { max-width: 760px; margin: 0 auto; padding: 0 20px; }

    .logo { text-align: center; padding: 18px 0 6px; }
    .logo img { height: 44px; }

    .topbar { display: flex; align-items: center; justify-content: center; gap: 14px; padding: 6px 0 10px; font-size: 11px; color: var(--text-3); font-weight: 500; }
    .topbar span.dot { width: 4px; height: 4px; border-radius: 50%; background: var(--text-3); }
    .topbar .live { color: var(--green); font-weight: 700; }
    .topbar .live::before { content: '●'; margin-right: 4px; animation: pulse 1.6s ease-in-out infinite; display: inline-block; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    .hero { text-align: center; padding: 14px 0 22px; }
    .hero .badge { display: inline-block; background: var(--accent-soft); color: var(--accent); font-size: 12px; font-weight: 700; padding: 6px 14px; border-radius: 20px; margin-bottom: 14px; letter-spacing: 0.3px; }
    .hero h1 { font-size: 30px; font-weight: 900; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 14px; color: var(--text); }
    .hero h1 em { font-style: normal; color: var(--accent); position: relative; white-space: nowrap; z-index: 0; }
    .hero h1 em::after { content: ''; position: absolute; left: -2px; right: -2px; bottom: 2px; height: 12px; background: linear-gradient(90deg, rgba(29,115,211,0.18) 0%, rgba(59,146,240,0.28) 100%); z-index: -1; border-radius: 4px; transform: skewX(-4deg); }
    .hero .sub { font-size: 16px; color: var(--text-2); margin-bottom: 10px; line-height: 1.5; max-width: 560px; margin-left: auto; margin-right: auto; }
    .hero .sub strong { color: var(--text); font-weight: 700; }

    .proof-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 16px 0 6px; }
    .proof-info { font-size: 12px; color: var(--text-2); line-height: 1.35; text-align: center; }
    .proof-info b { color: var(--text); font-weight: 700; }
    .proof-stars { color: var(--amber); font-size: 13px; letter-spacing: 1px; }

    .benefits { display: grid; gap: 10px; max-width: 520px; margin: 20px auto 0; text-align: left; }
    .benefit { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: var(--card); border: 1px solid var(--border); border-radius: 12px; font-size: 14px; color: var(--text); font-weight: 500; box-shadow: var(--shadow-sm); }
    .benefit .ic { width: 28px; height: 28px; border-radius: 50%; background: var(--accent-soft); color: var(--accent); display: flex; align-items: center; justify-content: center; font-weight: 800; flex-shrink: 0; font-size: 14px; }

    .cta-wrap { margin: 24px auto 0; max-width: 520px; }
    .cta-btn { display: block; width: 100%; background: var(--accent); color: #fff; font-family: var(--font); font-size: 17px; font-weight: 800; padding: 20px; border: none; border-radius: 14px; cursor: pointer; transition: all 0.2s; text-align: center; box-shadow: var(--shadow-md); letter-spacing: 0.2px; }
    .cta-btn:hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: var(--shadow-lg); }
    .cta-btn:active { transform: scale(0.98); }
    .cta-sub { text-align: center; font-size: 12px; color: var(--text-3); margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; }
    .cta-sub b { color: var(--text-2); font-weight: 600; }

    /* Dimensions-Row (5 Icons) */
    .dims { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; max-width: 560px; margin: 28px auto 0; }
    .dim { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 14px 8px; text-align: center; box-shadow: var(--shadow-sm); }
    .dim .d-ic { font-size: 22px; margin-bottom: 6px; }
    .dim .d-title { font-size: 11px; font-weight: 800; color: var(--text); line-height: 1.2; margin-bottom: 4px; }
    .dim .d-ex { font-size: 10px; color: var(--text-3); font-weight: 500; line-height: 1.3; }
    @media (max-width: 560px) { .dims { grid-template-columns: repeat(5, 1fr); gap: 4px; } .dim { padding: 10px 4px; } .dim .d-ic { font-size: 18px; } .dim .d-title { font-size: 10px; } .dim .d-ex { display: none; } }

    /* Symptoms-Mirror (Hero, 4 Karten matchend mit Ad) */
    .symptoms { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; max-width: 560px; margin: 22px auto 0; }
    .sym { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 14px 14px; display: flex; align-items: center; gap: 12px; box-shadow: var(--shadow-sm); text-align: left; }
    .sym .s-ic { font-size: 24px; flex-shrink: 0; }
    .sym .s-text { font-size: 13px; font-weight: 600; color: var(--text); line-height: 1.35; }
    .sym-hint { text-align: center; font-size: 13px; color: var(--text-2); margin-top: 14px; font-weight: 500; }
    .sym-hint b { color: var(--text); font-weight: 800; }
    @media (max-width: 540px) { .symptoms { grid-template-columns: 1fr; } .sym .s-text { font-size: 14px; } }

    /* Ozempic-Tag */
    .ozempic-tag { font-size: 12px; color: var(--text-2); margin-top: 12px; padding: 10px 14px; background: var(--accent-soft); border-radius: 10px; line-height: 1.45; text-align: center; max-width: 460px; margin-left: auto; margin-right: auto; }

    /* Stufen-Skala */
    .stages-section { max-width: 620px; margin: 32px auto; }
    .stages-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 6px; letter-spacing: -0.3px; }
    .stages-sub { font-size: 13px; color: var(--text-3); text-align: center; margin-bottom: 18px; }
    .stages-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; }
    .stage { padding: 14px 10px; border-radius: 10px; text-align: center; color: #fff; box-shadow: var(--shadow-sm); }
    .stage .s-num { font-size: 11px; font-weight: 700; opacity: 0.9; letter-spacing: 0.5px; text-transform: uppercase; }
    .stage .s-label { font-size: 13px; font-weight: 800; margin-top: 4px; line-height: 1.2; }
    .stage-1 { background: #16a34a; }
    .stage-2 { background: #f59e0b; }
    .stage-3 { background: #ea580c; }
    .stage-4 { background: #dc2626; }
    .stages-foot { font-size: 12px; color: var(--text-2); text-align: center; margin-top: 12px; }
    .stages-foot b { color: var(--text); font-weight: 700; }
    @media (max-width: 480px) { .stage .s-label { font-size: 11px; } .stage { padding: 12px 6px; } }

    /* Education-Block (Was ist MSM) */
    .edu-section { max-width: 620px; margin: 32px auto; }
    .edu-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 14px; letter-spacing: -0.3px; }
    .edu-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    @media (min-width: 600px) { .edu-grid { grid-template-columns: repeat(3, 1fr); } }
    .edu-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 16px; box-shadow: var(--shadow-sm); }
    .edu-card .e-ic { font-size: 24px; margin-bottom: 8px; }
    .edu-card h4 { font-size: 14px; font-weight: 800; margin-bottom: 6px; }
    .edu-card p { font-size: 13px; color: var(--text-2); line-height: 1.5; }
    .edu-source { font-size: 11px; color: var(--text-3); text-align: center; margin-top: 10px; line-height: 1.5; }

    /* Coach-Bridge */
    .coach-section { max-width: 620px; margin: 32px auto; padding: 18px; background: var(--card); border: 1px solid var(--border); border-radius: 16px; box-shadow: var(--shadow-sm); }
    .coach-row { display: flex; gap: 14px; align-items: center; }
    .coach-photos { display: flex; flex-shrink: 0; }
    .coach-photos img { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; border: 3px solid var(--card); background: var(--bg-soft); }
    .coach-photos img + img { margin-left: -14px; }
    .coach-text { flex: 1; }
    .coach-text strong { display: block; font-size: 14px; font-weight: 800; margin-bottom: 4px; color: var(--text); }
    .coach-text p { font-size: 13px; color: var(--text-2); line-height: 1.5; }
    @media (max-width: 480px) { .coach-row { flex-direction: column; text-align: center; } .coach-text strong { margin-top: 8px; } }

    /* 3-Schritte-Block */
    .steps { display: grid; grid-template-columns: 1fr; gap: 12px; max-width: 520px; margin: 28px auto 0; }
    @media (min-width: 600px) { .steps { grid-template-columns: 1fr 1fr 1fr; } }
    .stp { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 16px; box-shadow: var(--shadow-sm); text-align: center; }
    .stp .n { width: 32px; height: 32px; border-radius: 50%; background: var(--accent-soft); color: var(--accent); display: inline-flex; align-items: center; justify-content: center; font-weight: 800; margin-bottom: 10px; }
    .stp h4 { font-size: 15px; font-weight: 800; margin-bottom: 6px; }
    .stp p { font-size: 13px; color: var(--text-2); line-height: 1.45; }

    .trans { margin: 36px 0 20px; }
    .trans-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 4px; letter-spacing: -0.3px; }
    .trans-sub { font-size: 13px; color: var(--text-3); text-align: center; margin-bottom: 16px; }
    .trans-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; max-width: 520px; margin: 0 auto; }
    .trans-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; background: var(--card); }

    /* FAQ */
    .faq { max-width: 620px; margin: 36px auto 12px; }
    .faq-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 16px; letter-spacing: -0.3px; }
    details { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 14px 18px; margin-bottom: 8px; cursor: pointer; }
    details summary { font-weight: 700; font-size: 14px; color: var(--text); list-style: none; position: relative; padding-right: 24px; }
    details summary::-webkit-details-marker { display: none; }
    details summary::after { content: '+'; position: absolute; right: 0; top: -2px; font-size: 20px; color: var(--text-3); font-weight: 400; }
    details[open] summary::after { content: '−'; }
    details p { font-size: 13px; color: var(--text-2); line-height: 1.6; padding-top: 10px; margin-top: 10px; border-top: 1px solid var(--border); }

    .disclaimer { max-width: 620px; margin: 24px auto; padding: 14px 18px; background: #f8fafc; border: 1px solid var(--border); border-radius: 12px; font-size: 11px; color: var(--text-3); line-height: 1.5; }

    .sticky-cta { position: fixed; bottom: 0; left: 0; right: 0; padding: 10px 16px calc(10px + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.96); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-top: 1px solid var(--border); z-index: 50; transform: translateY(120%); transition: transform 0.35s cubic-bezier(0.2, 0.9, 0.3, 1); box-shadow: 0 -4px 20px rgba(0,0,0,0.08); }
    .sticky-cta.show { transform: translateY(0); }
    .sticky-cta .cta-btn { max-width: 520px; margin: 0 auto; box-shadow: none; }
    @media (min-width: 900px) { .sticky-cta { display: none; } }

    .divider { width: 40px; height: 2px; background: var(--accent); margin: 28px auto; opacity: 0.3; border-radius: 2px; }
    footer { text-align: center; padding: 24px 20px 32px; font-size: 11px; color: var(--text-3); }
    footer a { color: var(--text-3); text-decoration: none; }
    footer a:hover { color: var(--text-2); }

    /* ===== QUIZ ===== */
    #quiz { display: none; position: fixed; inset: 0; background: var(--bg); z-index: 100; flex-direction: column; overflow-y: auto; -webkit-overflow-scrolling: touch; }
    #quiz.on { display: flex; }
    .q-head { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border); position: sticky; top: 0; background: var(--bg); z-index: 10; }
    .q-head img { height: 34px; }
    .q-back { background: transparent; border: none; color: var(--text-3); font-size: 14px; font-weight: 600; cursor: pointer; padding: 6px 10px; display: flex; align-items: center; gap: 4px; font-family: var(--font); }
    .q-back:hover { color: var(--text); }
    .q-back.hidden { visibility: hidden; }
    .q-head .q-right { font-size: 12px; color: var(--text-3); font-weight: 600; font-variant-numeric: tabular-nums; }
    .q-progress { padding: 10px 20px 0; max-width: 620px; margin: 0 auto; width: 100%; position: sticky; top: 62px; background: var(--bg); z-index: 9; padding-bottom: 10px; }
    .q-bar { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
    .q-fill { height: 100%; background: linear-gradient(90deg, var(--accent) 0%, #3b92f0 100%); border-radius: 3px; transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1); width: 0%; }
    .q-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 6px; font-size: 11px; color: var(--text-3); font-weight: 600; }
    .q-meta .q-time { color: var(--accent); }

    .q-body { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 28px 20px 40px; }
    .step { display: none; max-width: 620px; width: 100%; animation: stepIn 0.35s cubic-bezier(0.2, 0.9, 0.3, 1); }
    .step.on { display: block; }
    @keyframes stepIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .step-eyebrow { text-align: center; font-size: 11px; font-weight: 700; color: var(--accent); letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 8px; }
    .step h2 { font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 8px; line-height: 1.3; letter-spacing: -0.4px; }
    .step .step-sub { font-size: 14px; color: var(--text-2); text-align: center; margin-bottom: 24px; }

    .opts { display: flex; flex-direction: column; gap: 10px; }
    .opt { background: var(--card); border: 2px solid var(--border); border-radius: 14px; padding: 16px 18px; font-size: 15px; font-weight: 500; color: var(--text); cursor: pointer; transition: all 0.18s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: left; display: flex; align-items: flex-start; gap: 14px; box-shadow: var(--shadow-sm); }
    .opt:hover { border-color: var(--accent); background: var(--accent-soft); transform: translateY(-1px); }
    .opt:active { transform: scale(0.98); }
    .opt strong { display: block; font-weight: 700; color: var(--text); font-size: 15px; }
    .opt span { font-size: 12px; color: var(--text-2); display: block; margin-top: 3px; line-height: 1.4; }
    .opt .opt-ic { width: 40px; height: 40px; border-radius: 10px; background: var(--accent-soft); color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .opt.selected { border-color: var(--accent); background: var(--accent-soft); }
    .opt.chk-sel { border-color: var(--accent); background: var(--accent-soft); }
    .opt .chk-mark { width: 22px; height: 22px; border-radius: 6px; border: 2px solid var(--border); background: #fff; flex-shrink: 0; margin-left: auto; align-self: center; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #fff; font-weight: 800; }
    .opt.chk-sel .chk-mark { background: var(--accent); border-color: var(--accent); }
    .opt.chk-sel .chk-mark::after { content: '✓'; }

    .opts.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

    .multi-note { text-align: center; font-size: 11px; color: var(--text-3); margin-bottom: 12px; font-weight: 600; letter-spacing: 0.3px; }
    .multi-submit { display: block; width: 100%; max-width: 460px; margin: 18px auto 0; background: var(--accent); color: #fff; font-family: var(--font); font-size: 15px; font-weight: 800; padding: 16px; border: none; border-radius: 12px; cursor: pointer; box-shadow: var(--shadow-md); transition: all 0.2s; }
    .multi-submit:disabled { opacity: 0.35; cursor: not-allowed; box-shadow: none; }
    .multi-submit:not(:disabled):hover { background: var(--accent-dark); transform: translateY(-1px); }

    /* Teaching-Einschub zwischen Fragen */
    .teach { background: #fefbf2; border: 1px solid #fde68a; border-radius: 12px; padding: 14px 16px; margin: 0 0 16px; font-size: 13px; color: #78350f; font-weight: 500; line-height: 1.5; display: flex; align-items: flex-start; gap: 10px; }
    .teach .t-ic { font-size: 18px; flex-shrink: 0; }

    /* Freitext */
    .textarea-field { background: var(--card); border: 2px solid var(--border); border-radius: 12px; padding: 16px; font-family: var(--font); font-size: 15px; color: var(--text); width: 100%; min-height: 120px; resize: vertical; transition: all 0.2s; }
    .textarea-field:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }
    .textarea-field::placeholder { color: var(--text-3); }

    /* Loading */
    .ld { text-align: center; padding: 20px 0; }
    .spinner { width: 64px; height: 64px; border: 4px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.9s linear infinite; margin: 0 auto 22px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ld h2 { font-size: 20px; margin-bottom: 6px; }
    .ld p { font-size: 14px; color: var(--text-2); margin-bottom: 22px; }
    .checks { text-align: left; max-width: 320px; margin: 0 auto; }
    .chk { display: flex; align-items: center; gap: 10px; padding: 8px 0; font-size: 14px; color: var(--text-2); opacity: 0; transform: translateX(-10px); transition: all 0.35s; }
    .chk.show { opacity: 1; transform: translateX(0); }
    .chk i { width: 22px; height: 22px; border-radius: 50%; background: var(--green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-style: normal; font-weight: 700; flex-shrink: 0; }

    /* Lead-Gate Formular */
    .form { text-align: center; }
    .form .tag { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: var(--green); background: #ecfdf5; padding: 6px 12px; border-radius: 20px; margin-bottom: 12px; }
    .form h2 { font-size: 22px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.3px; }
    .form .sub { font-size: 14px; color: var(--text-2); margin-bottom: 20px; line-height: 1.5; max-width: 460px; margin-left: auto; margin-right: auto; }
    .form .sub b { color: var(--text); font-weight: 700; }
    .fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; max-width: 460px; margin-left: auto; margin-right: auto; }
    .field { background: var(--card); border: 2px solid var(--border); border-radius: 12px; padding: 0 14px; display: flex; align-items: center; gap: 10px; transition: all 0.2s; }
    .field:focus-within { border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }
    .field .ic { font-size: 16px; flex-shrink: 0; opacity: 0.7; width: 20px; text-align: center; }
    .field input { flex: 1; background: transparent; border: none; outline: none; color: var(--text); font-family: var(--font); font-size: 15px; padding: 16px 0; }
    .field input::placeholder { color: var(--text-3); }
    .field .pre { font-size: 14px; color: var(--text-2); font-weight: 600; flex-shrink: 0; }
    .cb-row { display: flex; align-items: flex-start; gap: 8px; margin: 0 auto 16px; text-align: left; max-width: 460px; }
    .cb-row input[type="checkbox"] { accent-color: var(--accent); width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0; cursor: pointer; }
    .cb-row label { font-size: 11px; color: var(--text-3); line-height: 1.5; cursor: pointer; }
    .cb-row label a { color: var(--text-2); }
    .submit { display: block; width: 100%; max-width: 460px; margin: 0 auto; background: var(--accent); color: #fff; font-family: var(--font); font-size: 16px; font-weight: 800; padding: 18px; border: none; border-radius: 14px; cursor: pointer; transition: all 0.2s; box-shadow: var(--shadow-md); }
    .submit:disabled { opacity: 0.35; cursor: not-allowed; box-shadow: none; }
    .submit:not(:disabled):hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: var(--shadow-lg); }
    .submit:not(:disabled):active { transform: scale(0.98); }
    .form-proof { margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--border); max-width: 460px; margin-left: auto; margin-right: auto; }
    .form-proof .fp-row { display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 11px; color: var(--text-3); margin-bottom: 6px; }
    .form-proof .fp-row b { color: var(--text-2); font-weight: 600; }

    /* Exit-Screen */
    .exit { text-align: center; padding: 40px 20px; }
    .exit h2 { font-size: 22px; margin-bottom: 12px; }
    .exit p { font-size: 14px; color: var(--text-2); margin-bottom: 20px; line-height: 1.6; }
    .exit a { display: inline-block; background: var(--accent); color: #fff; text-decoration: none; padding: 14px 24px; border-radius: 12px; font-weight: 700; font-size: 15px; }

    @media (min-width: 600px) {
      .hero h1 { font-size: 40px; }
      .hero .sub { font-size: 17px; }
      .step h2 { font-size: 26px; }
    }
    @media (min-width: 900px) {
      .hero h1 { font-size: 46px; }
    }
  </style>
</head>
<body>

  <!-- ===== LANDING ===== -->
  <div id="lp">
    <div class="wrap">
      <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

      <div class="topbar">
        <span class="live">Live</span>
        <span class="dot"></span>
        <span><b id="liveCnt">9</b> Frauen machen gerade den MSM-Test</span>
      </div>

      <section class="hero">
        <div class="badge">MSM-Test · Frauen ab 40</div>
        <h1>Du nimmst nicht ab. Du schläfst nicht durch. Deine Gelenke ziehen. Und du fühlst dich wie <em>60</em>.</h1>
        <p class="sub">Es sind nicht vier Probleme. Es ist eines. <strong>MSM</strong>, das Muster, bei dem rund um die Wechseljahre mehrere Systeme gleichzeitig kippen. In 3 Minuten siehst du, in welcher von 4 Stufen du steckst und was als Nächstes hilft.</p>

        <div class="symptoms reveal-stagger">
          <div class="sym"><div class="s-ic">⚖️</div><div class="s-text">Du nimmst nicht ab, obwohl du dich quälst</div></div>
          <div class="sym"><div class="s-ic">🌙</div><div class="s-text">Du wachst um 3 Uhr und kommst nicht mehr in den Schlaf</div></div>
          <div class="sym"><div class="s-ic">🦴</div><div class="s-text">Deine Gelenke ziehen, vor allem morgens</div></div>
          <div class="sym"><div class="s-ic">⚡</div><div class="s-text">Du fühlst dich erschöpft wie mit 60</div></div>
        </div>
        <p class="sym-hint">Trifft <b>2 oder mehr</b> zu? Dann mach den Test.</p>

        <div class="cta-wrap">
          <button class="cta-btn" onclick="startQuiz()">In 3 Minuten weiss ich meine Stufe →</button>
          <p class="cta-sub"><b>Kostenlos</b> <span class="dot">·</span> <b>Anonym</b> <span class="dot">·</span> <b>Keine medizinische Diagnose</b></p>
          <p class="ozempic-tag">Du nimmst Ozempic oder Wegovy? Test gilt trotzdem, wir haben ein angepasstes Vorgehen.</p>
        </div>

        <div class="proof-bar">
          <div class="proof-info">
            <div class="proof-stars">★★★★★</div>
            Über <b>4.000 Schweizer Frauen</b> zwischen 40 und 60 begleitet, seit 2016
          </div>
        </div>
      </section>

      <div class="sticky-cta" id="stickyCta">
        <button class="cta-btn" onclick="startQuiz()" style="font-size:15px;padding:14px;">MSM-Test starten →</button>
      </div>

      <!-- Stufen-Vorschau (Ad-Continuation: "Welche Stufe bist du?") -->
      <section class="stages-section reveal">
        <h2 class="stages-title">Vier Stufen, eine Skala</h2>
        <p class="stages-sub">Der Test sortiert dich in eine von vier Stufen ein.</p>
        <div class="stages-bar reveal-stagger">
          <div class="stage stage-1"><div class="s-num">Stufe 1</div><div class="s-label">Frühwarnung</div></div>
          <div class="stage stage-2"><div class="s-num">Stufe 2</div><div class="s-label">Es kippt</div></div>
          <div class="stage stage-3"><div class="s-num">Stufe 3</div><div class="s-label">Es kippt deutlich</div></div>
          <div class="stage stage-4"><div class="s-num">Stufe 4</div><div class="s-label">Vollbild</div></div>
        </div>
        <p class="stages-foot">Rund <b>60% der Frauen 40+</b> liegen aktuell in Stufe 2 oder 3.</p>
      </section>

      <!-- Education: Was ist MSM? -->
      <section class="edu-section reveal">
        <h2 class="edu-title">Was ist MSM?</h2>
        <div class="edu-grid reveal-stagger">
          <div class="edu-card">
            <div class="e-ic">🧬</div>
            <h4>Östrogen sinkt</h4>
            <p>Ab 40 verändert sich der Hormonhaushalt. Östrogen schützt nicht mehr im gleichen Mass wie früher.</p>
          </div>
          <div class="edu-card">
            <div class="e-ic">🔗</div>
            <h4>Mehrere Systeme kippen</h4>
            <p>Muskel, Gelenke, Fettstoffwechsel, Schlaf, Energie reagieren gleichzeitig. Die 4 spürbaren Symptome haben einen gemeinsamen Treiber.</p>
          </div>
          <div class="edu-card">
            <div class="e-ic">🎯</div>
            <h4>Ein Muster, kein Zufall</h4>
            <p>Es wirkt wie 4 Krankheiten, ist aber ein Muster. MSM bündelt diese Veränderungen zu einer Sicht, statt sie einzeln zu behandeln.</p>
          </div>
        </div>
        <p class="edu-source">MSM (Musculoskeletal Syndrome of Menopause) wird seit 2024 in der internationalen Fachliteratur als gemeinsames Muster diskutiert. Kein offizieller Diagnosebegriff.</p>
      </section>

      <!-- Coach-Bridge -->
      <section class="coach-section reveal">
        <div class="coach-row">
          <div class="coach-photos">
            <img src="/images/coaches/fabian.png" alt="Fabian, Coach Fit on Time" loading="lazy" />
            <img src="/images/coaches/filip.png" alt="Filip, Coach Fit on Time" loading="lazy" />
          </div>
          <div class="coach-text">
            <strong>Fabian und Filip, Coaches bei Fit on Time</strong>
            <p>Wir begleiten seit 2016 über 4.000 Schweizerinnen 40+. Das Muster sehen wir bei unseren Klientinnen seit Jahren, jetzt hat die Forschung ihm einen Namen gegeben.</p>
          </div>
        </div>
      </section>

      <!-- Section: Im Detail, fünf Systeme reagieren -->
      <section class="reveal" style="margin: 32px 0;">
        <h2 style="font-size:22px;font-weight:800;text-align:center;margin-bottom:12px;letter-spacing:-0.4px;">Im Detail, fünf Systeme reagieren gleichzeitig</h2>
        <div style="max-width:560px;margin:0 auto;font-size:15px;color:var(--text-2);line-height:1.65;">
          <p style="margin-bottom:12px;">Was du als 4 Symptome spürst (nicht abnehmen, schlecht schlafen, ziehende Gelenke, erschöpft), läuft im Körper auf 5 Systemen ab: Muskel, Gelenke, Fettstoffwechsel, Schlafregulation, Energiehaushalt. Bisher wurde jedes einzeln betrachtet und einzeln behandelt.</p>
          <p style="margin-bottom:12px;">Seit 2024 wird in der internationalen Fachliteratur diskutiert, dass diese fünf Systeme rund um die Wechseljahre eng gekoppelt sind. Der MSM-Test zeigt dir, wie stark das Muster bei dir bereits ausgeprägt ist.</p>
          <p style="font-weight:700;color:var(--text);">Du bildest dir das nicht ein.</p>
        </div>
      </section>

      <!-- 3 Schritte -->
      <section class="reveal" style="margin: 32px 0 20px;">
        <h2 style="font-size:20px;font-weight:800;text-align:center;margin-bottom:6px;letter-spacing:-0.3px;">In 3 Minuten weisst du drei Dinge:</h2>
        <div class="steps reveal-stagger">
          <div class="stp"><div class="n">1</div><h4>Deine Stufe</h4><p>Vier Stufen von Frühwarnung bis Vollbild. Wo stehst DU?</p></div>
          <div class="stp"><div class="n">2</div><h4>Kritische Dimension</h4><p>Welche der fünf Dimensionen ist bei dir am aktivsten?</p></div>
          <div class="stp"><div class="n">3</div><h4>Nächste Schritte</h4><p>Persönlich per Telefon von unserem Team — innerhalb 10 Min.</p></div>
        </div>
      </section>

      <div class="cta-wrap">
        <button class="cta-btn" onclick="startQuiz()">MSM-Test starten →</button>
        <p class="cta-sub"><b>3 Minuten</b> <span class="dot">·</span> <b>Kostenlos</b> <span class="dot">·</span> <b>Keine Diagnose</b></p>
      </div>

      <!-- Transformationen -->
      <div class="trans reveal">
        <div class="trans-title">Frauen, die ihren Körper zurückgeholt haben</div>
        <div class="trans-sub">Über 4.000 Schweizer Frauen begleitet seit 2016</div>
        <div class="trans-grid reveal-stagger">
          <img src="/images/transformations/t1.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t3.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t5.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t7.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t8.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t9.jpg" alt="" loading="lazy" />
        </div>
      </div>

      <!-- Was wir NICHT tun -->
      <section style="margin: 32px 0;">
        <h2 style="font-size:20px;font-weight:800;text-align:center;margin-bottom:14px;letter-spacing:-0.3px;">Was wir dir NICHT sagen werden</h2>
        <div style="max-width:520px;margin:0 auto;">
          <div class="benefit" style="background:#fff7ed;border-color:#fed7aa;"><span class="ic" style="background:#fed7aa;color:#9a3412;">×</span><span>Keine Crash-Diät. Kein Low-Carb. Kein Verzicht.</span></div>
          <div class="benefit" style="background:#fff7ed;border-color:#fed7aa;margin-top:10px;"><span class="ic" style="background:#fed7aa;color:#9a3412;">×</span><span>Keine Ferndiagnose. Wir sind keine Ärzte.</span></div>
          <div class="benefit" style="background:#fff7ed;border-color:#fed7aa;margin-top:10px;"><span class="ic" style="background:#fed7aa;color:#9a3412;">×</span><span>Keine Versprechen in Kilo oder Wochen.</span></div>
          <div class="benefit" style="background:#fff7ed;border-color:#fed7aa;margin-top:10px;"><span class="ic" style="background:#fed7aa;color:#9a3412;">×</span><span>Keine Hormon-Empfehlungen. Das entscheidet dein Arzt.</span></div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="faq">
        <h2 class="faq-title">Häufige Fragen</h2>
        <details><summary>Was ist MSM genau?</summary><p>MSM steht für Musculoskeletal Syndrome of Menopause. Der Begriff bezeichnet eine in der Fachliteratur seit 2024 diskutierte Beobachtung, dass typische körperliche Veränderungen rund um die Wechseljahre in fünf Dimensionen zusammen auftreten können. Dies ist kein offizieller Diagnose-Begriff.</p></details>
        <details><summary>Ist das ein ärztlicher Test?</summary><p>Nein. Es ist ein freiwilliger Selbsttest zur persönlichen Reflexion. Er stellt keine Diagnose, ersetzt keine medizinische Untersuchung und ist kein Therapievorschlag. Bei gesundheitlichen Anliegen wende dich bitte an eine Ärztin oder einen Arzt.</p></details>
        <details><summary>Was passiert nach dem Test?</summary><p>Nach dem Test meldet sich innerhalb von 10 Minuten eine unserer Coaching-Beraterinnen telefonisch bei dir. Kurz, kostenlos. Sie spricht mit dir über deine Antworten und klärt, ob ein ausführliches Beratungsgespräch mit unserem Coach für dich interessant sein könnte.</p></details>
        <details><summary>Was kostet das?</summary><p>Der Test und das erste Gespräch sind kostenlos. Das ist unser Angebot an dich.</p></details>
        <details><summary>Ich habe noch keine Wechseljahre.</summary><p>Wahrscheinlich bist du in der Perimenopause — die Phase davor. Sie beginnt oft 8-10 Jahre vor der eigentlichen Menopause. Das Muster kann sich bereits entwickeln.</p></details>
        <details><summary>Ich nehme Ozempic / Wegovy.</summary><p>Bitte mach den Test trotzdem. Wir haben ein angepasstes Vorgehen für Frauen nach GLP-1-Medikamenten — die Muskel-Dynamik ist eine andere.</p></details>
        <details><summary>Rufen wir dir dauernd hinterher?</summary><p>Nein. Eine einzige Telefonnummer, ein Gespräch. Danach entscheidest du.</p></details>
      </section>

      <div class="cta-wrap">
        <button class="cta-btn" onclick="startQuiz()">Jetzt 3-Minuten-Test machen →</button>
      </div>

      <div class="disclaimer">
        <b>Wichtiger Hinweis:</b> Der MSM-Test ist ein freiwilliger Selbstcheck zur persönlichen Reflexion. Er stellt keine Diagnose, ist keine medizinische Untersuchung und ersetzt keinen ärztlichen Rat. Die in diesem Test genannten Konzepte basieren auf öffentlich beschriebenen Beobachtungen aus der Fachliteratur. Bei gesundheitlichen Anliegen wende dich bitte an eine qualifizierte Fachperson. Fit on Time bietet Coaching im Bereich Ernährung, Bewegung, Schlaf und Alltagsstruktur — keine medizinische Behandlung, keine Therapie, keine Ernährungsberatung im gesetzlich geregelten Sinn.
