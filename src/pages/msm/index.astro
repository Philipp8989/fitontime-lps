        <div class="opts" id="m9">
          <button class="opt" data-v="diaet" onclick="mtoggle(this)"><div><strong>Diäten</strong><span>Low-Carb, Keto, Intervallfasten…</span></div><div class="chk-mark"></div></button>
          <button class="opt" data-v="fitness" onclick="mtoggle(this)"><div><strong>Fitnessstudio oder Online-Training</strong></div><div class="chk-mark"></div></button>
          <button class="opt" data-v="arzt" onclick="mtoggle(this)"><div><strong>Hormon-Tests oder HRT beim Arzt</strong></div><div class="chk-mark"></div></button>
