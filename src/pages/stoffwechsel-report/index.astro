---
// Stoffwechsel-Report (Blockaden-Loesen) - FitonTime
// Struktur 1:1 an Live-Winner fit-on-time.ch/blockaden-loesen/ orientiert
// UI/UX-Upgrade: echte Vorher-Nachher-Bilder, cleaneres Typo-System, bessere Mobile-UX
import CookieBanner from '../../components/CookieBanner.astro';
const impressumUrl = 'https://fitontime.ch/impressum-datenschutz';
const datenschutzUrl = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Welcher Körper-Typ bist Du? | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preload" as="image" href="/images/transformations/t5.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --surface: #f0ebe0;
      --surface-2: #e5dfd2;
      --accent: #2b7de9;
      --accent-dark: #1a5bb8;
      --green: #22c55e;
      --amber: #f59e0b;
      --red: #ef4444;
      --text: #1a1a1a;
      --text-2: #4a4a4a;
      --text-3: #888;
      --r: 14px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    .wrap { max-width: 720px; margin: 0 auto; padding: 0 20px; }

    /* Logo */
    .logo { text-align: center; padding: 16px 0 8px; }
    .logo img { height: 40px; }

    /* Hero */
    .hero { text-align: center; padding: 16px 0 20px; }
    .hero h1 { font-size: 26px; font-weight: 800; line-height: 1.25; letter-spacing: -0.5px; margin-bottom: 12px; }
    .hero h1 em { font-style: normal; color: var(--accent); }
    .hero .sub { font-size: 15px; color: var(--text-2); margin-bottom: 12px; line-height: 1.5; }
    .hero .sub strong { color: var(--text); font-weight: 600; }

    /* CTA-Block: Geschlechter-Auswahl als Start */
    .start-block { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 20px 18px; margin: 12px 0; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
    .start-block .sb-q { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 12px; }
    .start-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .start-btn { background: var(--accent); color: #fff; border: none; border-radius: 12px; padding: 16px 12px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; box-shadow: 0 4px 14px rgba(43,125,233,0.25); }
    .start-btn:hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: 0 6px 18px rgba(43,125,233,0.35); }
    .start-btn:active { transform: scale(0.98); }
    .start-btn.secondary { background: #fff; color: var(--accent); border: 2px solid var(--accent); box-shadow: none; }
    .start-btn.secondary:hover { background: #eef6ff; }

    /* Social Proof */
    .proof-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 0 6px; flex-wrap: wrap; }
    .proof-avatars { display: flex; }
    .proof-avatars img { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--bg); margin-left: -10px; object-fit: cover; object-position: center 30%; }
    .proof-avatars img:first-child { margin-left: 0; }
    .proof-info { font-size: 12px; color: var(--text-3); line-height: 1.3; text-align: left; }
    .proof-info b { color: var(--text); }
    .proof-stars { color: var(--amber); font-size: 12px; letter-spacing: 1px; }
    .proof-trust { display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 12px; color: var(--text-2); margin-top: 6px; font-weight: 500; }
    .proof-trust .ic { color: var(--green); font-weight: 700; }

    /* Transformation Grid */
    .trans { margin: 28px 0; }
    .trans-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 6px; }
    .trans-sub { font-size: 13px; color: var(--text-3); text-align: center; margin-bottom: 16px; }
    .trans-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .trans-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; background: #fff; }
    .trans-cap { font-size: 11px; color: var(--text-3); text-align: center; margin-top: 10px; }

    /* Section Titles */
    .sec-eyebrow { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--red); font-weight: 700; text-align: center; margin-bottom: 6px; }
    .sec-eyebrow.amber { color: var(--amber); }
    .sec-eyebrow.green { color: var(--green); }
    .sec-title { font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 18px; letter-spacing: -0.3px; line-height: 1.25; }

    /* Info-Card-Stack (Pain / Benefit / Urgency) */
    .info-stack { display: flex; flex-direction: column; gap: 12px; }
    .info-card { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 18px; }
    .info-card.pain { border-left: 4px solid var(--red); }
    .info-card.benefit { border-left: 4px solid var(--green); }
    .info-card.urgency { background: #fffbeb; border: 1px solid #fde68a; border-left: 4px solid var(--amber); }
    .info-card h3 { font-size: 16px; font-weight: 800; margin-bottom: 6px; letter-spacing: -0.2px; }
    .info-card p { font-size: 14px; color: var(--text-2); line-height: 1.55; }
    .urgency-list { list-style: none; display: flex; flex-direction: column; gap: 6px; margin-top: 10px; }
    .urgency-list li { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-2); padding: 8px 12px; background: #fff; border-radius: 8px; border: 1px solid #fde68a; }
    .urgency-list li .ic { color: var(--amber); font-weight: 700; flex-shrink: 0; }

    /* Twist-Block */
    .twist { background: linear-gradient(135deg, #eef6ff 0%, #e0ecff 100%); border-radius: var(--r); padding: 22px 20px; text-align: center; margin: 20px 0; position: relative; overflow: hidden; }
    .twist h2 { font-size: 20px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.3px; }
    .twist p { font-size: 14px; color: var(--text-2); line-height: 1.55; position: relative; z-index: 1; }
    .twist .twist-emoji { font-size: 38px; margin-bottom: 4px; display: block; }

    /* Icon-Card-Grid (Pain/Benefit kompakt) */
    .icon-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 6px; }
    .icon-card { background: #fff; border: 1px solid #e8e4da; border-radius: 12px; padding: 14px 8px; text-align: center; position: relative; }
    .icon-card.pain { border-top: 3px solid var(--red); }
    .icon-card.benefit { border-top: 3px solid var(--green); }
    .icon-card .ic-emoji { font-size: 32px; display: block; margin-bottom: 4px; line-height: 1; }
    .icon-card h4 { font-size: 12px; font-weight: 800; margin-bottom: 4px; line-height: 1.25; letter-spacing: -0.1px; }
    .icon-card p { font-size: 11px; color: var(--text-3); line-height: 1.4; }

    /* Stat-Block (3 big numbers) */
    .stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin: 20px 0; }
    .stat { background: #fff; border: 1px solid #e8e4da; border-radius: 12px; padding: 14px 6px; text-align: center; }
    .stat .stat-num { font-size: 24px; font-weight: 800; color: var(--accent); letter-spacing: -0.5px; line-height: 1; }
    .stat .stat-label { font-size: 10px; color: var(--text-3); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 600; }

    /* Testimonial Cards mit Face */
    .testis { display: flex; flex-direction: column; gap: 10px; margin: 16px 0; }
    .testi { background: #fff; border: 1px solid #e8e4da; border-radius: 12px; padding: 14px; display: flex; gap: 12px; align-items: flex-start; }
    .testi-img { width: 56px; height: 56px; border-radius: 10px; object-fit: cover; flex-shrink: 0; }
    .testi-body { flex: 1; min-width: 0; }
    .testi-stars { color: var(--amber); font-size: 11px; letter-spacing: 1px; margin-bottom: 2px; }
    .testi-quote { font-size: 13px; color: var(--text-2); line-height: 1.5; margin-bottom: 6px; }
    .testi-quote strong { color: var(--text); font-weight: 700; }
    .testi-name { font-size: 11px; color: var(--text-3); font-weight: 600; }
    .testi-name b { color: var(--text-2); }

    /* Urgency Badges (inline) */
    .warn-badges { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 12px; }
    .warn-badge { background: #fff; border: 1px solid #fde68a; border-radius: 10px; padding: 12px 6px; text-align: center; }
    .warn-badge .wb-emoji { font-size: 24px; display: block; margin-bottom: 4px; }
    .warn-badge .wb-text { font-size: 11px; color: var(--text-2); font-weight: 600; line-height: 1.3; }

    /* Trust-Badges (ersetzt langer Authority-Block) */
    .trust-badges { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin: 20px 0; }
    .trust-badge { background: var(--surface); border-radius: 12px; padding: 14px 8px; text-align: center; }
    .trust-badge .tb-emoji { font-size: 24px; display: block; margin-bottom: 4px; }
    .trust-badge .tb-text { font-size: 11px; color: var(--text-2); font-weight: 600; line-height: 1.35; }

    /* Tipp-Hinweis */
    .tipp-hint { background: #eef6ff; border-left: 3px solid var(--accent); border-radius: 8px; padding: 12px 14px; margin: 16px 0; font-size: 13px; color: var(--text-2); line-height: 1.5; }
    .tipp-hint strong { color: var(--accent); font-weight: 700; }

    /* Divider */
    .divider { width: 40px; height: 2px; background: var(--accent); margin: 28px auto; opacity: 0.3; }

    /* Footer */
    footer { text-align: center; padding: 20px; font-size: 11px; color: var(--text-3); border-top: 1px solid #e8e4da; margin-top: 20px; }
    footer a { color: var(--text-3); text-decoration: none; }

    /* ===== QUIZ ===== */
    #quiz { display: none; position: fixed; inset: 0; background: var(--bg); z-index: 100; flex-direction: column; overflow-y: auto; -webkit-overflow-scrolling: touch; }
    #quiz.on { display: flex; }
    .q-head { display: flex; align-items: center; justify-content: center; padding: 14px 20px; border-bottom: 1px solid #e8e4da; position: sticky; top: 0; background: var(--bg); z-index: 10; }
    .q-head img { height: 32px; }
    .q-progress { padding: 12px 20px 0; max-width: 600px; margin: 0 auto; width: 100%; position: sticky; top: 57px; background: var(--bg); z-index: 10; }
    .q-bar { height: 6px; background: #e8e4da; border-radius: 3px; overflow: hidden; }
    .q-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.4s ease; width: 0%; }
    .q-num { font-size: 12px; color: var(--text-3); text-align: right; margin-top: 4px; font-weight: 500; }
    .q-body { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 32px 20px; }

    .step { display: none; max-width: 600px; width: 100%; animation: up 0.3s ease; }
    .step.on { display: block; }
    @keyframes up { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .step h2 { font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 20px; line-height: 1.3; letter-spacing: -0.3px; }
    .opts { display: flex; flex-direction: column; gap: 10px; }
    .opt { background: var(--surface); border: 2px solid transparent; border-radius: 12px; padding: 16px 18px; font-size: 15px; font-weight: 500; color: var(--text); cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: left; }
    .opt:hover { border-color: var(--accent); background: #fff; }
    .opt:active { transform: scale(0.98); border-color: var(--accent); }
    .opt strong { display: block; font-weight: 700; margin-bottom: 2px; }
    .opt span { font-size: 13px; color: var(--text-2); }

    /* Ja/Nein Buttons */
    .yn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; max-width: 400px; margin: 0 auto; }
    .yn-btn { background: var(--accent); color: #fff; border: 2px solid var(--accent); border-radius: 12px; padding: 18px 16px; font-size: 18px; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: center; }
    .yn-btn:hover { background: var(--accent-dark); border-color: var(--accent-dark); transform: translateY(-2px); }
    .yn-btn:active { transform: scale(0.97); }

    /* Tipp-Box unter jeder Frage */
    .tipp { background: #eef6ff; border: 1px solid #c4ddff; border-radius: 10px; padding: 12px 14px; margin-top: 16px; display: flex; align-items: flex-start; gap: 10px; }
    .tipp .tipp-icon { font-size: 16px; flex-shrink: 0; }
    .tipp .tipp-text { font-size: 12px; color: var(--text-2); line-height: 1.5; }
    .tipp .tipp-text strong { color: var(--accent); font-weight: 700; }

    /* Card-Optionen */
    .card-opts { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .card-opt { background: var(--surface); border: 2px solid transparent; border-radius: 12px; padding: 18px 12px; font-size: 14px; font-weight: 600; color: var(--text); cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: center; line-height: 1.3; }
    .card-opt:hover { border-color: var(--accent); background: #fff; transform: translateY(-2px); }
    .card-opt:active { transform: scale(0.97); border-color: var(--accent); }
    .card-opt .card-emoji { font-size: 26px; display: block; margin-bottom: 6px; }

    /* Loading */
    .ld { text-align: center; }
    .spinner { width: 56px; height: 56px; border: 3px solid #e8e4da; border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 20px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ld h2 { font-size: 18px; margin-bottom: 6px; }
    .ld p { font-size: 14px; color: var(--text-2); margin-bottom: 20px; }
    .checks { text-align: left; max-width: 280px; margin: 0 auto; }
    .chk { display: flex; align-items: center; gap: 10px; padding: 6px 0; font-size: 14px; color: var(--text-2); opacity: 0; transition: opacity 0.3s; }
    .chk.show { opacity: 1; }
    .chk i { width: 20px; height: 20px; border-radius: 50%; background: var(--green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 11px; font-style: normal; font-weight: 700; flex-shrink: 0; }

    /* Formular */
    .form { text-align: center; }
    .form .tag { font-size: 13px; font-weight: 600; color: var(--green); margin-bottom: 6px; }
    .form h2 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
    .form .sub { font-size: 14px; color: var(--text-2); margin-bottom: 20px; }
    .fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; max-width: 440px; margin-left: auto; margin-right: auto; }
    .field { background: #fff; border: 2px solid #e8e4da; border-radius: 12px; padding: 0 14px; display: flex; align-items: center; gap: 10px; transition: border-color 0.2s; }
    .field:focus-within { border-color: var(--accent); }
    .field .ic { font-size: 16px; flex-shrink: 0; opacity: 0.5; }
    .field input { flex: 1; background: transparent; border: none; outline: none; color: var(--text); font-family: var(--font); font-size: 15px; padding: 14px 0; }
    .field input::placeholder { color: var(--text-3); }
    .field .pre { font-size: 14px; color: var(--text-3); flex-shrink: 0; }
    .cb-row { display: flex; align-items: flex-start; gap: 8px; margin: 0 auto 16px; text-align: left; max-width: 440px; }
    .cb-row input[type="checkbox"] { accent-color: var(--accent); width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0; }
    .cb-row label { font-size: 11px; color: var(--text-3); line-height: 1.4; }
    .cb-row label a { color: var(--text-2); }
    .submit { display: block; width: 100%; max-width: 440px; margin: 0 auto; background: var(--accent); color: #fff; font-family: var(--font); font-size: 16px; font-weight: 700; padding: 16px; border: none; border-radius: 12px; cursor: pointer; transition: all 0.2s; }
    .submit:disabled { opacity: 0.4; cursor: not-allowed; }
    .submit:not(:disabled):hover { background: var(--accent-dark); }
    .submit:not(:disabled):active { opacity: 0.85; }
    .form-proof { margin-top: 16px; padding-top: 16px; border-top: 1px solid #e8e4da; max-width: 440px; margin-left: auto; margin-right: auto; }
    .form-proof .fp-row { display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 11px; color: var(--text-3); margin-bottom: 4px; }
    .form-proof .fp-row b { color: var(--text-2); }

    /* Ergebnis-Seite (wie Live-Winner: Zahnrad-Animation + YCBM + Scarcity) */
    .result { text-align: center; max-width: 600px; width: 100%; padding-bottom: 40px; }
    .result .cogs { display: flex; justify-content: center; margin: 10px 0 20px; position: relative; height: 110px; }
    .result .cog { font-size: 64px; position: absolute; display: inline-block; line-height: 1; }
    .result .cog.big { top: 6px; left: 50%; transform-origin: center; margin-left: -8px; animation: spin-fwd 4s linear infinite; }
    .result .cog.small { font-size: 44px; top: 48px; left: 50%; transform-origin: center; margin-left: -56px; animation: spin-bwd 3s linear infinite; }
    @keyframes spin-fwd { to { transform: rotate(360deg); } }
    @keyframes spin-bwd { to { transform: rotate(-360deg); } }
    .result h2 { font-size: 24px; font-weight: 800; margin-bottom: 8px; line-height: 1.25; letter-spacing: -0.3px; }
    .result h2 .confetti { margin-right: 6px; }
    .result .r-sub { font-size: 14px; color: var(--text-2); margin-bottom: 14px; }
    .result .r-lead { font-size: 17px; color: var(--text); font-weight: 600; line-height: 1.4; margin-bottom: 12px; padding: 0 4px; }
    .result .r-lead .ic { margin-right: 6px; }
    .result .r-push { font-size: 14px; color: var(--text-2); margin-bottom: 8px; font-weight: 500; }
    .result .r-when { font-size: 18px; font-weight: 800; margin: 18px 0 12px; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .result #ycbm-embed { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 10px; min-height: 400px; }
    .r-bullets { list-style: none; text-align: left; margin: 20px auto; max-width: 440px; padding: 18px 16px; background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); }
    .r-bullets li { padding: 6px 0; font-size: 14px; color: var(--text-2); display: flex; gap: 10px; line-height: 1.4; }
    .r-bullets li::before { content: "✓"; color: var(--green); font-weight: 700; flex-shrink: 0; }
    .r-bullets li strong { color: var(--text); }
    .r-reminder { font-size: 14px; color: var(--text-2); margin: 14px 0; line-height: 1.5; font-weight: 500; }
    .r-reminder .strong { color: var(--text); font-weight: 700; }
    .scarcity { background: var(--accent); color: #fff; border-radius: var(--r); padding: 18px 16px; margin: 20px 0; text-align: center; }
    .scarcity .sc-title { font-size: 14px; font-weight: 700; margin-bottom: 6px; display: flex; align-items: center; justify-content: center; gap: 6px; }
    .scarcity p { font-size: 13px; line-height: 1.55; opacity: 0.95; margin-bottom: 6px; }
    .scarcity p:last-child { margin-bottom: 0; font-size: 12px; opacity: 0.85; }
    .scarcity strong { font-weight: 700; }

    /* Desktop */
    @media (min-width: 600px) {
      .hero h1 { font-size: 36px; }
      .hero .sub { font-size: 17px; }
      .step h2 { font-size: 28px; }
      .opts { display: grid; grid-template-columns: 1fr; gap: 12px; }
      .opt { font-size: 16px; padding: 18px 20px; }
      .thankyou h2 { font-size: 32px; }
      .trans-grid { grid-template-columns: repeat(6, 1fr); }
    }
    @media (min-width: 900px) {
      .hero h1 { font-size: 42px; }
    }
  </style>
</head>
<body>

  <!-- ===== LANDING ===== -->
  <div id="lp">
    <div class="wrap">
      <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

      <section class="hero">
        <h1>Dein individueller <em>Stoffwechsel-Fahrplan</em>: Entdecke in 3 Minuten, warum dein Körper nicht abnimmt und wie du es in 4 Wochen änderst</h1>
        <p class="sub">Beantworte diese <strong>7 Fragen</strong> und erhalte deine individuelle Auswertung von unseren Ernährungsexperten, Fitness Coaches und Hormonspezialisten, kostenfrei!</p>

        <div class="start-block">
          <div class="sb-q">Verrate uns vorab dein Geschlecht:</div>
          <div class="start-row">
            <button class="start-btn" onclick="startQuiz('frau')">Frau</button>
            <button class="start-btn secondary" onclick="startQuiz('mann')">Mann</button>
          </div>
        </div>

        <div class="proof-bar">
          <div class="proof-avatars">
            <img src="/images/transformations/t5.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t1.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t3.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t6.jpg" alt="" loading="lazy" />
          </div>
          <div class="proof-info">
            <div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
