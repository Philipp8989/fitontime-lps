  <script is:inline>
    var quizAnswers = {};
    var TOTAL = 7;

    // Race-Schutz: __lp wird erst nach CookieBanner-Script gesetzt — retry bis verfuegbar.
    function tk(e, d) {
      var tries = 0;
      function fire() {
        if (window.__lp) {
          window.__lp.track(e, Object.assign({ page: 'stoffwechsel-report' }, d || {}), 'fot', 'Stoffwechsel Report');
          if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'Stoffwechsel Report Quiz Start', currency: 'CHF' });
          if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'Stoffwechsel Report Quiz Complete', currency: 'CHF' });
          if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'Stoffwechsel Report Lead', currency: 'CHF' });
        } else if (tries++ < 40) {
          setTimeout(fire, 50);
        }
      }
      fire();
    }
    tk('page_view');

    // Preview-Modus: ?preview=result springt direkt auf Ergebnis-Seite
    if (typeof window !== 'undefined' && /[?&]preview=result/.test(window.location.search)) {
      window.addEventListener('DOMContentLoaded', function() {
        document.getElementById('lp').style.display = 'none';
        document.getElementById('quiz').classList.add('on');
        document.querySelectorAll('.step').forEach(function(s){ s.classList.remove('on'); });
        var r = document.querySelector('.step[data-s="thankyou"]');
        r.style.display = 'block';
        r.classList.add('on');
        document.getElementById('r-name').textContent = 'Sarah';
        var ycbm = document.createElement('script');
        ycbm.src = 'https://embed.ycb.me';
        ycbm.async = true;
        ycbm.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
        ycbm.setAttribute('data-displaymode', 'auto');
        document.getElementById('ycbm-embed').appendChild(ycbm);
        document.getElementById('qn').textContent = 'Preview';
      });
    }

    function startQuiz(gender) {
      quizAnswers['gender'] = gender || 'frau';
      tk('quiz_start', { detail: 'gender_' + quizAnswers.gender });
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0,0);
    }

    function nxt(s, el, val) {
      quizAnswers['q' + s] = val;
      tk('quiz_answer', { detail: 'q' + s + '_' + val });

      document.querySelector('.step[data-s="' + s + '"]').classList.remove('on');
      if (s < TOTAL) {
        document.querySelector('.step[data-s="' + (s + 1) + '"]').classList.add('on');
        var p = Math.round(((s) / TOTAL) * 100);
        document.getElementById('qf').style.width = p + '%';
        document.getElementById('qn').textContent = (s + 1) + ' / ' + TOTAL;
        var body = document.querySelector('.q-body');
        if (body) body.scrollTop = 0;
      } else {
        tk('quiz_complete');
        load();
      }
    }

    function load() {
      var ld = document.querySelector('.step[data-s="ld"]');
      ld.classList.add('on');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qn').textContent = 'Auswertung...';
      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 600);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1400);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2200);
      setTimeout(function(){
        ld.classList.remove('on');
        document.querySelector('.step[data-s="form"]').classList.add('on');
        document.getElementById('qn').textContent = 'Fast fertig';
      }, 3200);
    }

    document.getElementById('ds').addEventListener('change', function() {
      document.getElementById('sbtn').disabled = !this.checked;
    });

    function send() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird verarbeitet...';

      // Atomarer Submit: lead_submit + Pixel + UI-Weiter NUR bei erfolgreichem Insert
      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          lp_slug: 'stoffwechsel-report',
          lp_name: 'Stoffwechsel Report',
          name: fn,
          email: em,
          phone: ph ? '+41' + ph : '',
          answers: quizAnswers
        })
      }).then(function(res){
        if (!res.ok) throw new Error('insert-failed');
        tk('lead_submit', { detail: fn });
        var firstName = (fn.split(' ')[0] || '').trim();
        if (firstName) document.getElementById('r-name').textContent = firstName;
        var ycbm = document.createElement('script');
        ycbm.src = 'https://embed.ycb.me';
        ycbm.async = true;
        ycbm.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
        ycbm.setAttribute('data-displaymode', 'auto');
        document.getElementById('ycbm-embed').appendChild(ycbm);
        document.querySelector('.step[data-s="form"]').classList.remove('on');
        document.querySelector('.step[data-s="thankyou"]').style.display = 'block';
        document.querySelector('.step[data-s="thankyou"]').classList.add('on');
        document.getElementById('qn').textContent = 'Termin wählen';
        var body = document.querySelector('.q-body');
        if (body) body.scrollTop = 0;
        tk('result_shown', { detail: 'booking' });
      }).catch(function(){
        btn.disabled = false;
        btn.textContent = 'Jetzt Report kostenlos erhalten ✨';
