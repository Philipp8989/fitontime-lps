---
// Stoffwechsel-Report (Blockaden-Loesen) - FitonTime
// Struktur 1:1 an Live-Winner fit-on-time.ch/blockaden-loesen/ orientiert
// UI/UX-Upgrade: echte Vorher-Nachher-Bilder, cleaneres Typo-System, bessere Mobile-UX
import CookieBanner from '../../components/CookieBanner.astro';
const impressumUrl = 'https://fitontime.ch/impressum-datenschutz';
const datenschutzUrl = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Welcher Körper-Typ bist Du? | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preload" as="image" href="/images/transformations/t5.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --surface: #f0ebe0;
      --surface-2: #e5dfd2;
      --accent: #2b7de9;
      --accent-dark: #1a5bb8;
      --green: #22c55e;
      --amber: #f59e0b;
      --red: #ef4444;
      --text: #1a1a1a;
      --text-2: #4a4a4a;
      --text-3: #888;
      --r: 14px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    .wrap { max-width: 720px; margin: 0 auto; padding: 0 20px; }

    /* Logo */
    .logo { text-align: center; padding: 16px 0 8px; }
    .logo img { height: 40px; }

    /* Hero */
    .hero { text-align: center; padding: 16px 0 20px; }
    .hero h1 { font-size: 26px; font-weight: 800; line-height: 1.25; letter-spacing: -0.5px; margin-bottom: 12px; }
    .hero h1 em { font-style: normal; color: var(--accent); }
    .hero .sub { font-size: 15px; color: var(--text-2); margin-bottom: 12px; line-height: 1.5; }
    .hero .sub strong { color: var(--text); font-weight: 600; }

    /* CTA-Block: Geschlechter-Auswahl als Start */
    .start-block { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 20px 18px; margin: 12px 0; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
    .start-block .sb-q { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 12px; }
    .start-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .start-btn { background: var(--accent); color: #fff; border: none; border-radius: 12px; padding: 16px 12px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; box-shadow: 0 4px 14px rgba(43,125,233,0.25); }
    .start-btn:hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: 0 6px 18px rgba(43,125,233,0.35); }
    .start-btn:active { transform: scale(0.98); }
    .start-btn.secondary { background: #fff; color: var(--accent); border: 2px solid var(--accent); box-shadow: none; }
    .start-btn.secondary:hover { background: #eef6ff; }

    /* Social Proof */
    .proof-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 0 6px; flex-wrap: wrap; }
    .proof-avatars { display: flex; }
    .proof-avatars img { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--bg); margin-left: -10px; object-fit: cover; object-position: center 30%; }
    .proof-avatars img:first-child { margin-left: 0; }
    .proof-info { font-size: 12px; color: var(--text-3); line-height: 1.3; text-align: left; }
    .proof-info b { color: var(--text); }
    .proof-stars { color: var(--amber); font-size: 12px; letter-spacing: 1px; }
    .proof-trust { display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 12px; color: var(--text-2); margin-top: 6px; font-weight: 500; }
    .proof-trust .ic { color: var(--green); font-weight: 700; }

    /* Transformation Grid */
    .trans { margin: 28px 0; }
    .trans-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 6px; }
    .trans-sub { font-size: 13px; color: var(--text-3); text-align: center; margin-bottom: 16px; }
    .trans-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .trans-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; background: #fff; }
    .trans-cap { font-size: 11px; color: var(--text-3); text-align: center; margin-top: 10px; }

    /* Section Titles */
    .sec-eyebrow { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; color: var(--red); font-weight: 700; text-align: center; margin-bottom: 6px; }
    .sec-eyebrow.amber { color: var(--amber); }
    .sec-eyebrow.green { color: var(--green); }
    .sec-title { font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 18px; letter-spacing: -0.3px; line-height: 1.25; }

    /* Info-Card-Stack (Pain / Benefit / Urgency) */
    .info-stack { display: flex; flex-direction: column; gap: 12px; }
    .info-card { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 18px; }
    .info-card.pain { border-left: 4px solid var(--red); }
    .info-card.benefit { border-left: 4px solid var(--green); }
    .info-card.urgency { background: #fffbeb; border: 1px solid #fde68a; border-left: 4px solid var(--amber); }
    .info-card h3 { font-size: 16px; font-weight: 800; margin-bottom: 6px; letter-spacing: -0.2px; }
    .info-card p { font-size: 14px; color: var(--text-2); line-height: 1.55; }
    .urgency-list { list-style: none; display: flex; flex-direction: column; gap: 6px; margin-top: 10px; }
    .urgency-list li { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--text-2); padding: 8px 12px; background: #fff; border-radius: 8px; border: 1px solid #fde68a; }
    .urgency-list li .ic { color: var(--amber); font-weight: 700; flex-shrink: 0; }

    /* Twist-Block (Doch es kann auch anders kommen) */
    .twist { background: linear-gradient(135deg, #eef6ff 0%, #e0ecff 100%); border-radius: var(--r); padding: 22px 20px; text-align: center; margin: 20px 0; }
    .twist h2 { font-size: 20px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.3px; }
    .twist p { font-size: 14px; color: var(--text-2); line-height: 1.55; }

    /* Authority-Block */
    .authority { background: var(--surface); border-radius: var(--r); padding: 22px 20px; margin: 20px 0; }
    .authority h2 { font-size: 20px; font-weight: 800; margin-bottom: 8px; text-align: center; }
    .authority p { font-size: 14px; color: var(--text-2); line-height: 1.6; margin-bottom: 10px; }
    .authority p:last-child { margin-bottom: 0; }

    /* Tipp-Hinweis */
    .tipp-hint { background: #eef6ff; border-left: 3px solid var(--accent); border-radius: 8px; padding: 12px 14px; margin: 16px 0; font-size: 13px; color: var(--text-2); line-height: 1.5; }
    .tipp-hint strong { color: var(--accent); font-weight: 700; }

    /* Divider */
    .divider { width: 40px; height: 2px; background: var(--accent); margin: 28px auto; opacity: 0.3; }

    /* Footer */
    footer { text-align: center; padding: 20px; font-size: 11px; color: var(--text-3); border-top: 1px solid #e8e4da; margin-top: 20px; }
    footer a { color: var(--text-3); text-decoration: none; }

    /* ===== QUIZ ===== */
    #quiz { display: none; position: fixed; inset: 0; background: var(--bg); z-index: 100; flex-direction: column; overflow-y: auto; -webkit-overflow-scrolling: touch; }
    #quiz.on { display: flex; }
    .q-head { display: flex; align-items: center; justify-content: center; padding: 14px 20px; border-bottom: 1px solid #e8e4da; position: sticky; top: 0; background: var(--bg); z-index: 10; }
    .q-head img { height: 32px; }
    .q-progress { padding: 12px 20px 0; max-width: 600px; margin: 0 auto; width: 100%; position: sticky; top: 57px; background: var(--bg); z-index: 10; }
    .q-bar { height: 6px; background: #e8e4da; border-radius: 3px; overflow: hidden; }
    .q-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.4s ease; width: 0%; }
    .q-num { font-size: 12px; color: var(--text-3); text-align: right; margin-top: 4px; font-weight: 500; }
    .q-body { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 32px 20px; }

    .step { display: none; max-width: 600px; width: 100%; animation: up 0.3s ease; }
    .step.on { display: block; }
    @keyframes up { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .step h2 { font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 20px; line-height: 1.3; letter-spacing: -0.3px; }
    .opts { display: flex; flex-direction: column; gap: 10px; }
    .opt { background: var(--surface); border: 2px solid transparent; border-radius: 12px; padding: 16px 18px; font-size: 15px; font-weight: 500; color: var(--text); cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: left; }
    .opt:hover { border-color: var(--accent); background: #fff; }
    .opt:active { transform: scale(0.98); border-color: var(--accent); }
    .opt strong { display: block; font-weight: 700; margin-bottom: 2px; }
    .opt span { font-size: 13px; color: var(--text-2); }

    /* Ja/Nein Buttons */
    .yn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; max-width: 400px; margin: 0 auto; }
    .yn-btn { background: var(--accent); color: #fff; border: 2px solid var(--accent); border-radius: 12px; padding: 18px 16px; font-size: 18px; font-weight: 700; cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: center; }
    .yn-btn:hover { background: var(--accent-dark); border-color: var(--accent-dark); transform: translateY(-2px); }
    .yn-btn:active { transform: scale(0.97); }

    /* Tipp-Box unter jeder Frage */
    .tipp { background: #eef6ff; border: 1px solid #c4ddff; border-radius: 10px; padding: 12px 14px; margin-top: 16px; display: flex; align-items: flex-start; gap: 10px; }
    .tipp .tipp-icon { font-size: 16px; flex-shrink: 0; }
    .tipp .tipp-text { font-size: 12px; color: var(--text-2); line-height: 1.5; }
    .tipp .tipp-text strong { color: var(--accent); font-weight: 700; }

    /* Card-Optionen */
    .card-opts { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .card-opt { background: var(--surface); border: 2px solid transparent; border-radius: 12px; padding: 18px 12px; font-size: 14px; font-weight: 600; color: var(--text); cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: center; line-height: 1.3; }
    .card-opt:hover { border-color: var(--accent); background: #fff; transform: translateY(-2px); }
    .card-opt:active { transform: scale(0.97); border-color: var(--accent); }
    .card-opt .card-emoji { font-size: 26px; display: block; margin-bottom: 6px; }

    /* Loading */
    .ld { text-align: center; }
    .spinner { width: 56px; height: 56px; border: 3px solid #e8e4da; border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 20px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ld h2 { font-size: 18px; margin-bottom: 6px; }
    .ld p { font-size: 14px; color: var(--text-2); margin-bottom: 20px; }
    .checks { text-align: left; max-width: 280px; margin: 0 auto; }
    .chk { display: flex; align-items: center; gap: 10px; padding: 6px 0; font-size: 14px; color: var(--text-2); opacity: 0; transition: opacity 0.3s; }
    .chk.show { opacity: 1; }
    .chk i { width: 20px; height: 20px; border-radius: 50%; background: var(--green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 11px; font-style: normal; font-weight: 700; flex-shrink: 0; }

    /* Formular */
    .form { text-align: center; }
    .form .tag { font-size: 13px; font-weight: 600; color: var(--green); margin-bottom: 6px; }
    .form h2 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
    .form .sub { font-size: 14px; color: var(--text-2); margin-bottom: 20px; }
    .fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; max-width: 440px; margin-left: auto; margin-right: auto; }
    .field { background: #fff; border: 2px solid #e8e4da; border-radius: 12px; padding: 0 14px; display: flex; align-items: center; gap: 10px; transition: border-color 0.2s; }
    .field:focus-within { border-color: var(--accent); }
    .field .ic { font-size: 16px; flex-shrink: 0; opacity: 0.5; }
    .field input { flex: 1; background: transparent; border: none; outline: none; color: var(--text); font-family: var(--font); font-size: 15px; padding: 14px 0; }
    .field input::placeholder { color: var(--text-3); }
    .field .pre { font-size: 14px; color: var(--text-3); flex-shrink: 0; }
    .cb-row { display: flex; align-items: flex-start; gap: 8px; margin: 0 auto 16px; text-align: left; max-width: 440px; }
    .cb-row input[type="checkbox"] { accent-color: var(--accent); width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0; }
    .cb-row label { font-size: 11px; color: var(--text-3); line-height: 1.4; }
    .cb-row label a { color: var(--text-2); }
    .submit { display: block; width: 100%; max-width: 440px; margin: 0 auto; background: var(--accent); color: #fff; font-family: var(--font); font-size: 16px; font-weight: 700; padding: 16px; border: none; border-radius: 12px; cursor: pointer; transition: all 0.2s; }
    .submit:disabled { opacity: 0.4; cursor: not-allowed; }
    .submit:not(:disabled):hover { background: var(--accent-dark); }
    .submit:not(:disabled):active { opacity: 0.85; }
    .form-proof { margin-top: 16px; padding-top: 16px; border-top: 1px solid #e8e4da; max-width: 440px; margin-left: auto; margin-right: auto; }
    .form-proof .fp-row { display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 11px; color: var(--text-3); margin-bottom: 4px; }
    .form-proof .fp-row b { color: var(--text-2); }

    /* Danke-Seite */
    .thankyou { text-align: center; max-width: 600px; width: 100%; padding-bottom: 40px; }
    .thankyou-badge { display: inline-block; background: rgba(34,197,94,0.1); color: var(--green); font-size: 12px; font-weight: 700; padding: 4px 14px; border-radius: 20px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
    .thankyou h2 { font-size: 26px; font-weight: 800; margin-bottom: 8px; }
    .thankyou .ty-sub { font-size: 15px; color: var(--text-2); line-height: 1.6; margin-bottom: 20px; }
    .thankyou .ty-box { background: #fff; border-radius: var(--r); padding: 20px; border: 1px solid #e8e4da; margin-bottom: 20px; text-align: left; }
    .thankyou .ty-box h3 { font-size: 16px; font-weight: 700; margin-bottom: 10px; text-align: center; }
    .ty-steps { list-style: none; display: flex; flex-direction: column; gap: 10px; }
    .ty-steps li { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: var(--text-2); }
    .ty-steps li .num { width: 24px; height: 24px; border-radius: 50%; background: var(--accent); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
    .thankyou-cta { background: var(--accent); color: #fff; font-family: var(--font); font-size: 16px; font-weight: 700; padding: 16px 32px; border: none; border-radius: 12px; cursor: pointer; display: block; width: 100%; text-decoration: none; text-align: center; transition: background 0.2s; margin-bottom: 8px; }
    .thankyou-cta:hover { background: var(--accent-dark); }
    .thankyou-spots { font-size: 11px; color: var(--amber); font-weight: 600; }

    /* Desktop */
    @media (min-width: 600px) {
      .hero h1 { font-size: 36px; }
      .hero .sub { font-size: 17px; }
      .step h2 { font-size: 28px; }
      .opts { display: grid; grid-template-columns: 1fr; gap: 12px; }
      .opt { font-size: 16px; padding: 18px 20px; }
      .thankyou h2 { font-size: 32px; }
      .trans-grid { grid-template-columns: repeat(6, 1fr); }
    }
    @media (min-width: 900px) {
      .hero h1 { font-size: 42px; }
    }
  </style>
</head>
<body>

  <!-- ===== LANDING ===== -->
  <div id="lp">
    <div class="wrap">
      <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

      <section class="hero">
        <h1>Dein individueller <em>Stoffwechsel-Fahrplan</em>: Entdecke in 3 Minuten, warum dein Körper nicht abnimmt und wie du es in 4 Wochen änderst</h1>
        <p class="sub">Beantworte diese <strong>7 Fragen</strong> und erhalte deine individuelle Auswertung von unseren Ernährungsexperten, Fitness Coaches und Hormonspezialisten, kostenfrei!</p>

        <div class="start-block">
          <div class="sb-q">Verrate uns vorab dein Geschlecht:</div>
          <div class="start-row">
            <button class="start-btn" onclick="startQuiz('frau')">Frau</button>
            <button class="start-btn secondary" onclick="startQuiz('mann')">Mann</button>
          </div>
        </div>

        <div class="proof-bar">
          <div class="proof-avatars">
            <img src="/images/transformations/t5.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t1.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t3.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t6.jpg" alt="" loading="lazy" />
          </div>
          <div class="proof-info">
            <div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            Über <b>2.847</b> Frauen haben ihren Report bereits erhalten!
          </div>
        </div>
        <div class="proof-trust"><span class="ic">&#10003;</span> Von Ernährungsexperten entwickelt</div>
      </section>

      <div class="divider"></div>

      <!-- Vorher-Nachher Grid -->
      <div class="trans">
        <h3 class="trans-title">Echte Teilnehmerinnen. Echte Resultate.</h3>
        <p class="trans-sub">Ein kleiner Ausschnitt aus über 1.600 erfolgreichen Transformationen</p>
        <div class="trans-grid">
          <img src="/images/transformations/t5.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t1.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t2.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t3.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t4.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t6.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
        </div>
        <p class="trans-cap">&#9733;&#9733;&#9733;&#9733;&#9733; 4.9 von 5 &middot; 1.600 halten ihr Wunschgewicht</p>
      </div>

      <div class="divider"></div>

      <!-- Pain Section (3 Cards, wie Original) -->
      <p class="sec-eyebrow">&#9888; Kurz- und Langzeitfolgen</p>
      <h2 class="sec-title">Was passiert, wenn du deinen Stoffwechsel nicht optimierst?</h2>
      <div class="info-stack">
        <div class="info-card pain">
          <h3>Scheiternde Abnehmversuche</h3>
          <p>Deine Abnehmversuche werden weiterhin scheitern. Die Diäten bringen deinen Stoffwechsel auf ein absolutes Minimum. Sport greift bei dir nicht wie bei anderen Menschen das Fett an.</p>
        </div>
        <div class="info-card pain">
          <h3>Stoffwechsel kann irreparabel geschädigt werden</h3>
          <p>Durch falsche Ernährung, den falschen Sport und radikale Abnehmversuche wird dein Stoffwechsel bei jedem Versuch angegriffen, bis er irgendwann nicht mehr zu retten ist.</p>
        </div>
        <div class="info-card pain">
          <h3>Gesundheitliche Kurz- und Langzeit Folgen</h3>
          <p>Herz-Kreislauf-Probleme, Diabetes und Hormonstörungen treten mit erhöhtem Risiko bei übergewichtigen Menschen auf, und damit bei allen, deren Stoffwechsel nicht richtig oder gar nicht mehr funktioniert.</p>
        </div>
      </div>

      <div class="divider"></div>

      <!-- 2. CTA -->
      <section class="hero" style="padding-top:0;">
        <p class="sub">Beantworte diese <strong>7 Fragen</strong> und erhalte deine individuelle Auswertung, kostenfrei!</p>
        <div class="start-block">
          <div class="sb-q">Verrate uns vorab dein Geschlecht:</div>
          <div class="start-row">
            <button class="start-btn" onclick="startQuiz('frau')">Frau</button>
            <button class="start-btn secondary" onclick="startQuiz('mann')">Mann</button>
          </div>
        </div>
        <div class="tipp-hint">
          <strong>Bonus:</strong> Unter jeder Frage findest du Tipps und Fakten, die du sofort anwenden kannst, um deinen Stoffwechsel zu optimieren.<br/><span style="font-size:11px;color:var(--text-3);">*Diese Tipps sind allgemeine Tipps, die nicht auf jeden zutreffen müssen.</span>
        </div>
      </section>

      <div class="divider"></div>

      <!-- Twist-Block: Doch es kann anders kommen -->
      <div class="twist">
        <h2>Doch es kann auch anders kommen</h2>
        <p><strong>Dein Stoffwechsel arbeitet GEGEN dich!</strong> Nicht weil du etwas falsch machst, sondern weil dein Körper im Sparmodus festhängt. Das lässt sich ändern.</p>
      </div>

      <!-- Benefit Section (3 Cards, wie Original) -->
      <p class="sec-eyebrow green">&#10003; Was moeglich ist</p>
      <h2 class="sec-title">Dein Leben mit einem aktiven Stoffwechsel</h2>
      <div class="info-stack">
        <div class="info-card benefit">
          <h3>Abnehmen und körperliches Wohlbefinden</h3>
          <p>Deine Abnehmversuche funktionieren so, wie du es bei anderen siehst. Abnehmen gelingt ohne Stress und funktioniert ohne grossen Aufwand.</p>
        </div>
        <div class="info-card benefit">
          <h3>Deine Gesundheit wird es dir danken</h3>
          <p>Durch einen funktionierenden Stoffwechsel, der für dich arbeitet, kannst du vielen Krankheitserscheinungen im Alter und schon jetzt vorbeugen.</p>
        </div>
        <div class="info-card benefit">
          <h3>Mehr Energie für ein erfolgreiches Leben</h3>
          <p>Ein schlechter Stoffwechsel sorgt für Trägheit, Energielosigkeit und Müdigkeit im Alltag. Mit einem funktionierenden Stoffwechsel wirst du die Powerfrau, die du mal warst oder immer sein wolltest.</p>
        </div>
      </div>

      <div class="divider"></div>

      <!-- Urgency Section -->
      <p class="sec-eyebrow amber">&#9888; Der richtige Zeitpunkt ist genau jetzt</p>
      <h2 class="sec-title">Wieso du jetzt handeln solltest</h2>
      <div class="info-stack">
        <div class="info-card urgency">
          <p>Ist dein Stoffwechsel schon angegriffen oder gerade dabei abzubauen, schickt dir dein Körper Warnsignale. Er schaltet in den Notfallmodus und klammert sich an jede Kalorie als Fettreserve:</p>
          <ul class="urgency-list">
            <li><span class="ic">&#9888;</span>Ständige Müdigkeit</li>
            <li><span class="ic">&#9888;</span>Heisshunger-Attacken</li>
            <li><span class="ic">&#9888;</span>Stagnierendes oder steigendes Gewicht, meist als schleichender Prozess</li>
          </ul>
        </div>
      </div>

      <div class="divider"></div>

      <!-- 3. CTA -->
      <section class="hero" style="padding-top:0;">
        <p class="sub">Beantworte diese <strong>7 Fragen</strong> und erhalte deine individuelle Auswertung, kostenfrei!</p>
        <div class="start-block">
          <div class="sb-q">Verrate uns vorab dein Geschlecht:</div>
          <div class="start-row">
            <button class="start-btn" onclick="startQuiz('frau')">Frau</button>
            <button class="start-btn secondary" onclick="startQuiz('mann')">Mann</button>
          </div>
        </div>
        <div class="proof-bar">
          <div class="proof-info">
            <div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            Über <b>2.847</b> Frauen haben ihren Report bereits erhalten!
          </div>
        </div>
        <div class="proof-trust"><span class="ic">&#10003;</span> Von Ernährungsexperten entwickelt</div>
      </section>

      <div class="divider"></div>

      <!-- Authority / Wieso wir das machen -->
      <div class="authority">
        <h2>Wieso wir das machen?</h2>
        <p>Was du hier individuell auf dich zugeschnitten bekommst, ist Gold wert! Wir bieten dir eine kostenlose Analyse anhand deiner Antworten. Zudem erhältst du wichtige und wertvolle Tipps zu jeder Frage.</p>
        <p>Wir sind davon überzeugt, dass jeder das Recht haben sollte, seinen individuellen Weg zu einem gesunden Körper kostenfrei zu erhalten.</p>
        <p>Nachdem du deinen persönlichen Stoffwechsel-Report erhalten hast, bist du theoretisch bereit, auf eigene Faust loszulegen. Aber du musst es nicht allein tun! Viele wünschen sich nach der Diagnose Unterstützung, um die empfohlenen Schritte schnell und effektiv umzusetzen, genau dafür gibt es uns.</p>
      </div>

      <footer>
        <a href={impressumUrl} target="_blank" rel="noopener">Impressum</a> &middot;
        <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutzerklärung</a>
      </footer>
    </div>
  </div>

  <!-- ===== QUIZ ===== -->
  <div id="quiz">
    <div class="q-head"><img src="/images/logo.png" alt="Fit on Time" /></div>
    <div class="q-progress"><div class="q-bar"><div class="q-fill" id="qf"></div></div><div class="q-num" id="qn">1 / 7</div></div>
    <div class="q-body">

      <!-- Frage 1: Ja/Nein -->
      <div class="step on" data-s="1">
        <h2>Bist du beruflich sehr ausgelastet?</h2>
        <div class="yn-row">
          <button class="yn-btn" onclick="nxt(1,this,'ja')">&#128077; Ja</button>
          <button class="yn-btn" onclick="nxt(1,this,'nein')">&#128078; Nein</button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Morgens Zitronenwasser trinken. Starte den Tag mit einem Glas warmem Zitronenwasser, das kurbelt die Verdauung an.</div>
        </div>
      </div>

      <!-- Frage 2: 4 Karten -->
      <div class="step" data-s="2">
        <h2>Was hiervon ist dir am wichtigsten?</h2>
        <div class="card-opts">
          <button class="card-opt" onclick="nxt(2,this,'aussehen')"><span class="card-emoji">&#128142;</span>Besseres Aussehen</button>
          <button class="card-opt" onclick="nxt(2,this,'gesundheit')"><span class="card-emoji">&#128154;</span>Mehr Gesundheit</button>
          <button class="card-opt" onclick="nxt(2,this,'wohlbefinden')"><span class="card-emoji">&#128522;</span>Mehr Wohlbefinden</button>
          <button class="card-opt" onclick="nxt(2,this,'abnehmen')"><span class="card-emoji">&#9878;</span>Nachhaltig abnehmen</button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Mehr Eiweiss, weniger Heisshunger. Eiweissreiche Mahlzeiten halten länger satt und steigern den Kalorienverbrauch.</div>
        </div>
      </div>

      <!-- Frage 3: Grösse -->
      <div class="step" data-s="3">
        <h2>Wie gross bist du?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(3,this,'klein')"><strong>Kleiner als 1,62 m</strong></button>
          <button class="opt" onclick="nxt(3,this,'mittel1')"><strong>1,63 m bis 1,68 m</strong></button>
          <button class="opt" onclick="nxt(3,this,'mittel2')"><strong>1,69 m bis 1,74 m</strong></button>
          <button class="opt" onclick="nxt(3,this,'gross')"><strong>Grösser als 1,74 m</strong></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> 10 Minuten Spaziergang nach dem Essen helfen, den Blutzucker zu stabilisieren und die Verdauung anzuregen.</div>
        </div>
      </div>

      <!-- Frage 4: Gewicht -->
      <div class="step" data-s="4">
        <h2>Wieviel wiegst du momentan?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(4,this,'u60')"><strong>Weniger als 60 kg</strong></button>
          <button class="opt" onclick="nxt(4,this,'60-68')"><strong>Zwischen 60 und 68 kg</strong></button>
          <button class="opt" onclick="nxt(4,this,'69-77')"><strong>Zwischen 69 und 77 kg</strong></button>
          <button class="opt" onclick="nxt(4,this,'ue78')"><strong>Über 78 kg</strong></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Eiskaltes Wasser trinken zwingt den Körper, Energie zum Erwärmen aufzuwenden, und verbrennt so extra Kalorien.</div>
        </div>
      </div>

      <!-- Frage 5: Alter -->
      <div class="step" data-s="5">
        <h2>Wie alt bist du?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(5,this,'18-29')"><strong>18 bis 29 Jahre</strong></button>
          <button class="opt" onclick="nxt(5,this,'30-39')"><strong>30 bis 39 Jahre</strong></button>
          <button class="opt" onclick="nxt(5,this,'40-49')"><strong>40 bis 49 Jahre</strong></button>
          <button class="opt" onclick="nxt(5,this,'50+')"><strong>50+ Jahre</strong></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Schlaf optimieren. 7-8 Stunden Schlaf sind der grösste Stoffwechsel-Booster, den es gibt.</div>
        </div>
      </div>

      <!-- Frage 6: Sport -->
      <div class="step" data-s="6">
        <h2>Wie oft treibst du Sport?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(6,this,'nie')"><strong>Nie</strong></button>
          <button class="opt" onclick="nxt(6,this,'1-2x')"><strong>1 bis 2x pro Woche</strong></button>
          <button class="opt" onclick="nxt(6,this,'3-4x')"><strong>3 bis 4x pro Woche</strong></button>
          <button class="opt" onclick="nxt(6,this,'taeglich')"><strong>Täglich</strong></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Krafttraining schlägt Cardio. Muskeln verbrennen auch in Ruhe Kalorien. Schon 2x pro Woche macht einen Unterschied.</div>
        </div>
      </div>

      <!-- Frage 7: Was probiert -->
      <div class="step" data-s="7">
        <h2>Was hast du schon probiert?</h2>
        <div class="card-opts">
          <button class="card-opt" onclick="nxt(7,this,'diaeten')"><span class="card-emoji">&#127869;</span>Diäten</button>
          <button class="card-opt" onclick="nxt(7,this,'sport')"><span class="card-emoji">&#127939;</span>Sport-Programme</button>
          <button class="card-opt" onclick="nxt(7,this,'nahrungserg')"><span class="card-emoji">&#128138;</span>Nahrungsergänzung</button>
          <button class="card-opt" onclick="nxt(7,this,'nichts')"><span class="card-emoji">&#129300;</span>Nichts</button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Dein Stoffwechsel ist einzigartig. Was bei anderen funktioniert, muss bei dir nicht klappen. Deshalb ist ein individueller Plan so wichtig.</div>
        </div>
      </div>

      <!-- Loading -->
      <div class="step ld" data-s="ld">
        <div class="spinner"></div>
        <h2>Dein Stoffwechsel-Report wird erstellt...</h2>
        <p>Das dauert nur ein paar Sekunden</p>
        <div class="checks">
          <div class="chk" id="c1"><i>&#10003;</i>Antworten analysiert</div>
          <div class="chk" id="c2"><i>&#10003;</i>Stoffwechsel-Typ bestimmt</div>
          <div class="chk" id="c3"><i>&#10003;</i>Persönlicher 4-Wochen-Fahrplan erstellt</div>
        </div>
      </div>

      <!-- Formular -->
      <div class="step form" data-s="form">
        <div class="tag">&#10003; Analyse abgeschlossen!</div>
        <h2>Dein Stoffwechsel-Fahrplan ist bereit!</h2>
        <p class="sub">Trage dich ein und erhalte deinen individuellen Report, kostenlos per E-Mail.</p>
        <div class="fields">
          <div class="field"><span class="ic">&#128075;</span><input type="text" id="fn" placeholder="Dein Vor- und Nachname" required /></div>
          <div class="field"><span class="ic">&#128236;</span><input type="email" id="em" placeholder="Deine E-Mail" required /></div>
          <div class="field"><span class="ic">&#128222;</span><span class="pre">+41</span><input type="tel" id="ph" placeholder="Deine Telefonnummer" required /></div>
        </div>
        <div class="cb-row">
          <input type="checkbox" id="ds" />
          <label for="ds">Ich akzeptiere die <a href={datenschutzUrl} target="_blank">Datenschutzbestimmungen</a></label>
        </div>
        <button class="submit" id="sbtn" disabled onclick="send()">Jetzt Report kostenlos erhalten &#10024;</button>
        <div class="form-proof">
          <div class="fp-row"><span>&#128274;</span> Deine Daten sind sicher &amp; werden nicht weitergegeben</div>
          <div class="fp-row"><span class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span> <b>2.847+</b> zufriedene Teilnehmerinnen</div>
        </div>
      </div>

      <!-- Danke-Seite -->
      <div class="step thankyou" data-s="thankyou" style="display:none;">
        <span class="thankyou-badge">&#10003; Erfolgreich</span>
        <h2>Vielen Dank! Dein Report ist unterwegs.</h2>
        <p class="ty-sub">Wir haben dir deinen persönlichen Stoffwechsel-Fahrplan per E-Mail geschickt. Schau auch im Spam-Ordner nach.</p>
        <div class="ty-box">
          <h3>Dein nächster Schritt</h3>
          <ul class="ty-steps">
            <li><span class="num">1</span><span>Öffne deinen Report in der E-Mail</span></li>
            <li><span class="num">2</span><span>Buche dein kostenloses Beratungsgespräch, wir besprechen deinen Fahrplan persönlich</span></li>
            <li><span class="num">3</span><span>Starte in 4 Wochen mit sichtbaren Ergebnissen</span></li>
          </ul>
        </div>
        <a href="https://fitontime-stoffwechsel-report.youcanbook.me" class="thankyou-cta" id="ty-cta" target="_blank" rel="noopener">Jetzt kostenloses Beratungsgespräch buchen &#128197;</a>
        <div class="thankyou-spots">&#128293; Nur noch wenige Plätze diese Woche verfügbar</div>
      </div>

    </div>
  </div>

  <script is:inline>
    var quizAnswers = {};
    var TOTAL = 7;

    function tk(e, d) {
      if (window.__lp) {
        window.__lp.track(e, Object.assign({ page: 'stoffwechsel-report' }, d || {}), 'fot', 'Stoffwechsel Report');
      }
      if (window.__lp) {
        if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'Stoffwechsel Report Quiz Start', currency: 'CHF' });
        if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'Stoffwechsel Report Quiz Complete', currency: 'CHF' });
        if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'Stoffwechsel Report Lead', currency: 'CHF' });
      }
    }
    tk('page_view');

    function startQuiz(gender) {
      quizAnswers['gender'] = gender || 'frau';
      tk('quiz_start', { detail: 'gender_' + quizAnswers.gender });
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0,0);
    }

    function nxt(s, el, val) {
      quizAnswers['q' + s] = val;
      tk('quiz_answer', { detail: 'q' + s + '_' + val });

      document.querySelector('.step[data-s="' + s + '"]').classList.remove('on');
      if (s < TOTAL) {
        document.querySelector('.step[data-s="' + (s + 1) + '"]').classList.add('on');
        var p = Math.round(((s) / TOTAL) * 100);
        document.getElementById('qf').style.width = p + '%';
        document.getElementById('qn').textContent = (s + 1) + ' / ' + TOTAL;
        var body = document.querySelector('.q-body');
        if (body) body.scrollTop = 0;
      } else {
        tk('quiz_complete');
        load();
      }
    }

    function load() {
      var ld = document.querySelector('.step[data-s="ld"]');
      ld.classList.add('on');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qn').textContent = 'Auswertung...';
      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 600);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1400);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2200);
      setTimeout(function(){
        ld.classList.remove('on');
        document.querySelector('.step[data-s="form"]').classList.add('on');
        document.getElementById('qn').textContent = 'Fast fertig';
      }, 3200);
    }

    document.getElementById('ds').addEventListener('change', function() {
      document.getElementById('sbtn').disabled = !this.checked;
    });

    function send() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird verarbeitet...';

      tk('lead_submit', { detail: fn });

      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fn,
          email: em,
          phone: ph ? '+41' + ph : '',
          answers: quizAnswers
        })
      }).catch(function(){});

      setTimeout(function(){
        document.querySelector('.step[data-s="form"]').classList.remove('on');
        document.querySelector('.step[data-s="thankyou"]').style.display = 'block';
        document.querySelector('.step[data-s="thankyou"]').classList.add('on');
        document.getElementById('qn').textContent = 'Geschafft!';
        tk('result_shown', { detail: 'thankyou' });
      }, 1200);
    }
  </script>

