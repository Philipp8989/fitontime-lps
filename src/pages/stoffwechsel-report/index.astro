---
// Stoffwechsel-Report Quiz - FitonTime
// Angleichung an proven Winner stoffwechsel-test: personalisiertes Ergebnis + Wistia-Video + YCBM
// CRO: echte Vorher-Nachher-Bilder, Pain/Benefit/Urgency fuer Cold Traffic
import CookieBanner from '../../components/CookieBanner.astro';
const impressumUrl = 'https://fitontime.ch/impressum-datenschutz';
const datenschutzUrl = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dein Stoffwechsel-Report in 60 Sekunden | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preload" as="image" href="/images/transformations/t5.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --surface: #f0ebe0;
      --surface-2: #e5dfd2;
      --accent: #2b7de9;
      --accent-dark: #1a5bb8;
      --green: #22c55e;
      --amber: #f59e0b;
      --red: #ef4444;
      --text: #1a1a1a;
      --text-2: #4a4a4a;
      --text-3: #888;
      --r: 14px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    .wrap { max-width: 720px; margin: 0 auto; padding: 0 20px; }

    /* Sticky Trust-Badge oben */
    .top-bar { background: #fff; border-bottom: 1px solid #e8e4da; padding: 8px 0; position: sticky; top: 0; z-index: 50; }
    .top-bar .tb-inner { max-width: 720px; margin: 0 auto; padding: 0 20px; display: flex; align-items: center; justify-content: space-between; gap: 10px; font-size: 12px; color: var(--text-2); }
    .top-bar .tb-inner b { color: var(--text); }
    .top-bar .tb-dot { display: inline-block; width: 8px; height: 8px; background: var(--green); border-radius: 50%; margin-right: 6px; animation: pulse 2s infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

    /* Logo */
    .logo { text-align: center; padding: 16px 0 8px; }
    .logo img { height: 40px; }

    /* Hero */
    .hero { text-align: center; padding: 16px 0 20px; }
    .hero h1 { font-size: 26px; font-weight: 800; line-height: 1.25; letter-spacing: -0.5px; margin-bottom: 12px; }
    .hero h1 em { font-style: normal; color: var(--accent); }
    .hero .sub { font-size: 15px; color: var(--text-2); margin-bottom: 8px; line-height: 1.5; }
    .hero .sub strong { color: var(--text); font-weight: 600; }
    .hero .time-hint { font-size: 13px; color: var(--accent); font-weight: 600; margin-bottom: 12px; }

    /* Proof Bar mit echten Teilnehmerinnen */
    .proof-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 10px 0; margin-bottom: 8px; flex-wrap: wrap; }
    .proof-avatars { display: flex; }
    .proof-avatars img { width: 34px; height: 34px; border-radius: 50%; border: 2px solid var(--bg); margin-left: -10px; object-fit: cover; object-position: center 30%; }
    .proof-avatars img:first-child { margin-left: 0; }
    .proof-info { font-size: 12px; color: var(--text-3); line-height: 1.3; text-align: left; }
    .proof-info b { color: var(--text); }
    .proof-stars { color: var(--amber); font-size: 12px; letter-spacing: 1px; }

    /* CTA Button */
    .cta-btn { display: block; width: 100%; max-width: 480px; margin: 20px auto 0; background: var(--accent); color: #fff; font-family: var(--font); font-size: 17px; font-weight: 700; padding: 18px; border: none; border-radius: 12px; cursor: pointer; transition: all 0.2s; text-align: center; box-shadow: 0 4px 14px rgba(43,125,233,0.25); }
    .cta-btn:hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: 0 6px 18px rgba(43,125,233,0.35); }
    .cta-btn:active { transform: scale(0.98); }
    .cta-sub { text-align: center; font-size: 12px; color: var(--text-3); margin-top: 8px; }

    /* Benefit-Liste */
    .benefit-list { text-align: left; margin: 20px auto; max-width: 480px; }
    .benefit-item { display: flex; align-items: flex-start; gap: 10px; padding: 8px 0; font-size: 14px; color: var(--text-2); }
    .benefit-item .ic { color: var(--green); font-size: 16px; flex-shrink: 0; margin-top: 1px; }
    .benefit-item strong { color: var(--text); font-weight: 600; }

    /* Transformation Grid */
    .trans { margin: 28px 0; }
    .trans-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 6px; }
    .trans-sub { font-size: 13px; color: var(--text-3); text-align: center; margin-bottom: 16px; }
    .trans-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .trans-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; background: #fff; }
    .trans-cap { font-size: 11px; color: var(--text-3); text-align: center; margin-top: 8px; }

    /* Pain Section */
    .pain { background: #fff; border-radius: var(--r); padding: 22px 20px; margin: 20px 0; border: 1px solid #e8e4da; }
    .pain h2 { font-size: 19px; font-weight: 800; text-align: center; margin-bottom: 6px; }
    .pain .pain-sub { font-size: 13px; color: var(--text-2); text-align: center; margin-bottom: 14px; line-height: 1.5; }
    .pain-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .pain-list li { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-2); padding: 8px 12px; background: #fef2f2; border-radius: 8px; }
    .pain-list li .ic { color: var(--red); font-size: 13px; flex-shrink: 0; }

    /* Benefit Cards */
    .benefits { margin: 24px 0; text-align: center; }
    .benefits h2 { font-size: 19px; font-weight: 800; margin-bottom: 14px; }
    .benefit-cards { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
    .benefit-card { background: #fff; border-radius: 12px; padding: 14px 8px; border: 1px solid #e8e4da; text-align: center; }
    .benefit-card .benefit-icon { font-size: 30px; margin-bottom: 6px; }
    .benefit-card h4 { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
    .benefit-card p { font-size: 11px; color: var(--text-3); line-height: 1.35; }

    /* Urgency */
    .urgency { background: #fff8ed; border-radius: var(--r); padding: 22px 20px; margin: 20px 0; border: 1px solid #fde68a; }
    .urgency h2 { font-size: 19px; font-weight: 800; text-align: center; margin-bottom: 6px; }
    .urgency .urgency-sub { font-size: 13px; color: var(--text-2); text-align: center; margin-bottom: 14px; line-height: 1.5; }
    .urgency-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
    .urgency-list li { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-2); padding: 8px 12px; background: #fffbeb; border-radius: 8px; }
    .urgency-list li .ic { color: var(--amber); font-size: 13px; flex-shrink: 0; }

    /* Divider */
    .divider { width: 40px; height: 2px; background: var(--accent); margin: 24px auto; opacity: 0.3; }

    /* Footer */
    footer { text-align: center; padding: 20px; font-size: 11px; color: var(--text-3); border-top: 1px solid #e8e4da; }
    footer a { color: var(--text-3); text-decoration: none; }

    /* ===== QUIZ ===== */
    #quiz { display: none; position: fixed; inset: 0; background: var(--bg); z-index: 100; flex-direction: column; overflow-y: auto; -webkit-overflow-scrolling: touch; }
    #quiz.on { display: flex; }
    .q-head { display: flex; align-items: center; justify-content: center; padding: 14px 20px; border-bottom: 1px solid #e8e4da; position: sticky; top: 0; background: var(--bg); z-index: 10; }
    .q-head img { height: 32px; }
    .q-progress { padding: 12px 20px 0; max-width: 600px; margin: 0 auto; width: 100%; position: sticky; top: 57px; background: var(--bg); z-index: 10; }
    .q-bar { height: 6px; background: #e8e4da; border-radius: 3px; overflow: hidden; }
    .q-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.4s ease; width: 0%; }
    .q-num { font-size: 12px; color: var(--text-3); text-align: right; margin-top: 4px; font-weight: 500; }
    .q-body { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 32px 20px; }

    .step { display: none; max-width: 600px; width: 100%; animation: up 0.3s ease; }
    .step.on { display: block; }
    @keyframes up { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .step h2 { font-size: 22px; font-weight: 800; text-align: center; margin-bottom: 20px; line-height: 1.3; letter-spacing: -0.3px; }
    .opts { display: flex; flex-direction: column; gap: 10px; }
    .opt { background: var(--surface); border: 2px solid transparent; border-radius: 12px; padding: 16px 18px; font-size: 15px; font-weight: 500; color: var(--text); cursor: pointer; transition: all 0.2s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: left; }
    .opt:hover { border-color: var(--accent); background: #fff; }
    .opt:active { transform: scale(0.98); border-color: var(--accent); }
    .opt strong { display: block; font-weight: 700; margin-bottom: 2px; }
    .opt span { font-size: 13px; color: var(--text-2); }

    /* Micro-Tipp nach jeder Frage */
    .tipp { background: #eef6ff; border: 1px solid #c4ddff; border-radius: 10px; padding: 12px 14px; margin-top: 16px; display: flex; align-items: flex-start; gap: 10px; }
    .tipp .tipp-icon { font-size: 16px; flex-shrink: 0; }
    .tipp .tipp-text { font-size: 12px; color: var(--text-2); line-height: 1.5; }
    .tipp .tipp-text strong { color: var(--accent); font-weight: 700; }

    /* Loading */
    .ld { text-align: center; }
    .spinner { width: 56px; height: 56px; border: 3px solid #e8e4da; border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 20px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ld h2 { font-size: 18px; margin-bottom: 6px; }
    .ld p { font-size: 14px; color: var(--text-2); margin-bottom: 20px; }
    .checks { text-align: left; max-width: 280px; margin: 0 auto; }
    .chk { display: flex; align-items: center; gap: 10px; padding: 6px 0; font-size: 14px; color: var(--text-2); opacity: 0; transition: opacity 0.3s; }
    .chk.show { opacity: 1; }
    .chk i { width: 20px; height: 20px; border-radius: 50%; background: var(--green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 11px; font-style: normal; font-weight: 700; flex-shrink: 0; }

    /* Formular */
    .form { text-align: center; }
    .form .tag { font-size: 13px; font-weight: 600; color: var(--green); margin-bottom: 6px; }
    .form h2 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
    .form .sub { font-size: 14px; color: var(--text-2); margin-bottom: 20px; }
    .fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; max-width: 440px; margin-left: auto; margin-right: auto; }
    .field { background: #fff; border: 2px solid #e8e4da; border-radius: 12px; padding: 0 14px; display: flex; align-items: center; gap: 10px; transition: border-color 0.2s; }
    .field:focus-within { border-color: var(--accent); }
    .field .ic { font-size: 16px; flex-shrink: 0; opacity: 0.5; }
    .field input { flex: 1; background: transparent; border: none; outline: none; color: var(--text); font-family: var(--font); font-size: 15px; padding: 14px 0; }
    .field input::placeholder { color: var(--text-3); }
    .field .pre { font-size: 14px; color: var(--text-3); flex-shrink: 0; }
    .cb-row { display: flex; align-items: flex-start; gap: 8px; margin: 0 auto 16px; text-align: left; max-width: 440px; }
    .cb-row input[type="checkbox"] { accent-color: var(--accent); width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0; }
    .cb-row label { font-size: 11px; color: var(--text-3); line-height: 1.4; }
    .cb-row label a { color: var(--text-2); }
    .submit { display: block; width: 100%; max-width: 440px; margin: 0 auto; background: var(--accent); color: #fff; font-family: var(--font); font-size: 16px; font-weight: 700; padding: 16px; border: none; border-radius: 12px; cursor: pointer; transition: all 0.2s; }
    .submit:disabled { opacity: 0.4; cursor: not-allowed; }
    .submit:not(:disabled):hover { background: var(--accent-dark); }
    .submit:not(:disabled):active { opacity: 0.85; }
    .form-proof { margin-top: 16px; padding-top: 16px; border-top: 1px solid #e8e4da; max-width: 440px; margin-left: auto; margin-right: auto; }
    .form-proof .fp-row { display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 11px; color: var(--text-3); margin-bottom: 4px; }
    .form-proof .fp-row b { color: var(--text-2); }

    /* ===== ERGEBNIS-SEITE ===== */
    .result { text-align: center; max-width: 600px; width: 100%; padding-bottom: 40px; }
    .result-badge { display: inline-block; background: rgba(43,125,233,0.1); color: var(--accent); font-size: 12px; font-weight: 700; padding: 4px 14px; border-radius: 20px; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
    .result h2 { font-size: 26px; font-weight: 800; margin-bottom: 8px; }
    .result .result-type { font-size: 17px; color: var(--accent); font-weight: 700; margin-bottom: 16px; }
    .result-summary { font-size: 14px; color: var(--text-2); line-height: 1.6; text-align: left; margin-bottom: 20px; padding: 16px; background: #fff; border-radius: var(--r); border: 1px solid #e8e4da; }
    .result-cta-box { background: var(--accent); color: #fff; border-radius: var(--r); padding: 20px; margin: 20px 0; }
    .result-cta-box h3 { font-size: 18px; font-weight: 800; margin-bottom: 6px; }
    .result-cta-box p { font-size: 13px; opacity: 0.92; line-height: 1.5; }
    .result-bullets { list-style: none; text-align: left; margin: 16px 0; padding: 0; }
    .result-bullets li { padding: 6px 0; font-size: 13px; display: flex; gap: 8px; }
    .result-bullets li::before { content: "✓"; color: var(--green); font-weight: 700; flex-shrink: 0; }
    .result-meta { display: flex; flex-direction: column; gap: 4px; margin: 14px 0; text-align: center; }
    .result-meta .rm-hot { font-size: 13px; color: var(--amber); font-weight: 600; }
    .result-meta .rm-sm { font-size: 12px; color: var(--text-3); }

    /* Desktop */
    @media (min-width: 600px) {
      .hero h1 { font-size: 38px; }
      .hero .sub { font-size: 17px; }
      .step h2 { font-size: 28px; }
      .opts { display: grid; grid-template-columns: 1fr; gap: 12px; }
      .opt { font-size: 16px; padding: 18px 20px; }
      .result h2 { font-size: 32px; }
      .trans-grid { grid-template-columns: repeat(6, 1fr); }
    }
    @media (min-width: 900px) {
      .hero h1 { font-size: 44px; }
    }
  </style>
</head>
<body>

  <!-- Sticky Live-Trust-Bar -->
  <div class="top-bar">
    <div class="tb-inner">
      <span><span class="tb-dot"></span>Aktuell bewertet dein Ergebnis</span>
      <span><b>2.847+</b> Reports &middot; 4.9 &#9733;</span>
    </div>
  </div>

  <!-- ===== LANDING ===== -->
  <div id="lp">
    <div class="wrap">
      <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

      <section class="hero">
        <h1>Dein individueller <em>Stoffwechsel-Report</em>: Entdecke in 60 Sekunden, warum dein Körper nicht abnimmt, und was du in 4 Wochen ändern kannst</h1>
        <p class="sub">Mit <strong>7 kurzen Fragen</strong> erfährst du, wie dein Stoffwechsel tickt und welcher Ansatz zu deinem Körper passt. Kostenlos und unverbindlich.</p>
        <p class="time-hint">&#9201; 60 Sekunden. Keine Anmeldung, bevor du dein Ergebnis siehst.</p>

        <div class="proof-bar">
          <div class="proof-avatars">
            <img src="/images/transformations/t5.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t1.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t3.jpg" alt="" loading="lazy" />
            <img src="/images/transformations/t6.jpg" alt="" loading="lazy" />
          </div>
          <div class="proof-info">
            <div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <b>2.847+</b> Frauen haben ihren Report erhalten
          </div>
        </div>

        <div class="benefit-list">
          <div class="benefit-item"><span class="ic">&#10003;</span><span><strong>Warum dein Körper nicht abnimmt</strong>, trotz Sport und Disziplin</span></div>
          <div class="benefit-item"><span class="ic">&#10003;</span><span><strong>Dein persönlicher 4-Wochen-Fahrplan</strong> zum Stoffwechsel-Reset</span></div>
          <div class="benefit-item"><span class="ic">&#10003;</span><span><strong>Welche Lebensmittel deinen Stoffwechsel bremsen</strong>, und welche ihn ankurbeln</span></div>
          <div class="benefit-item"><span class="ic">&#10003;</span><span><strong>Einfache Alltagstipps</strong>, die sofort wirken, ohne Diät und ohne Verzicht</span></div>
        </div>

        <button class="cta-btn" onclick="startQuiz()">Jetzt Stoffwechsel-Report starten &#10024;</button>
        <p class="cta-sub">&#128274; Kostenlos &middot; Keine Anmeldung vor dem Ergebnis &middot; Ergebnis sofort</p>
      </section>

      <div class="divider"></div>

      <!-- Echte Vorher-Nachher Transformationen -->
      <div class="trans">
        <h3 class="trans-title">Echte Teilnehmerinnen. Echte Resultate.</h3>
        <p class="trans-sub">Ein kleiner Ausschnitt aus über 1.600 erfolgreichen Transformationen</p>
        <div class="trans-grid">
          <img src="/images/transformations/t5.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t1.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t2.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t3.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t4.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
          <img src="/images/transformations/t6.jpg" alt="Vorher-Nachher Fit on Time" loading="lazy" />
        </div>
        <p class="trans-cap">&#9733;&#9733;&#9733;&#9733;&#9733; 4.9 von 5 &middot; 1.600 halten ihr Wunschgewicht</p>
      </div>

      <div class="divider"></div>

      <!-- Problem-Section -->
      <div class="pain">
        <h2>Was passiert, wenn du nichts änderst?</h2>
        <p class="pain-sub">Ein blockierter Stoffwechsel hat Folgen, und sie werden mit der Zeit schlimmer.</p>
        <ul class="pain-list">
          <li><span class="ic">&#10007;</span>Scheiternde Abnehmversuche trotz Disziplin und Verzicht</li>
          <li><span class="ic">&#10007;</span>Jojo-Effekt und Crash-Diäten, die den Stoffwechsel weiter bremsen</li>
          <li><span class="ic">&#10007;</span>Schlafstörungen, Stimmungstiefs, Heisshunger-Attacken</li>
          <li><span class="ic">&#10007;</span>Frustration und sinkender Selbstwert durch ausbleibende Ergebnisse</li>
        </ul>
      </div>

      <!-- Benefits -->
      <div class="benefits">
        <h2>Was ein aktiver Stoffwechsel für dich bedeutet</h2>
        <div class="benefit-cards">
          <div class="benefit-card">
            <div class="benefit-icon">&#9878;</div>
            <h4>Abnehmen ohne Stress</h4>
            <p>Dein Körper verbrennt wieder effizient, ohne Hungern</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">&#128154;</div>
            <h4>Bessere Gesundheit</h4>
            <p>Stabilere Hormone, besserer Schlaf, starkes Immunsystem</p>
          </div>
          <div class="benefit-card">
            <div class="benefit-icon">&#9889;</div>
            <h4>Mehr Energie</h4>
            <p>Kein Mittagstief, konstante Energie den ganzen Tag</p>
          </div>
        </div>
      </div>

      <!-- Urgency -->
      <div class="urgency">
        <h2>&#9888; Wieso du jetzt handeln solltest</h2>
        <p class="urgency-sub">Diese Warnsignale zeigen dir, dass dein Stoffwechsel bereits gebremst ist:</p>
        <ul class="urgency-list">
          <li><span class="ic">&#9888;</span><strong>Ständige Müdigkeit</strong>, besonders nachmittags</li>
          <li><span class="ic">&#9888;</span><strong>Unkontrollierbarer Heisshunger</strong>, vor allem auf Süsses</li>
          <li><span class="ic">&#9888;</span><strong>Stagnierendes Gewicht</strong> trotz Sport und bewusster Ernährung</li>
          <li><span class="ic">&#9888;</span><strong>Verdauungsprobleme</strong>, Blähungen, Völlegefühl</li>
        </ul>
        <p class="urgency-sub" style="margin-top:14px;margin-bottom:0;"><strong>Je länger du wartest, desto schwieriger wird es.</strong> Dein Stoffwechsel gewöhnt sich an den Sparmodus.</p>
      </div>

      <!-- 2. CTA -->
      <section class="hero" style="padding-top:0;">
        <p class="sub" style="margin-bottom:4px;"><strong>In 60 Sekunden</strong> weisst du, was deinen Stoffwechsel blockiert, und wie du es änderst.</p>
        <button class="cta-btn" onclick="startQuiz()">Jetzt Stoffwechsel-Report starten &#10024;</button>
        <p class="cta-sub">&#128274; Kostenlos &middot; Keine Anmeldung vor dem Ergebnis</p>
      </section>

      <footer>
        <a href={impressumUrl} target="_blank" rel="noopener">Impressum</a> &middot;
        <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutzerklärung</a>
      </footer>
    </div>
  </div>

  <!-- ===== QUIZ ===== -->
  <div id="quiz">
    <div class="q-head"><img src="/images/logo.png" alt="Fit on Time" /></div>
    <div class="q-progress"><div class="q-bar"><div class="q-fill" id="qf"></div></div><div class="q-num" id="qn">1 / 7</div></div>
    <div class="q-body">

      <!-- Frage 1: Körperbau -->
      <div class="step on" data-s="1">
        <h2>Welcher Körperbau beschreibt dich am besten?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(1,this,'ecto')"><strong>Schlank &amp; zierlich</strong><span>Schmale Schultern, nehme schwer zu, verliere schnell Gewicht.</span></button>
          <button class="opt" onclick="nxt(1,this,'meso')"><strong>Mittel &amp; athletisch</strong><span>Ausgewogene Proportionen, baue leicht Muskeln auf.</span></button>
          <button class="opt" onclick="nxt(1,this,'endo')"><strong>Kräftiger Bau</strong><span>Breitere Hüften, nehme leicht zu, vor allem an Bauch und Hüfte.</span></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Wusstest du?</strong> Dein Körperbau bestimmt, wie dein Stoffwechsel auf Essen reagiert, und das ist bei jeder Frau anders.</div>
        </div>
      </div>

      <!-- Frage 2: Grösstes Problem -->
      <div class="step" data-s="2">
        <h2>Was ist dein grösstes Problem beim Abnehmen?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(2,this,'jojo')"><strong>Jojo-Effekt</strong><span>Ich nehme ab, dann wieder zu, ein endloser Kreislauf.</span></button>
          <button class="opt" onclick="nxt(2,this,'hunger')"><strong>Heisshunger</strong><span>Plötzliche Essattacken sabotieren jeden Fortschritt.</span></button>
          <button class="opt" onclick="nxt(2,this,'sport')"><strong>Keine Resultate trotz Sport</strong><span>Ich bewege mich viel, aber die Waage bewegt sich nicht.</span></button>
          <button class="opt" onclick="nxt(2,this,'moti')"><strong>Motivation</strong><span>Ich starte motiviert, gebe aber nach wenigen Wochen auf.</span></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> 92% der Frauen scheitern, weil ihr Ansatz nicht zu ihrem Stoffwechsel-Typ passt, nicht an fehlender Disziplin.</div>
        </div>
      </div>

      <!-- Frage 3: Energielevel -->
      <div class="step" data-s="3">
        <h2>Wie würdest du dein Energielevel beschreiben?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(3,this,'schwankend')"><strong>Schwankend</strong><span>Mal super energiegeladen, dann komplett platt.</span></button>
          <button class="opt" onclick="nxt(3,this,'hoch')"><strong>Konstant hoch</strong><span>Ich habe meistens genug Energie für den Tag.</span></button>
          <button class="opt" onclick="nxt(3,this,'niedrig')"><strong>Eher niedrig</strong><span>Ich fühle mich oft müde und schlapp.</span></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Schwankende Energie ist ein Signal für Blutzucker-Achterbahn, lässt sich mit dem richtigen Timing lösen.</div>
        </div>
      </div>

      <!-- Frage 4: Mahlzeiten -->
      <div class="step" data-s="4">
        <h2>Wie oft isst du pro Tag?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(4,this,'1-2')"><strong>1 bis 2 Mahlzeiten</strong><span>Ich frühstücke selten und komme mit wenig aus.</span></button>
          <button class="opt" onclick="nxt(4,this,'3')"><strong>3 Mahlzeiten</strong><span>Frühstück, Mittag, Abendessen, relativ regelmässig.</span></button>
          <button class="opt" onclick="nxt(4,this,'3+')"><strong>Mehr als 3</strong><span>Ich snacke zwischendurch oder esse häufig kleine Portionen.</span></button>
          <button class="opt" onclick="nxt(4,this,'unreg')"><strong>Unregelmässig</strong><span>Mal viel, mal gar nichts, kein festes Muster.</span></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> 10-Minuten-Spaziergang nach dem Essen stabilisiert den Blutzucker und kurbelt den Stoffwechsel an.</div>
        </div>
      </div>

      <!-- Frage 5: Alltag -->
      <div class="step" data-s="5">
        <h2>Was beschreibt deinen Alltag?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(5,this,'sitzend')"><strong>Sitzend (Büro)</strong><span>Ich verbringe den Grossteil des Tages im Sitzen.</span></button>
          <button class="opt" onclick="nxt(5,this,'maessig')"><strong>Mässig aktiv</strong><span>Ich bewege mich regelmässig, aber nicht täglich intensiv.</span></button>
          <button class="opt" onclick="nxt(5,this,'aktiv')"><strong>Sehr aktiv</strong><span>Ich bin fast jeden Tag körperlich aktiv.</span></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Schon 2 Minuten Bewegung pro Stunde im Büro steigern deinen Kalorienverbrauch um bis zu 15%.</div>
        </div>
      </div>

      <!-- Frage 6: Alter -->
      <div class="step" data-s="6">
        <h2>Wie alt bist du?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(6,this,'18-29')"><strong>18 bis 29 Jahre</strong></button>
          <button class="opt" onclick="nxt(6,this,'30-39')"><strong>30 bis 39 Jahre</strong></button>
          <button class="opt" onclick="nxt(6,this,'40-49')"><strong>40 bis 49 Jahre</strong></button>
          <button class="opt" onclick="nxt(6,this,'50+')"><strong>50+ Jahre</strong></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Tipp:</strong> Ab 35 verlangsamt sich der Stoffwechsel jährlich um 1-2%, der richtige Ansatz macht den Unterschied.</div>
        </div>
      </div>

      <!-- Frage 7: Ziel -->
      <div class="step" data-s="7">
        <h2>Was ist dein Ziel in den nächsten 3 Monaten?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(7,this,'3-5')"><strong>3 bis 5 kg verlieren</strong><span>Feinschliff, die letzten hartnäckigen Kilos.</span></button>
          <button class="opt" onclick="nxt(7,this,'6-10')"><strong>6 bis 10 kg verlieren</strong><span>Deutlich sichtbare Veränderung am Körper.</span></button>
          <button class="opt" onclick="nxt(7,this,'10+')"><strong>Mehr als 10 kg</strong><span>Eine echte Transformation, die alles verändert.</span></button>
          <button class="opt" onclick="nxt(7,this,'fitter')"><strong>Einfach fitter werden</strong><span>Mehr Energie, besseres Körpergefühl.</span></button>
        </div>
        <div class="tipp">
          <span class="tipp-icon">&#128161;</span>
          <div class="tipp-text"><strong>Fast fertig!</strong> Wir erstellen gleich deinen persönlichen Stoffwechsel-Fahrplan basierend auf deinen Antworten.</div>
        </div>
      </div>

      <!-- Loading -->
      <div class="step ld" data-s="ld">
        <div class="spinner"></div>
        <h2>Dein Stoffwechsel-Report wird erstellt...</h2>
        <p>Das dauert nur ein paar Sekunden</p>
        <div class="checks">
          <div class="chk" id="c1"><i>&#10003;</i>Antworten analysiert</div>
          <div class="chk" id="c2"><i>&#10003;</i>Stoffwechsel-Typ bestimmt</div>
          <div class="chk" id="c3"><i>&#10003;</i>Persönlicher 4-Wochen-Fahrplan erstellt</div>
        </div>
      </div>

      <!-- Formular -->
      <div class="step form" data-s="form">
        <div class="tag">&#10003; Analyse abgeschlossen!</div>
        <h2>Dein Stoffwechsel-Fahrplan ist bereit!</h2>
        <p class="sub">Trage dich ein, um dein persönliches Ergebnis zu sehen.</p>
        <div class="fields">
          <div class="field"><span class="ic">&#128075;</span><input type="text" id="fn" placeholder="Dein Vor- und Nachname" required /></div>
          <div class="field"><span class="ic">&#128236;</span><input type="email" id="em" placeholder="Deine E-Mail" required /></div>
          <div class="field"><span class="ic">&#128222;</span><span class="pre">+41</span><input type="tel" id="ph" placeholder="Deine Telefonnummer" required /></div>
        </div>
        <div class="cb-row">
          <input type="checkbox" id="ds" />
          <label for="ds">Ich akzeptiere die <a href={datenschutzUrl} target="_blank">Datenschutzbestimmungen</a></label>
        </div>
        <button class="submit" id="sbtn" disabled onclick="send()">Jetzt Report anzeigen &#10024;</button>
        <div class="form-proof">
          <div class="fp-row"><span>&#128274;</span> Deine Daten sind sicher &amp; werden nicht weitergegeben</div>
          <div class="fp-row"><span class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span> <b>2.847+</b> zufriedene Teilnehmerinnen</div>
        </div>
      </div>

      <!-- Ergebnis-Seite mit Typ + Wistia + YCBM -->
      <div class="step result" data-s="result" style="display:none;">
        <span class="result-badge">&#9889; Dein Ergebnis ist da!</span>
        <h2 id="r-title">Dein Stoffwechsel-Typ</h2>
        <p class="result-type" id="r-type">, wird ermittelt &middot;</p>

        <!-- Wistia Video (zielbasiert) -->
        <div id="wistia-container" style="margin:16px 0; border-radius:12px; overflow:hidden; background:#000; aspect-ratio:16/9;"></div>

        <div class="result-summary" id="r-summary"></div>

        <div class="result-cta-box">
          <h3>Jetzt kostenlose Standortbestimmung sichern</h3>
          <p>In 30 Minuten besprechen wir gemeinsam, wo dein Stoffwechsel steht und welche Schritte für dich in den nächsten 4 Wochen den grössten Unterschied machen.</p>
          <ul class="result-bullets">
            <li>Dein individueller 4-Wochen-Fahrplan</li>
            <li>Wie du ohne Kalorienzählen abnimmst</li>
            <li>Wie du ohne Jojo-Effekt langfristig schlank bleibst</li>
            <li>Persönliche Empfehlung, welche Schritte JETZT zählen</li>
          </ul>
        </div>

        <!-- YCBM Booking Embed -->
        <div id="ycbm-container" style="margin:16px 0;"></div>

        <div class="result-meta">
          <span class="rm-hot">&#128293; Freie Plätze schnell vergeben</span>
          <span class="rm-sm">Rückmeldung in 24h &middot; 100% kostenlos &middot; unverbindlich</span>
        </div>
      </div>

    </div>
  </div>

  <script is:inline>
    var quizAnswers = {};
    var TOTAL = 7;

    function tk(e, d) {
      if (window.__lp) {
        window.__lp.track(e, Object.assign({ page: 'stoffwechsel-report' }, d || {}), 'fot', 'Stoffwechsel Report');
      }
      if (window.__lp) {
        if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'Stoffwechsel Report Quiz Start', currency: 'CHF' });
        if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'Stoffwechsel Report Quiz Complete', currency: 'CHF' });
        if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'Stoffwechsel Report Lead', currency: 'CHF' });
      }
    }
    tk('page_view');

    function startQuiz() {
      tk('quiz_start');
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0,0);
    }

    function nxt(s, el, val) {
      var label = el && el.querySelector('strong') ? el.querySelector('strong').textContent.trim() : '';
      quizAnswers['q' + s] = label;
      quizAnswers['q' + s + '_val'] = val;
      tk('quiz_answer', { detail: 'q' + s + '_' + val });

      document.querySelector('.step[data-s="' + s + '"]').classList.remove('on');
      if (s < TOTAL) {
        document.querySelector('.step[data-s="' + (s + 1) + '"]').classList.add('on');
        var p = Math.round(((s) / TOTAL) * 100);
        document.getElementById('qf').style.width = p + '%';
        document.getElementById('qn').textContent = (s + 1) + ' / ' + TOTAL;
        var body = document.querySelector('.q-body');
        if (body) body.scrollTop = 0;
      } else {
        tk('quiz_complete');
        load();
      }
    }

    function load() {
      var ld = document.querySelector('.step[data-s="ld"]');
      ld.classList.add('on');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qn').textContent = 'Auswertung...';
      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 600);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1400);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2200);
      setTimeout(function(){
        ld.classList.remove('on');
        document.querySelector('.step[data-s="form"]').classList.add('on');
        document.getElementById('qn').textContent = 'Fast fertig';
      }, 3200);
    }

    // Personalisiertes Profil bestimmen
    function getProfile() {
      var body = quizAnswers.q1_val || 'meso';
      var problem = quizAnswers.q2_val || 'jojo';
      var profiles = {
        ecto: {
          title: 'Der Verbrennungstyp',
          summary: 'Dein Stoffwechsel arbeitet schnell, verbrennt aber oft die falschen Energiequellen. Du nimmst zwar nicht leicht zu, aber wenn du abnehmen willst, verlierst du häufig Muskeln statt Fett. Dein Körper braucht regelmässige, nährstoffreiche Mahlzeiten, um stabil zu bleiben.',
        },
        meso: {
          title: 'Der Allrounder',
          summary: 'Dein Körper reagiert gut auf Training und Ernährungsumstellungen. Du baust leicht Muskeln auf und kannst auch abnehmen, wenn du den richtigen Reiz setzt. Dein Problem ist oft nicht der Körper, sondern die Konstanz, und genau da setzt unser Ansatz an.',
        },
        endo: {
          title: 'Der Speichertyp',
          summary: 'Dein Körper speichert Energie besonders effizient, evolutionär ein Vorteil, heute eine Herausforderung. Standard-Diäten mit Kaloriendefizit funktionieren bei dir kaum, weil dein Körper sofort in den Sparmodus schaltet. Statt weniger essen, anders essen, das ist der Schlüssel.',
        }
      };
      var p = Object.assign({}, profiles[body] || profiles.meso);

      if (problem === 'hunger') {
        p.summary += ' Dein Hauptproblem Heisshunger deutet auf schwankenden Blutzucker hin, das lässt sich mit dem richtigen Mahlzeiten-Timing lösen.';
      } else if (problem === 'jojo') {
        p.summary += ' Der Jojo-Effekt zeigt, dass bisherige Ansätze deinen Stoffwechsel nicht respektiert haben. Unser Ansatz setzt genau da an.';
      } else if (problem === 'sport') {
        p.summary += ' Wenn trotz Sport nichts passiert, stimmt oft das Verhältnis zwischen Training und Ernährung nicht, genau das optimieren wir.';
      } else if (problem === 'moti') {
        p.summary += ' Fehlende Motivation ist kein Charakter-Problem, es fehlt nur der Plan, der wirklich zu dir passt. Wenn du siehst, dass es wirkt, bleibt Motivation von allein.';
      }
      return p;
    }

    document.getElementById('ds').addEventListener('change', function() {
      document.getElementById('sbtn').disabled = !this.checked;
    });

    function send() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird ausgewertet...';

      var profile = getProfile();
      tk('lead_submit', { detail: fn + ' - ' + (quizAnswers.q1_val || 'unknown') });

      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fn,
          email: em,
          phone: ph ? '+41' + ph : '',
          answers: Object.assign({}, quizAnswers, { profile_type: quizAnswers.q1_val })
        })
      }).catch(function(){});

      setTimeout(function(){
        // Ergebnis-Text setzen
        document.getElementById('r-title').textContent = 'Dein Stoffwechsel-Typ: ' + profile.title;
        var firstName = (fn.split(' ')[0] || '').trim();
        document.getElementById('r-type').textContent = (firstName ? firstName + ', ' : '') + 'hier ist deine individuelle Auswertung';
        document.getElementById('r-summary').textContent = profile.summary;

        // Wistia Video basierend auf Ziel (Q7)
        var goal = quizAnswers.q7_val || '6-10';
        var videoMap = {
          '3-5': 'zuef2ev1j4',
          '6-10': 'g7g5ttzij5',
          '10+': 'b6bkslxgxy',
          'fitter': 'zuef2ev1j4'
        };
        var videoId = videoMap[goal] || 'g7g5ttzij5';

        var wc = document.getElementById('wistia-container');
        var wd = document.createElement('div');
        wd.className = 'wistia_embed wistia_async_' + videoId;
        wd.style.cssText = 'width:100%;height:100%;';
        wc.appendChild(wd);
        var ws = document.createElement('script');
        ws.src = 'https://fast.wistia.com/assets/external/E-v1.js';
        ws.async = true;
        wc.appendChild(ws);

        // YCBM Kalender
        var ys = document.createElement('script');
        ys.src = 'https://embed.ycb.me';
        ys.async = true;
        ys.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
        ys.setAttribute('data-displaymode', 'auto');
        document.getElementById('ycbm-container').appendChild(ys);

        document.querySelector('.step[data-s="form"]').classList.remove('on');
        document.querySelector('.step[data-s="result"]').style.display = 'block';
        document.querySelector('.step[data-s="result"]').classList.add('on');
        document.getElementById('qn').textContent = 'Dein Ergebnis';
        var body = document.querySelector('.q-body');
        if (body) body.scrollTop = 0;
        tk('result_shown', { detail: goal + '_' + (quizAnswers.q1_val || 'meso') });
      }, 1200);
    }
  </script>

  {/* Hyros als First-Party-Attribution essentiell  -  laedt ohne Consent */}
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <CookieBanner
    metaPixelId="1349136525891811"
    consentKey="fot_stoffwechsel_report_consent"
    impressumUrl={impressumUrl}
    datenschutzUrl={datenschutzUrl}
  />
</body>
</html>
