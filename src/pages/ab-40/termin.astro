---
// VSL-Call-Funnel "Ab 40", Schritt 3: Qualifizierung + YouCanBook.me-Booking
// 4 Pflichtfragen VOR dem Kalender (Hyperscale-Pattern: Application vor Booking),
// Antworten gehen als Event ins Tracking. YCBM sendet kein Buchungs-Event (nur Hoehe),
// daher leitet YCBM nach der Buchung auf /ab-40/bestaetigt weiter, wo call_booked feuert.
import CookieBanner from '../../components/CookieBanner.astro';

const LP_SLUG = 'ab-40';
const LP_NAME = 'Ab-40 VSL Funnel';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
// YouCanBook.me Subdomain (data-domain aus dem Embed-Snippet)
const YCBM_DOMAIN = (import.meta.env.PUBLIC_FOT_YCBM_DOMAIN || 'fitontime-analyse-fot-vsl').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dein kostenloser Stoffwechsel-Check | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --accent: #2b7de9;
      --accent-dark: #1a5bb8;
      --green: #22c55e;
      --amber: #f59e0b;
      --red: #ef4444;
      --text: #1a1a1a;
      --text-2: #4a4a4a;
      --text-3: #888;
      --r: 14px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    .wrap { max-width: 680px; margin: 0 auto; padding: 0 20px; }

    .logo { text-align: center; padding: 16px 0 8px; }
    .logo img { height: 40px; }

    .hero { text-align: center; padding: 4px 0 14px; }
    .hero h1 { font-size: 24px; font-weight: 800; line-height: 1.25; letter-spacing: -0.4px; margin-bottom: 8px; }
    .hero h1 em { font-style: normal; color: var(--accent); }
    .hero .sub { font-size: 14.5px; color: var(--text-2); }

    .progress { height: 6px; background: #e8e4da; border-radius: 999px; overflow: hidden; margin: 4px 0; }
    .progress-fill { height: 100%; background: var(--accent); border-radius: 999px; transition: width 0.3s ease; width: 25%; }
    .progress-label { font-size: 11px; color: var(--text-3); text-align: right; margin-bottom: 14px; }

    .step { display: none; animation: fade 0.25s ease; }
    .step.active { display: block; }
    @keyframes fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

    .q-card { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 22px 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
    .q-card h2 { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 16px; line-height: 1.3; }
    .answers { display: flex; flex-direction: column; gap: 10px; }
    .answer { background: #fff; border: 2px solid #e8e4da; border-radius: 12px; padding: 16px 18px; font-size: 15px; font-weight: 600; cursor: pointer; text-align: center; transition: all 0.15s; font-family: var(--font); color: var(--text); -webkit-tap-highlight-color: transparent; }
    .answer:hover { border-color: var(--accent); background: #eef6ff; }
    .answer:active { transform: scale(0.99); }

    .softblock { text-align: center; padding: 10px 0; }
    .softblock .sb-emoji { font-size: 40px; display: block; margin-bottom: 8px; }
    .softblock h2 { font-size: 19px; font-weight: 800; margin-bottom: 8px; }
    .softblock p { font-size: 14px; color: var(--text-2); line-height: 1.6; margin-bottom: 14px; }
    .softblock a { color: var(--accent); font-weight: 700; }

    .cal-head { text-align: center; margin: 6px 0 10px; }
    .cal-head h2 { font-size: 19px; font-weight: 800; margin-bottom: 4px; }
    .cal-head p { font-size: 13px; color: var(--text-2); }
    .cal-note { font-size: 12px; color: var(--text-3); text-align: center; margin-top: 4px; }
    #ycbmEmbed { min-height: 760px; }

    footer { padding: 26px 16px 22px; text-align: center; color: var(--text-3); font-size: 11.5px; }
    footer a { color: var(--text-3); }

    @media (max-width: 480px) { .hero h1 { font-size: 21px; } }
  </style>
</head>
<body>
  <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

  <main class="wrap">
    <section class="hero">
      <h1>Fast geschafft: <em>4 kurze Fragen</em>, dann suchst du dir deinen Termin aus</h1>
      <p class="sub">So kann sich Fabians Team optimal auf dein Gespräch vorbereiten.</p>
    </section>

    <div class="progress" id="progress"><div class="progress-fill" id="progressFill"></div></div>
    <p class="progress-label" id="progressLabel">Frage 1 von 4</p>

    <!-- Frage 1 -->
    <div class="step active" data-step="1">
      <div class="q-card">
        <h2>Was beschreibt deine Situation am besten?</h2>
        <div class="answers">
          <button class="answer" data-q="situation" data-v="alles-probiert">Ich habe schon mehrere Diäten oder Programme probiert, ohne dauerhaften Erfolg</button>
          <button class="answer" data-q="situation" data-v="wechseljahre">Seit den Wechseljahren nehme ich zu, obwohl ich nichts verändert habe</button>
          <button class="answer" data-q="situation" data-v="erste-schritte">Ich fange gerade erst an, mich mit dem Thema zu beschäftigen</button>
        </div>
      </div>
    </div>

    <!-- Frage 2 -->
    <div class="step" data-step="2">
      <div class="q-card">
        <h2>Wie viel möchtest du abnehmen?</h2>
        <div class="answers">
          <button class="answer" data-q="ziel" data-v="unter-5">Unter 5 kg</button>
          <button class="answer" data-q="ziel" data-v="5-10">5 bis 10 kg</button>
          <button class="answer" data-q="ziel" data-v="10-15">10 bis 15 kg</button>
          <button class="answer" data-q="ziel" data-v="ueber-15">Mehr als 15 kg</button>
        </div>
      </div>
    </div>

    <!-- Frage 3 -->
    <div class="step" data-step="3">
      <div class="q-card">
        <h2>Professionelle 1:1-Begleitung ist eine Investition in dich. Bist du grundsätzlich bereit, in deine Gesundheit zu investieren, wenn es für dich passt?</h2>
        <div class="answers">
          <button class="answer" data-q="invest" data-v="ja">Ja, wenn mich der Weg überzeugt</button>
          <button class="answer" data-q="invest" data-v="unsicher">Ich bin unsicher, möchte es aber verstehen</button>
          <button class="answer" data-q="invest" data-v="nein">Nein, ich suche nur kostenlose Tipps</button>
        </div>
      </div>
    </div>

    <!-- Frage 4 -->
    <div class="step" data-step="4">
      <div class="q-card">
        <h2>Entscheidest du selbst über solche Themen?</h2>
        <div class="answers">
          <button class="answer" data-q="entscheidung" data-v="ja">Ja, das entscheide ich selbst</button>
          <button class="answer" data-q="entscheidung" data-v="mit-partner">Ich bespreche es mit meinem Partner</button>
        </div>
      </div>
    </div>

    <!-- Soft-Block für "nur kostenlose Tipps" -->
    <div class="step" data-step="90">
      <div class="q-card softblock">
        <span class="sb-emoji">💛</span>
        <h2>Danke für deine Ehrlichkeit</h2>
        <p>Der Stoffwechsel-Check ist für Frauen gedacht, die bereit sind, ihre Situation wirklich anzugehen, die Plätze sind begrenzt.<br /><br />Schau dir in der Zwischenzeit gern unsere kostenlosen Inhalte an. Und wenn der Zeitpunkt für dich gekommen ist, bist du herzlich willkommen.</p>
        <a href="https://fit-on-time.ch" target="_blank" rel="noopener">Zu den kostenlosen Inhalten von Fit on Time →</a>
      </div>
    </div>

    <!-- Kalender -->
    <div class="step" data-step="5">
      <div class="cal-head">
        <h2>Such dir jetzt deinen Wunschtermin aus</h2>
        <p>Das Gespräch dauert ca. 30 Minuten und findet per Telefon oder Zoom statt.</p>
      </div>
      <div id="ycbmEmbed"></div>
      <p class="cal-note">Der Kalender kann einen Moment zum Laden brauchen.</p>
    </div>
  </main>

  <footer>
    <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Impressum</a> · <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutz</a>
  </footer>

  <CookieBanner
    metaPixelId={PIXEL_ID}
    hyrosPh={HYROS_ID}
    impressumUrl={IMPRESSUM_URL}
    datenschutzUrl={DATENSCHUTZ_URL}
    consentKey="fot_consent"
  />

  <script is:inline define:vars={{ LP_SLUG, LP_NAME, YCBM_DOMAIN }}>
    const SESSION_KEY = 'fot_session';
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }
    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({ event, lp: LP_SLUG, lp_name: LP_NAME, session }, extra || {}));
      try {
        if (navigator.sendBeacon) { navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' })); return; }
      } catch (e) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }

    track('page_view', { page: 'termin' });

    const answers = {};
    let current = 1;
    const TOTAL = 4;

    function show(step) {
      document.querySelectorAll('.step').forEach((s) => s.classList.toggle('active', Number(s.dataset.step) === step));
      const isQuestion = step >= 1 && step <= TOTAL;
      document.getElementById('progress').hidden = !isQuestion;
      document.getElementById('progressLabel').hidden = !isQuestion;
      if (isQuestion) {
        document.getElementById('progressFill').style.width = Math.round((step / TOTAL) * 100) + '%';
        document.getElementById('progressLabel').textContent = 'Frage ' + step + ' von ' + TOTAL;
      }
      window.scrollTo({ top: 0, behavior: 'instant' });
    }

    let ycbmLoaded = false;
    function loadYcbm() {
      // YouCanBook.me Embed-Script (rendert das Booking-Widget in #ycbmEmbed).
      // data-domain nimmt nur die Subdomain, KEIN Prefill-Query (das wuerde die URL brechen).
      if (ycbmLoaded) return;
      ycbmLoaded = true;
      const s = document.createElement('script');
      s.src = 'https://embed.ycb.me';
      s.async = true;
      s.setAttribute('data-domain', YCBM_DOMAIN);
      s.setAttribute('data-displaymode', 'auto');
      document.getElementById('ycbmEmbed').appendChild(s);
      // call_booked feuert auf /ab-40/bestaetigt (YCBM leitet nach Buchung dorthin weiter).
      // Qualifizierungs-Antworten fuer das dortige Event zwischenspeichern.
      try { sessionStorage.setItem('fot_ab40_answers', JSON.stringify(answers)); } catch (e) {}
    }

    document.querySelectorAll('.answer').forEach((btn) => {
      btn.addEventListener('click', () => {
        answers[btn.dataset.q] = btn.dataset.v;
        track('qualify_answer', { question: btn.dataset.q, value: btn.dataset.v });

        // Takeaway: "nur kostenlose Tipps" bekommt keinen Kalender
        if (btn.dataset.q === 'invest' && btn.dataset.v === 'nein') {
          track('qualify_softblock');
          show(90);
          return;
        }
        if (current < TOTAL) {
          current += 1;
          show(current);
        } else {
          track('qualify_complete', answers);
          show(5);
          loadYcbm();
        }
      });
    });
  </script>
</body>
</html>
