        if (window.__lp) {
          window.__lp.track(e, Object.assign({ page: 'longevity' }, d || {}), 'fot', 'Longevity Check');
          if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'FoT Quiz Start', currency: 'EUR' });
          if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'FoT Quiz Complete', currency: 'EUR' });
          if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'FoT Lead', currency: 'EUR' });
        } else if (tries++ < 40) {
          setTimeout(fire, 50);
        }
      }
      fire();
    }
    tk('page_view');

    // Reveal-on-Scroll via IntersectionObserver
    (function reveal(){
      if (!('IntersectionObserver' in window)) {
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el){ el.classList.add('in'); });
        return;
      }
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if (e.isIntersecting) {
            e.target.classList.add('in');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el){ io.observe(el); });
    })();

    function startQuiz() {
      tk('quiz_start');
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0, 0);
    }

    function stepIndex(key) {
      return FLOW.indexOf(key);
    }

    function progressPos(key) {
      // Gate ist Schritt 13 (nach allen 12 Fragen)
      if (key === 'gate') return 12.5;
      if (key === 'ld' || key === 'exit') return 13;
      var n = parseInt(key, 10);
      return isNaN(n) ? 0 : n;
    }

    function setProgress(key) {
      var pos = progressPos(key);
      var p = Math.round((pos / TOTAL) * 100);
      document.getElementById('qf').style.width = p + '%';
      var bar = document.getElementById('qbar');
      if (bar) bar.setAttribute('aria-valuenow', p);
      if (key === 'gate') {
        document.getElementById('qr').textContent = '✓';
        document.getElementById('qp').textContent = 'Letzter Schritt · Auswertung erhalten';
      } else if (!isNaN(parseInt(key, 10))) {
        document.getElementById('qr').textContent = key + '/12';
        document.getElementById('qp').textContent = 'Frage ' + key + ' von 12';
      }
      var left = Math.max(10, Math.round((TOTAL - pos) * 14));
      document.getElementById('qt').textContent = '⏱ ~' + left + ' Sek.';
      document.getElementById('qback').classList.toggle('hidden', qHistory.length <= 1);
    }

    function show(key) {
      document.querySelectorAll('.step').forEach(function(el){ el.classList.remove('on'); });
      var target = document.querySelector('.step[data-s="' + key + '"]');
      if (target) target.classList.add('on');
      setProgress(key);
    }

    function nxt(s, el, val, pts) {
      quizAnswers['q' + s] = el ? (el.querySelector('strong') ? el.querySelector('strong').textContent.trim() : el.textContent.trim()) : '';
      quizAnswers['q' + s + '_val'] = val;
      quizAnswers['q' + s + '_pts'] = pts || 0;

      // F1 Exit: Unter 35
      if (s === 1 && val === 'u35') {
        setTimeout(function(){ show('exit'); }, 200);
        return;
      }

      scoreAccum += (pts || 0);
      tk('quiz_answer', { detail: 'q' + s + '_' + val });
      if (el) el.classList.add('selected');

      setTimeout(function(){
        var currentKey = String(s);
        var idx = stepIndex(currentKey);
        var next = FLOW[idx + 1];
        if (!next) { finalize(); return; }
        qHistory.push(next);
        show(next);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, 180);
    }

    // Multi-Select-Fragen (F9, F11)
    function mtoggle(el) {
      el.classList.toggle('chk-sel');
      var parent = el.parentElement;
      var any = parent.querySelectorAll('.chk-sel').length > 0;
      var subId = parent.id === 'm9' ? 'm9sub' : 'm11sub';
      document.getElementById(subId).disabled = !any;
    }

    function msubmit(s) {
      var parent = document.getElementById('m' + s);
      var selected = Array.from(parent.querySelectorAll('.chk-sel')).map(function(el){ return el.getAttribute('data-v'); });
      quizAnswers['q' + s] = selected.join(',');
      quizAnswers['q' + s + '_val'] = selected;

      if (s === 9) {
        // Familienrisiko: mehr Diagnosen = hoeherer Aufschlag, "nichts" zaehlt nicht
        var risk = selected.filter(function(v){ return v !== 'nichts'; }).length;
        var pts = risk >= 3 ? 12 : risk === 2 ? 9 : risk === 1 ? 5 : 2;
        quizAnswers.q9_pts = pts;
        scoreAccum += pts;
      }

      tk('quiz_answer', { detail: 'q' + s + '_multi' });
      setTimeout(function(){
        var idx = stepIndex(String(s));
        var next = FLOW[idx + 1];
        qHistory.push(next);
        show(next);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }, 180);
    }

    // F12: Freitext
    var goalEl = document.getElementById('goal');
    var goalCnt = document.getElementById('goalCnt');
    var goalSub = document.getElementById('goalSub');
    goalEl.addEventListener('input', function(){
      var len = goalEl.value.trim().length;
      goalCnt.textContent = len;
      goalSub.disabled = len < 10;
    });
    function goalSubmit() {
      var t = goalEl.value.trim();
      if (t.length < 10) return;
      quizAnswers.q12 = t;
      // Score schon hier berechnen + Preview-Card im Gate fuellen (Reward vor Form)
      var preview = computeResult();
      window.__lvPreview = preview;
      renderScorePreview(preview);
      qHistory.push('gate');
      show('gate');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function renderScorePreview(_r) {
      // No-Op: Ergebnis wird vor Optin bewusst NICHT angezeigt. Das eigentliche Ergebnis
      // erscheint erst auf /longevity/ergebnis/. Funktion bleibt aufrufbar, um Call-Sites
      // unverändert zu lassen.
    }

    // Lead-Gate
    document.getElementById('ds').addEventListener('change', function(){
      document.getElementById('gbtn').disabled = !this.checked;
    });

    function normalizePhone(raw) {
      var c = (raw || '').replace(/[^\d+]/g, '');
      if (!c) return '';
      if (c.charAt(0) === '+') return c;
      if (c.charAt(0) === '0') return '+41' + c.slice(1);
      return '+41' + c;
    }
    function gateSubmit() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = normalizePhone(document.getElementById('ph').value);
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      quizAnswers.gate_name = fn;
      quizAnswers.gate_email = em;
      quizAnswers.gate_phone = ph;
      tk('quiz_lead_gate_submitted', { detail: fn });

      // Gate ist letzter Schritt → direkt zur Auswertung
      finalize();
    }

    function back() {
      if (qHistory.length <= 1) return;
      qHistory.pop();
      var prev = qHistory[qHistory.length - 1];
      show(prev);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // SCORING: biologisches Alter, verlorene Jahre, Rueckgewinn, groesster Hebel
    function computeResult() {
      // Echtes Alter aus Q1 ableiten (Mittelwert der Range)
      var ageMap = { 'u35': 32, '35-39': 37, '40-44': 42, '45-49': 47, '50-55': 52, '56+': 58 };
      var realAge = ageMap[quizAnswers.q1_val] || 45;
      // MAX = Summe der maximalen Hebel-Punkte: q2 15 + q3 12 + q4 15 + q5 12 + q6 12 + q7 10 + q8 10 + q9 12
      var MAX = 98;
      var pct = Math.min(1, scoreAccum / MAX);
      var yearsOver = Math.round(pct * 12);                         // bis zu 12 Jahre biologisch drauf
      var bioAge = realAge + yearsOver;
      var lostYears = yearsOver;                                    // gesunde Jahre, die du gerade verlierst
      var regainYears = Math.min(15, Math.max(3, yearsOver + 5));   // Rueckgewinn-Potenzial bei Handeln

      var score = Math.round(pct * 100);
      var stufe = 1, stufeName = 'Jünger als dein Alter';
      if (yearsOver >= 9) { stufe = 4; stufeName = 'Stark beschleunigt'; }
      else if (yearsOver >= 5) { stufe = 3; stufeName = 'Beschleunigt'; }
      else if (yearsOver >= 2) { stufe = 2; stufeName = 'Im Soll'; }

      // Hebel-Dimensionen: hoeherer Prozentsatz = groesserer Hebel
      var dims = {
        energie:     { pts: quizAnswers.q2_pts || 0, max: 15, label: 'Energie' },
        schlaf:      { pts: quizAnswers.q3_pts || 0, max: 12, label: 'Schlaf' },
        muskel:      { pts: quizAnswers.q4_pts || 0, max: 15, label: 'Muskel und Bewegung' },
        ernaehrung:  { pts: quizAnswers.q5_pts || 0, max: 12, label: 'Ernährung' },
        stoffwechsel:{ pts: quizAnswers.q6_pts || 0, max: 12, label: 'Stoffwechsel' },
        kopf:        { pts: quizAnswers.q7_pts || 0, max: 10, label: 'Kopf und Fokus' },
        stress:      { pts: quizAnswers.q8_pts || 0, max: 10, label: 'Stress' },
        risiko:      { pts: quizAnswers.q9_pts || 0, max: 12, label: 'Veranlagung' }
      };
      var critKey = 'energie', critPct = 0;
      Object.keys(dims).forEach(function(k){
        var p = Math.round((dims[k].pts / dims[k].max) * 100);
        dims[k].pct = p;
        if (p > critPct) { critPct = p; critKey = k; }
      });
      return {
        realAge: realAge,
        bioAge: bioAge,
        lostYears: lostYears,
        regainYears: regainYears,
        score: score,
        stufe: stufe,
        stufeName: stufeName,
        critDim: critKey,
        critDimLabel: dims[critKey].label,
        critPct: critPct,
        dims: dims
      };
    }

    function finalize() {
      tk('quiz_complete');
      show('ld');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qback').classList.add('hidden');

      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 500);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1200);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 1900);
      setTimeout(function(){ document.getElementById('c4').classList.add('show'); }, 2600);
      setTimeout(function(){
        var result = computeResult();
        submitLead(result);
      }, 3400);
    }

    function submitLead(result) {
      var payload = {
        name: quizAnswers.gate_name,
        email: quizAnswers.gate_email,
        phone: quizAnswers.gate_phone,
        lp_slug: 'longevity',
        lp_name: 'Longevity-Check v1',
        answers: Object.assign({}, quizAnswers, {
          longevity_real_age: result.realAge,
          longevity_bio_age: result.bioAge,
          longevity_lost_years: result.lostYears,
          longevity_regain_years: result.regainYears,
          longevity_score: result.score,
          longevity_stufe: result.stufe,
          longevity_stufe_name: result.stufeName,
          longevity_crit_dim: result.critDim,
          longevity_crit_dim_label: result.critDimLabel,
          longevity_crit_pct: result.critPct
        })
      };

      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      }).then(function(res){
        if (!res.ok) throw new Error('insert-failed');
        tk('lead_submit', { detail: quizAnswers.gate_name + ' · Bioalter ' + result.bioAge + ' · +' + result.regainYears + ' Jahre' });
        storeResult(result);
        window.location.href = '/longevity/ergebnis/';
      }).catch(function(){
        // Fallback: trotzdem weiterleiten, damit der Nutzer sein Ergebnis sieht
        storeResult(result);
        window.location.href = '/longevity/ergebnis/';
      });
    }

    function storeResult(result) {
      try {
        sessionStorage.setItem('fot_longevity_result', JSON.stringify({
          name: (quizAnswers.gate_name || '').split(' ')[0],
          realAge: result.realAge,
          bioAge: result.bioAge,
          lostYears: result.lostYears,
          regainYears: result.regainYears,
          score: result.score,
          stufe: result.stufe,
          stufeName: result.stufeName,
          critDim: result.critDim,
          critDimLabel: result.critDimLabel,
          critPct: result.critPct,
          phone: quizAnswers.gate_phone,
          ts: Date.now()
        }));
      } catch (e) {}
    }
  </script>

  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <CookieBanner
    metaPixelId="1214902253584066"
    consentKey="fot_longevity_consent"
    impressumUrl={impressumUrl}
    datenschutzUrl={datenschutzUrl}
  />
