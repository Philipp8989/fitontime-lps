    // Live-Counter, organische Drift mit Tageszeit-Awareness (H-004 CRO-Hypothese)
    // Range 7-23, vormittags höher (10-21 Uhr Spitze), nachts niedriger
    (function liveCounter(){
      var el = document.getElementById('liveCnt');
      if (!el) return;
      // Tageszeit-aware Range: morgens 9-13 / vormittags 12-21 / nachmittags 10-19 / abend 8-15 / nacht 7-11
      function rangeForHour(h) {
        if (h >= 9 && h < 12) return [12, 21];   // Vormittag = Peak
        if (h >= 12 && h < 17) return [10, 19];  // Nachmittag = mittel
        if (h >= 17 && h < 21) return [11, 17];  // früher Abend = mittel
        if (h >= 21 || h < 6)  return [7, 11];   // Nacht = low
        return [9, 14];                           // morgens-früh = ramp-up
      }
      var range = rangeForHour(new Date().getHours());
      var n = range[0] + Math.floor(Math.random() * (range[1] - range[0] + 1));
      el.textContent = n;
      function tick(){
        var r = rangeForHour(new Date().getHours());
        var step = Math.random() < 0.5 ? -1 : 1;
        if (Math.random() < 0.25) step *= 2;
        n = Math.max(r[0], Math.min(r[1], n + step));
        el.textContent = n;
        // Cadence ~30s mit jitter (H-004 Spec: alle 30 Sekunden)
        setTimeout(tick, 25000 + Math.floor(Math.random() * 12000));
      }
      setTimeout(tick, 25000 + Math.floor(Math.random() * 12000));
    })();

    // Tracking
    function tk(e, d) {
