---
// Bewerbungs-Funnel "Stoffwechsel-Bewerbung", Schritt 1: VSL + Bewerbung auf einer Seite
// Vorbild: skalierenzurmillion.org Application-Funnel (VSL + Inline-Bewerbung + Scarcity),
// übersetzt auf FoT: Qualifier-Callout, System-Name "Speicher-Schalter", echte Proof-Zahlen,
// Bewerbungs-Framing statt "Termin buchen" (Status-Umkehr: sie bewirbt sich bei uns).
import CookieBanner from '../../components/CookieBanner.astro';

const LP_SLUG = 'stoffwechsel-bewerbung';
const LP_NAME = 'Stoffwechsel Bewerbungs-Funnel';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';

// VSL: eigene Env-Var, fällt auf das Ab-40-VSL zurück (gleiches Video, gleiche Botschaft)
const VSL_EMBED = (import.meta.env.PUBLIC_FOT_BEWERBUNG_VSL_URL || import.meta.env.PUBLIC_FOT_AB40_VSL_URL || '').trim();

// Scarcity-Zahl: mit Fabian abstimmen, muss der echten Aufnahme-Kapazität entsprechen
const SPOTS = 10;
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Bewirb dich auf deinen kostenlosen Stoffwechsel-Check | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Hyros First-Party-Attribution, lädt ohne Consent (analog zu allen FOT-Funnels) -->
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --surface: #f0ebe0;
      --accent: #2b7de9;
      --accent-dark: #1a5bb8;
      --green: #22c55e;
      --amber: #f59e0b;
      --red: #ef4444;
      --text: #1a1a1a;
      --text-2: #4a4a4a;
      --text-3: #888;
      --r: 14px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    .wrap { max-width: 680px; margin: 0 auto; padding: 0 20px; }

    .topbar { background: var(--text); color: #fff; text-align: center; font-size: 12.5px; font-weight: 600; padding: 9px 14px; line-height: 1.4; }
    .topbar b { color: var(--amber); }

    .logo { text-align: center; padding: 16px 0 8px; }
    .logo img { height: 40px; }

    .eyebrow { font-size: 13px; text-transform: uppercase; letter-spacing: 1px; color: var(--red); font-weight: 700; text-align: center; margin: 10px 0 10px; }

    .hero { text-align: center; padding: 4px 0 8px; }
    .hero h1 { font-size: 27px; font-weight: 800; line-height: 1.22; letter-spacing: -0.5px; margin-bottom: 14px; }
    .hero h1 em { font-style: normal; color: var(--accent); }
    .hero .sub { font-size: 16px; color: var(--text-2); margin-bottom: 6px; line-height: 1.5; }
    .hero .sub strong { color: var(--text); font-weight: 700; }

    .mantra { display: flex; justify-content: center; gap: 8px; flex-wrap: wrap; margin: 12px 0 4px; }
    .mantra span { background: #fff; border: 1px solid #e8e4da; border-radius: 999px; padding: 7px 16px; font-size: 13px; font-weight: 700; color: var(--text-2); }

    .video-shell { position: relative; border-radius: var(--r); overflow: hidden; background: #111; aspect-ratio: 16 / 9; box-shadow: 0 10px 34px rgba(0,0,0,0.16); margin: 16px 0 10px; }
    .video-shell iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
    .video-placeholder { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; color: #fff; text-align: center; padding: 20px; }
    .video-placeholder .pp { width: 56px; height: 56px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 22px; }
    .video-placeholder p { font-size: 13px; color: #ddd; max-width: 360px; }

    .proof-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 8px 0 4px; flex-wrap: wrap; }
    .proof-avatars { display: flex; }
    .proof-avatars img { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--bg); margin-left: -10px; object-fit: cover; object-position: center 30%; }
    .proof-avatars img:first-child { margin-left: 0; }
    .proof-info { font-size: 12px; color: var(--text-3); line-height: 1.3; text-align: left; }
    .proof-info b { color: var(--text); }
    .proof-stars { color: var(--amber); font-size: 12px; letter-spacing: 1px; }

    .apply-head { text-align: center; margin: 26px 0 6px; }
    .apply-head h2 { font-size: 22px; font-weight: 800; letter-spacing: -0.3px; line-height: 1.25; margin-bottom: 8px; }
    .apply-head p { font-size: 14px; color: var(--text-2); line-height: 1.55; }
    .scarcity { display: inline-block; background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412; border-radius: 999px; padding: 7px 16px; font-size: 13px; font-weight: 700; margin-top: 10px; }

    .apply-card { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 22px 20px; margin: 14px 0 10px; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }

    .progress { height: 6px; background: #e8e4da; border-radius: 999px; overflow: hidden; margin: 2px 0; }
    .progress-fill { height: 100%; background: var(--accent); border-radius: 999px; transition: width 0.3s ease; width: 20%; }
    .progress-label { font-size: 11px; color: var(--text-3); text-align: right; margin: 4px 2px 14px; }

    .step { display: none; animation: fade 0.25s ease; }
    .step.active { display: block; }
    @keyframes fade { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

    .step h3 { font-size: 17.5px; font-weight: 800; text-align: center; margin-bottom: 16px; line-height: 1.3; }
    .answers { display: flex; flex-direction: column; gap: 10px; }
    .answer { background: #fff; border: 2px solid #e8e4da; border-radius: 12px; padding: 16px 18px; font-size: 15px; font-weight: 600; cursor: pointer; text-align: center; transition: all 0.15s; font-family: var(--font); color: var(--text); -webkit-tap-highlight-color: transparent; }
    .answer:hover { border-color: var(--accent); background: #eef6ff; }
    .answer:active { transform: scale(0.99); }

    form.contact { display: flex; flex-direction: column; gap: 12px; }
    form.contact input { width: 100%; padding: 15px 18px; font: inherit; font-size: 16px; border: 2px solid #e8e4da; border-radius: 12px; background: #fff; color: var(--text); }
    form.contact input:focus { outline: none; border-color: var(--accent); }
    .btn { display: block; width: 100%; background: var(--accent); color: #fff; border: none; border-radius: 999px; padding: 17px 28px; font: inherit; font-size: 17px; font-weight: 700; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 14px rgba(43,125,233,0.3); -webkit-tap-highlight-color: transparent; }
    .btn:hover { background: var(--accent-dark); transform: translateY(-1px); }
    .btn:active { transform: scale(0.98); }
    .btn[disabled] { opacity: 0.6; cursor: wait; transform: none; }
    .privacy-note { font-size: 11px; color: var(--text-3); text-align: center; line-height: 1.45; }
    .privacy-note a { color: var(--text-3); }
    .err { display: none; font-size: 13px; color: var(--red); text-align: center; font-weight: 600; }
    .err.show { display: block; }

    .softblock { text-align: center; padding: 10px 0; }
    .softblock .sb-emoji { font-size: 40px; display: block; margin-bottom: 8px; }
    .softblock h3 { font-size: 19px; font-weight: 800; margin-bottom: 8px; }
    .softblock p { font-size: 14px; color: var(--text-2); line-height: 1.6; margin-bottom: 14px; }
    .softblock a { color: var(--accent); font-weight: 700; }

    .trans { margin: 26px 0 8px; }
    .trans-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 4px; }
    .trans-sub { font-size: 13px; color: var(--text-3); text-align: center; margin-bottom: 14px; }
    .trans-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .trans-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; background: #fff; }
    .trans-cap { font-size: 11px; color: var(--text-3); text-align: center; margin-top: 8px; }

    .stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin: 18px 0; }
    .stat { background: #fff; border: 1px solid #e8e4da; border-radius: 12px; padding: 14px 6px; text-align: center; }
    .stat .stat-num { font-size: 24px; font-weight: 800; color: var(--accent); letter-spacing: -0.5px; line-height: 1; }
    .stat .stat-label { font-size: 10px; color: var(--text-3); margin-top: 5px; text-transform: uppercase; letter-spacing: 0.3px; font-weight: 600; }

    .cta-repeat { text-align: center; margin: 8px 0 26px; }
    .cta-repeat a { display: inline-block; background: var(--accent); color: #fff; text-decoration: none; border-radius: 999px; padding: 16px 34px; font-size: 16px; font-weight: 700; box-shadow: 0 4px 14px rgba(43,125,233,0.3); }

    footer { padding: 26px 16px 22px; text-align: center; color: var(--text-3); font-size: 11.5px; line-height: 1.6; }
    footer a { color: var(--text-3); }
    .disclaimer { max-width: 640px; margin: 0 auto 10px; font-size: 10.5px; color: #aaa; }

    @media (max-width: 480px) {
      .hero h1 { font-size: 23px; }
      .apply-head h2 { font-size: 19px; }
    }
  </style>
</head>
<body>
  <div class="topbar">Fabians Team nimmt diesen Monat nur <b>{SPOTS} neue Frauen</b> in die persönliche 1:1-Betreuung auf.</div>

  <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

  <main class="wrap">
    <p class="eyebrow">Für Frauen ab 40, die schon alles probiert haben:</p>

    <section class="hero">
      <h1>Gemeinsam legen wir deinen <em>„Speicher-Schalter"</em> wieder um: mit dem System, mit dem über 4.000 Frauen abgenommen haben</h1>
      <p class="sub"><strong>Ohne Diät, ohne Spritze, ohne Verzicht.</strong> Schau dir das kurze Video an und bewirb dich danach auf deinen kostenlosen Stoffwechsel-Check.</p>
      <div class="mantra">
        <span>Ein Plan.</span>
        <span>Eine Betreuung.</span>
        <span>Ein Ziel.</span>
      </div>
    </section>

    <div class="video-shell">
      {VSL_EMBED ? (
        <iframe src={VSL_EMBED} allow="autoplay; fullscreen" allowfullscreen title="Der Speicher-Schalter"></iframe>
      ) : (
        <div class="video-placeholder">
          <div class="pp">▶</div>
          <p><strong>Hier erscheint Fabians Video</strong><br />„Der Speicher-Schalter: Warum ab 40 nichts mehr wirkt" (ca. 12 Minuten)</p>
        </div>
      )}
    </div>

    <div class="proof-bar">
      <div class="proof-avatars">
        <img src="/images/transformations/t1.jpg" alt="" /><img src="/images/transformations/t2.jpg" alt="" /><img src="/images/transformations/t3.jpg" alt="" /><img src="/images/transformations/t4.jpg" alt="" />
      </div>
      <div class="proof-info"><span class="proof-stars">★★★★★</span><br /><b>4.000+ Frauen</b> in der Schweiz &amp; D-A-CH</div>
    </div>

    <section class="apply-head" id="bewerbung">
      <h2>Bewirb dich jetzt auf deinen kostenlosen Stoffwechsel-Check</h2>
      <p>Fülle die kurze Bewerbung aus (dauert keine 2 Minuten). Kostenlos und unverbindlich. Beantworte die Fragen kurz und ehrlich, damit sich Fabians Team optimal auf dein Gespräch vorbereiten kann.</p>
      <span class="scarcity">Nur {SPOTS} Plätze diesen Monat</span>
    </section>

    <div class="apply-card">
      <div class="progress" id="progress"><div class="progress-fill" id="progressFill"></div></div>
      <p class="progress-label" id="progressLabel">Frage 1 von 4</p>

      <!-- Frage 1 -->
      <div class="step active" data-step="1">
        <h3>Was beschreibt deine Situation am besten?</h3>
        <div class="answers">
          <button class="answer" data-q="situation" data-v="alles-probiert">Ich habe schon mehrere Diäten oder Programme probiert, ohne dauerhaften Erfolg</button>
          <button class="answer" data-q="situation" data-v="wechseljahre">Seit den Wechseljahren nehme ich zu, obwohl ich nichts verändert habe</button>
          <button class="answer" data-q="situation" data-v="erste-schritte">Ich fange gerade erst an, mich mit dem Thema zu beschäftigen</button>
        </div>
      </div>

      <!-- Frage 2 -->
      <div class="step" data-step="2">
        <h3>Wie viel möchtest du abnehmen?</h3>
        <div class="answers">
          <button class="answer" data-q="ziel" data-v="unter-5">Unter 5 kg</button>
          <button class="answer" data-q="ziel" data-v="5-10">5 bis 10 kg</button>
          <button class="answer" data-q="ziel" data-v="10-15">10 bis 15 kg</button>
          <button class="answer" data-q="ziel" data-v="ueber-15">Mehr als 15 kg</button>
        </div>
      </div>

      <!-- Frage 3 -->
      <div class="step" data-step="3">
        <h3>Professionelle 1:1-Begleitung ist eine Investition in dich. Bist du grundsätzlich bereit, in deine Gesundheit zu investieren, wenn es für dich passt?</h3>
        <div class="answers">
          <button class="answer" data-q="invest" data-v="ja">Ja, wenn mich der Weg überzeugt</button>
          <button class="answer" data-q="invest" data-v="unsicher">Ich bin unsicher, möchte es aber verstehen</button>
          <button class="answer" data-q="invest" data-v="nein">Nein, ich suche nur kostenlose Tipps</button>
        </div>
      </div>

      <!-- Frage 4 -->
      <div class="step" data-step="4">
        <h3>Entscheidest du selbst über solche Themen?</h3>
        <div class="answers">
          <button class="answer" data-q="entscheidung" data-v="ja">Ja, das entscheide ich selbst</button>
          <button class="answer" data-q="entscheidung" data-v="mit-partner">Ich bespreche es mit meinem Partner</button>
        </div>
      </div>

      <!-- Schritt 5: Kontaktdaten -->
      <div class="step" data-step="5">
        <h3>Fast geschafft: Wohin dürfen wir deine Bestätigung schicken?</h3>
        <form class="contact" id="applyForm" novalidate>
          <input type="text" name="fname" placeholder="Dein Vorname" autocomplete="given-name" required />
          <input type="email" name="email" placeholder="Deine E-Mail-Adresse" autocomplete="email" required />
          <input type="tel" name="phone" placeholder="Deine Handynummer (optional)" autocomplete="tel" />
          <button class="btn" id="submitBtn" type="submit">Bewerbung absenden →</button>
          <p class="err" id="formErr">Bitte Vorname und eine gültige E-Mail-Adresse eintragen.</p>
          <p class="privacy-note">100% kostenlos. Kein Spam. Mit dem Absenden akzeptierst du die <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutzerklärung</a>.</p>
        </form>
      </div>

      <!-- Soft-Block für "nur kostenlose Tipps" -->
      <div class="step" data-step="90">
        <div class="softblock">
          <span class="sb-emoji">💛</span>
          <h3>Danke für deine Ehrlichkeit</h3>
          <p>Der Stoffwechsel-Check ist für Frauen gedacht, die bereit sind, ihre Situation wirklich anzugehen. Die Plätze sind begrenzt.<br /><br />Schau dir in der Zwischenzeit gern unsere kostenlosen Inhalte an. Und wenn der Zeitpunkt für dich gekommen ist, bist du herzlich willkommen.</p>
          <a href="https://fit-on-time.ch" target="_blank" rel="noopener">Zu den kostenlosen Inhalten von Fit on Time →</a>
        </div>
      </div>
    </div>

    <section class="trans">
      <p class="trans-title">Echte Frauen. Echte Ergebnisse.</p>
      <p class="trans-sub">Ein kleiner Ausschnitt aus über 4.000 Erfolgsgeschichten</p>
      <div class="trans-grid">
        <img src="/images/transformations/t5.jpg" alt="Transformation" loading="lazy" />
        <img src="/images/transformations/t6.jpg" alt="Transformation" loading="lazy" />
        <img src="/images/transformations/t7.jpg" alt="Transformation" loading="lazy" />
      </div>
      <p class="trans-cap">Individuelle Ergebnisse. Resultate hängen von persönlichen Voraussetzungen ab.</p>
    </section>

    <div class="stats">
      <div class="stat"><div class="stat-num">4.000+</div><div class="stat-label">Frauen begleitet</div></div>
      <div class="stat"><div class="stat-num">97%</div><div class="stat-label">erreichen ihr Ziel</div></div>
      <div class="stat"><div class="stat-num">94%</div><div class="stat-label">halten es nach 12 Mo.</div></div>
    </div>

    <div class="cta-repeat"><a href="#bewerbung">Jetzt Bewerbung ausfüllen →</a></div>
  </main>

  <footer>
    <p class="disclaimer">Dieses Angebot richtet sich an gesunde Erwachsene. Die gezeigten Ergebnisse sind individuelle Erfahrungen und keine Erfolgsgarantie. Kein Ersatz für ärztliche Beratung. Diese Website ist kein Teil der Facebook-Website oder von Meta Platforms Inc. und wird in keiner Weise von Meta unterstützt.</p>
    <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Impressum</a> · <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutz</a>
  </footer>

  <CookieBanner
    metaPixelId={PIXEL_ID}
    hyrosPh={HYROS_ID}
    impressumUrl={IMPRESSUM_URL}
    datenschutzUrl={DATENSCHUTZ_URL}
    consentKey="fot_consent"
  />

  <script is:inline define:vars={{ LP_SLUG, LP_NAME }}>
    const SESSION_KEY = 'fot_session';
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }

    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({ event, lp: LP_SLUG, lp_name: LP_NAME, session }, extra || {}));
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
          return;
        }
      } catch (e) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }

    track('page_view', { page: 'bewerbung' });

    const answers = {};
    let current = 1;
    const TOTAL = 4;

    function show(step) {
      document.querySelectorAll('.step').forEach((s) => s.classList.toggle('active', Number(s.dataset.step) === step));
      const isQuestion = step >= 1 && step <= TOTAL;
      document.getElementById('progress').hidden = !isQuestion && step !== 5;
      document.getElementById('progressLabel').hidden = !isQuestion && step !== 5;
      if (isQuestion) {
        document.getElementById('progressFill').style.width = Math.round((step / (TOTAL + 1)) * 100) + '%';
        document.getElementById('progressLabel').textContent = 'Frage ' + step + ' von ' + TOTAL;
      } else if (step === 5) {
        document.getElementById('progressFill').style.width = '95%';
        document.getElementById('progressLabel').textContent = 'Letzter Schritt';
      }
      document.getElementById('bewerbung').scrollIntoView({ behavior: 'instant', block: 'start' });
    }

    document.querySelectorAll('.answer').forEach((btn) => {
      btn.addEventListener('click', () => {
        answers[btn.dataset.q] = btn.dataset.v;
        track('qualify_answer', { question: btn.dataset.q, value: btn.dataset.v });

        // Takeaway: "nur kostenlose Tipps" bekommt kein Kontaktformular
        if (btn.dataset.q === 'invest' && btn.dataset.v === 'nein') {
          track('qualify_softblock');
          show(90);
          return;
        }
        if (current < TOTAL) {
          current += 1;
          show(current);
        } else {
          track('qualify_complete', answers);
          show(5);
        }
      });
    });

    // Feld-Fortschritt ohne PII: welche Felder ausgefüllt wurden, nicht deren Inhalt
    document.querySelectorAll('#applyForm input').forEach((el) => {
      el.addEventListener('blur', () => {
        if (el.value.trim()) track('field_filled', { field: el.name });
      }, { once: true });
    });

    const form = document.getElementById('applyForm');
    const btn = document.getElementById('submitBtn');
    const err = document.getElementById('formErr');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      err.classList.remove('show');
      const fd = new FormData(form);
      const name = (fd.get('fname') || '').toString().trim();
      const email = (fd.get('email') || '').toString().trim();
      const phone = (fd.get('phone') || '').toString().trim();
      if (!name || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        err.classList.add('show');
        return;
      }
      btn.disabled = true;
      btn.textContent = 'Einen Moment …';
      try {
        const res = await fetch('/api/sheets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone, lp_slug: LP_SLUG, lp_name: LP_NAME, session, answers }),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'Fehler beim Senden');
        }
        track('lead_submit', answers);
        if (window.__lp) window.__lp.meta('Lead', { content_name: 'FoT Bewerbung Lead', currency: 'CHF' });
        // Name/E-Mail für Calendly-Prefill auf der Terminseite merken
        sessionStorage.setItem('fot_bewerbung_lead', JSON.stringify({ name: name.split(' ')[0], email }));
        window.location.href = '/stoffwechsel-bewerbung/termin';
      } catch (ex) {
        btn.disabled = false;
        btn.textContent = 'Bewerbung absenden →';
        err.textContent = 'Das hat leider nicht geklappt. Bitte versuch es nochmal.';
        err.classList.add('show');
      }
    });
  </script>
</body>
</html>
