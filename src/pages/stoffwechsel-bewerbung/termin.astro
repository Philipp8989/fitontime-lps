---
// Bewerbungs-Funnel, Schritt 2: Terminwahl (Calendly)
// Die Qualifizierung ist schon in der Bewerbung passiert, hier nur noch Kalender.
import CookieBanner from '../../components/CookieBanner.astro';

const LP_SLUG = 'stoffwechsel-bewerbung';
const LP_NAME = 'Stoffwechsel Bewerbungs-Funnel';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const CALENDAR_URL = (import.meta.env.PUBLIC_FOT_CALENDAR_URL || 'https://calendly.com/fitontime/abnehm-strategie').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Bewerbung eingegangen: Such dir deinen Termin aus | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --accent: #2b7de9;
      --green: #22c55e;
      --text: #1a1a1a;
      --text-2: #4a4a4a;
      --text-3: #888;
      --r: 14px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }
    .wrap { max-width: 680px; margin: 0 auto; padding: 0 20px; }

    .logo { text-align: center; padding: 16px 0 8px; }
    .logo img { height: 40px; }

    .hero { text-align: center; padding: 4px 0 14px; }
    .hero .badge { display: inline-flex; align-items: center; gap: 7px; background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; border-radius: 999px; padding: 7px 16px; font-size: 13px; font-weight: 700; margin-bottom: 12px; }
    .hero h1 { font-size: 24px; font-weight: 800; line-height: 1.25; letter-spacing: -0.4px; margin-bottom: 8px; }
    .hero h1 em { font-style: normal; color: var(--accent); }
    .hero .sub { font-size: 14.5px; color: var(--text-2); }

    .cal-note { font-size: 12px; color: var(--text-3); text-align: center; margin-top: 4px; }
    #calendlyEmbed { min-height: 760px; }

    footer { padding: 26px 16px 22px; text-align: center; color: var(--text-3); font-size: 11.5px; }
    footer a { color: var(--text-3); }

    @media (max-width: 480px) { .hero h1 { font-size: 21px; } }
  </style>
</head>
<body>
  <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

  <main class="wrap">
    <section class="hero">
      <span class="badge">✓ Deine Bewerbung ist eingegangen</span>
      <h1>Letzter Schritt: <em>Such dir deinen Wunschtermin aus</em></h1>
      <p class="sub">Der Stoffwechsel-Check dauert ca. 30 Minuten und findet per Telefon oder Zoom statt.</p>
    </section>

    <div id="calendlyEmbed"></div>
    <p class="cal-note">Der Kalender kann einen Moment zum Laden brauchen.</p>
  </main>

  <footer>
    <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Impressum</a> · <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutz</a>
  </footer>

  <CookieBanner
    metaPixelId={PIXEL_ID}
    hyrosPh={HYROS_ID}
    impressumUrl={IMPRESSUM_URL}
    datenschutzUrl={DATENSCHUTZ_URL}
    consentKey="fot_consent"
  />

  <script is:inline define:vars={{ LP_SLUG, LP_NAME, CALENDAR_URL }}>
    const SESSION_KEY = 'fot_session';
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }
    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({ event, lp: LP_SLUG, lp_name: LP_NAME, session }, extra || {}));
      try {
        if (navigator.sendBeacon) { navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' })); return; }
      } catch (e) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }

    track('page_view', { page: 'termin' });

    // Calendly-Inline-Widget mit Prefill aus der Bewerbung
    let prefill = '';
    try {
      const lead = JSON.parse(sessionStorage.getItem('fot_bewerbung_lead') || 'null');
      if (lead) {
        const params = new URLSearchParams();
        if (lead.name) params.set('name', lead.name);
        if (lead.email) params.set('email', lead.email);
        params.set('utm_source', 'stoffwechsel-bewerbung');
        prefill = '?' + params.toString();
      }
    } catch (e) {}
    const s = document.createElement('script');
    s.src = 'https://assets.calendly.com/assets/external/widget.js';
    s.async = true;
    document.head.appendChild(s);
    const div = document.getElementById('calendlyEmbed');
    div.className = 'calendly-inline-widget';
    div.dataset.url = CALENDAR_URL + prefill;
    div.style.minWidth = '300px';
    div.style.height = '760px';

    // Booking-Event von Calendly abfangen → Tracking + Weiterleitung auf Bestätigungsseite
    window.addEventListener('message', (e) => {
      if (e.origin.indexOf('calendly.com') === -1) return;
      const type = e.data && e.data.event;
      if (type === 'calendly.event_scheduled') {
        track('call_booked');
        if (window.__lp) window.__lp.meta('Schedule', { content_name: 'FoT Bewerbung Call' });
        setTimeout(() => { window.location.href = '/stoffwechsel-bewerbung/bestaetigt'; }, 1500);
      }
    });
  </script>
</body>
</html>
