---
// Abnehmpotential-Quiz, Nachbau des Funnelcockpit-Funnels "blockadenloeser"
// Single-Page-SPA, alle Steps client-side, schnelle Ladezeit fuer Paid Traffic
import CookieBanner from '../../components/CookieBanner.astro';

const LP_SLUG = 'abnehmpotential';
const LP_NAME = 'Abnehmpotential Quiz';
// trim() entfernt versehentliche Newlines aus Vercel-Env-Werten
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const CALENDAR_URL = (import.meta.env.PUBLIC_FOT_CALENDAR_URL || 'https://calendly.com/fitontime/abnehm-strategie').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Wie hoch ist dein Abnehmpotential? | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Meta Pixel laeuft DSGVO-konform ueber CookieBanner.astro nach Consent -->
  <!-- Hyros als First-Party-Attribution essentiell, laedt ohne Consent (analog zu allen FOT-Funnels) -->
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>


  <style is:global>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#ffffff;
      --surface:#f8f9fb;
      --border:#e5e7eb;
      --text:#1f2937;
      --text-2:#6b7280;
      --text-3:#9ca3af;
      --accent:#0ea5e9;
      --accent-dark:#0284c7;
      --green:#10b981;
      --r:14px;
      --font:'Inter',system-ui,-apple-system,sans-serif;
    }
    html{-webkit-text-size-adjust:100%}
    body{font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.5;-webkit-font-smoothing:antialiased;min-height:100dvh;display:flex;flex-direction:column}
    main{flex:1;display:flex;flex-direction:column;align-items:center;padding:0 16px}
    .wrap{width:100%;max-width:560px;margin:0 auto}

    header{padding:18px 0 8px;text-align:center}
    header img{height:40px}

    .step{display:none;animation:fade .25s ease}
    .step.active{display:block}
    @keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

    h1{font-size:26px;font-weight:800;letter-spacing:-.4px;line-height:1.2;text-align:center;margin:24px 0 12px}
    h2{font-size:22px;font-weight:700;line-height:1.3;text-align:center;margin:20px 0 16px}
    p.lead{color:var(--text-2);font-size:15px;text-align:center;margin-bottom:8px}
    p.note{color:var(--text-3);font-size:12px;text-align:center;margin-top:6px;font-style:italic}
    .center{text-align:center}

    .btn{display:inline-block;background:var(--accent);color:#fff;border:0;border-radius:999px;padding:16px 32px;font:inherit;font-weight:700;font-size:17px;cursor:pointer;width:100%;transition:background .15s,transform .1s;-webkit-tap-highlight-color:transparent}
    .btn:hover{background:var(--accent-dark)}
    .btn:active{transform:scale(.98)}
    .btn-secondary{background:#fff;color:var(--accent);border:2px solid var(--accent)}

    .answers{display:flex;flex-direction:column;gap:12px;margin:20px 0}
    .answer{background:#fff;border:2px solid var(--border);border-radius:var(--r);padding:18px 20px;font-size:16px;font-weight:600;cursor:pointer;text-align:center;transition:all .15s;-webkit-tap-highlight-color:transparent}
    .answer:hover,.answer:focus-visible{border-color:var(--accent);background:#f0f9ff;outline:none}
    .answer:active{transform:scale(.99)}

    .slider-wrap{margin:32px 0 20px}
    .slider-value{font-size:48px;font-weight:800;text-align:center;color:var(--accent);line-height:1;margin-bottom:6px}
    .slider-unit{font-size:14px;color:var(--text-2);text-align:center;margin-bottom:24px}
    .slider{width:100%;-webkit-appearance:none;appearance:none;height:8px;border-radius:999px;background:linear-gradient(to right,var(--accent) 0%,var(--accent) 50%,var(--border) 50%);outline:none}
    .slider::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:28px;height:28px;border-radius:50%;background:#fff;border:3px solid var(--accent);cursor:pointer;box-shadow:0 2px 6px rgba(0,0,0,.15)}
    .slider::-moz-range-thumb{width:28px;height:28px;border-radius:50%;background:#fff;border:3px solid var(--accent);cursor:pointer;box-shadow:0 2px 6px rgba(0,0,0,.15)}
    .slider-range{display:flex;justify-content:space-between;color:var(--text-3);font-size:13px;margin-top:8px}

    form.optin{display:flex;flex-direction:column;gap:12px;margin:20px 0}
    form.optin label{display:flex;align-items:center;gap:10px;font-size:13px;color:var(--text-2);padding:6px 4px}
    form.optin input[type=text],form.optin input[type=email],form.optin input[type=tel]{width:100%;padding:14px 18px;font:inherit;font-size:16px;border:2px solid var(--border);border-radius:var(--r);background:#fff;color:var(--text)}
    form.optin input:focus{outline:none;border-color:var(--accent)}
    form.optin input[type=checkbox]{width:18px;height:18px;accent-color:var(--accent)}

    .progress{height:6px;background:var(--border);border-radius:999px;overflow:hidden;margin:8px 0 4px}
    .progress-fill{height:100%;background:var(--accent);border-radius:999px;transition:width .3s ease;width:0%}
    .progress-label{font-size:11px;color:var(--text-3);text-align:right;margin-bottom:18px}

    .trust{display:flex;flex-direction:column;gap:6px;margin:18px 0;color:var(--text-2);font-size:14px;text-align:center}
    .trust strong{color:var(--text);font-weight:700}

    .loader{margin:60px auto;width:48px;height:48px;border:4px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite}
    @keyframes spin{to{transform:rotate(360deg)}}

    .result-hero{text-align:center;padding:24px 0 8px}
    .result-hero .label{font-size:14px;color:var(--text-2);text-transform:uppercase;letter-spacing:1px}
    .result-hero .big{font-size:54px;font-weight:800;color:var(--accent);line-height:1;margin:8px 0}
    .result-hero .target{font-size:16px;color:var(--text-2);margin-top:4px}
    .result-hero .name{font-size:18px;font-weight:600;margin-top:18px}

    .alert{background:#fef3c7;border-left:4px solid #f59e0b;border-radius:8px;padding:12px 14px;margin:16px 0;font-size:14px;color:#78350f}
    .alert strong{display:block;margin-bottom:4px}

    .features{margin:24px 0;display:flex;flex-direction:column;gap:10px}
    .feature{padding:12px 14px;background:var(--surface);border-radius:10px;font-size:14px;display:flex;gap:8px;align-items:flex-start}

    .testimonial{background:var(--surface);border-radius:var(--r);padding:18px;margin:20px 0;font-style:italic;color:var(--text);font-size:14px;line-height:1.6}
    .testimonial cite{display:block;margin-top:8px;font-style:normal;color:var(--text-2);font-size:13px}

    /* Vorher/Nachher-Galerie */
    .ba-section{margin:32px 0 16px}
    .ba-title{font-size:18px;font-weight:700;text-align:center;margin-bottom:6px}
    .ba-sub{font-size:13px;color:var(--text-2);text-align:center;margin-bottom:18px}
    .ba-grid{display:flex;flex-direction:column;gap:14px}
    .ba-grid img{width:100%;height:auto;border-radius:var(--r);box-shadow:0 4px 14px rgba(0,0,0,.08);display:block}

    footer{padding:32px 16px 24px;text-align:center;color:var(--text-3);font-size:12px}
    footer a{color:var(--text-3);margin:0 6px;text-decoration:underline}

    .err{color:#b91c1c;font-size:13px;text-align:center;margin-top:6px;min-height:18px}

    /* Silhouette: dick (Hintergrund, hellgrau) + duenn (im Vordergrund, blau, animiert)
       Beides exakt gleiche Hoehe und vertikal zentriert -> visuelle "Schrumpfung" */
    .sil{position:relative;width:160px;height:240px;margin:20px auto 8px}
    .sil svg{position:absolute;inset:0;width:100%;height:100%;display:block}
    .sil .thick path{fill:#e5e7eb}
    .sil .slim path{fill:var(--accent);filter:drop-shadow(0 6px 14px rgba(14,165,233,.35))}
    .sil .slim{animation:silShrink 3.2s ease-in-out infinite}
    @keyframes silShrink{
      0%,100%{transform:scaleX(1)}
      50%{transform:scaleX(.85)}
    }
    .sil-label{font-size:11px;color:var(--text-3);text-align:center;margin-top:-6px;margin-bottom:14px;letter-spacing:.5px;text-transform:uppercase;font-weight:600}

    .silhouette-loader{margin:18px auto 0;display:flex;justify-content:center}
    .silhouette-loader svg{width:90px;height:auto;opacity:.85;animation:pulse 1.6s ease-in-out infinite}
    @keyframes pulse{0%,100%{transform:scale(1);opacity:.85}50%{transform:scale(1.05);opacity:1}}
  </style>
</head>
<body>
  <header><img src="/images/logo.png" alt="Fit on Time" /></header>

  <main>
    <div class="wrap">
      <div class="progress" id="progress" hidden><div class="progress-fill" id="progressFill"></div></div>
      <div class="progress-label" id="progressLabel" hidden></div>

      <!-- Step 0: Startseite -->
      <section class="step active" data-step="0">
        <h1>Wie hoch ist dein Abnehmpotential in den nächsten 4 Monaten?</h1>
        <p class="lead">Finde in 2 Minuten heraus, wie viele Kilos du gesund verlieren kannst und was dich gerade blockiert.</p>
        <div class="sil" aria-hidden="true">
          <svg class="thick" viewBox="0 0 100 240" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
            <path d="M50 4 C62 4 66 14 66 22 C66 31 60 36 54 37 C56 39 56 41 56 43 C70 45 80 54 82 70 C84 86 80 100 78 110 C82 124 84 140 80 158 C76 178 70 200 66 222 C66 230 64 234 60 234 L40 234 C36 234 34 230 34 222 C30 200 24 178 20 158 C16 140 18 124 22 110 C20 100 16 86 18 70 C20 54 30 45 44 43 C44 41 44 39 46 37 C40 36 34 31 34 22 C34 14 38 4 50 4 Z" />
          </svg>
          <svg class="slim" viewBox="0 0 100 240" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
            <path d="M50 4 C58 4 62 12 62 20 C62 28 58 34 54 35 C55 37 55 39 55 41 C64 43 70 50 71 64 C72 78 70 90 68 100 C70 112 71 126 68 142 C66 162 62 184 60 220 C60 228 58 234 56 234 L44 234 C42 234 40 228 40 220 C38 184 34 162 32 142 C29 126 30 112 32 100 C30 90 28 78 29 64 C30 50 36 43 45 41 C45 39 45 37 46 35 C42 34 38 28 38 20 C38 12 42 4 50 4 Z" />
          </svg>
        </div>
        <div class="sil-label">Dein Potenzial</div>
        <div style="margin:28px 0">
          <button class="btn" type="button" onclick="next()">Jetzt starten</button>
        </div>
        <div class="trust">
          <div><strong>Über 3.400 Frauen</strong> haben ihren Plan bereits erhalten</div>
          <div>✓ Von Ernährungsexperten entwickelt</div>
        </div>
        <p class="note">*Alle Zahlen beziehen sich auf gesundes Abnehmen ohne Jojo-Effekt</p>
      </section>

      <!-- Step 1: Auslastung -->
      <section class="step" data-step="1">
        <h2>Bist du beruflich sehr ausgelastet?</h2>
        <div class="answers">
          <button class="answer" type="button" onclick="answer('auslastung','ja')">Ja</button>
          <button class="answer" type="button" onclick="answer('auslastung','nein')">Nein</button>
        </div>
      </section>

      <!-- Step 2: Prioritaet -->
      <section class="step" data-step="2">
        <h2>Was davon ist dir am wichtigsten?</h2>
        <div class="answers">
          <button class="answer" type="button" onclick="answer('prioritaet','aussehen')">Besseres Aussehen</button>
          <button class="answer" type="button" onclick="answer('prioritaet','gesundheit')">Mehr Gesundheit</button>
          <button class="answer" type="button" onclick="answer('prioritaet','wohlbefinden')">Mehr Wohlbefinden</button>
          <button class="answer" type="button" onclick="answer('prioritaet','nachhaltig')">Nachhaltig abnehmen</button>
        </div>
      </section>

      <!-- Step 3: Groesse -->
      <section class="step" data-step="3">
        <h2>Deine Körpergröße</h2>
        <div class="slider-wrap">
          <div class="slider-value"><span id="valGroesse">165</span></div>
          <div class="slider-unit">Zentimeter</div>
          <input type="range" class="slider" id="sliderGroesse" min="145" max="195" value="165" />
          <div class="slider-range"><span>145 cm</span><span>195 cm</span></div>
        </div>
        <button class="btn" type="button" onclick="answer('groesse', document.getElementById('sliderGroesse').value)">Weiter</button>
      </section>

      <!-- Step 4: Gewicht -->
      <section class="step" data-step="4">
        <h2>Dein aktuelles Gewicht</h2>
        <div class="slider-wrap">
          <div class="slider-value"><span id="valGewicht">75</span></div>
          <div class="slider-unit">Kilogramm</div>
          <input type="range" class="slider" id="sliderGewicht" min="45" max="150" value="75" />
          <div class="slider-range"><span>45 kg</span><span>150 kg</span></div>
        </div>
        <button class="btn" type="button" onclick="answer('gewicht', document.getElementById('sliderGewicht').value)">Weiter</button>
      </section>

      <!-- Step 5: Alter -->
      <section class="step" data-step="5">
        <h2>Wie alt bist du?</h2>
        <div class="slider-wrap">
          <div class="slider-value"><span id="valAlter">32</span></div>
          <div class="slider-unit">Jahre</div>
          <input type="range" class="slider" id="sliderAlter" min="18" max="65" value="32" />
          <div class="slider-range"><span>18</span><span>65</span></div>
        </div>
        <button class="btn" type="button" onclick="answer('alter', document.getElementById('sliderAlter').value)">Weiter</button>
      </section>

      <!-- Step 6: Trigger -->
      <section class="step" data-step="6">
        <h2>Was triggert dich am meisten? Was konsumierst du bei Heißhunger?</h2>
        <div class="answers">
          <button class="answer" type="button" onclick="answer('trigger','salzig')">Salziges Essen</button>
          <button class="answer" type="button" onclick="answer('trigger','fettig')">Hauptsache fettig</button>
          <button class="answer" type="button" onclick="answer('trigger','suess')">Süßes</button>
          <button class="answer" type="button" onclick="answer('trigger','egal')">Ist mir egal</button>
        </div>
      </section>

      <!-- Step 7: Koerperfett -->
      <section class="step" data-step="7">
        <h2>Was beschreibt dich am besten?</h2>
        <div class="answers">
          <button class="answer" type="button" onclick="answer('koerperfett','ganzkoerper')">Mein Körperfett ist hoch und verteilt sich über den ganzen Körper. Ich bin eher unzufrieden mit meiner Figur.</button>
          <button class="answer" type="button" onclick="answer('koerperfett','huefte')">Mein Körperfett befindet sich an Hüften, Oberschenkeln und am Gesäßbereich.</button>
          <button class="answer" type="button" onclick="answer('koerperfett','schlank')">Mein Körperfett ist gleichmäßig verteilt. Ich habe eine relativ schlanke Figur.</button>
        </div>
      </section>

      <!-- Step 8: Loading -->
      <section class="step" data-step="8">
        <h2>Antworten werden überprüft</h2>
        <p class="lead">Dein Ergebnis wird generiert</p>
        <div class="silhouette-loader">
          <svg viewBox="0 0 100 220" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path fill="#0ea5e9" d="M50 8c-7 0-12 5-12 12s5 12 12 12 12-5 12-12S57 8 50 8zm-9 32c-5 1-9 5-10 11l-5 28c-1 4 2 7 6 7h2l-3 28c-.5 4 2 7 5 7l4 50c0 4 3 7 7 7h6c4 0 7-3 7-7l4-50c3 0 5-3 5-7l-3-28h2c4 0 7-3 6-7l-5-28c-1-6-5-10-10-11-3 1-6 2-9 2s-6-1-9-2z" />
          </svg>
        </div>
        <div class="loader"></div>
      </section>

      <!-- Step 9: Optin -->
      <section class="step" data-step="9">
        <h2>Geschafft! 🎉</h2>
        <p class="lead">Dein Abnehmpotential wurde berechnet. Trag deine Daten ein und du erhältst kostenlos dein Ergebnis und deine persönliche Strategie.</p>
        <form class="optin" id="optinForm" onsubmit="submitLead(event)">
          <input type="text" name="fname" placeholder="Dein Vor- und Nachname" required autocomplete="name" />
          <input type="email" name="email" placeholder="Deine E-Mail" required autocomplete="email" />
          <input type="tel" name="phone" placeholder="Deine Telefonnummer" required autocomplete="tel" />
          <label>
            <input type="checkbox" name="datenschutz" required />
            <span>Ich akzeptiere die <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener" style="color:var(--accent)">Datenschutzbestimmungen</a></span>
          </label>
          <button class="btn" type="submit" id="submitBtn">Jetzt Ergebnis erfahren ✨</button>
          <div class="err" id="optinErr"></div>
        </form>
      </section>

      <!-- Step 10: Ergebnis -->
      <section class="step" data-step="10">
        <div class="result-hero">
          <div class="label">Dein Potenzial</div>
          <div class="big">−<span id="resPotenzial">0</span> kg</div>
          <div class="target">in 4 Monaten — Zielgewicht: <strong><span id="resZiel">0</span> kg</strong></div>
          <div class="name"><span id="resName">Du</span>, du hast es fast geschafft!</div>
        </div>

        <div class="sil" aria-hidden="true">
          <svg class="thick" viewBox="0 0 100 240" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
            <path d="M50 4 C62 4 66 14 66 22 C66 31 60 36 54 37 C56 39 56 41 56 43 C70 45 80 54 82 70 C84 86 80 100 78 110 C82 124 84 140 80 158 C76 178 70 200 66 222 C66 230 64 234 60 234 L40 234 C36 234 34 230 34 222 C30 200 24 178 20 158 C16 140 18 124 22 110 C20 100 16 86 18 70 C20 54 30 45 44 43 C44 41 44 39 46 37 C40 36 34 31 34 22 C34 14 38 4 50 4 Z" />
          </svg>
          <svg class="slim" viewBox="0 0 100 240" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
            <path d="M50 4 C58 4 62 12 62 20 C62 28 58 34 54 35 C55 37 55 39 55 41 C64 43 70 50 71 64 C72 78 70 90 68 100 C70 112 71 126 68 142 C66 162 62 184 60 220 C60 228 58 234 56 234 L44 234 C42 234 40 228 40 220 C38 184 34 162 32 142 C29 126 30 112 32 100 C30 90 28 78 29 64 C30 50 36 43 45 41 C45 39 45 37 46 35 C42 34 38 28 38 20 C38 12 42 4 50 4 Z" />
          </svg>
        </div>
        <div class="sil-label">Dein Ziel</div>

        <div class="alert">
          <strong>⚠ Wichtiger Hinweis</strong>
          Wir können nur eine begrenzte Zahl an Plänen sofort persönlich übergeben. Sichere dir jetzt deinen Termin, bevor du auf die Warteliste musst.
        </div>

        <h2 style="margin-top:24px">📅 Wann willst du deinen Plan erhalten?</h2>
        <p class="lead">Im persönlichen Gespräch übergeben wir dir deinen individuellen Plan. Termin direkt buchen:</p>

        <div id="ycb-embed" style="margin:20px 0;min-height:480px">
          <script src="https://embed.ycb.me" async data-domain="fitontime-abnehm-blockaden-check" data-displaymode="auto" is:inline></script>
        </div>

        <div class="features">
          <div class="feature">⚡ <span><strong>Dein aktueller Stoffwechsel-Standort</strong> — was du sofort tun kannst, um ihn zu pushen.</span></div>
          <div class="feature">📊 <span><strong>Wissen aus 4000+ Transformationen</strong>, sofort anwendbar.</span></div>
          <div class="feature">📖 <span><strong>Dein eigener Plan</strong>, auf deine Antworten zugeschnitten.</span></div>
          <div class="feature">📆 <span><strong>Langzeitstrategie</strong> — Wunschgewicht erreichen und halten.</span></div>
        </div>

        <section class="ba-section">
          <div class="ba-title">Echte Transformationen</div>
          <div class="ba-sub">Frauen, die Fit on Time gewählt haben</div>
          <div class="ba-grid">
            <img src="/abnehmpotential/ba1.jpg" alt="Vorher Nachher Transformation 1" loading="lazy" />
            <img src="/abnehmpotential/ba2.jpg" alt="Vorher Nachher Transformation 2" loading="lazy" />
            <img src="/abnehmpotential/ba3.jpg" alt="Vorher Nachher Transformation 3" loading="lazy" />
          </div>
        </section>

        <div class="testimonial">
          „Ich hätte nie gedacht, dass mein Stoffwechsel so blockiert war. Durch das Gespräch wusste ich endlich, was ich ändern muss und es hat funktioniert."
          <cite>— Sandra, 47, Zürich</cite>
        </div>

        <p class="note">Falls du keinen Termin buchst, bekommst du dein Ergebnis automatisch innerhalb von 14 Werktagen, aber ohne persönliche Erklärung.</p>
      </section>
    </div>
  </main>

  <footer>
    <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener">Impressum</a>·
    <a href="https://fitontime.ch/impressum-datenschutz" target="_blank" rel="noopener">Datenschutz</a>
  </footer>

  <CookieBanner
    metaPixelId={PIXEL_ID}
    hyrosPh={HYROS_ID}
    impressumUrl={IMPRESSUM_URL}
    datenschutzUrl={DATENSCHUTZ_URL}
    consentKey="fot_consent"
  />

  <script is:inline define:vars={{ LP_SLUG, LP_NAME }}>
    // Quiz-State
    const STATE_KEY = 'fot_abnehmpotential_state';
    const SESSION_KEY = 'fot_session';
    const TOTAL_STEPS = 8; // Quiz-Steps 1..8 fuer Progress (ohne Start, Loading, Optin, Ergebnis)

    const state = JSON.parse(sessionStorage.getItem(STATE_KEY) || '{"step":0,"answers":{}}');
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }

    function saveState() { sessionStorage.setItem(STATE_KEY, JSON.stringify(state)); }

    // Tracking, robust mit sendBeacon Fallback
    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({
        event, lp: LP_SLUG, lp_name: LP_NAME, session, step: state.step,
      }, extra || {}));
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
          return;
        }
      } catch (e) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }

    // Step-Anzeige
    function showStep(i) {
      document.querySelectorAll('.step').forEach(s => s.classList.toggle('active', Number(s.dataset.step) === i));
      window.scrollTo({ top: 0, behavior: 'instant' });
      // Progress nur waehrend Quiz (Steps 1..8 inkl. Loading)
      const showProg = i >= 1 && i <= 8;
      const prog = document.getElementById('progress');
      const lbl = document.getElementById('progressLabel');
      prog.hidden = !showProg;
      lbl.hidden = !showProg;
      if (showProg) {
        const pct = Math.round((i / TOTAL_STEPS) * 100);
        document.getElementById('progressFill').style.width = pct + '%';
        lbl.textContent = `Schritt ${i} von ${TOTAL_STEPS}`;
      }
      track('step_view', { step_index: i });
      // Zusaetzlich Standard-Funnel-Events fuer Dashboard-Aggregation:
      if (i === 1 && !state.startedFired) { state.startedFired = true; saveState(); track('quiz_start'); }
      if (i === 8 && !state.completedFired) { state.completedFired = true; saveState(); track('quiz_complete'); }

      // Loading-Step automatisch weiterleiten
      if (i === 8) {
        setTimeout(() => { state.step = 9; saveState(); showStep(9); }, 2200);
      }
      // Optin Lead-Event
      if (i === 9) {
        track('optin_view');
        if (window.fbq) window.fbq('track', 'InitiateCheckout');
      }
      // Ergebnis personalisieren
      if (i === 10) renderErgebnis();
    }

    // Naechster Step
    function next() {
      state.step++;
      saveState();
      showStep(state.step);
    }
    window.next = next;

    // Antwort speichern und weiter
    function answer(key, val) {
      state.answers[key] = val;
      saveState();
      track('quiz_answer', { key, value: val });
      next();
    }
    window.answer = answer;

    // Slider-Sync
    function bindSlider(id, valId) {
      const s = document.getElementById(id);
      const v = document.getElementById(valId);
      if (!s) return;
      const update = () => {
        v.textContent = s.value;
        const pct = ((s.value - s.min) / (s.max - s.min)) * 100;
        s.style.background = `linear-gradient(to right, var(--accent) 0%, var(--accent) ${pct}%, var(--border) ${pct}%, var(--border) 100%)`;
      };
      s.addEventListener('input', update);
      update();
    }
    bindSlider('sliderGroesse', 'valGroesse');
    bindSlider('sliderGewicht', 'valGewicht');
    bindSlider('sliderAlter', 'valAlter');

    // Lead-Submit
    async function submitLead(e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      const err = document.getElementById('optinErr');
      err.textContent = '';
      btn.disabled = true;
      btn.textContent = 'Wird gesendet...';

      const fd = new FormData(e.target);
      const payload = {
        name: fd.get('fname'),
        email: fd.get('email'),
        phone: fd.get('phone'),
        lp_slug: LP_SLUG,
        lp_name: LP_NAME,
        session,
        answers: {
          q1: state.answers.auslastung || '',
          q2: state.answers.prioritaet || '',
          q3: state.answers.groesse ? state.answers.groesse + ' cm' : '',
          q4: state.answers.gewicht ? state.answers.gewicht + ' kg' : '',
          q5: state.answers.alter ? state.answers.alter + ' J' : '',
          q6: state.answers.trigger || '',
          q7: state.answers.koerperfett || '',
          q8: '',
          q9: '',
        },
      };

      try {
        const res = await fetch('/api/sheets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'Fehler beim Senden');
        }
        track('lead_submit');
        if (window.fbq) window.fbq('track', 'Lead');
        // Name fuer Ergebnisseite merken
        state.lead = { name: (fd.get('fname') || '').toString().split(' ')[0] };
        state.step = 10;
        saveState();
        showStep(10);
      } catch (e2) {
        err.textContent = e2.message || 'Etwas ist schiefgelaufen, bitte nochmal versuchen.';
        btn.disabled = false;
        btn.textContent = 'Jetzt Ergebnis erfahren ✨';
      }
    }
    window.submitLead = submitLead;

    // Ergebnisseite personalisieren, BMI-basiert, mehr Potenzial bei hoeherem Gewicht.
    // Cap bei 18% Koerpergewicht in 4 Monaten (~1%/Woche, medizinisch realistisch).
    function renderErgebnis() {
      const w = parseFloat(state.answers.gewicht || '75');
      const h = parseFloat(state.answers.groesse || '165');
      const heightM = h / 100;
      const bmi = w / (heightM * heightM);

      // Ziel-BMI je nach Ausgangs-BMI
      let bmiTarget;
      if (bmi < 22)      bmiTarget = bmi - 0.5;   // Normalgewicht: minimal
      else if (bmi < 25) bmiTarget = 21.5;        // oberer Normalbereich
      else if (bmi < 30) bmiTarget = 23;          // Uebergewicht
      else if (bmi < 35) bmiTarget = 25;          // Adipositas I
      else               bmiTarget = bmi - 8;     // schwere Adipositas

      const targetW = bmiTarget * heightM * heightM;
      let potenzial = w - targetW;
      potenzial = Math.min(potenzial, w * 0.18);  // Hard-Cap 18%
      potenzial = Math.max(potenzial, 1.5);       // Mindest-Motivation 1,5 kg

      const potenzial1 = +potenzial.toFixed(1);
      const ziel = +(w - potenzial1).toFixed(1);

      document.getElementById('resPotenzial').textContent = potenzial1.toString().replace('.', ',');
      document.getElementById('resZiel').textContent = ziel.toString().replace('.', ',');
      document.getElementById('resName').textContent = state.lead?.name || 'Du';
      track('result_shown');
    }

    // Initial
    showStep(state.step);
    track('page_view');
  </script>
</body>
</html>
