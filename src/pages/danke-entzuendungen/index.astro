---
// Danke-Seite nach Anmeldung "Entzuendungen Webinar"
// Bestaetigung, Datum, Workshop-Link zum Speichern, anonymous-Hinweis, Kalender-Add
const LP_SLUG = 'entzuendungen';
const LP_NAME = 'Entzündungen Webinar Danke';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';

const LIVE_DATUM = 'Dienstag, 12. Mai 2026 um 18:00 Uhr';
const LIVE_DATUM_KURZ = 'Dienstag, 12.05.2026 · 18:00 Uhr';
const WORKSHOP_LINK = 'https://workshop.fitontime.ch';
// Google-Calendar-Einladung (UTC-Zeiten: 18:00 CEST = 16:00 UTC)
const GCAL_LINK = 'https://calendar.google.com/calendar/render?action=TEMPLATE' +
  '&text=' + encodeURIComponent('Fit on Time: Entzündungs-Webinar') +
  '&dates=20260512T160000Z/20260512T173000Z' +
  '&details=' + encodeURIComponent('Live-Webinar von Fit on Time. Zugang über workshop.fitontime.ch (Link wurde dir per WhatsApp und E-Mail zugesendet).') +
  '&location=' + encodeURIComponent('Online (workshop.fitontime.ch)');
const ICS_LINK = '/api/ics-entzuendungen';
---
<html lang="de-CH">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Vielen Dank! Wir sehen uns am 12.05. | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Hyros first-party tracking -->
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <style is:global>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#ffffff;
      --surface:#f7faf9;
      --border:#e5e7eb;
      --text:#0f172a;
      --text-2:#475569;
      --text-3:#94a3b8;
      --accent:#0caa4f;
      --accent-dark:#089042;
      --accent-soft:#d1fae5;
      --r:14px;
      --font:'Inter',system-ui,-apple-system,sans-serif;
    }
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
    body{font-family:var(--font);background:linear-gradient(180deg,#f0fdf4 0%,#fff 25%,#fff 100%);color:var(--text);line-height:1.5;-webkit-font-smoothing:antialiased;min-height:100dvh;display:flex;flex-direction:column;font-feature-settings:"ss01","cv11"}
    main{flex:1}
    .wrap{width:100%;max-width:680px;margin:0 auto;padding:0 18px}

    header{padding:20px 0 8px;text-align:center}
    header img{height:38px}

    /* Confetti pop */
    @keyframes pop{0%{transform:scale(.6);opacity:0}60%{transform:scale(1.08);opacity:1}100%{transform:scale(1)}}

    .hero{padding:36px 0 24px;text-align:center}
    .check-circle{width:84px;height:84px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-dark));display:inline-flex;align-items:center;justify-content:center;margin-bottom:22px;box-shadow:0 14px 40px rgba(12,170,79,.36),0 0 0 8px var(--accent-soft);animation:pop .5s cubic-bezier(.22,1,.36,1) both}
    .check-circle svg{width:42px;height:42px;color:#fff}
    h1{font-size:30px;font-weight:800;line-height:1.2;letter-spacing:-.5px;color:var(--text);margin-bottom:10px}
    @media(min-width:840px){h1{font-size:38px}}
    h1 .name{color:var(--accent)}
    .sub{font-size:17px;color:var(--text-2);line-height:1.55;margin-bottom:8px;max-width:520px;margin-inline:auto}

    .anon{display:inline-flex;align-items:center;gap:8px;background:var(--accent-soft);color:#065f46;padding:8px 14px;border-radius:999px;font-size:13.5px;font-weight:700;margin-top:10px}
    .anon svg{width:14px;height:14px}

    /* Cards */
    .card{background:#fff;border:1px solid var(--border);border-radius:18px;padding:26px;box-shadow:0 8px 30px rgba(15,23,42,.05);margin-bottom:18px}
    .card .label{display:block;font-size:11.5px;font-weight:800;letter-spacing:1.4px;text-transform:uppercase;color:var(--accent);margin-bottom:8px}
    .card h2{font-size:22px;font-weight:800;line-height:1.25;letter-spacing:-.3px;color:var(--text);margin-bottom:14px}
    .card p{font-size:15.5px;color:var(--text-2);line-height:1.6;margin-bottom:10px}

    /* Date Block */
    .date-block{display:flex;align-items:center;gap:16px;padding:18px;background:linear-gradient(135deg,#f0fdf4,#ecfdf5);border:1px solid var(--accent-soft);border-radius:14px;margin-bottom:16px}
    .date-block .icon{width:54px;height:54px;border-radius:13px;background:#fff;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 14px rgba(12,170,79,.18);flex-shrink:0;font-size:26px}
    .date-block .info .day{font-size:13px;color:var(--accent);font-weight:800;letter-spacing:.6px;text-transform:uppercase}
    .date-block .info .date{font-size:18.5px;font-weight:800;color:var(--text);letter-spacing:-.2px}
    .date-block .info .time{font-size:14px;color:var(--text-2);font-weight:600}

    /* Buttons */
    .btn-row{display:flex;flex-direction:column;gap:10px;margin-top:8px}
    @media(min-width:600px){.btn-row{flex-direction:row}.btn-row .btn{flex:1}}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border-radius:13px;padding:14px 20px;font:inherit;font-weight:700;font-size:15px;cursor:pointer;transition:transform .1s,box-shadow .15s,background .15s;text-decoration:none;text-align:center;border:0;line-height:1.2}
    .btn-primary{background:var(--accent);color:#fff;box-shadow:0 6px 18px rgba(12,170,79,.28)}
    .btn-primary:hover{background:var(--accent-dark);box-shadow:0 10px 24px rgba(12,170,79,.36);transform:translateY(-1px)}
    .btn-secondary{background:#fff;color:var(--text);border:1.5px solid var(--border)}
    .btn-secondary:hover{border-color:var(--accent);color:var(--accent)}
    .btn svg{width:16px;height:16px}

    /* Workshop Link Block */
    .link-block{background:#0f172a;border-radius:14px;padding:18px 20px;display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-top:14px}
    .link-block .url{font-family:'SF Mono',Menlo,monospace;font-size:14.5px;color:#86efac;font-weight:600;letter-spacing:.2px;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .link-block .copy-btn{background:rgba(255,255,255,.1);color:#fff;border:0;border-radius:9px;padding:8px 14px;font:inherit;font-size:12.5px;font-weight:700;cursor:pointer;transition:background .15s;display:inline-flex;align-items:center;gap:6px;flex-shrink:0}
    .link-block .copy-btn:hover{background:rgba(255,255,255,.18)}
    .link-block .copy-btn svg{width:13px;height:13px}
    .link-block .copy-btn.copied{background:var(--accent)}

    /* Steps */
    .steps{display:flex;flex-direction:column;gap:14px;margin-top:6px}
    .step{display:flex;gap:14px;align-items:flex-start}
    .step-num{flex-shrink:0;width:32px;height:32px;border-radius:50%;background:var(--accent-soft);color:var(--accent);font-weight:800;font-size:14px;display:flex;align-items:center;justify-content:center;letter-spacing:-.2px}
    .step-content{flex:1;padding-top:4px}
    .step-content strong{display:block;font-size:15px;color:var(--text);margin-bottom:2px;font-weight:700}
    .step-content span{font-size:14px;color:var(--text-2);line-height:1.55}

    /* Bonus card */
    .bonus-card{background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1px solid #fde68a;border-radius:14px;padding:18px 20px 18px 60px;position:relative;color:#854d0e;font-size:14.5px;line-height:1.55}
    .bonus-card::before{content:"🎁";position:absolute;left:18px;top:14px;font-size:28px;line-height:1}
    .bonus-card strong{display:block;color:var(--text);font-size:15px;margin-bottom:4px;font-weight:800}

    footer{padding:40px 18px 30px;text-align:center;color:var(--text-3);font-size:13px}
    footer .copy{margin-bottom:6px;color:var(--text-2);font-weight:600}
    footer a{color:var(--text-3);margin:0 8px;text-decoration:underline}
  </style>
</head>
<body>
  <header><img src="/images/logo.png" alt="Fit on Time" /></header>

  <main>
    <div class="wrap">
      <section class="hero">
        <div class="check-circle" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 12 10 18 20 6"/></svg>
        </div>
        <h1 id="hero-title">Vielen Dank<span id="hero-name"></span>! 🎉</h1>
        <p class="sub">Du bist offiziell für das <strong>kostenlose Live-Webinar</strong> angemeldet.</p>
        <div class="anon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4-8-12V5l8-3 8 3v5c0 8-8 12-8 12z"/><polyline points="9 12 11 14 15 10"/></svg>
          Du bist im Workshop völlig anonym
        </div>
      </section>

      <section class="card">
        <span class="label">📅 So geht es weiter</span>
        <h2>Trag dir den Termin ein und speichere dir den Link.</h2>

        <div class="date-block">
          <div class="icon">🗓</div>
          <div class="info">
            <div class="day">Dienstag</div>
            <div class="date">12. Mai 2026</div>
            <div class="time">um 18:00 Uhr</div>
          </div>
        </div>

        <div class="btn-row">
          <a class="btn btn-primary" href={GCAL_LINK} target="_blank" rel="noopener" onclick="trackClick('add_to_gcal')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
            Zu Google Calendar
          </a>
          <a class="btn btn-secondary" href={ICS_LINK} download="fit-on-time-webinar.ics" onclick="trackClick('add_to_ics')">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Apple/Outlook (.ics)
          </a>
        </div>

        <p style="margin:18px 0 6px;font-size:14px;color:var(--text-2)"><strong style="color:var(--text)">Speichere dir auch diesen Workshop-Link ab:</strong></p>
        <div class="link-block">
          <span class="url" id="workshopUrl">{WORKSHOP_LINK}</span>
          <button type="button" class="copy-btn" id="copyBtn" onclick="copyLink()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span id="copyLabel">Kopieren</span>
          </button>
        </div>
        <p style="margin:10px 0 0;font-size:13px;color:var(--text-3);text-align:center;font-style:italic">Der Link wurde dir auch per WhatsApp und E-Mail zugesendet.</p>
      </section>

      <section class="card">
        <span class="label">3 schnelle Schritte</span>
        <h2>Damit du am Webinar nichts verpasst.</h2>
        <div class="steps">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-content">
              <strong>Termin in den Kalender eintragen</strong>
              <span>Klick oben auf einen der beiden Kalender-Buttons. Du bekommst zusätzlich 30 Minuten vorher eine WhatsApp-Erinnerung.</span>
            </div>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-content">
              <strong>WhatsApp-Bestätigung prüfen</strong>
              <span>Wir senden dir den Zugangslink in den nächsten Minuten per WhatsApp und E-Mail zu. Schau ggf. in den Spam-Ordner.</span>
            </div>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-content">
              <strong>Notizblock und Wasser bereitstellen</strong>
              <span>Du wirst konkrete Insights bekommen, die du sofort umsetzen kannst. Plane 60 ungestörte Minuten ein.</span>
            </div>
          </div>
        </div>
      </section>

      <section class="bonus-card">
        <strong>Dein PDF-Bonus wartet</strong>
        Direkt im Webinar bekommst du die 7-Punkte-Checkliste gegen Entzündungen plus die Insider-Tricks für sofort spürbar mehr Kalorienverbrauch.
      </section>
    </div>
  </main>

  <footer>
    <div class="copy">© Fit on Time {new Date().getFullYear()}</div>
    <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Impressum</a>·
    <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Datenschutzerklärung</a>
  </footer>

  <script is:inline define:vars={{ LP_SLUG, LP_NAME, WORKSHOP_LINK, PIXEL_ID }}>
    // Session
    const SESSION_KEY = 'fot_session';
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }

    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({
        event, lp: LP_SLUG, lp_name: LP_NAME, session, schema_version: 'v1',
      }, extra || {}));
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
          return;
        }
      } catch (e) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }

    // Vornamen aus Query-Param ?n=Name (von /entzuendungen Form-Submit) personalisiert
    const params = new URLSearchParams(window.location.search);
    const vorname = (params.get('n') || '').trim().slice(0, 30);
    if (vorname) {
      const safe = vorname.replace(/[<>\"'&]/g, '');
      document.getElementById('hero-name').textContent = ', ' + safe;
    }

    // Copy-Link
    function copyLink() {
      const link = WORKSHOP_LINK;
      const lbl = document.getElementById('copyLabel');
      const btn = document.getElementById('copyBtn');
      navigator.clipboard.writeText(link).then(() => {
        lbl.textContent = 'Kopiert!';
        btn.classList.add('copied');
        track('workshop_link_copied');
        setTimeout(() => { lbl.textContent = 'Kopieren'; btn.classList.remove('copied'); }, 2000);
      }).catch(() => {
        lbl.textContent = 'Manuell kopieren';
      });
    }
    window.copyLink = copyLink;

    function trackClick(action) { track(action); }
    window.trackClick = trackClick;

    // Meta-Pixel: Schedule-Event (analog zum Original-Funnelcockpit-Setup)
    if (window.fbq) {
      window.fbq('track', 'CompleteRegistration');
      window.fbq('track', 'Schedule', { content_category: 'Webinar Anmeldung' });
    }
    track('thankyou_view');
  </script>
</body>
</html>
