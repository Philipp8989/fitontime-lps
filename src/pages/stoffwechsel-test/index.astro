---
// Stoffwechsel-Profil Quiz  -  Neu gebaut auf Basis stoffwechsel-test.ch (3 Jahre Winner)
// LETZTE Frage (Körperbau) entscheidet über 3 Ergebnisse: ecto / meso / endo
// CRO-Upgrade: Visuelle Karten, Live-Proof, Micro-Commitments, Typ-Match-Animation
import CookieBanner from '../../components/CookieBanner.astro';
const impressumUrl = 'https://fitontime.ch/impressum-datenschutz';
const datenschutzUrl = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <meta name="theme-color" content="#1d73d3" />
  <title>Welcher Stoffwechsel-Typ bist du? In 60 Sekunden | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preload" as="image" href="/images/logo.png" fetchpriority="high" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #fafaf8;
      --bg-soft: #f3ede1;
      --card: #ffffff;
      --border: #e8e4da;
      --accent: #1d73d3;
      --accent-dark: #155aa8;
      --accent-soft: #eaf2fc;
      --green: #16a34a;
      --amber: #f59e0b;
      --red: #dc2626;
      --text: #0f172a;
      --text-2: #475569;
      --text-3: #94a3b8;
      --r: 16px;
      --font: 'DM Sans', system-ui, -apple-system, sans-serif;
      --shadow-sm: 0 2px 8px rgba(15,23,42,0.04);
      --shadow-md: 0 6px 20px rgba(29,115,211,0.14);
      --shadow-lg: 0 12px 28px rgba(29,115,211,0.22);
    }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    /* Fokus-Ring für Keyboard-Nutzer (WCAG 2.4.7) */
    button:focus-visible, a:focus-visible, input:focus-visible, label:focus-visible { outline: 3px solid var(--accent); outline-offset: 3px; border-radius: 6px; }
    .opt:focus-visible, .body-card:focus-visible, .cta-btn:focus-visible, .submit:focus-visible { outline-offset: 4px; }

    /* Reduced-Motion: weniger Transitions für sensible User (WCAG 2.3.3) */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; scroll-behavior: auto !important; }
    }

    .wrap { max-width: 760px; margin: 0 auto; padding: 0 20px; }

    /* Logo */
    .logo { text-align: center; padding: 18px 0 6px; }
    .logo img { height: 44px; }

    /* Trust-Bar oben */
    .topbar { display: flex; align-items: center; justify-content: center; gap: 14px; padding: 6px 0 10px; font-size: 11px; color: var(--text-3); font-weight: 500; }
    .topbar span.dot { width: 4px; height: 4px; border-radius: 50%; background: var(--text-3); }
    .topbar .live { color: var(--green); font-weight: 700; }
    .topbar .live::before { content: '●'; margin-right: 4px; animation: pulse 1.6s ease-in-out infinite; display: inline-block; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    /* Hero */
    .hero { text-align: center; padding: 14px 0 22px; }
    .hero .badge { display: inline-block; background: var(--accent-soft); color: var(--accent); font-size: 12px; font-weight: 700; padding: 6px 14px; border-radius: 20px; margin-bottom: 14px; letter-spacing: 0.3px; }
    .hero h1 { font-size: 30px; font-weight: 900; line-height: 1.15; letter-spacing: -0.8px; margin-bottom: 14px; color: var(--text); }
    .hero h1 em { font-style: normal; color: var(--accent); position: relative; white-space: nowrap; z-index: 0; }
    .hero h1 em::after { content: ''; position: absolute; left: -2px; right: -2px; bottom: 2px; height: 12px; background: linear-gradient(90deg, rgba(29,115,211,0.18) 0%, rgba(59,146,240,0.28) 100%); z-index: -1; border-radius: 4px; transform: skewX(-4deg); }
    .hero .sub { font-size: 16px; color: var(--text-2); margin-bottom: 10px; line-height: 1.5; max-width: 560px; margin-left: auto; margin-right: auto; }
    .hero .sub strong { color: var(--text); font-weight: 700; }

    /* Proof unter Hero */
    .proof-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 16px 0 6px; }
    .proof-avatars { display: flex; }
    .proof-avatars img { width: 34px; height: 34px; border-radius: 50%; border: 2px solid var(--bg); margin-left: -10px; object-fit: cover; object-position: center 30%; }
    .proof-avatars img:first-child { margin-left: 0; }
    .proof-info { font-size: 12px; color: var(--text-2); line-height: 1.35; text-align: left; }
    .proof-info b { color: var(--text); font-weight: 700; }
    .proof-stars { color: var(--amber); font-size: 13px; letter-spacing: 1px; }

    /* Benefits */
    .benefits { display: grid; gap: 10px; max-width: 520px; margin: 20px auto 0; text-align: left; }
    .benefit { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: var(--card); border: 1px solid var(--border); border-radius: 12px; font-size: 14px; color: var(--text); font-weight: 500; box-shadow: var(--shadow-sm); }
    .benefit .ic { width: 28px; height: 28px; border-radius: 50%; background: var(--accent-soft); color: var(--accent); display: flex; align-items: center; justify-content: center; font-weight: 800; flex-shrink: 0; font-size: 14px; }

    /* CTA */
    .cta-wrap { margin: 24px auto 0; max-width: 520px; }
    .cta-btn { display: block; width: 100%; background: var(--accent); color: #fff; font-family: var(--font); font-size: 17px; font-weight: 800; padding: 20px; border: none; border-radius: 14px; cursor: pointer; transition: all 0.2s; text-align: center; box-shadow: var(--shadow-md); letter-spacing: 0.2px; }
    .cta-btn:hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: var(--shadow-lg); }
    .cta-btn:active { transform: scale(0.98); }
    .cta-sub { text-align: center; font-size: 12px; color: var(--text-3); margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; }
    .cta-sub b { color: var(--text-2); font-weight: 600; }

    /* Transformationen */
    .trans { margin: 36px 0 20px; }
    .trans-title { font-size: 18px; font-weight: 800; text-align: center; margin-bottom: 4px; letter-spacing: -0.3px; }
    .trans-sub { font-size: 13px; color: var(--text-3); text-align: center; margin-bottom: 16px; }
    .trans-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; max-width: 520px; margin: 0 auto; }
    .trans-grid img { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 10px; background: var(--card); }

    /* Sticky Mobile CTA */
    .sticky-cta { position: fixed; bottom: 0; left: 0; right: 0; padding: 10px 16px calc(10px + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.96); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-top: 1px solid var(--border); z-index: 50; transform: translateY(120%); transition: transform 0.35s cubic-bezier(0.2, 0.9, 0.3, 1); box-shadow: 0 -4px 20px rgba(0,0,0,0.08); }
    .sticky-cta.show { transform: translateY(0); }
    .sticky-cta .cta-btn { max-width: 520px; margin: 0 auto; box-shadow: none; }
    @media (min-width: 900px) { .sticky-cta { display: none; } }

    /* Divider + Footer */
    .divider { width: 40px; height: 2px; background: var(--accent); margin: 28px auto; opacity: 0.3; border-radius: 2px; }
    footer { text-align: center; padding: 24px 20px 32px; font-size: 11px; color: var(--text-3); }
    footer a { color: var(--text-3); text-decoration: none; }
    footer a:hover { color: var(--text-2); }

    /* ===== QUIZ ===== */
    #quiz { display: none; position: fixed; inset: 0; background: var(--bg); z-index: 100; flex-direction: column; overflow-y: auto; -webkit-overflow-scrolling: touch; }
    #quiz.on { display: flex; }
    .q-head { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--border); position: sticky; top: 0; background: var(--bg); z-index: 10; }
    .q-head img { height: 34px; }
    .q-back { background: transparent; border: none; color: var(--text-3); font-size: 14px; font-weight: 600; cursor: pointer; padding: 6px 10px; display: flex; align-items: center; gap: 4px; font-family: var(--font); }
    .q-back:hover { color: var(--text); }
    .q-back.hidden { visibility: hidden; }
    .q-head .q-right { font-size: 12px; color: var(--text-3); font-weight: 600; font-variant-numeric: tabular-nums; }
    .q-progress { padding: 10px 20px 0; max-width: 620px; margin: 0 auto; width: 100%; position: sticky; top: 62px; background: var(--bg); z-index: 9; padding-bottom: 10px; }
    .q-bar { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
    .q-fill { height: 100%; background: linear-gradient(90deg, var(--accent) 0%, #3b92f0 100%); border-radius: 3px; transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1); width: 0%; }
    .q-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 6px; font-size: 11px; color: var(--text-3); font-weight: 600; }
    .q-meta .q-time { color: var(--accent); }

    .q-body { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 28px 20px 40px; }
    .step { display: none; max-width: 620px; width: 100%; animation: stepIn 0.35s cubic-bezier(0.2, 0.9, 0.3, 1); }
    .step.on { display: block; }
    @keyframes stepIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .step-eyebrow { text-align: center; font-size: 11px; font-weight: 700; color: var(--accent); letter-spacing: 0.8px; text-transform: uppercase; margin-bottom: 8px; }
    .step h2 { font-size: 24px; font-weight: 800; text-align: center; margin-bottom: 8px; line-height: 1.25; letter-spacing: -0.4px; }
    .step .step-sub { font-size: 14px; color: var(--text-2); text-align: center; margin-bottom: 24px; }

    .opts { display: flex; flex-direction: column; gap: 10px; }
    .opt { background: var(--card); border: 2px solid var(--border); border-radius: 14px; padding: 18px 20px; font-size: 15px; font-weight: 500; color: var(--text); cursor: pointer; transition: all 0.18s; font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: left; display: flex; align-items: center; gap: 14px; box-shadow: var(--shadow-sm); }
    .opt:hover { border-color: var(--accent); background: var(--accent-soft); transform: translateY(-1px); }
    .opt:active { transform: scale(0.98); }
    .opt strong { display: block; font-weight: 700; color: var(--text); font-size: 16px; }
    .opt span { font-size: 13px; color: var(--text-2); display: block; margin-top: 2px; line-height: 1.4; }
    .opt .opt-ic { width: 44px; height: 44px; border-radius: 10px; background: var(--accent-soft); color: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
    .opt.selected { border-color: var(--accent); background: var(--accent-soft); }

    /* 2-Column-Layout für kurze Optionen */
    .opts.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .opts.grid-2 .opt { flex-direction: column; text-align: center; padding: 20px 14px; }
    .opts.grid-2 .opt .opt-ic { margin: 0 auto 8px; }

    /* Körpertyp-Karten (finale Frage) - Silhouetten prominent wie im Original */
    .body-cards { display: grid; grid-template-columns: 1fr; gap: 12px; }
    @media (min-width: 560px) { .body-cards { grid-template-columns: 1fr 1fr 1fr; } }
    .body-card { background: linear-gradient(180deg, var(--accent) 0%, #3b92f0 60%, var(--accent-dark) 100%); border: 3px solid transparent; border-radius: 18px; padding: 0; overflow: hidden; cursor: pointer; transition: all 0.25s cubic-bezier(0.2, 0.9, 0.3, 1); font-family: var(--font); -webkit-tap-highlight-color: transparent; text-align: center; box-shadow: var(--shadow-md); display: flex; flex-direction: column; color: #fff; }
    .body-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); border-color: var(--accent-dark); }
    .body-card:active { transform: scale(0.97); }
    .body-card .bc-visual { aspect-ratio: 3/5; display: flex; align-items: flex-end; justify-content: center; position: relative; overflow: hidden; padding-top: 18px; }
    .body-card .bc-visual svg { width: 85%; height: 96%; color: #fff; filter: drop-shadow(0 6px 18px rgba(0,0,0,0.25)); position: relative; z-index: 1; transition: transform 0.3s; }
    .body-card:hover .bc-visual svg { transform: scale(1.05) translateY(-4px); }
    .body-card .bc-body { padding: 14px 12px 18px; background: rgba(255,255,255,0.08); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); border-top: 1px solid rgba(255,255,255,0.14); }
    .body-card h3 { font-size: 17px; font-weight: 800; color: #fff; margin-bottom: 6px; letter-spacing: -0.2px; }
    .body-card p { font-size: 12px; color: rgba(255,255,255,0.88); line-height: 1.45; }
    .body-card .bc-body { padding: 14px 14px 18px; }
    .body-card h3 { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 6px; letter-spacing: -0.2px; }
    .body-card p { font-size: 12px; color: var(--text-2); line-height: 1.45; }

    /* Loading */
    .ld { text-align: center; padding: 20px 0; }
    .spinner { width: 64px; height: 64px; border: 4px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.9s linear infinite; margin: 0 auto 22px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ld h2 { font-size: 20px; margin-bottom: 6px; }
    .ld p { font-size: 14px; color: var(--text-2); margin-bottom: 22px; }
    .checks { text-align: left; max-width: 300px; margin: 0 auto; }
    .chk { display: flex; align-items: center; gap: 10px; padding: 8px 0; font-size: 14px; color: var(--text-2); opacity: 0; transform: translateX(-10px); transition: all 0.35s; }
    .chk.show { opacity: 1; transform: translateX(0); }
    .chk i { width: 22px; height: 22px; border-radius: 50%; background: var(--green); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 12px; font-style: normal; font-weight: 700; flex-shrink: 0; }

    /* Formular (Opt-in) */
    .form { text-align: center; }
    .form .tag { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: var(--green); background: #ecfdf5; padding: 6px 12px; border-radius: 20px; margin-bottom: 12px; }
    .form h2 { font-size: 24px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.3px; }
    .form .sub { font-size: 14px; color: var(--text-2); margin-bottom: 22px; line-height: 1.5; }
    .form .sub b { color: var(--text); font-weight: 700; }
    .fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; max-width: 460px; margin-left: auto; margin-right: auto; }
    .field { background: var(--card); border: 2px solid var(--border); border-radius: 12px; padding: 0 14px; display: flex; align-items: center; gap: 10px; transition: all 0.2s; }
    .field:focus-within { border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }
    .field .ic { font-size: 16px; flex-shrink: 0; opacity: 0.7; width: 20px; text-align: center; }
    .field input { flex: 1; background: transparent; border: none; outline: none; color: var(--text); font-family: var(--font); font-size: 15px; padding: 16px 0; }
    .field input::placeholder { color: var(--text-3); }
    .field .pre { font-size: 14px; color: var(--text-2); font-weight: 600; flex-shrink: 0; }
    .cb-row { display: flex; align-items: flex-start; gap: 8px; margin: 0 auto 16px; text-align: left; max-width: 460px; }
    .cb-row input[type="checkbox"] { accent-color: var(--accent); width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0; cursor: pointer; }
    .cb-row label { font-size: 11px; color: var(--text-3); line-height: 1.5; cursor: pointer; }
    .cb-row label a { color: var(--text-2); }
    .submit { display: block; width: 100%; max-width: 460px; margin: 0 auto; background: var(--accent); color: #fff; font-family: var(--font); font-size: 16px; font-weight: 800; padding: 18px; border: none; border-radius: 14px; cursor: pointer; transition: all 0.2s; box-shadow: var(--shadow-md); }
    .submit:disabled { opacity: 0.35; cursor: not-allowed; box-shadow: none; }
    .submit:not(:disabled):hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: var(--shadow-lg); }
    .submit:not(:disabled):active { transform: scale(0.98); }
    .form-proof { margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--border); max-width: 460px; margin-left: auto; margin-right: auto; }
    .form-proof .fp-row { display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 11px; color: var(--text-3); margin-bottom: 6px; }
    .form-proof .fp-row b { color: var(--text-2); font-weight: 600; }

    /* ===== RESULT ===== */
    .result { max-width: 640px; width: 100%; padding-bottom: 40px; }
    .result-hero { text-align: center; margin-bottom: 20px; }
    .result-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--accent); color: #fff; font-size: 11px; font-weight: 800; padding: 6px 14px; border-radius: 20px; margin-bottom: 14px; letter-spacing: 0.6px; text-transform: uppercase; box-shadow: var(--shadow-md); }
    .result-type-label { font-size: 12px; color: var(--text-3); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .result-hero h2 { font-size: 28px; font-weight: 900; margin-bottom: 6px; line-height: 1.2; letter-spacing: -0.6px; color: var(--accent); }
    .result-hero .r-sub { font-size: 15px; color: var(--text-2); line-height: 1.5; max-width: 540px; margin: 8px auto 0; }

    .result-section { background: var(--card); border: 1px solid var(--border); border-radius: var(--r); padding: 20px; margin: 16px 0; box-shadow: var(--shadow-sm); }
    .result-section h3 { font-size: 17px; font-weight: 800; margin-bottom: 10px; letter-spacing: -0.2px; display: flex; align-items: center; gap: 8px; }
    .result-section p { font-size: 14px; color: var(--text-2); line-height: 1.6; }

    .result-pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 16px 0; }
    .pillar { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 14px; }
    .pillar .p-ic { font-size: 22px; margin-bottom: 6px; }
    .pillar h4 { font-size: 13px; font-weight: 800; margin-bottom: 4px; }
    .pillar p { font-size: 12px; color: var(--text-2); line-height: 1.45; }

    #wistia-container { margin: 18px 0; border-radius: 14px; overflow: hidden; box-shadow: var(--shadow-md); background: #000; aspect-ratio: 16/9; }
    #ycbm-container { margin: 20px 0; min-height: 400px; }

    .result-cta-wrap { background: linear-gradient(135deg, var(--accent) 0%, #3b92f0 100%); border-radius: var(--r); padding: 22px 20px; color: #fff; text-align: center; margin: 20px 0; }
    .result-cta-wrap h3 { color: #fff; font-size: 19px; font-weight: 800; margin-bottom: 6px; justify-content: center; }
    .result-cta-wrap p { color: rgba(255,255,255,0.92); font-size: 14px; margin-bottom: 14px; line-height: 1.5; }
    .result-cta { background: #fff; color: var(--accent); font-family: var(--font); font-size: 16px; font-weight: 800; padding: 16px 24px; border: none; border-radius: 12px; cursor: pointer; display: inline-block; width: 100%; max-width: 340px; text-decoration: none; text-align: center; transition: all 0.2s; box-shadow: 0 4px 14px rgba(0,0,0,0.2); }
    .result-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.3); }

    .scarcity { background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412; padding: 12px 16px; border-radius: 12px; font-size: 13px; font-weight: 600; margin: 16px 0; display: flex; align-items: center; justify-content: center; gap: 8px; }
    .scarcity b { color: #7c2d12; font-weight: 800; }

    .want-list { text-align: left; }
    .want-list li { font-size: 14px; color: var(--text-2); padding: 6px 0; display: flex; align-items: flex-start; gap: 10px; list-style: none; }
    .want-list li::before { content: '✓'; color: var(--green); font-weight: 800; flex-shrink: 0; font-size: 14px; margin-top: 2px; }

    /* Desktop-Anpassungen */
    @media (min-width: 600px) {
      .hero h1 { font-size: 42px; }
      .hero .sub { font-size: 17px; }
      .step h2 { font-size: 28px; }
      .result-hero h2 { font-size: 36px; }
    }
    @media (min-width: 900px) {
      .hero h1 { font-size: 48px; }
    }
  </style>
</head>
<body>

  <!-- ===== LANDING ===== -->
  <div id="lp">
    <div class="wrap">
      <div class="logo"><img src="/images/logo.png" alt="Fit on Time" /></div>

      <div class="topbar">
        <span class="live">Live</span>
        <span class="dot"></span>
        <span><b id="liveCnt">12</b> Frauen starten gerade das Quiz</span>
      </div>

      <section class="hero">
          <div class="badge">60-Sekunden-Test &middot; 5.000+ Teilnehmerinnen</div>
          <h1>Warum bei dir bisher <em>keine Diät</em> wirklich funktioniert hat.</h1>
          <p class="sub">In <strong>7 kurzen Fragen</strong> erfährst du deinen Stoffwechsel-Typ und was wirklich für dich funktioniert. <b>Ohne Verzicht. Ohne Jojo.</b></p>

        <div class="proof-bar">
          <div class="proof-avatars">
            <img src="/images/proof1.png" alt="" />
            <img src="/images/proof2.png" alt="" />
            <img src="/images/proof3.png" alt="" />
          </div>
          <div class="proof-info">
            <div class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <b>1.600 Frauen</b> halten ihr Wunschgewicht
          </div>
        </div>

        <div class="benefits">
          <div class="benefit"><span class="ic">&#10003;</span><span>Endlich essen, ohne schlechtes Gewissen</span></div>
          <div class="benefit"><span class="ic">&#10003;</span><span>Dein Wunschgewicht, ohne Jojo-Effekt</span></div>
          <div class="benefit"><span class="ic">&#10003;</span><span>Alltagstauglich, auch bei viel Stress</span></div>
          <div class="benefit"><span class="ic">&#10003;</span><span>Ein individueller Plan für deinen Körper</span></div>
        </div>

        <div class="cta-wrap">
          <button class="cta-btn" onclick="startQuiz()">Jetzt mein Stoffwechsel-Profil entdecken &rarr;</button>
          <p class="cta-sub"><b>&#128274; 100% kostenlos</b> <span class="dot">&middot;</span> <b>Keine Anmeldung</b> <span class="dot">&middot;</span> <b>Ergebnis sofort</b></p>
        </div>
      </section>

      <!-- Sticky Mobile CTA -->
      <div class="sticky-cta" id="stickyCta">
        <button class="cta-btn" onclick="startQuiz()" style="font-size:15px;padding:14px;">Quiz starten &rarr;</button>
      </div>

      <div class="trans">
        <div class="trans-title">Was andere Frauen bereits erreicht haben</div>
        <div class="trans-sub">Echte Teilnehmerinnen, echte Ergebnisse</div>
        <div class="trans-grid">
          <img src="/images/transformations/t1.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t3.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t5.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t7.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t8.jpg" alt="" loading="lazy" />
          <img src="/images/transformations/t9.jpg" alt="" loading="lazy" />
        </div>
      </div>

      <!-- Zweite CTA nach Social Proof -->
      <div class="cta-wrap" style="margin-bottom:20px;">
        <button class="cta-btn" onclick="startQuiz()">Jetzt meinen Typ finden &rarr;</button>
        <p class="cta-sub"><b>Kostenlos &middot; 60 Sek. &middot; Sofortiges Ergebnis</b></p>
      </div>

      <div class="divider"></div>

      <footer>
        <a href={impressumUrl} target="_blank" rel="noopener">Impressum</a> &middot;
        <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutzerklärung</a>
      </footer>
    </div>
  </div>

  <!-- ===== QUIZ ===== -->
  <div id="quiz">
    <div class="q-head">
      <button class="q-back hidden" id="qback" onclick="back()" aria-label="Zurück">&larr; Zurück</button>
      <img src="/images/logo.png" alt="Fit on Time" />
      <div class="q-right"><span id="qr">1/7</span></div>
    </div>
    <div class="q-progress">
      <div class="q-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Quiz-Fortschritt" id="qbar"><div class="q-fill" id="qf"></div></div>
      <div class="q-meta">
        <span id="qp">Frage 1 von 7</span>
        <span class="q-time" id="qt">&#9201; ~60 Sek.</span>
      </div>
    </div>
    <div class="q-body">

      <!-- Q1: Alltag / Zeitdruck -->
      <div class="step on" data-s="1">
        <div class="step-eyebrow">Dein Alltag</div>
        <h2>Bist du beruflich stark ausgelastet?</h2>
        <p class="step-sub">Das hilft uns, den Aufwand an deinen Alltag anzupassen.</p>
        <div class="opts grid-2">
          <button class="opt" onclick="nxt(1,this,'ja')"><span class="opt-ic">&#128338;</span><strong>Ja, oft</strong><span>Wenig Zeit für lange Pläne.</span></button>
          <button class="opt" onclick="nxt(1,this,'nein')"><span class="opt-ic">&#128513;</span><strong>Nein, entspannt</strong><span>Ich habe Zeit für mich.</span></button>
        </div>
      </div>

      <!-- Q2: Hauptziel -->
      <div class="step" data-s="2">
        <div class="step-eyebrow">Dein Fokus</div>
        <h2>Was ist dir am wichtigsten?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(2,this,'aussehen')"><span class="opt-ic">&#128151;</span><div><strong>Besser aussehen</strong><span>Ich möchte mich in meinem Körper wieder wohlfühlen.</span></div></button>
          <button class="opt" onclick="nxt(2,this,'gesundheit')"><span class="opt-ic">&#129505;</span><div><strong>Mehr Gesundheit</strong><span>Fit bleiben, Energie gewinnen, Werte verbessern.</span></div></button>
          <button class="opt" onclick="nxt(2,this,'wohlbefinden')"><span class="opt-ic">&#10024;</span><div><strong>Mehr Wohlbefinden</strong><span>Leichter werden, körperlich und mental.</span></div></button>
          <button class="opt" onclick="nxt(2,this,'abnehmen')"><span class="opt-ic">&#9878;&#65039;</span><div><strong>Nachhaltig abnehmen</strong><span>Kilos dauerhaft los, ohne Jojo.</span></div></button>
        </div>
      </div>

      <!-- Q3: Grösse -->
      <div class="step" data-s="3">
        <div class="step-eyebrow">Deine Werte</div>
        <h2>Wie gross bist du?</h2>
        <div class="opts grid-2">
          <button class="opt" onclick="nxt(3,this,'lt162')"><strong>&lt; 1.62 m</strong></button>
          <button class="opt" onclick="nxt(3,this,'162-168')"><strong>1.63 &ndash; 1.68 m</strong></button>
          <button class="opt" onclick="nxt(3,this,'169-174')"><strong>1.69 &ndash; 1.74 m</strong></button>
          <button class="opt" onclick="nxt(3,this,'gt174')"><strong>&gt; 1.74 m</strong></button>
        </div>
      </div>

      <!-- Q4: Gewicht -->
      <div class="step" data-s="4">
        <div class="step-eyebrow">Deine Werte</div>
        <h2>Wie viel wiegst du aktuell?</h2>
        <p class="step-sub">Deine Angabe bleibt zu 100% privat.</p>
        <div class="opts grid-2">
          <button class="opt" onclick="nxt(4,this,'lt60')"><strong>&lt; 60 kg</strong></button>
          <button class="opt" onclick="nxt(4,this,'60-68')"><strong>60 &ndash; 68 kg</strong></button>
          <button class="opt" onclick="nxt(4,this,'69-77')"><strong>69 &ndash; 77 kg</strong></button>
          <button class="opt" onclick="nxt(4,this,'gt78')"><strong>&gt; 78 kg</strong></button>
        </div>
      </div>

      <!-- Q5: Alter -->
      <div class="step" data-s="5">
        <div class="step-eyebrow">Dein Alter</div>
        <h2>Wie alt bist du?</h2>
        <div class="opts grid-2">
          <button class="opt" onclick="nxt(5,this,'18-28')"><strong>18 &ndash; 28</strong></button>
          <button class="opt" onclick="nxt(5,this,'29-36')"><strong>29 &ndash; 36</strong></button>
          <button class="opt" onclick="nxt(5,this,'37-45')"><strong>37 &ndash; 45</strong></button>
          <button class="opt" onclick="nxt(5,this,'gt45')"><strong>Über 45</strong></button>
        </div>
      </div>

      <!-- Q6: Hauptproblem -->
      <div class="step" data-s="6">
        <div class="step-eyebrow">Deine Herausforderung</div>
        <h2>Was ist dein grösstes Problem beim Abnehmen?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(6,this,'jojo')"><span class="opt-ic">&#128009;</span><div><strong>Jojo-Effekt</strong><span>Ich nehme ab, dann wieder zu. Endloser Kreislauf.</span></div></button>
          <button class="opt" onclick="nxt(6,this,'hunger')"><span class="opt-ic">&#127830;</span><div><strong>Heisshunger</strong><span>Essattacken sabotieren jeden Fortschritt.</span></div></button>
          <button class="opt" onclick="nxt(6,this,'sport')"><span class="opt-ic">&#127947;&#65039;&zwj;&#9792;&#65039;</span><div><strong>Keine Resultate trotz Sport</strong><span>Viel Bewegung, aber die Waage steht still.</span></div></button>
          <button class="opt" onclick="nxt(6,this,'moti')"><span class="opt-ic">&#128167;</span><div><strong>Motivation</strong><span>Ich starte stark, gebe nach 2&ndash;3 Wochen auf.</span></div></button>
        </div>
      </div>

      <!-- Q7 = FINALE FRAGE - entscheidet über die 3 Ergebnisse -->
      <div class="step" data-s="7">
        <div class="step-eyebrow">Letzte Frage</div>
        <h2>Was beschreibt deinen Körperbau am besten?</h2>
        <p class="step-sub">Deine Antwort bestimmt deinen Stoffwechsel-Typ.</p>
        <div class="body-cards">
          <button class="body-card" onclick="nxt(7,this,'staemmig')">
            <div class="bc-visual">
              <svg viewBox="0 0 100 210" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <g fill="currentColor">
                  <ellipse cx="50" cy="18" rx="13" ry="15"/>
                  <path d="M 42 33 L 58 33 L 60 42 C 67 44 70 50 69 57 L 67 72 C 72 76 76 84 76 94 L 78 108 C 80 118 72 126 66 132 L 68 155 L 70 204 L 58 204 L 54 155 L 52 130 L 50 120 L 48 130 L 46 155 L 42 204 L 30 204 L 32 155 L 34 132 C 28 126 20 118 22 108 L 24 94 C 24 84 28 76 33 72 L 31 57 C 30 50 33 44 40 42 Z"/>
                </g>
              </svg>
            </div>
            <div class="bc-body">
              <h3>Stämmig</h3>
              <p>Kurvig, breitere Hüften und kräftige Oberschenkel.</p>
            </div>
          </button>
          <button class="body-card" onclick="nxt(7,this,'soft')">
            <div class="bc-visual">
              <svg viewBox="0 0 100 210" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <g fill="currentColor">
                  <ellipse cx="50" cy="18" rx="11" ry="13"/>
                  <path d="M 43 31 L 57 31 L 59 40 C 64 42 66 48 65 55 L 63 70 C 67 74 69 82 67 91 L 65 108 C 67 116 63 124 60 130 L 62 155 L 65 204 L 55 204 L 53 155 L 51 130 L 50 120 L 49 130 L 47 155 L 45 204 L 35 204 L 38 155 L 40 130 C 37 124 33 116 35 108 L 33 91 C 31 82 33 74 37 70 L 35 55 C 34 48 36 42 41 40 Z"/>
                </g>
              </svg>
            </div>
            <div class="bc-body">
              <h3>Soft</h3>
              <p>Ausgewogene Sanduhr-Silhouette, definierte Taille.</p>
            </div>
          </button>
          <button class="body-card" onclick="nxt(7,this,'zierlich')">
            <div class="bc-visual">
              <svg viewBox="0 0 100 210" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <g fill="currentColor">
                  <ellipse cx="50" cy="18" rx="9" ry="11"/>
                  <path d="M 44 29 L 56 29 L 57 38 C 60 40 61 46 60 53 L 59 72 C 62 76 62 86 61 96 L 60 112 C 61 120 59 128 58 135 L 60 155 L 62 204 L 54 204 L 52 155 L 50 135 L 49 125 L 48 135 L 46 155 L 38 204 L 40 155 L 42 135 C 41 128 39 120 40 112 L 39 96 C 38 86 38 76 41 72 L 40 53 C 39 46 40 40 43 38 Z"/>
                </g>
              </svg>
            </div>
            <div class="bc-body">
              <h3>Zierlich</h3>
              <p>Schmale, feingliedrige Silhouette ohne ausgeprägte Kurven.</p>
            </div>
          </button>
        </div>
      </div>

      <!-- Loading -->
      <div class="step ld" data-s="ld">
        <div class="spinner"></div>
        <h2>Dein Stoffwechsel-Profil wird erstellt</h2>
        <p>Das dauert nur wenige Sekunden...</p>
        <div class="checks">
          <div class="chk" id="c1"><i>&#10003;</i>Antworten analysiert</div>
          <div class="chk" id="c2"><i>&#10003;</i>Stoffwechsel-Typ bestimmt</div>
          <div class="chk" id="c3"><i>&#10003;</i>Persönliche Empfehlung erstellt</div>
        </div>
      </div>

      <!-- Opt-in -->
      <div class="step form" data-s="form">
        <div class="tag">&#10003; Fast geschafft</div>
        <h2>Dein Ergebnis ist fertig.</h2>
        <p class="sub">Trage dich ein, um dein <b>persönliches Stoffwechsel-Profil</b> und den Fahrplan zu sehen.</p>
        <div class="fields">
          <div class="field"><span class="ic" aria-hidden="true">&#128100;</span><input type="text" id="fn" placeholder="Dein Vor- und Nachname" autocomplete="name" aria-label="Vor- und Nachname" required /></div>
          <div class="field"><span class="ic" aria-hidden="true">&#128231;</span><input type="email" id="em" placeholder="Deine E-Mail-Adresse" autocomplete="email" aria-label="E-Mail-Adresse" required /></div>
          <div class="field"><span class="ic" aria-hidden="true">&#128222;</span><span class="pre">+41</span><input type="tel" id="ph" placeholder="Telefonnummer" autocomplete="tel-national" aria-label="Telefonnummer" required /></div>
        </div>
        <p style="font-size:11px;color:var(--text-3);margin:-4px auto 14px;max-width:460px;text-align:center;">Kein Newsletter. Nur dein Ergebnis.</p>
        <div class="cb-row">
          <input type="checkbox" id="ds" />
          <label for="ds">Ich akzeptiere die <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutzbestimmungen</a> und erhalte mein Stoffwechsel-Profil per E-Mail.</label>
        </div>
        <button class="submit" id="sbtn" disabled onclick="send()">Jetzt Ergebnis anzeigen &rarr;</button>
        <div class="form-proof">
          <div class="fp-row"><span>&#128274;</span> <b>SSL-verschlüsselt</b> &middot; Deine Daten bleiben bei uns.</div>
          <div class="fp-row"><span class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span> <b>5.000+</b> zufriedene Teilnehmerinnen</div>
        </div>
      </div>

      {/* Result-Seite lebt in eigenen URLs: /stoffwechsel-test/{typ}/ */}

    </div>
  </div>

  <script is:inline>
    var quizAnswers = {};
    var TOTAL = 7;
    var qHistory = [1];

    // Sticky-CTA zeigen, sobald Hero unsichtbar
    (function stickyCta(){
      var sticky = document.getElementById('stickyCta');
      if (!sticky) return;
      window.addEventListener('scroll', function(){
        var quizOn = document.getElementById('quiz').classList.contains('on');
        if (quizOn) { sticky.classList.remove('show'); return; }
        sticky.classList.toggle('show', window.scrollY > 600);
      }, { passive: true });
    })();

    // Live-Counter leicht variabel für Lebendigkeit
    (function liveCounter(){
      var el = document.getElementById('liveCnt');
      if (!el) return;
      setInterval(function(){
        var n = 8 + Math.floor(Math.random() * 11); // 8 - 18
        el.textContent = n;
      }, 4500);
    })();

    // Tracking (LP Machine Pattern)
    function tk(e, d) {
      var tries = 0;
      function fire() {
        if (window.__lp) {
          window.__lp.track(e, Object.assign({ page: 'stoffwechsel-test' }, d || {}), 'fot', 'Stoffwechsel Test');
          if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'Stoffwechsel Test Quiz Start', currency: 'EUR' });
          if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'Stoffwechsel Test Quiz Complete', currency: 'EUR' });
          if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'Stoffwechsel Test Lead', currency: 'EUR' });
        } else if (tries++ < 40) {
          setTimeout(fire, 50);
        }
      }
      fire();
    }
    tk('page_view');

    function startQuiz() {
      tk('quiz_start');
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0, 0);
    }

    function setProgress(s) {
      var p = Math.round(((s - 1) / TOTAL) * 100);
      document.getElementById('qf').style.width = p + '%';
      var bar = document.getElementById('qbar');
      if (bar) bar.setAttribute('aria-valuenow', p);
      document.getElementById('qr').textContent = s + '/' + TOTAL;
      document.getElementById('qp').textContent = 'Frage ' + s + ' von ' + TOTAL;
      var left = Math.max(10, Math.round((TOTAL - s + 1) * 8));
      document.getElementById('qt').textContent = '⏱ ~' + left + ' Sek.';
      document.getElementById('qback').classList.toggle('hidden', s <= 1);
    }

    function show(s) {
      document.querySelectorAll('.step').forEach(function(el){ el.classList.remove('on'); });
      var target = typeof s === 'number' ? document.querySelector('.step[data-s="' + s + '"]') : document.querySelector('.step[data-s="' + s + '"]');
      if (target) target.classList.add('on');
      if (typeof s === 'number') setProgress(s);
    }

    function nxt(s, el, val) {
      quizAnswers['q' + s] = el ? (el.querySelector('strong') ? el.querySelector('strong').textContent.trim() : el.textContent.trim()) : '';
      quizAnswers['q' + s + '_val'] = val;
      tk('quiz_answer', { detail: 'q' + s + '_' + val });

      // Visuelles Feedback (kurz aufblitzen)
      if (el) el.classList.add('selected');

      setTimeout(function(){
        if (s < TOTAL) {
          var next = s + 1;
          qHistory.push(next);
          show(next);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          tk('quiz_complete');
          load();
        }
      }, 180);
    }

    function back() {
      if (qHistory.length <= 1) return;
      qHistory.pop();
      var prev = qHistory[qHistory.length - 1];
      show(prev);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function load() {
      show('ld');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qr').textContent = 'Auswertung';
      document.getElementById('qp').textContent = 'Dein Profil wird erstellt...';
      document.getElementById('qt').textContent = '⏱ ~5 Sek.';
      document.getElementById('qback').classList.add('hidden');

      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 500);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1300);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2100);
      setTimeout(function(){
        show('form');
        document.getElementById('qp').textContent = 'Fast fertig';
      }, 3100);
    }

    document.getElementById('ds').addEventListener('change', function(){
      document.getElementById('sbtn').disabled = !this.checked;
    });

    function send() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird ausgewertet...';

      // FINALE Frage (Q7) entscheidet über die 3 Ergebnisse
      var typ = quizAnswers.q7_val || 'soft';
      var validTypes = { staemmig: 1, soft: 1, zierlich: 1 };
      if (!validTypes[typ]) typ = 'soft';

      tk('lead_submit', { detail: fn + ' - ' + typ });

      // Lead an Google Sheets
      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fn,
          email: em,
          phone: ph ? '+41' + ph : '',
          answers: Object.assign({}, quizAnswers, { profile_type: typ })
        })
      }).catch(function(){});

      // Personalisierungs-Kontext fuer Result-Page in sessionStorage ablegen
      try {
        sessionStorage.setItem('fot_result', JSON.stringify({
          name: fn.split(' ')[0],
          typ: typ,
          problem: quizAnswers.q6_val,
          goal: quizAnswers.q2_val,
          ts: Date.now()
        }));
      } catch (e) {}

      // Kurzer Loading-Tick, dann Redirect zur typ-spezifischen URL
      setTimeout(function(){
        window.location.href = '/stoffwechsel-test/' + typ + '/';
      }, 600);
    }

  </script>

  {/* Hyros als First-Party-Attribution essentiell - laedt ohne Consent */}
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <CookieBanner
    metaPixelId="1349136525891811"
    consentKey="fot_stoffwechsel_consent"
    impressumUrl={impressumUrl}
    datenschutzUrl={datenschutzUrl}
  />
</body>
</html>
