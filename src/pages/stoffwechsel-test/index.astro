  <script is:inline>
    var quizAnswers = {};
    var TOTAL = 7;
    var qHistory = [1];

    // Sticky-CTA zeigen, sobald Hero unsichtbar
    (function stickyCta(){
      var sticky = document.getElementById('stickyCta');
      if (!sticky) return;
      window.addEventListener('scroll', function(){
        var quizOn = document.getElementById('quiz').classList.contains('on');
        if (quizOn) { sticky.classList.remove('show'); return; }
        sticky.classList.toggle('show', window.scrollY > 600);
      }, { passive: true });
    })();

    // Live-Counter leicht variabel für Lebendigkeit
    (function liveCounter(){
      var el = document.getElementById('liveCnt');
      if (!el) return;
      setInterval(function(){
        var n = 8 + Math.floor(Math.random() * 11); // 8 - 18
        el.textContent = n;
      }, 4500);
    })();

    // Tracking (LP Machine Pattern)
    function tk(e, d) {
      var tries = 0;
      function fire() {
        if (window.__lp) {
          window.__lp.track(e, Object.assign({ page: 'stoffwechsel-test' }, d || {}), 'fot', 'Stoffwechsel Test');
          if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'Stoffwechsel Test Quiz Start', currency: 'EUR' });
          if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'Stoffwechsel Test Quiz Complete', currency: 'EUR' });
          if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'Stoffwechsel Test Lead', currency: 'EUR' });
        } else if (tries++ < 40) {
          setTimeout(fire, 50);
        }
      }
      fire();
    }
    tk('page_view');

    function startQuiz() {
      tk('quiz_start');
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0, 0);
    }

    function setProgress(s) {
      var p = Math.round(((s - 1) / TOTAL) * 100);
      document.getElementById('qf').style.width = p + '%';
      var bar = document.getElementById('qbar');
      if (bar) bar.setAttribute('aria-valuenow', p);
      document.getElementById('qr').textContent = s + '/' + TOTAL;
      document.getElementById('qp').textContent = 'Frage ' + s + ' von ' + TOTAL;
      var left = Math.max(10, Math.round((TOTAL - s + 1) * 8));
      document.getElementById('qt').textContent = '⏱ ~' + left + ' Sek.';
      document.getElementById('qback').classList.toggle('hidden', s <= 1);
    }

    function show(s) {
      document.querySelectorAll('.step').forEach(function(el){ el.classList.remove('on'); });
      var target = typeof s === 'number' ? document.querySelector('.step[data-s="' + s + '"]') : document.querySelector('.step[data-s="' + s + '"]');
      if (target) target.classList.add('on');
      if (typeof s === 'number') setProgress(s);
    }

    function nxt(s, el, val) {
      quizAnswers['q' + s] = el ? (el.querySelector('strong') ? el.querySelector('strong').textContent.trim() : el.textContent.trim()) : '';
      quizAnswers['q' + s + '_val'] = val;
      tk('quiz_answer', { detail: 'q' + s + '_' + val });

      // Visuelles Feedback (kurz aufblitzen)
      if (el) el.classList.add('selected');

      setTimeout(function(){
        if (s < TOTAL) {
          var next = s + 1;
          qHistory.push(next);
          show(next);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          tk('quiz_complete');
          load();
        }
      }, 180);
    }

    function back() {
      if (qHistory.length <= 1) return;
      qHistory.pop();
      var prev = qHistory[qHistory.length - 1];
      show(prev);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function load() {
      show('ld');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qr').textContent = 'Auswertung';
      document.getElementById('qp').textContent = 'Dein Profil wird erstellt...';
      document.getElementById('qt').textContent = '⏱ ~5 Sek.';
      document.getElementById('qback').classList.add('hidden');

      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 500);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1300);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2100);
      setTimeout(function(){
        show('form');
        document.getElementById('qp').textContent = 'Fast fertig';
      }, 3100);
    }

    // 3 Profile - entschieden durch Q7 (Körperbau)
    var PROFILES = {
      endo: {
        title: 'Der Speichertyp',
        label: 'Langsamer Stoffwechsel',
        summary: 'Dein Körper speichert Energie besonders effizient. Evolutionär ein Vorteil, heute eine Herausforderung. Standard-Diäten greifen bei dir kaum, weil dein Körper sofort in den Sparmodus schaltet.',
        food: 'Leichte, warme Kost. Viel Gemüse, Hülsenfrüchte, Ingwer-Tee. Wenig Weizen, Zucker, Milchprodukte.',
        move: 'Tägliche Bewegung ist Pflicht. Krafttraining plus zügiges Walken. Gerade dann, wenn die Motivation fehlt.',
        time: 'Leichtes Frühstück oder 16:8-Fasten. Hauptmahlzeit mittags. Nichts Schweres nach 18 Uhr.',
        mistake: 'Zu wenig essen, kaum bewegen. Crash-Diäten verlangsamen deinen Stoffwechsel weiter.',
        video: 'g7g5ttzij5'
      },
      meso: {
        title: 'Der Allrounder',
        label: 'Ausgewogener Stoffwechsel',
        summary: 'Dein Körper reagiert gut auf Training und Ernährungsumstellungen. Du baust leichter Muskeln auf und kannst auch gezielt abnehmen. Dein Problem ist selten der Körper, sondern die Konstanz.',
        food: 'Ausgewogene Makros: 40% Kohlenhydrate, 30% Protein, 30% Fett. Viel Gemüse und magere Proteine.',
        move: 'Mix aus Kraft und Cardio. HIIT 2x pro Woche, Krafttraining 2&ndash;3x pro Woche.',
        time: '3 feste Mahlzeiten. Optional 1 Protein-Snack nach dem Training. Abends leichter essen.',
        mistake: 'Sich auf natürliche Fitness verlassen und nachlässig werden. Ohne Struktur kommt auch bei dir der Stillstand.',
        video: 'b6bkslxgxy'
      },
      ecto: {
        title: 'Der Verbrennungstyp',
        label: 'Schneller Stoffwechsel',
        summary: 'Dein Stoffwechsel arbeitet schnell, verbrennt aber oft die falschen Energiequellen. Du nimmst nicht leicht zu, verlierst aber schnell Muskeln statt Fett. Dein Körper braucht regelmässige, nährstoffreiche Mahlzeiten.',
        food: 'Proteinreiche Mahlzeiten, komplexe Kohlenhydrate, gesunde Fette. Nie eine Mahlzeit auslassen.',
        move: 'Krafttraining 3x pro Woche, leichtes Cardio. Zu viel Ausdauer verbrennt wertvolle Muskelmasse.',
        time: '3 Hauptmahlzeiten plus 2 Snacks. Frühstück innerhalb 30 Min. nach dem Aufstehen.',
        mistake: 'Mahlzeiten auslassen oder nur Salat essen. Dein Körper hält dann an jeder Kalorie fest.',
        video: 'zuef2ev1j4'
      }
    };

    function personalize(p) {
      var prob = quizAnswers.q6_val;
      var extra = '';
      if (prob === 'hunger') extra = ' Dein Heisshunger deutet auf schwankenden Blutzucker hin, das lösen wir mit dem richtigen Mahlzeiten-Timing.';
      else if (prob === 'jojo') extra = ' Der Jojo-Effekt zeigt: Bisherige Ansätze haben deinen Typ ignoriert. Unser Ansatz setzt genau da an.';
      else if (prob === 'sport') extra = ' Wenn Sport nicht wirkt, stimmt das Verhältnis zwischen Training und Ernährung nicht, genau das optimieren wir.';
      else if (prob === 'moti') extra = ' Die Motivation bricht ein, wenn dein Plan zu viel von dir will. Deiner wird an deinen Alltag angepasst.';
      return p.summary + extra;
    }

    document.getElementById('ds').addEventListener('change', function(){
      document.getElementById('sbtn').disabled = !this.checked;
    });

    function send() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird ausgewertet...';

      // FINALE Frage (Q7) entscheidet über die 3 Ergebnisse
      var typ = quizAnswers.q7_val || 'meso';
      var p = PROFILES[typ] || PROFILES.meso;
      tk('lead_submit', { detail: fn + ' - ' + typ });

      // Lead an Google Sheets
      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: fn,
          email: em,
          phone: ph ? '+41' + ph : '',
          answers: Object.assign({}, quizAnswers, { profile_type: typ })
        })
      }).catch(function(){});

      setTimeout(function(){
        // Profil-Texte einsetzen
        document.getElementById('rLabel').textContent = p.label;
        document.getElementById('rTitle').textContent = p.title;
        document.getElementById('rSummary').textContent = personalize(p);
        document.getElementById('rFood').textContent = p.food;
        document.getElementById('rMove').innerHTML = p.move;
        document.getElementById('rTime').textContent = p.time;
        document.getElementById('rMistake').textContent = p.mistake;

        // Wistia-Video laden
        var wc = document.getElementById('wistia-container');
        var wd = document.createElement('div');
        wd.className = 'wistia_embed wistia_async_' + p.video;
        wd.style.cssText = 'width:100%;aspect-ratio:16/9;';
        wc.appendChild(wd);
        var ws = document.createElement('script');
        ws.src = 'https://fast.wistia.com/assets/external/E-v1.js';
        ws.async = true;
        wc.appendChild(ws);

        // YCBM-Kalender
        var ys = document.createElement('script');
        ys.src = 'https://embed.ycb.me';
        ys.async = true;
        ys.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
        ys.setAttribute('data-displaymode', 'auto');
        document.getElementById('ycbm-container').appendChild(ys);

        show('result');
        document.querySelector('.step[data-s="result"]').style.display = 'block';
        document.getElementById('qp').textContent = 'Dein Ergebnis';
        document.getElementById('qt').textContent = '✓ Geschafft';
        tk('result_shown', { detail: typ + '_' + p.video });

        // Scarcity-Variation
        var s = document.getElementById('spots');
        if (s) s.textContent = 5 + Math.floor(Math.random() * 4); // 5-8
      }, 1000);
    }
  </script>

