            <div class="bc-visual">
              <svg viewBox="0 0 100 160" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <ellipse cx="50" cy="20" rx="11" ry="13"/>
                <path d="M34 42 Q50 36 66 42 L72 98 Q72 116 60 122 L57 155 L52 155 L51 125 L49 125 L48 155 L43 155 L40 122 Q28 116 28 98 Z"/>
