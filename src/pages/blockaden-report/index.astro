    .scarcity { background: #fff8ed; border: 1px solid #fde68a; border-radius: var(--r); padding: 16px; margin: 16px 0; text-align: center; }
    .scarcity .sc-title { font-size: 13px; font-weight: 800; color: var(--amber); margin-bottom: 4px; display: flex; align-items: center; justify-content: center; gap: 6px; }
