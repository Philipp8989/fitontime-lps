    .result-testi { background: #fff; border: 1px solid #e8e4da; border-radius: var(--r); padding: 16px; display: flex; gap: 12px; align-items: flex-start; margin: 16px 0; text-align: left; border-left: 4px solid var(--type, var(--accent)); }
