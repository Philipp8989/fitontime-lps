    .result-testi .rt-body { flex: 1; min-width: 0; }
    .result-testi .rt-stars { color: var(--amber); font-size: 12px; letter-spacing: 1px; margin-bottom: 2px; }
    .result-testi .rt-quote { font-size: 13px; color: var(--text-2); line-height: 1.5; margin-bottom: 6px; font-style: italic; }
    .result-testi .rt-name { font-size: 11px; color: var(--text-3); font-weight: 600; }
    .result-testi .rt-name b { color: var(--text-2); }

    /* Desktop */
