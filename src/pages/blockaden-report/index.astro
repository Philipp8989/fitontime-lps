  <!-- ===== QUIZ ===== -->
  <div id="quiz">
    <div class="q-head"><img src="/images/logo.png" alt="Fit on Time" /></div>
    <div class="q-progress"><div class="q-bar"><div class="q-fill" id="qf"></div></div><div class="q-num" id="qn">1 / 11</div></div>
    <div class="q-body">

      <!-- Frage 1: Körperbau -->
      <div class="step on" data-s="1">
        <h2>Welcher Körperbau beschreibt dich am besten?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(1,'vata')"><strong>Schlank, zierlich, schmale Schultern</strong><span>Ich nehme schwer zu, verliere aber auch schnell Gewicht. Mein Körper ist eher dünn.</span></button>
          <button class="opt" onclick="nxt(1,'pitta')"><strong>Mittel, muskulös, athletisch</strong><span>Ich baue leicht Muskeln auf und habe ausgewogene Proportionen.</span></button>
          <button class="opt" onclick="nxt(1,'kapha')"><strong>Kräftig, rundlich, breite Hüften</strong><span>Ich nehme leicht zu, besonders an Hüften und Oberschenkeln. Mein Körper ist weich und rund.</span></button>
        </div>
      </div>

      <!-- Frage 2: Wo nimmst du zu -->
      <div class="step" data-s="2">
        <h2>Wo nimmst du als ERSTES zu?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(2,'vata')"><strong>Überall ein bisschen, aber nie wirklich viel</strong><span>Mein Gewicht schwankt um 2-3 Kilo, grundsätzlich bin ich eher schlank.</span></button>
          <button class="opt" onclick="nxt(2,'pitta')"><strong>Gleichmässig am Körper, vor allem am Bauch</strong><span>Wenn ich zunehme, sehe ich es zuerst am Bauch und der Taille.</span></button>
          <button class="opt" onclick="nxt(2,'kapha')"><strong>Hüften, Oberschenkel, Po. Die Problemzonen.</strong><span>Mein Unterkörper speichert Fett am schnellsten.</span></button>
        </div>
      </div>

      <!-- Frage 3: Appetit -->
      <div class="step" data-s="3">
        <h2>Wie würdest du deinen Appetit beschreiben?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(3,'vata')"><strong>Unregelmässig, mal Heisshunger, mal vergesse ich zu essen</strong><span>Mein Hunger kommt in Wellen, manchmal riesig, dann stundenlang keiner.</span></button>
          <button class="opt" onclick="nxt(3,'pitta')"><strong>Stark &amp; regelmässig. Ich MUSS pünktlich essen.</strong><span>Wenn ich Hunger habe, wird es schnell ernst. Ich werde gereizt und brauche JETZT Essen.</span></button>
          <button class="opt" onclick="nxt(3,'kapha')"><strong>Moderat &amp; stabil, ich könnte Mahlzeiten auslassen</strong><span>Ich habe selten richtigen Hunger, esse oft aus Gewohnheit.</span></button>
        </div>
      </div>

      <!-- Frage 4: Energielevel -->
      <div class="step" data-s="4">
        <h2>Was beschreibt dein Energielevel am besten?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(4,'vata')"><strong>In Schüben. Mal super energiegeladen, dann platt.</strong><span>Meine Energie ist wie eine Achterbahn. Hyperaktiv, dann komplett erschöpft.</span></button>
          <button class="opt" onclick="nxt(4,'pitta')"><strong>Konstant hoch, aber ich brenne schnell aus</strong><span>Ich bin meist sehr aktiv. Aber wenn ich übertreibe, komme ich ins Burn-out.</span></button>
          <button class="opt" onclick="nxt(4,'kapha')"><strong>Gleichmässig, aber eher niedrig, ich bin oft müde</strong><span>Morgens komme ich schwer in die Gänge. Energie stabil, aber nie wirklich hoch.</span></button>
        </div>
      </div>

      <!-- Frage 5: Schlaf -->
      <div class="step" data-s="5">
        <h2>Wie schläfst du?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(5,'vata')"><strong>Leichter Schlaf, wache oft auf, Gedankenkarussell</strong><span>Meine Gedanken rasen beim Einschlafen. Jedes Geräusch weckt mich.</span></button>
          <button class="opt" onclick="nxt(5,'pitta')"><strong>Mittlerer Schlaf, 6-7 Stunden, wache ausgeruht auf</strong><span>Ich schlafe gut, aber nicht zu tief. Brauche nicht viel Schlaf.</span></button>
          <button class="opt" onclick="nxt(5,'kapha')"><strong>Tiefer, langer Schlaf, könnte 9+ Stunden schlafen</strong><span>Ich liebe schlafen. Morgens werde ich schwer wach.</span></button>
        </div>
      </div>

      <!-- Frage 6: Stress -->
      <div class="step" data-s="6">
        <h2>Wie reagierst du auf Stress?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(6,'vata')"><strong>Nervosität, Angst, innere Unruhe</strong><span>Stress macht mich ängstlich. Ich mache mir Sorgen und kann nicht abschalten.</span></button>
          <button class="opt" onclick="nxt(6,'pitta')"><strong>Gereiztheit, Wut, Perfektionismus</strong><span>Unter Stress werde ich ungeduldig und kritisch, mit mir und anderen.</span></button>
          <button class="opt" onclick="nxt(6,'kapha')"><strong>Rückzug, Antriebslosigkeit, Emotional Eating</strong><span>Stress lässt mich emotional essen. Ich ziehe mich zurück, keine Motivation.</span></button>
        </div>
      </div>

      <!-- Frage 7: Heisshunger -->
      <div class="step" data-s="7">
        <h2>Worauf hast du am ehesten Heisshunger?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(7,'vata')"><strong>Knuspriges, Salziges, Kaffee</strong><span>Chips, Cracker, Kaffee. Ich mag trockene, knusprige Sachen.</span></button>
          <button class="opt" onclick="nxt(7,'pitta')"><strong>Kaltes, Süsses, Erfrischendes</strong><span>Eis, Schokolade, kalte Getränke. Ich mag kühlende, süsse Sachen.</span></button>
          <button class="opt" onclick="nxt(7,'kapha')"><strong>Cremiges, Schweres, Brot &amp; Pasta</strong><span>Käse, Pasta, Brot, Kuchen. Herzhafte, schwere Comfort-Foods.</span></button>
        </div>
      </div>

      <!-- Frage 8: Temperatur -->
      <div class="step" data-s="8">
        <h2>Wie ist dir meistens?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(8,'vata')"><strong>Oft kalt, kalte Hände &amp; Füsse</strong><span>Ich friere schnell und brauche immer eine Jacke. Meine Hände sind oft eiskalt.</span></button>
          <button class="opt" onclick="nxt(8,'pitta')"><strong>Eher warm, schwitze schnell</strong><span>Mir ist selten kalt. Ich schwitze leicht und mag kühle Räume.</span></button>
          <button class="opt" onclick="nxt(8,'kapha')"><strong>Wechselnd, aber generell robust</strong><span>Ich komme mit verschiedenen Temperaturen klar.</span></button>
        </div>
      </div>

      <!-- Frage 9: Training-Vorlieben -->
      <div class="step" data-s="9">
        <h2>Was beschreibt deine Trainings-Vorlieben?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(9,'vata')"><strong>Ich mag Abwechslung, neue Kurse, Tanz, Yoga</strong><span>Routine langweilt mich. Ich brauche ständig neue Reize.</span></button>
          <button class="opt" onclick="nxt(9,'pitta')"><strong>Ich mag Wettkampf, Challenges, intensives Training</strong><span>HIIT, Crossfit, Laufen. Je intensiver, desto besser.</span></button>
          <button class="opt" onclick="nxt(9,'kapha')"><strong>Ich bevorzuge sanftes, konstantes Training wie Walken</strong><span>Ich mag gemütliches Training. Zu intensiv demotiviert mich.</span></button>
        </div>
      </div>

      <!-- Frage 10: Eigenschaft -->
      <div class="step" data-s="10">
        <h2>Welche Eigenschaft trifft am ehesten auf dich zu?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(10,'vata')"><strong>Kreativ, spontan, unruhig</strong><span>Ich habe viele Ideen, springe aber oft von einem zum nächsten. Routine stresst mich.</span></button>
          <button class="opt" onclick="nxt(10,'pitta')"><strong>Fokussiert, ehrgeizig, perfektionistisch</strong><span>Ich bin zielorientiert und will alles richtig machen. Ich kritisiere mich stark.</span></button>
          <button class="opt" onclick="nxt(10,'kapha')"><strong>Geduldig, gemütlich, beständig</strong><span>Ich bin der ruhige Pol. Brauche Zeit für Veränderungen, dann halte ich aber durch.</span></button>
        </div>
      </div>

      <!-- Frage 11: Abnehm-Erfahrung -->
      <div class="step" data-s="11">
        <h2>Was beschreibt deine Abnehm-Erfahrung am besten?</h2>
        <div class="opts">
          <button class="opt" onclick="nxt(11,'vata')"><strong>Mein Gewicht schwankt ständig (Jojo-Effekt)</strong><span>Ich nehme schnell ab, aber genauso schnell wieder zu. Mein Gewicht ist nie stabil.</span></button>
          <button class="opt" onclick="nxt(11,'pitta')"><strong>Wenn ich will, schaffe ich es, aber nur mit extremer Disziplin</strong><span>Ich kann abnehmen, wenn ich einen Plan habe. Aber nur mit knallharter Konsequenz.</span></button>
          <button class="opt" onclick="nxt(11,'kapha')"><strong>Ich tue mir SEHR schwer mit dem Abnehmen</strong><span>Egal was ich versuche, mein Körper hält das Gewicht. Jedes Kilo ist ein Kampf.</span></button>
        </div>
      </div>

      <!-- Loading -->
      <div class="step ld" data-s="ld">
        <div class="spinner"></div>
        <h2>Wir analysieren deine Antworten...</h2>
        <p>Dein Ayurveda-Typ wird gleich bestimmt</p>
        <div class="checks">
          <div class="chk" id="c1"><i>&#10003;</i>Antworten analysiert</div>
          <div class="chk" id="c2"><i>&#10003;</i>Dosha-Score berechnet</div>
          <div class="chk" id="c3"><i>&#10003;</i>Persönlicher Plan erstellt</div>
        </div>
      </div>

      <!-- Formular -->
      <div class="step form" data-s="form">
        <div class="tag">&#10003; Geschafft!</div>
        <h2>Dein Ayurveda-Typ ist bereit</h2>
        <p class="sub">Um zu erfahren welcher Typ du bist, trage dich hier ein.<br/>Im nächsten Schritt siehst du dein Ergebnis und einen Plan, der auf deinen Typen zugeschnitten ist.</p>
        <div class="fields">
          <div class="field"><span class="ic">&#128075;</span><input type="text" id="fn" placeholder="Dein Vor- und Nachname" required /></div>
          <div class="field"><span class="ic">&#128236;</span><input type="email" id="em" placeholder="Deine E-Mail" required /></div>
          <div class="field"><span class="ic">&#128222;</span><span class="pre">+41</span><input type="tel" id="ph" placeholder="Deine Telefonnummer" required /></div>
        </div>
        <div class="cb-row">
          <input type="checkbox" id="ds" />
          <label for="ds">Ich akzeptiere die <a href={datenschutzUrl} target="_blank">Datenschutzbestimmungen</a></label>
        </div>
        <button class="submit" id="sbtn" disabled onclick="send()">Jetzt Ergebnis erfahren &#10024;</button>
        <div class="form-proof">
          <div class="fp-row"><span>&#128274;</span> Deine Daten sind sicher &amp; werden nicht weitergegeben</div>
          <div class="fp-row"><span class="proof-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span> <b>2.847+</b> Frauen haben teilgenommen</div>
        </div>
      </div>

      <!-- Ergebnis-Seite (dynamisch Dosha-spezifisch) -->
      <div class="step result" data-s="result" id="result-step" style="display:none;">
        <div class="dosha-hero">
          <span class="dosha-symbol" id="d-symbol">&#128165;</span>
          <div class="dosha-label" id="d-label">Dein Ayurveda-Typ</div>
          <h2 class="dosha-name"><span id="d-name-prefix">Du bist der</span> <span class="type-word" id="d-type">PITTA</span>-Typ</h2>
          <div class="dosha-archetype" id="d-archetype">Die Ehrgeizige Perfektionistin</div>
          <div class="dosha-elements" id="d-elements">Feuer &middot; Wasser</div>
        </div>

        <div class="notice-card">
          <strong>&#9888; Wichtig</strong> &middot; Die meisten Menschen sind Mischformen aus verschiedenen Doshas. Deinen exakten typ-basierten Plan bekommst du im kostenlosen Strategie-Call mit uns.
        </div>

        <div class="r-section problem-card">
          <h3><span class="h3-emoji">&#128293;</span>Dein Abnehm-Problem</h3>
          <p id="d-problem"></p>
        </div>

        <div class="r-section solution-card">
          <h3><span class="h3-emoji">&#128161;</span>Die Lösung für dich</h3>
          <p id="d-solution-intro"></p>
          <ul class="solution-tips" id="d-tips"></ul>
        </div>

        <div class="mantra">
          <div class="m-label">Dein Abnehm-Mantra</div>
          <div class="m-quote" id="d-mantra"></div>
        </div>

        <div class="result-cta-box">
          <h3>Hol dir deinen persönlichen <span id="d-type2">PITTA</span>-Plan</h3>
          <p class="rc-sub">Im kostenlosen Strategie-Call besprechen wir deinen exakten Typ und was JETZT zählt.</p>
          <ul class="result-bullets">
            <li>Dein <strong>individueller</strong> Typ-basierter Plan (nicht die Standard-Diät)</li>
            <li>Welche Lebensmittel deinen Stoffwechsel <strong>bremsen oder ankurbeln</strong></li>
            <li>Das richtige Training für deinen Typ, das <strong>endlich Fett verbrennt</strong></li>
            <li>Wie du ohne Kalorienzählen dauerhaft schlank bleibst</li>
          </ul>
        </div>

        <div class="r-when"><span>&#128197;</span><span>Wann willst du starten?</span></div>

        <!-- YCBM Embed -->
        <div id="ycbm-embed"></div>

        <div class="scarcity">
          <div class="sc-title"><span>&#9888;</span><span>Nur begrenzte Plätze</span></div>
          <p>Wir können nur eine begrenzte Zahl an Strategie-Calls <strong>sofort persönlich anbieten</strong>.</p>
          <p><strong>Sichere dir jetzt deinen Platz</strong>, bevor du auf die Warteliste musst.</p>
          <p>*Erfolgsquote über 95%, 95+ von 100 Frauen erreichen ihre Ziele mit FitonTime in wenigen Monaten.</p>
        </div>

        <!-- Typ-spezifisches Testimonial -->
        <div class="result-testi" id="d-testi">
          <img src="/images/transformations/t5.jpg" alt="" loading="lazy" id="d-testi-img" />
          <div class="rt-body">
            <div class="rt-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
            <p class="rt-quote" id="d-testi-quote"></p>
            <div class="rt-name"><b id="d-testi-name"></b></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script is:inline>
    var quizAnswers = {};
    var scores = { vata: 0, pitta: 0, kapha: 0 };
    var TOTAL = 11;

    function tk(e, d) {
      if (window.__lp) {
        window.__lp.track(e, Object.assign({ page: 'blockaden-report' }, d || {}), 'fot', 'Ayurveda Check');
      }
      if (window.__lp) {
        if (e === 'quiz_start') window.__lp.meta('ViewContent', { content_name: 'Ayurveda Check Quiz Start', currency: 'CHF' });
        if (e === 'quiz_complete') window.__lp.meta('CompleteRegistration', { content_name: 'Ayurveda Check Quiz Complete', currency: 'CHF' });
        if (e === 'lead_submit') window.__lp.meta('Lead', { content_name: 'Ayurveda Check Lead', currency: 'CHF' });
      }
    }
    tk('page_view');

    // Preview-Mode fuer Ergebnis
    if (/[?&]preview=result/.test(window.location.search)) {
      window.addEventListener('DOMContentLoaded', function() {
        var type = (window.location.search.match(/[?&]type=(vata|pitta|kapha)/) || [])[1] || 'pitta';
        scores[type] = 10;
        document.getElementById('lp').style.display = 'none';
        document.getElementById('quiz').classList.add('on');
        document.querySelectorAll('.step').forEach(function(s){ s.classList.remove('on'); });
        showResult('Sarah', type);
      });
    }

    function startQuiz(gender) {
      quizAnswers['gender'] = gender || 'frau';
      tk('quiz_start', { detail: 'gender_' + quizAnswers.gender });
      document.getElementById('lp').style.display = 'none';
      document.getElementById('quiz').classList.add('on');
      window.scrollTo(0,0);
    }

    function nxt(s, val) {
      quizAnswers['q' + s] = val;
      if (scores[val] !== undefined) scores[val]++;
      tk('quiz_answer', { detail: 'q' + s + '_' + val });

      document.querySelector('.step[data-s="' + s + '"]').classList.remove('on');
      if (s < TOTAL) {
        document.querySelector('.step[data-s="' + (s + 1) + '"]').classList.add('on');
        var p = Math.round((s / TOTAL) * 100);
        document.getElementById('qf').style.width = p + '%';
        document.getElementById('qn').textContent = (s + 1) + ' / ' + TOTAL;
        var body = document.querySelector('.q-body');
        if (body) body.scrollTop = 0;
      } else {
        tk('quiz_complete');
        load();
      }
    }

    function load() {
      var ld = document.querySelector('.step[data-s="ld"]');
      ld.classList.add('on');
      document.getElementById('qf').style.width = '100%';
      document.getElementById('qn').textContent = 'Auswertung...';
      setTimeout(function(){ document.getElementById('c1').classList.add('show'); }, 600);
      setTimeout(function(){ document.getElementById('c2').classList.add('show'); }, 1400);
      setTimeout(function(){ document.getElementById('c3').classList.add('show'); }, 2200);
      setTimeout(function(){
        ld.classList.remove('on');
        document.querySelector('.step[data-s="form"]').classList.add('on');
        document.getElementById('qn').textContent = 'Fast fertig';
      }, 3200);
    }

    // Dosha-Typ bestimmen (hoechster Score gewinnt, Tie-Breaker: letzter gewaehlt)
    function determineType() {
      var order = ['vata', 'pitta', 'kapha'];
      var best = order[0];
      for (var i = 1; i < order.length; i++) {
        if (scores[order[i]] > scores[best]) best = order[i];
      }
      return best;
    }

    var DOSHA_DATA = {
      vata: {
        symbol: '\u{1F32C}\u{FE0F}',
        label: 'Dein Dosha',
        archetype: 'Die Kreative Unruhige',
        elements: 'Luft \u00B7 Raum',
        problem: 'Dein Stoffwechsel ist wie ein flackerndes Feuer im Wind, mal brennt es hell, mal geht es fast aus. Du vergisst Mahlzeiten, snackst unregelmässig, und dein Körper weiss nicht, wann die nächste Energie kommt. Er schaltet in den Spar-Modus. Zu viel Training und zu wenig Essen bedeuten Cortisol-Chaos, dein Körper hält jede Kalorie fest.',
        solutionIntro: 'Für Vata gilt: ROUTINE ist dein Freund. Regelmässigkeit, Wärme und Nähren statt Verzicht bringen dein inneres Feuer zurück in Balance.',
        tips: [
          { e: '\u{23F0}', t: 'Iss zu festen Zeiten', b: 'Routine beruhigt dein Nervensystem und stabilisiert den Stoffwechsel.' },
          { e: '\u{1F372}', t: 'Warme, gekochte Mahlzeiten', b: 'Suppen, Eintöpfe, gedünstetes Gemüse. Rohkost verschlimmert Vata.' },
          { e: '\u{1F951}', t: 'Gesunde Fette nähren dich', b: 'Ghee, Avocado, Nüsse beruhigen Vata.' },
          { e: '\u{1F9D8}}', t: 'Sanftes Training statt HIIT', b: 'Yoga, Pilates, lange Spaziergänge, kein tägliches HIIT.' }
        ],
        mantra: '"Weniger ist mehr. Routine statt Chaos. Nähren statt Aushungern."',
        testiImg: '/images/transformations/t3.jpg',
        testiQuote: 'Ich habe jahrelang zu wenig gegessen und zu viel trainiert. Kein Wunder dass nichts funktionierte. Seitdem ich meinen Vata-Plan habe, habe ich meine Wunschfigur erreicht und verzichte auf fast nichts.',
        testiName: 'Lisa, 31'
      },
      pitta: {
        symbol: '\u{1F525}',
        label: 'Dein Dosha',
        archetype: 'Die Ehrgeizige Perfektionistin',
        elements: 'Feuer \u00B7 Wasser',
        problem: 'Dein Stoffwechsel ist wie ein brennendes Feuer: stark, aber auch zerstörerisch, wenn es ausser Kontrolle gerät. Entzündungen, Cortisol-Spikes, Heisshunger-Attacken. HIIT, Stress und scharfes Essen führen zu Pitta-Überschuss, du baust Fett auf, trotz Training.',
        solutionIntro: 'Für Pitta gilt: KÜHLEN ist dein Freund. Weniger Feuer, mehr Balance, sonst verbrennt dein System.',
        tips: [
          { e: '\u{1F96C}', t: 'Kühlende Lebensmittel', b: 'Gurke, Melone, Kokosnuss, süsses Obst. Weniger Chili und Koffein.' },
          { e: '\u{1F9D8}}', t: 'Moderates Training statt HIIT', b: 'Krafttraining und Yoga, kein tägliches HIIT. Dein Feuer ist schon gross genug.' },
          { e: '\u{1F9D8}}', t: 'Stressmanagement ist Pflicht', b: 'Meditation, Atemübungen, bewusste Pausen. Sonst brennst du aus.' },
          { e: '\u{1F9CA}', t: 'Kalte Duschen helfen', b: 'Regulieren deinen inneren Thermostat, reduzieren Entzündungen.' }
        ],
        mantra: '"Weniger Druck. Mehr Kühle. Loslassen statt Kontrollieren."',
        testiImg: '/images/transformations/t5.jpg',
        testiQuote: 'Ich habe HIIT gemacht wie eine Besessene, 6x pro Woche. Und trotzdem: Bauchfett. Seitdem ich mit FitonTime meinen PITTA-Plan entworfen habe, schmilzt das Fett endlich.',
        testiName: 'Nina, 35'
      },
      kapha: {
        symbol: '\u{1F332}',
        label: 'Dein Dosha',
        archetype: 'Die Geduldige Beständige',
        elements: 'Erde \u00B7 Wasser',
        problem: 'Dein Stoffwechsel ist wie ein nasses Lagerfeuer, schwer zu entfachen, schwer in Gang zu halten. Du isst nicht viel, bewegst dich, und trotzdem hält dein Körper jedes Gramm Fett fest. Dein Stoffwechsel ist einfach LANGSAM. Zu viel schwere, cremige Nahrung führt zu Wassereinlagerungen und Gewichtszunahme.',
        solutionIntro: 'Für Kapha gilt: AKTIVIEREN ist dein Freund. Leichtigkeit, Bewegung und Wärme kurbeln deinen trägen Stoffwechsel an.',
        tips: [
          { e: '\u{1F963}', t: 'Warme, leichte Mahlzeiten', b: 'Gedünstetes Gemüse, Hülsenfrüchte, Suppen. Weniger Weizen und Milchprodukte.' },
          { e: '\u{1F3C3}}', t: 'Mehr Bewegung, jeden Tag', b: 'Cardio, Krafttraining, tägliche Spaziergänge. Stillstand verschlimmert Kapha.' },
          { e: '\u{1F305}', t: 'Morgens früh aufstehen', b: 'Kapha-Zeit ist 6 bis 10 Uhr. Hier Bewegung ist am effektivsten.' },
          { e: '\u{1F336}\u{FE0F}', t: 'Scharfe, warme Gewürze', b: 'Ingwer, Kurkuma, Pfeffer aktivieren deinen Stoffwechsel.' }
        ],
        mantra: '"Leichtigkeit statt Schwere. Bewegung statt Couch. Aktivierung statt Trägheit."',
        testiImg: '/images/transformations/t8.jpg',
        testiQuote: 'Jahrelang dachte ich, ich muss noch weniger essen. Aber mein Problem war nicht die Menge, es war die ART der Lebensmittel. Seitdem ich mit FitonTime meinen KAPHA-Plan habe, habe ich 13 Kilo abgenommen.',
        testiName: 'Andrea, 38'
      }
    };

    function showResult(firstName, type) {
      var data = DOSHA_DATA[type];
      var typeUpper = type.toUpperCase();

      // Result-Element mit Typ-Klasse versehen (fuer Farbe)
      var resultEl = document.getElementById('result-step');
      resultEl.classList.remove('vata', 'pitta', 'kapha');
      resultEl.classList.add(type);
      resultEl.style.display = 'block';
      resultEl.classList.add('on');

      // Header
      document.getElementById('d-symbol').textContent = data.symbol;
      document.getElementById('d-name-prefix').textContent = (firstName ? firstName + ', du bist der' : 'Du bist der');
      document.getElementById('d-type').textContent = typeUpper;
      document.getElementById('d-type2').textContent = typeUpper;
      document.getElementById('d-archetype').textContent = data.archetype;
      document.getElementById('d-elements').textContent = data.elements;

      // Problem & Solution
      document.getElementById('d-problem').textContent = data.problem;
      document.getElementById('d-solution-intro').textContent = data.solutionIntro;

      // Tips
      var tipsHtml = data.tips.map(function(tip) {
        return '<li><span class="tip-emoji">' + tip.e + '</span><div class="tip-body"><span class="tip-title">' + tip.t + '</span>' + tip.b + '</div></li>';
      }).join('');
      document.getElementById('d-tips').innerHTML = tipsHtml;

      // Mantra
      document.getElementById('d-mantra').textContent = data.mantra;

      // Testi
      document.getElementById('d-testi-img').src = data.testiImg;
      document.getElementById('d-testi-quote').textContent = data.testiQuote;
      document.getElementById('d-testi-name').textContent = data.testiName + ' \u00B7 ' + typeUpper + '-Typ';

      // YCBM Embed
      var embed = document.getElementById('ycbm-embed');
      if (embed && !embed.hasChildNodes()) {
        var ycbm = document.createElement('script');
        ycbm.src = 'https://embed.ycb.me';
        ycbm.async = true;
        ycbm.setAttribute('data-domain', 'fitontime-stoffwechsel-report');
        ycbm.setAttribute('data-displaymode', 'auto');
        embed.appendChild(ycbm);
      }

      document.getElementById('qn').textContent = 'Dein ' + typeUpper + '-Typ';
      var body = document.querySelector('.q-body');
      if (body) body.scrollTop = 0;
    }

    document.getElementById('ds').addEventListener('change', function() {
      document.getElementById('sbtn').disabled = !this.checked;
    });

    function send() {
      var fn = document.getElementById('fn').value.trim();
      var em = document.getElementById('em').value.trim();
      var ph = document.getElementById('ph').value.trim();
      if (!fn || !em || !ph) {
        if (!fn) document.getElementById('fn').parentElement.style.borderColor = 'var(--red)';
        if (!em) document.getElementById('em').parentElement.style.borderColor = 'var(--red)';
        if (!ph) document.getElementById('ph').parentElement.style.borderColor = 'var(--red)';
        return;
      }
      var btn = document.getElementById('sbtn');
      btn.disabled = true;
      btn.textContent = 'Wird ausgewertet...';

      var type = determineType();
      quizAnswers.dosha_type = type;
      quizAnswers.vata_score = scores.vata;
      quizAnswers.pitta_score = scores.pitta;
      quizAnswers.kapha_score = scores.kapha;

      tk('lead_submit', { detail: fn + ' - ' + type });

      fetch('/api/sheets', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          lp_slug: 'blockaden-report',
          lp_name: 'Ayurveda Check',
          name: fn,
          email: em,
          phone: ph ? '+41' + ph : '',
          answers: quizAnswers
        })
      }).catch(function(){});

      setTimeout(function(){
        var firstName = (fn.split(' ')[0] || '').trim();
        document.querySelector('.step[data-s="form"]').classList.remove('on');
        showResult(firstName, type);
        tk('result_shown', { detail: type });
      }, 1200);
    }
  </script>

  {/* Hyros als First-Party-Attribution essentiell  -  laedt ohne Consent */}
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <CookieBanner
    metaPixelId="1349136525891811"
    consentKey="fot_ayurveda_check_consent"
    impressumUrl={impressumUrl}
    datenschutzUrl={datenschutzUrl}
  />
</body>
