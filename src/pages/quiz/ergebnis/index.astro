---
// /quiz/ergebnis - Ergebnisseite des 60-Sekunden Stoffwechsel-Quiz
// Inhalte 1:1 aus dem Original-Funnel (Bullets + Filip Mursic Block)
import CookieBanner from '../../../components/CookieBanner.astro';

const LP_SLUG = 'quiz';
const LP_NAME = '60-Sekunden Stoffwechsel-Quiz, Ergebnis';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Dein Ergebnis | 60-Sekunden Stoffwechsel-Quiz</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preload" as="image" href="/quiz/logo.png" fetchpriority="high" />
  <link rel="preload" as="image" href="/quiz/filip-mursic.jpg" fetchpriority="high" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" rel="stylesheet" />

  {HYROS_ID && <script is:inline src={`https://t.hyros.com/v1/lst/universal-script?ph=${HYROS_ID}`}></script>}

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      font-family: 'Lato', sans-serif;
      background: #ffffff;
      color: #000000;
      font-size: 14px;
      line-height: 1.4;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: 1170px; margin: 0 auto; padding: 0 15px; }

    .logo-row { padding: 30px 0 0; text-align: center; }
    .logo-row img { max-width: 280px; width: 100%; height: auto; display: inline-block; }

    .spacing { height: 30px; }

    /* Result-Hero */
    .result-hero {
      text-align: center;
      padding: 30px 20px 10px;
      max-width: 760px;
      margin: 0 auto;
    }
    .result-badge {
      display: inline-block;
      background: #e8f5ea;
      color: #1c7c34;
      font-size: 12px;
      font-weight: 700;
      padding: 6px 14px;
      border-radius: 20px;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .result-hero h1 {
      font-size: 30px;
      font-weight: 900;
      line-height: 1.2;
      color: #000;
      margin: 0 0 10px;
    }
    .result-hero h1 em { font-style: normal; color: #1d73d3; }
    .result-hero p {
      font-size: 16px;
      color: #444;
      max-width: 620px;
      margin: 0 auto;
      line-height: 1.5;
    }

    /* Bullets-Block */
    .editor-headline {
      color: #333;
      font-size: 30px;
      font-weight: 700;
      text-align: center;
      text-shadow: 1px 0 1px #333;
      margin: 40px 0 18px;
      line-height: 1.2;
    }
    .bullet-list {
      list-style: none;
      padding: 0;
      max-width: 720px;
      margin: 0 auto;
    }
    .bullet-list li {
      font-size: 20px;
      text-align: center;
      margin: 10px 0;
      color: #333;
      line-height: 1.4;
    }

    /* Filip-Block */
    .filip-section { background: #fafafa; padding: 50px 0 30px; margin-top: 50px; border-top: 1px solid #eee; }
    .filip-photo {
      max-width: 250px;
      margin: 0 auto 16px;
      text-align: center;
      border-radius: 200px;
      overflow: hidden;
      width: 250px;
      height: 250px;
    }
    .filip-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .testimonials-quote {
      font-size: 18px;
      color: #333;
      text-align: center;
      max-width: 700px;
      margin: 0 auto 24px;
      font-style: italic;
      line-height: 1.5;
      padding: 0 20px;
    }
    .testimonials-quote::before { content: '"'; font-size: 32px; color: #999; margin-right: 4px; }
    .testimonials-quote::after { content: '"'; font-size: 32px; color: #999; margin-left: 4px; }
    .signature {
      text-align: center;
      margin: 0 auto 24px;
      font-size: 15px;
      color: #333;
      line-height: 1.6;
    }
    .signature .name { font-weight: 700; }
    .signature .role { color: #666; }

    /* Primary CTA, leitet zum Booking auf fitontime.ch */
    .primary-cta-wrap { text-align: center; margin: 30px auto 10px; padding: 0 20px; }
    .primary-cta {
      display: inline-block;
      background: #5cb85c;
      color: #fff !important;
      font-size: 18px;
      font-weight: 700;
      padding: 16px 32px;
      border-radius: 6px;
      text-decoration: none !important;
      box-shadow: 0 4px 14px rgba(92,184,92,0.3);
      transition: all 0.2s;
    }
    .primary-cta:hover { background: #4cae4c; transform: translateY(-2px); box-shadow: 0 6px 18px rgba(92,184,92,0.4); }
    .retake-link {
      display: inline-block;
      margin-top: 18px;
      font-size: 14px;
      color: #1d73d3;
      text-decoration: underline;
    }

    .footer-logo { padding: 20px 0; text-align: center; }
    .footer-logo img { max-width: 180px; opacity: 0.55; }

    .footer-legal {
      text-align: center;
      color: rgba(135,135,135,0.61);
      font-size: 12px;
      padding: 10px 15px 30px;
    }
    .footer-legal a { text-decoration: underline; }
    .footer-legal a:hover { color: #555; }

    /* Vimeo Video */
    .video-wrap {
      max-width: 820px;
      margin: 24px auto 10px;
      padding: 0 15px;
    }
    .video-embed {
      padding: 56.25% 0 0 0;
      position: relative;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    }
    .video-embed iframe {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      border: 0;
    }

    /* Modal Overlay + Form */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      z-index: 9999;
      overflow-y: auto;
      padding: 20px;
      align-items: flex-start;
      justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: #fff;
      max-width: 620px;
      width: 100%;
      margin: 30px auto;
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      position: relative;
    }
    .modal-close {
      position: absolute;
      top: 12px; right: 14px;
      background: transparent;
      border: 0;
      font-size: 26px;
      line-height: 1;
      color: #888;
      cursor: pointer;
      z-index: 2;
    }
    .modal-close:hover { color: #000; }
    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 24px;
      border-bottom: 1px solid #eee;
    }
    .modal-header img { max-width: 110px; height: auto; }
    .modal-header .modal-badge {
      color: #777;
      font-size: 13px;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      font-weight: 700;
    }
    .modal-headline {
      background: #8b2418;
      color: #fff;
      font-size: 18px;
      font-weight: 900;
      text-align: center;
      padding: 14px 20px;
      line-height: 1.35;
    }
    .modal-headline u { text-decoration: underline; }
    .modal-body { padding: 22px 28px 8px; }
    .modal-bullets {
      list-style: disc;
      padding-left: 22px;
      margin: 0 0 20px;
    }
    .modal-bullets li {
      font-size: 16px;
      color: #1a1a1a;
      line-height: 1.55;
      margin-bottom: 6px;
    }
    .modal-bullets li b { font-weight: 900; }
    .modal-bullets li u { text-decoration: underline; }
    .field {
      position: relative;
      margin: 0 0 12px;
    }
    .field .icon {
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: #1d73d3;
      font-size: 16px;
      pointer-events: none;
    }
    .field input, .field select {
      width: 100%;
      padding: 14px 14px 14px 44px;
      border: 1px solid #d6d6d6;
      border-radius: 4px;
      background: #fafafa;
      font-size: 15px;
      font-family: inherit;
      color: #222;
      box-sizing: border-box;
      appearance: none;
      -webkit-appearance: none;
    }
    .field input:focus, .field select:focus {
      outline: none;
      border-color: #1d73d3;
      background: #fff;
    }
    .field select { background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path fill='%23666' d='M6 8L0 0h12z'/></svg>"); background-repeat: no-repeat; background-position: right 14px center; padding-right: 36px; }
    .submit-btn {
      width: 100%;
      background: #dc3545;
      color: #fff;
      border: 0;
      padding: 16px 20px;
      font-size: 19px;
      font-weight: 900;
      border-radius: 4px;
      cursor: pointer;
      letter-spacing: 0.3px;
      font-family: inherit;
      margin-top: 4px;
      transition: background 0.15s;
    }
    .submit-btn:hover:not(:disabled) { background: #c1303f; }
    .submit-btn:disabled { background: #999; cursor: not-allowed; }
    .modal-footer {
      text-align: center;
      padding: 14px 20px 24px;
      color: #333;
      font-size: 13px;
      line-height: 1.6;
    }
    .modal-footer div { margin: 2px 0; }
    .form-error {
      color: #c1303f;
      font-size: 13px;
      text-align: center;
      margin: 8px 0 0;
      display: none;
    }
    .form-error.visible { display: block; }

    @media (max-width: 600px) {
      .result-hero h1 { font-size: 24px; }
      .editor-headline { font-size: 24px; }
      .bullet-list li { font-size: 17px; }
      .filip-photo { width: 200px; height: 200px; max-width: 200px; }
      .primary-cta { font-size: 16px; padding: 14px 24px; }
      .modal-headline { font-size: 16px; padding: 12px 16px; }
      .modal-body { padding: 18px 18px 6px; }
      .modal-header { padding: 14px 18px; }
      .modal-header .modal-badge { font-size: 11px; letter-spacing: 1px; }
      .modal-bullets li { font-size: 15px; }
      .submit-btn { font-size: 17px; padding: 14px 18px; }
    }
  </style>
</head>
<body>
  <main>
    <!-- Logo top -->
    <div class="logo-row">
      <img src="/quiz/logo.png" alt="Fit on Time" width="280" height="55" />
    </div>
    <div class="spacing"></div>

    <!-- Result-Hero -->
    <section class="result-hero">
      <span class="result-badge">✓ Dein Ergebnis ist bereit</span>
      <h1>Dein Stoffwechsel ist <em>aktivierbar</em>.</h1>
      <p>Basierend auf deinen Antworten zeigen wir dir, wie du langfristig abnehmen kannst, ohne Verzicht oder JoJo-Effekt.</p>
    </section>

    <!-- Value Video -->
    <section class="video-wrap" id="valueVideo">
      <div class="video-embed">
        <iframe
          src="https://player.vimeo.com/video/690587118?h=25a23ed7fc&badge=0&autopause=0&player_id=0&app_id=58479"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          title="Value Video"
        ></iframe>
      </div>
    </section>

    <!-- Bullets -->
    <section class="container">
      <div class="editor-headline">Mit dieser Methode kannst du herausfinden:</div>
      <ul class="bullet-list">
        <li>💥 Wie du abnehmen kannst ohne Veränderungen</li>
        <li>⏰ Wie du abnehmen kannst ohne viel Zeit aufzuwenden</li>
        <li>🍽️ Wie du langfristig abnehmen kannst ohne Verzicht</li>
        <li>💁‍♀️ Wie du dich wohlfühlen kannst im eigenen Körper</li>
        <li>🎉 Wie du Abnehmen kannst ohne Jojo-Effekt</li>
      </ul>
    </section>

    <!-- Filip Section -->
    <section class="filip-section">
      <div class="container">
        <div class="filip-photo">
          <img src="/quiz/filip-mursic.jpg" alt="Filip Mursic, Gründer der ZSU-Strategie" width="250" height="250" />
        </div>
        <p class="testimonials-quote">Mit diesem 60-Sekunden-Quiz kannst du sehen, ob dein Stoffwechsel "eingeschlafen" ist oder nicht.</p>
        <div class="signature">
          <div class="name">Filip Mursic</div>
          <div class="role">Gründer der ZSU-Strategie</div>
        </div>

        <div class="primary-cta-wrap">
          <button type="button" class="primary-cta" id="openModalBtn">
            Jetzt kostenfreie Analyse sichern »
          </button>
          <br />
          <a href="/quiz/" class="retake-link" id="retakeLink">Quiz neu starten</a>
        </div>

        <div class="spacing"></div>
        <div class="footer-logo">
          <img src="/quiz/logo.png" alt="Fit on Time" width="180" height="35" />
        </div>
        <div class="footer-legal">
          <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Impressum</a> | <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutz</a>
        </div>
      </div>
    </section>
  </main>

  <!-- Lead-Capture Modal -->
  <div class="modal-overlay" id="leadModal" role="dialog" aria-modal="true" aria-labelledby="modalHeadline">
    <div class="modal-box">
      <button type="button" class="modal-close" id="closeModalBtn" aria-label="Schliessen">×</button>
      <div class="modal-header">
        <img src="/quiz/logo.png" alt="Fit on Time" />
        <span class="modal-badge">Kostenlose Beratung</span>
      </div>
      <div class="modal-headline" id="modalHeadline">
        JA, ich möchte kontaktiert werden und <u>das hier</u> haben:
      </div>
      <div class="modal-body">
        <ul class="modal-bullets">
          <li><b>Einen individuellen Fahrplan</b> für die nächsten 6 Wochen</li>
          <li>Wie du <b><u>ohne</u> Kalorienzählen</b> oder viel Disziplin abnimmst</li>
          <li>Wie du <b><u>nie wieder</u></b> an deinen "Problemzonen" Fett zulegst</li>
          <li>Wie du ohne Jojo-Effekt <b>langfristig Schlank</b> bleibst</li>
        </ul>

        <form id="leadForm" novalidate>
          <div class="field">
            <span class="icon">👤</span>
            <input type="text" name="name" id="leadName" placeholder="Dein Vor- & Nachname" autocomplete="name" required />
          </div>
          <div class="field">
            <span class="icon">✉️</span>
            <input type="email" name="email" id="leadEmail" placeholder="Deine E-Mail-Adresse..." autocomplete="email" required />
          </div>
          <div class="field">
            <span class="icon">📞</span>
            <input type="tel" name="phone" id="leadPhone" placeholder="Deine Handynummer..." autocomplete="tel" required />
          </div>
          <div class="field">
            <span class="icon">⏰</span>
            <select name="erreichbar" id="leadErreichbar" required>
              <option value="" disabled selected>Wann bist du erreichbar?</option>
              <option value="Vormittags (08-12 Uhr)">Vormittags (08-12 Uhr)</option>
              <option value="Mittags (12-14 Uhr)">Mittags (12-14 Uhr)</option>
              <option value="Nachmittags (14-17 Uhr)">Nachmittags (14-17 Uhr)</option>
              <option value="Abends (17-20 Uhr)">Abends (17-20 Uhr)</option>
              <option value="Flexibel">Flexibel</option>
            </select>
          </div>
          <button type="submit" class="submit-btn" id="leadSubmit">Weiter ➜</button>
          <p class="form-error" id="formError">Bitte alle Felder korrekt ausfüllen.</p>
        </form>
      </div>
      <div class="modal-footer">
        <div>📅 <b>Freie Plätze i.d.R. schnell vergeben.</b></div>
        <div>⏰ Dauer ca. 45 Minuten.</div>
      </div>
    </div>
  </div>

  <CookieBanner metaPixelId={PIXEL_ID} hyrosPh={HYROS_ID} impressumUrl={IMPRESSUM_URL} datenschutzUrl={DATENSCHUTZ_URL} consentKey="lp_consent_quiz" />

  <script is:inline define:vars={{ LP_SLUG, LP_NAME }}>
    // Tracking auf Ergebnisseite
    const SESSION_KEY = `${LP_SLUG}_session`;
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }

    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({
        event, lp: LP_SLUG, lp_name: LP_NAME, session, step: 'ergebnis',
      }, extra || {}));
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
          return;
        }
      } catch (e) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }

    track('result_view');

    document.getElementById('retakeLink')?.addEventListener('click', () => track('result_retake_click'));

    // Modal: open / close
    const modal = document.getElementById('leadModal');
    const openBtn = document.getElementById('openModalBtn');
    const closeBtn = document.getElementById('closeModalBtn');
    const formError = document.getElementById('formError');

    function openModal() {
      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
      track('modal_open');
      setTimeout(() => document.getElementById('leadName')?.focus(), 100);
    }
    function closeModal() {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    }
    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.classList.contains('open')) closeModal(); });

    // Form-Submit -> /api/sheets -> /quiz/danke
    const form = document.getElementById('leadForm');
    const submitBtn = document.getElementById('leadSubmit');

    function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      formError.classList.remove('visible');

      const name = document.getElementById('leadName').value.trim();
      const email = document.getElementById('leadEmail').value.trim();
      const phone = document.getElementById('leadPhone').value.trim();
      const erreichbar = document.getElementById('leadErreichbar').value;

      if (!name || name.length < 2 || !isValidEmail(email) || phone.length < 5 || !erreichbar) {
        formError.textContent = 'Bitte alle Felder korrekt ausfüllen.';
        formError.classList.add('visible');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Wird gesendet…';
      track('lead_submit_attempt');

      try {
        const res = await fetch('/api/sheets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name, email, phone,
            lp_slug: LP_SLUG,
            lp_name: LP_NAME,
            session_id: session,
            answers: { erreichbar },
          }),
        });
        if (!res.ok) throw new Error('server');
        // Lead-Daten kurzfristig fuer Danke-Seite vorhalten (nur Vorname)
        try { sessionStorage.setItem('lead_firstname', name.split(/\s+/)[0] || ''); } catch (_) {}
        track('lead_submit_success');
        window.location.href = '/quiz/danke';
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Weiter ➜';
        formError.textContent = 'Etwas ist schiefgelaufen. Bitte erneut versuchen.';
        formError.classList.add('visible');
        track('lead_submit_error');
      }
    });
  </script>
</body>
</html>
