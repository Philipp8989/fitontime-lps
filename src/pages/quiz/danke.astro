---
// /quiz/danke - Danke-Seite nach Lead-Submit, mit YCBM-Booking eingebettet
import CookieBanner from '../../components/CookieBanner.astro';

const LP_SLUG = 'quiz';
const LP_NAME = '60-Sekunden Stoffwechsel-Quiz, Danke';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Danke! Termin sichern | Fit on Time</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&display=swap" rel="stylesheet" />

  {HYROS_ID && <script is:inline src={`https://t.hyros.com/v1/lst/universal-script?ph=${HYROS_ID}`}></script>}

  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { -webkit-text-size-adjust: 100%; }
    body {
      font-family: 'Lato', sans-serif;
      background: #ffffff;
      color: #000000;
      font-size: 14px;
      line-height: 1.4;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: 1170px; margin: 0 auto; padding: 0 15px; }

    .logo-row { padding: 30px 0 0; text-align: center; }
    .logo-row img { max-width: 280px; width: 100%; height: auto; display: inline-block; }

    .danke-hero {
      text-align: center;
      padding: 36px 20px 16px;
      max-width: 760px;
      margin: 0 auto;
    }
    .danke-badge {
      display: inline-block;
      background: #e8f5ea;
      color: #1c7c34;
      font-size: 12px;
      font-weight: 700;
      padding: 6px 14px;
      border-radius: 20px;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .danke-hero h1 {
      font-size: 30px;
      font-weight: 900;
      line-height: 1.2;
      color: #000;
      margin: 0 0 12px;
    }
    .danke-hero h1 em { font-style: normal; color: #1d73d3; }
    .danke-hero p {
      font-size: 17px;
      color: #444;
      max-width: 620px;
      margin: 0 auto;
      line-height: 1.55;
    }

    .steps {
      max-width: 720px;
      margin: 24px auto 8px;
      padding: 0 20px;
      list-style: none;
    }
    .steps li {
      font-size: 16px;
      color: #333;
      margin: 8px 0;
      line-height: 1.5;
    }
    .steps li b { color: #000; }

    .ycbm-section { background: #fafafa; padding: 30px 0 30px; margin-top: 24px; border-top: 1px solid #eee; }
    .ycbm-heading {
      text-align: center;
      font-size: 24px;
      font-weight: 900;
      color: #000;
      margin: 0 0 18px;
      line-height: 1.2;
      padding: 0 20px;
    }
    .ycbm-wrap {
      max-width: 820px;
      margin: 0 auto;
      padding: 0 10px;
    }
    #ycbmiframefitontime-analyse {
      width: 100%;
      min-height: 1000px;
      border: 0;
      background-color: transparent;
    }

    .footer-logo { padding: 20px 0; text-align: center; }
    .footer-logo img { max-width: 180px; opacity: 0.55; }
    .footer-legal {
      text-align: center;
      color: rgba(135,135,135,0.61);
      font-size: 12px;
      padding: 10px 15px 30px;
    }
    .footer-legal a { text-decoration: underline; }
    .footer-legal a:hover { color: #555; }

    @media (max-width: 600px) {
      .danke-hero h1 { font-size: 24px; }
      .ycbm-heading { font-size: 20px; }
      .steps li { font-size: 15px; }
    }
  </style>
</head>
<body>
  <main>
    <div class="logo-row">
      <img src="/quiz/logo.png" alt="Fit on Time" width="280" height="55" />
    </div>

    <section class="danke-hero">
      <span class="danke-badge">✓ Anfrage eingegangen</span>
      <h1 id="danke-h1">Danke! Letzter Schritt: <em>Termin sichern</em>.</h1>
      <p>Wähle direkt unten einen passenden Termin für deine kostenlose Stoffwechsel-Analyse. Wir rufen dich pünktlich an.</p>
    </section>

    <ul class="steps">
      <li>1️⃣ <b>Termin wählen</b> im Kalender unten</li>
      <li>2️⃣ <b>Bestätigungs-Mail</b> kommt sofort in dein Postfach</li>
      <li>3️⃣ <b>Pünktlicher Anruf</b> zu deiner gewählten Zeit (ca. 45 Min.)</li>
    </ul>

    <section class="ycbm-section">
      <div class="container">
        <h2 class="ycbm-heading">Wähle deinen Termin</h2>
        <div class="ycbm-wrap">
          <iframe
            src="https://fitontime-analyse.youcanbook.me/?noframe=true&skipHeaderFooter=true"
            id="ycbmiframefitontime-analyse"
            frameborder="0"
            allowtransparency="true"
          ></iframe>
        </div>
        <div class="footer-logo">
          <img src="/quiz/logo.png" alt="Fit on Time" width="180" height="35" />
        </div>
        <div class="footer-legal">
          <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Impressum</a> | <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutz</a>
        </div>
      </div>
    </section>
  </main>

  <CookieBanner metaPixelId={PIXEL_ID} hyrosPh={HYROS_ID} impressumUrl={IMPRESSUM_URL} datenschutzUrl={DATENSCHUTZ_URL} consentKey="lp_consent_quiz" />

  <script is:inline define:vars={{ LP_SLUG, LP_NAME }}>
    // Vorname personalisieren wenn vorhanden
    try {
      const first = sessionStorage.getItem('lead_firstname');
      if (first) {
        const h1 = document.getElementById('danke-h1');
        if (h1) h1.innerHTML = `Danke, ${first}! Letzter Schritt: <em>Termin sichern</em>.`;
      }
    } catch (_) {}

    // Tracking
    const SESSION_KEY = `${LP_SLUG}_session`;
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }
    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({
        event, lp: LP_SLUG, lp_name: LP_NAME, session, step: 'danke',
      }, extra || {}));
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
          return;
        }
      } catch (_) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }
    track('danke_view');

    // YCBM dynamic resize + booking-tracking
    window.addEventListener && window.addEventListener('message', function(event){
      if (event.origin === 'https://fitontime-analyse.youcanbook.me') {
        const el = document.getElementById('ycbmiframefitontime-analyse');
        if (el) {
          el.style.height = event.data + 'px';
          if (!el.dataset.tracked) { el.dataset.tracked = '1'; track('booking_widget_loaded'); }
        }
      }
    }, false);
  </script>
</body>
</html>
