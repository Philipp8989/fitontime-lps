  <footer>
    <div class="copy">© Fit on Time {new Date().getFullYear()}</div>
    <a href={IMPRESSUM_URL} target="_blank" rel="noopener">Impressum</a>·
    <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutzerklärung</a>
  </footer>

  <!-- Opt-in Modal -->
  <div class="modal-overlay" id="modalOverlay" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal">
      <div class="modal-head">
        <button class="modal-close" type="button" onclick="closeModal()" aria-label="Schliessen">✕</button>
        <span class="pill-mini"><span></span> Live · 12.05. · 18 Uhr</span>
        <h3 id="modalTitle">Sichere dir deinen Platz.</h3>
        <p class="lead2">Wir senden dir den Zugangslink per WhatsApp und E-Mail.</p>
      </div>
      <div class="modal-body">
        <form class="optin" id="optinForm" onsubmit="submitLead(event)">
          <div class="field">
            <input id="fname" type="text" name="fname" placeholder="Vor- und Nachname" required autocomplete="name" />
          </div>
          <div class="field">
            <input id="email" type="email" name="email" placeholder="E-Mail-Adresse" required autocomplete="email" />
          </div>
          <div class="field">
            <div class="phone-row">
              <span class="phone-prefix"><span class="ch-flag-mini" aria-hidden="true"></span> +41</span>
              <input id="phone" type="tel" name="phone" placeholder="76 123 45 67" required autocomplete="tel-national" inputmode="tel" />
            </div>
          </div>
          <label class="tos">
            <input type="checkbox" name="datenschutz" required />
            <span>Ich akzeptiere die <a href={DATENSCHUTZ_URL} target="_blank" rel="noopener">Datenschutzbestimmungen</a> und stimme zu, den Zugangslink per WhatsApp und E-Mail zu erhalten.</span>
          </label>
          <button class="btn" type="submit" id="submitBtn">🔓 Kostenlos anmelden <span class="btn-arrow">→</span></button>
          <div class="err" id="optinErr"></div>
        </form>
        <div class="modal-trust">
          <span class="item">🔒 SSL</span>
          <span class="item">🇨🇭 Schweizer Server</span>
          <span class="item">⚡ Sofort-Zugang</span>
        </div>
      </div>
    </div>
  </div>

  <CookieBanner
    metaPixelId={PIXEL_ID}
    hyrosPh={HYROS_ID}
    impressumUrl={IMPRESSUM_URL}
    datenschutzUrl={DATENSCHUTZ_URL}
    consentKey="fot_consent"
  />

  <script is:inline define:vars={{ LP_SLUG, LP_NAME }}>
    const SESSION_KEY = 'fot_session';
    let session = sessionStorage.getItem(SESSION_KEY);
    if (!session) {
      session = (crypto.randomUUID ? crypto.randomUUID() : Math.random().toString(36).slice(2) + Date.now());
      sessionStorage.setItem(SESSION_KEY, session);
    }

    function track(event, extra) {
      const payload = JSON.stringify(Object.assign({
        event, lp: LP_SLUG, lp_name: LP_NAME, session, schema_version: 'v1',
      }, extra || {}));
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
          return;
        }
      } catch (e) {}
      fetch('/api/track', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: payload, keepalive: true }).catch(() => {});
    }

    let modalOpened = false;
    function openModal(source) {
      const m = document.getElementById('modalOverlay');
      m.classList.add('open');
      document.body.style.overflow = 'hidden';
      if (!modalOpened) {
        modalOpened = true;
        track('optin_view', { source: source || 'unknown' });
        if (window.fbq) window.fbq('track', 'InitiateCheckout');
      }
      setTimeout(() => document.getElementById('fname')?.focus(), 100);
    }
    function closeModal() {
      document.getElementById('modalOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }
    window.openModal = openModal;
    window.closeModal = closeModal;

    document.getElementById('modalOverlay').addEventListener('click', (e) => {
      if (e.target.id === 'modalOverlay') closeModal();
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    function normalizePhone(raw) {
      const cleaned = (raw || '').replace(/[^\d+]/g, '');
      if (!cleaned) return '';
      if (cleaned.startsWith('+')) return cleaned;
      if (cleaned.startsWith('0')) return '+41' + cleaned.slice(1);
      return '+41' + cleaned;
    }

    async function submitLead(e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      const err = document.getElementById('optinErr');
      err.textContent = '';
      btn.disabled = true;
      btn.innerHTML = 'Wird gesendet...';

      const fd = new FormData(e.target);
      const payload = {
        name: (fd.get('fname') || '').toString().trim(),
        email: (fd.get('email') || '').toString().trim(),
        phone: normalizePhone((fd.get('phone') || '').toString()),
        lp_slug: LP_SLUG,
        lp_name: LP_NAME,
        session,
        answers: {},
      };

      try {
        const res = await fetch('/api/sheets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) {
          const j = await res.json().catch(() => ({}));
          throw new Error(j.error || 'Fehler beim Senden');
        }
        track('lead_submit');
        if (window.fbq) window.fbq('track', 'Lead');
        const vorname = payload.name.split(/\s+/)[0] || '';
        const url = '/danke-entzuendungen/' + (vorname ? '?n=' + encodeURIComponent(vorname) : '');
        window.location.href = url;
      } catch (e2) {
        err.textContent = e2.message || 'Etwas ist schiefgelaufen, bitte nochmal versuchen.';
        btn.disabled = false;
        btn.innerHTML = '🔓 Kostenlos anmelden <span class="btn-arrow">→</span>';
      }
    }
    window.submitLead = submitLead;

    track('page_view');
  </script>
</body>
</html>
