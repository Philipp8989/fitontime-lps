---
// Webinar-Opt-in "Entzuendungen", Nachbau go.fit-on-time.ch/entzndungen mit UX/UI-Overhaul
// Single-Page, Modal-Form, alle Visuals als HTML/CSS, Schweiz-Trust, Redirect zu /danke-entzuendungen/
import CookieBanner from '../../components/CookieBanner.astro';

const LP_SLUG = 'entzuendungen';
const LP_NAME = 'Entzündungen Webinar';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';

// Live-Termin als Konstante
const LIVE_DATE_ISO = '2026-05-12T18:00:00+02:00';
const LIVE_DATUM = 'Dienstag, 12. Mai 2026 um 18:00 Uhr';
const LIVE_DATUM_KURZ = 'Live am 12.05. um 18 Uhr';
---
<html lang="de-CH">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Gratis Webinar: Entzündungen, der versteckte Abnehm-Stopper | Fit on Time</title>
  <meta name="description" content="Live-Webinar für Frauen: Wie du Entzündungen auflöst, Wassereinlagerungen verlierst und automatisch in den Fettverbrennungs-Modus kommst." />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Hyros laedt ohne Consent (First-Party-Attribution), Meta Pixel via CookieBanner nach Consent -->
  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <style is:global>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#ffffff;
      --surface:#f7faf9;
      --surface-2:#ecf6f0;
      --border:#e5e7eb;
      --text:#0f172a;
      --text-2:#475569;
      --text-3:#94a3b8;
      --accent:#0caa4f;
      --accent-dark:#089042;
      --accent-soft:#d1fae5;
      --warn:#dc2626;
      --warn-soft:#fef2f2;
      --r:14px;
      --font:'Inter',system-ui,-apple-system,sans-serif;
    }
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
    body{font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.5;-webkit-font-smoothing:antialiased;min-height:100dvh;display:flex;flex-direction:column;font-feature-settings:"ss01","cv11"}
    main{flex:1}
    .wrap{width:100%;max-width:1120px;margin:0 auto;padding:0 18px}

    /* Top scarcity bar */
    .topbar{background:linear-gradient(90deg,#fff7ed,#fef3c7);color:#854d0e;border-bottom:1px solid #fde68a;padding:9px 16px;text-align:center;font-size:13.5px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:8px;letter-spacing:.1px}
    .topbar .pulse{width:8px;height:8px;border-radius:50%;background:#dc2626;animation:pulseDot 1.4s infinite;flex-shrink:0}
    @keyframes pulseDot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}

    header{padding:18px 0 4px;text-align:center}
    header img{height:38px}

    /* Hero */
    .hero{padding:24px 0 36px}
    @media(min-width:840px){.hero{padding:36px 0 52px}}
    .hero-grid{display:grid;grid-template-columns:1fr;gap:28px;align-items:center}
    @media(min-width:900px){.hero-grid{grid-template-columns:1.05fr 1fr;gap:56px}}

    .pill{display:inline-flex;align-items:center;gap:6px;background:var(--accent-soft);color:#065f46;padding:6px 12px;border-radius:999px;font-size:12.5px;font-weight:700;letter-spacing:.2px;text-transform:uppercase;margin-bottom:14px}
    .pill .pulse{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:pulseDot 1.4s infinite}

    h1{font-size:32px;font-weight:800;line-height:1.14;letter-spacing:-.6px;color:var(--text);margin-bottom:14px}
    @media(min-width:840px){h1{font-size:44px}}
    h1 .hl{background:linear-gradient(180deg,transparent 60%,#fee2e2 60%);padding:0 4px;border-radius:3px;color:var(--warn)}

    .lead{font-size:17px;color:var(--text-2);margin-bottom:22px;line-height:1.55}
    @media(min-width:840px){.lead{font-size:18.5px}}

    .checks{list-style:none;display:flex;flex-direction:column;gap:11px;margin:0 0 24px}
    .checks li{display:flex;gap:12px;font-size:15.5px;line-height:1.5;color:var(--text);align-items:flex-start}
    .check-ico{flex-shrink:0;width:22px;height:22px;border-radius:50%;background:var(--accent);display:inline-flex;align-items:center;justify-content:center;color:#fff;margin-top:2px}
    .check-ico svg{width:13px;height:13px}

    /* Buttons */
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;background:var(--accent);color:#fff;border:0;border-radius:14px;padding:18px 28px;font:inherit;font-weight:800;font-size:17.5px;cursor:pointer;width:100%;transition:background .15s,transform .1s,box-shadow .2s;-webkit-tap-highlight-color:transparent;text-decoration:none;text-align:center;box-shadow:0 8px 24px rgba(12,170,79,.32);letter-spacing:.1px}
    .btn:hover{background:var(--accent-dark);box-shadow:0 12px 30px rgba(12,170,79,.4);transform:translateY(-1px)}
    .btn:active{transform:scale(.98)}
    .btn-large{padding:20px 32px;font-size:19px}
    .btn-arrow{display:inline-block;transition:transform .2s}
    .btn:hover .btn-arrow{transform:translateX(4px)}

    .cta-meta{font-size:13.5px;color:var(--text-2);text-align:center;margin-top:11px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap}
    .cta-meta::before{content:"📅";font-size:14px}

    /* Trust row */
    .trust-row{display:flex;flex-wrap:wrap;gap:16px;margin-top:22px;color:var(--text-2);font-size:13.5px;align-items:center;font-weight:600}
    .trust-row .item{display:flex;align-items:center;gap:6px}
    .trust-row .ch-flag{width:18px;height:12px;border-radius:2px;background:#dc2626;position:relative;display:inline-block;flex-shrink:0;box-shadow:inset 0 0 0 1px rgba(0,0,0,.05)}
    .trust-row .ch-flag::before,.trust-row .ch-flag::after{content:"";position:absolute;background:#fff}
    .trust-row .ch-flag::before{left:7px;top:2px;width:4px;height:8px}
    .trust-row .ch-flag::after{left:4px;top:5px;width:10px;height:2px}

    /* Hero visual: HTML statt Funnelcockpit-Screenshot */
    .hero-visual{position:relative;aspect-ratio:1/1;max-width:480px;margin:0 auto;border-radius:24px;background:radial-gradient(circle at 30% 30%,#bbf7d0,#d1fae5 40%,#ecfdf5 70%,#f0fdf4);overflow:hidden;box-shadow:0 20px 50px rgba(15,23,42,.08),0 4px 14px rgba(15,23,42,.04)}
    .hero-visual::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 70% 80%,rgba(255,255,255,.6),transparent 60%);pointer-events:none}
    .hero-visual .body-illu{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:55%}
    .hero-visual .body-illu svg{width:100%;height:auto;filter:drop-shadow(0 10px 24px rgba(15,23,42,.08))}
    .hero-visual .symptom{position:absolute;background:#fff;padding:11px 14px;border-radius:14px;box-shadow:0 8px 22px rgba(15,23,42,.12);display:flex;align-items:center;gap:10px;font-size:13.5px;font-weight:700;color:var(--text);max-width:200px;line-height:1.3;animation:floatY 3.4s ease-in-out infinite}
    .hero-visual .symptom .dot{width:9px;height:9px;border-radius:50%;background:var(--warn);flex-shrink:0;box-shadow:0 0 0 4px rgba(220,38,38,.14)}
    .hero-visual .s1{top:8%;left:6%;animation-delay:0s}
    .hero-visual .s2{top:15%;right:6%;animation-delay:.6s}
    .hero-visual .s3{bottom:18%;left:4%;animation-delay:1.2s}
    .hero-visual .s4{bottom:8%;right:8%;animation-delay:1.8s}
    @keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}

    /* Bonus card */
    .bonus{margin-top:24px;background:linear-gradient(135deg,#f0fdf4,#ecfdf5);border:1px solid var(--accent-soft);border-radius:16px;padding:18px 18px 18px 60px;position:relative;font-size:14.5px;line-height:1.5;color:#065f46}
    .bonus::before{content:"🎁";position:absolute;left:16px;top:16px;font-size:30px;line-height:1}
    .bonus strong{color:var(--text);display:block;margin-bottom:3px}

    /* Section: Erwartet */
    section.erwartet{padding:64px 0;background:var(--surface)}
    .sec-eyebrow{display:block;text-align:center;color:var(--accent);font-size:13px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px}
    .sec-h{font-size:28px;font-weight:800;text-align:center;line-height:1.22;color:var(--text);margin-bottom:14px;letter-spacing:-.4px}
    @media(min-width:840px){.sec-h{font-size:34px}}
    .sec-sub{text-align:center;color:var(--text-2);font-size:16px;margin:0 auto 36px;max-width:620px;line-height:1.55}

    .cards{display:grid;grid-template-columns:1fr;gap:20px}
    @media(min-width:760px){.cards{grid-template-columns:repeat(3,1fr)}}
    .card{background:#fff;border:1px solid var(--border);border-radius:18px;padding:28px 24px;box-shadow:0 4px 20px rgba(15,23,42,.05);position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s}
    .card:hover{transform:translateY(-4px);box-shadow:0 12px 30px rgba(15,23,42,.08)}
    .card .ico{width:54px;height:54px;border-radius:14px;background:linear-gradient(135deg,var(--accent),var(--accent-dark));display:flex;align-items:center;justify-content:center;margin-bottom:18px;box-shadow:0 6px 16px rgba(12,170,79,.28)}
    .card .ico svg{width:26px;height:26px;color:#fff}
    .card-num{font-size:12px;font-weight:800;color:var(--accent);letter-spacing:1.3px;text-transform:uppercase;margin-bottom:6px}
    .card h3{font-size:19px;font-weight:800;color:var(--text);margin-bottom:10px;line-height:1.3;letter-spacing:-.2px}
    .card p{font-size:14.5px;color:var(--text-2);line-height:1.6}

    /* Bonus showcase (HTML statt iPad-Mockup) */
    .bonus-section{padding:64px 0;background:#fff}
    .bonus-grid{display:grid;grid-template-columns:1fr;gap:32px;align-items:center}
    @media(min-width:840px){.bonus-grid{grid-template-columns:1fr 1.05fr;gap:56px}}
    .bonus-card{background:linear-gradient(180deg,#0f172a,#1e293b);border-radius:24px;padding:28px;color:#fff;position:relative;overflow:hidden;box-shadow:0 30px 60px -10px rgba(15,23,42,.4)}
    .bonus-card::before{content:"";position:absolute;top:-50%;right:-30%;width:80%;height:200%;background:radial-gradient(circle,rgba(12,170,79,.25),transparent 60%);pointer-events:none}
    .bonus-card .label{display:inline-block;background:var(--accent);color:#fff;padding:5px 12px;border-radius:999px;font-size:11.5px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;margin-bottom:18px;position:relative}
    .bonus-card h4{font-size:24px;font-weight:800;line-height:1.25;margin-bottom:14px;position:relative;letter-spacing:-.3px}
    .bonus-card .checklist{list-style:none;display:flex;flex-direction:column;gap:11px;margin:18px 0 0;position:relative}
    .bonus-card .checklist li{font-size:14.5px;display:flex;align-items:flex-start;gap:10px;color:#cbd5e1;line-height:1.5}
    .bonus-card .checklist li::before{content:"✓";flex-shrink:0;width:22px;height:22px;border-radius:50%;background:var(--accent);color:#fff;font-size:12px;font-weight:800;display:inline-flex;align-items:center;justify-content:center;margin-top:1px}
    .bonus-card .checklist li strong{color:#fff;font-weight:700}
    .bonus-text h3{font-size:28px;font-weight:800;line-height:1.2;letter-spacing:-.4px;margin-bottom:14px;color:var(--text)}
    @media(min-width:840px){.bonus-text h3{font-size:32px}}
    .bonus-text p{font-size:16px;color:var(--text-2);line-height:1.6;margin-bottom:14px}

    /* Social Proof */
    .social-proof{padding:64px 0;background:var(--surface-2)}
    .ba-grid{display:grid;grid-template-columns:1fr;gap:18px;margin:36px 0 28px}
    @media(min-width:760px){.ba-grid{grid-template-columns:repeat(3,1fr)}}
    .ba-grid img{width:100%;height:auto;border-radius:16px;box-shadow:0 8px 24px rgba(15,23,42,.1);display:block}
    .testimonial{background:#fff;border-radius:18px;padding:26px;max-width:780px;margin:0 auto;box-shadow:0 8px 24px rgba(15,23,42,.06);position:relative}
    .testimonial::before{content:"”";position:absolute;top:6px;left:14px;font-size:80px;color:var(--accent-soft);font-family:Georgia,serif;line-height:1;font-weight:700}
    .testimonial p{font-size:16px;line-height:1.65;color:var(--text);margin:0 0 16px;padding-left:36px;font-style:italic}
    .testimonial cite{display:flex;align-items:center;gap:12px;padding-left:36px;font-style:normal;color:var(--text-2);font-size:14px;font-weight:600}
    .testimonial .avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-dark));display:inline-flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:14px;flex-shrink:0}

    /* Final CTA */
    .final-cta{padding:64px 0 56px;text-align:center;background:linear-gradient(180deg,#fff,var(--surface))}
    .final-cta .countdown{display:inline-flex;gap:8px;background:#fff;border:1px solid var(--border);border-radius:14px;padding:14px 20px;margin-bottom:22px;box-shadow:0 4px 14px rgba(15,23,42,.05)}
    .final-cta .countdown .item{display:flex;flex-direction:column;align-items:center;min-width:54px}
    .final-cta .countdown .num{font-size:24px;font-weight:800;color:var(--text);font-variant-numeric:tabular-nums;line-height:1}
    .final-cta .countdown .lbl{font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.8px;margin-top:4px;font-weight:700}
    .final-cta .countdown .sep{width:1px;background:var(--border)}
    .final-cta h2{font-size:28px;font-weight:800;line-height:1.22;letter-spacing:-.4px;margin-bottom:14px;color:var(--text)}
    @media(min-width:840px){.final-cta h2{font-size:34px}}
    .final-cta .btn-wrap{max-width:520px;margin:8px auto 0}
    .final-cta .scarcity-line{margin:14px 0 0;font-size:14px;color:var(--warn);font-weight:700;display:flex;align-items:center;justify-content:center;gap:6px}
    .disclaimer{max-width:680px;margin:22px auto 0;font-size:13px;color:var(--text-3);text-align:center;line-height:1.6;font-style:italic;padding:0 12px}

    footer{padding:32px 18px 40px;text-align:center;color:var(--text-3);font-size:13px;border-top:1px solid var(--border);background:#fff}
    footer .copy{margin-bottom:6px;color:var(--text-2);font-weight:600}
    footer a{color:var(--text-3);margin:0 8px;text-decoration:underline}

    /* Modal */
    .modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.72);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);display:none;align-items:flex-start;justify-content:center;z-index:9999;padding:20px;overflow-y:auto}
    .modal-overlay.open{display:flex;animation:fadeIn .2s}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    .modal{background:#fff;border-radius:24px;width:100%;max-width:480px;padding:0;position:relative;margin:24px auto;box-shadow:0 30px 80px rgba(0,0,0,.5);animation:modalIn .3s cubic-bezier(.22,1,.36,1);overflow:hidden}
    @keyframes modalIn{from{opacity:0;transform:translateY(30px) scale(.95)}to{opacity:1;transform:none}}
    .modal-head{background:linear-gradient(135deg,#0f172a,#1e293b);color:#fff;padding:28px 28px 24px;position:relative}
    .modal-head::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 80% 20%,rgba(12,170,79,.3),transparent 50%);pointer-events:none}
    .modal-close{position:absolute;top:12px;right:14px;background:rgba(255,255,255,.1);border:0;font-size:18px;cursor:pointer;color:#fff;line-height:1;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .15s;z-index:2}
    .modal-close:hover{background:rgba(255,255,255,.2)}
    .modal-head .live-pill{display:inline-flex;align-items:center;gap:7px;background:rgba(220,38,38,.15);border:1px solid rgba(220,38,38,.4);color:#fecaca;padding:6px 12px;border-radius:999px;font-size:12px;font-weight:700;margin-bottom:14px;position:relative;letter-spacing:.2px;text-transform:uppercase}
    .modal-head .live-pill::before{content:"";width:7px;height:7px;border-radius:50%;background:#fca5a5;animation:pulseDot 1.4s infinite}
    .modal-head h3{font-size:22px;font-weight:800;line-height:1.25;margin:0 0 6px;letter-spacing:-.3px;position:relative}
    .modal-head p.lead2{font-size:14.5px;color:#cbd5e1;line-height:1.45;margin:0;position:relative}

    .modal-body{padding:24px 28px 28px}
    form.optin{display:flex;flex-direction:column;gap:11px}
    form.optin label{font-size:12.5px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.8px;display:block;margin-bottom:5px}
    form.optin .field input[type=text],
    form.optin .field input[type=email]{width:100%;padding:13px 16px;font:inherit;font-size:15.5px;border:1.5px solid var(--border);border-radius:11px;background:#fff;color:var(--text);transition:border-color .15s,box-shadow .15s}
    form.optin .field input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(12,170,79,.15)}

    /* Phone with CH-prefix */
    .phone-row{display:flex;gap:0}
    .phone-prefix{display:flex;align-items:center;gap:6px;background:#f1f5f9;border:1.5px solid var(--border);border-right:0;border-radius:11px 0 0 11px;padding:0 12px;font-weight:700;font-size:14.5px;color:var(--text);user-select:none;flex-shrink:0}
    .phone-prefix .ch-flag-mini{width:18px;height:14px;border-radius:2px;background:#dc2626;position:relative;display:inline-block;box-shadow:inset 0 0 0 1px rgba(0,0,0,.05)}
    .phone-prefix .ch-flag-mini::before,.phone-prefix .ch-flag-mini::after{content:"";position:absolute;background:#fff}
    .phone-prefix .ch-flag-mini::before{left:7px;top:3px;width:4px;height:8px}
    .phone-prefix .ch-flag-mini::after{left:4px;top:6px;width:10px;height:2px}
    .phone-row input[type=tel]{flex:1;padding:13px 16px;font:inherit;font-size:15.5px;border:1.5px solid var(--border);border-radius:0 11px 11px 0;background:#fff;color:var(--text)}
    .phone-row input[type=tel]:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(12,170,79,.15)}

    form.optin label.tos{display:flex;align-items:flex-start;gap:9px;font-size:12.5px;color:var(--text-2);padding:6px 2px;line-height:1.5;text-transform:none;letter-spacing:0;font-weight:500;margin-bottom:0}
    form.optin label.tos input[type=checkbox]{width:18px;height:18px;flex-shrink:0;margin-top:1px;accent-color:var(--accent);cursor:pointer}
    form.optin label.tos a{color:var(--accent);text-decoration:underline;font-weight:600}
    .err{color:#b91c1c;font-size:13px;text-align:center;margin-top:4px;min-height:18px;font-weight:600}
    .modal-trust{display:flex;align-items:center;justify-content:center;gap:14px;margin-top:14px;color:var(--text-3);font-size:11.5px;font-weight:600}
    .modal-trust .item{display:flex;align-items:center;gap:5px}
    .modal-trust svg{width:13px;height:13px;color:var(--accent)}

    /* Hide page when modal is open (a11y nicety): trap scroll on body */
  </style>
</head>
<body>
  <div class="topbar"><span class="pulse"></span> <span><strong>Live in Kürze:</strong> Nur noch <strong>5 Plätze</strong> verfügbar</span></div>

  <header><img src="/images/logo.png" alt="Fit on Time" /></header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="wrap">
        <div class="hero-grid">
          <div>
            <span class="pill"><span class="pulse"></span> Gratis Live-Webinar</span>
            <h1>Blockieren <span class="hl">Entzündungen</span> dein Wohlbefinden?</h1>
            <p class="lead">Warum Frauen mit Entzündungen NIEMALS richtig abnehmen, egal was sie probieren. Erkenntnisse aus über 3.000 Fällen.</p>

            <ul class="checks">
              <li>
                <span class="check-ico"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>
                <span>Die <strong>3 versteckten Entzündungs-Trigger</strong>, die fast jede Frau täglich konsumiert und die deine Haut, Energie und Figur ruinieren</span>
              </li>
              <li>
                <span class="check-ico"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>
                <span>Wie du deinen Körper wieder in einen Zustand bringst, in dem er <strong>automatisch Fett verbrennt</strong></span>
              </li>
              <li>
                <span class="check-ico"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>
