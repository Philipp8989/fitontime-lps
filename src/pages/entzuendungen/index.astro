---
// Webinar-Opt-in "Entzuendungen", v3 image-led und tight
import CookieBanner from '../../components/CookieBanner.astro';

const LP_SLUG = 'entzuendungen';
const LP_NAME = 'Entzündungen Webinar';
const PIXEL_ID = (import.meta.env.PUBLIC_META_PIXEL_ID || '').trim();
const HYROS_ID = (import.meta.env.PUBLIC_HYROS_ID || '').trim();
const IMPRESSUM_URL = 'https://fitontime.ch/impressum-datenschutz';
const DATENSCHUTZ_URL = 'https://fitontime.ch/impressum-datenschutz';
---
<html lang="de-CH">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Live-Workshop am 12.05.: Entzündungen auflösen, automatisch Fett verbrennen | Fit on Time</title>
  <meta name="description" content="Gratis Live-Workshop für Frauen am 12.05.2026. Wie du Entzündungen auflöst, automatisch Fett verbrennst und dich endlich wieder leicht fühlst." />
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <script is:inline src="https://t.hyros.com/v1/lst/universal-script?ph=689a71ca1ab3be1cb1caddbe6b7902a4ad2c51a228f4ec9ea7fef3123a705f63"></script>

  <style is:global>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    :root{
      --bg:#fafaf9;
      --surface:#fff;
      --surface-2:#f4f6f5;
      --border:#e5e7eb;
      --text:#0a0f1c;
      --text-2:#475569;
      --text-3:#94a3b8;
      --accent:#0caa4f;
      --accent-dark:#089042;
      --accent-soft:#d1fae5;
      --warn:#dc2626;
      --r:14px;
      --font:'Inter',system-ui,-apple-system,sans-serif;
    }
    html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
    body{font-family:var(--font);background:var(--bg);color:var(--text);line-height:1.5;-webkit-font-smoothing:antialiased;min-height:100dvh;display:flex;flex-direction:column;font-feature-settings:"ss01","cv11"}
    main{flex:1}
    .wrap{width:100%;max-width:1180px;margin:0 auto;padding:0 18px}

    /* Top scarcity bar */
    .topbar{background:var(--text);color:#d1fae5;padding:9px 16px;text-align:center;font-size:13px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:8px;letter-spacing:.1px}
    .topbar .pulse{width:7px;height:7px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 0 rgba(12,170,79,.6);animation:pulseDot 1.6s infinite}
    @keyframes pulseDot{0%{box-shadow:0 0 0 0 rgba(12,170,79,.6)}70%{box-shadow:0 0 0 8px rgba(12,170,79,0)}100%{box-shadow:0 0 0 0 rgba(12,170,79,0)}}
    .topbar strong{color:#fff}

    header{padding:18px 0 4px;text-align:center}
    header img{height:36px}

    /* Hero */
    .hero{padding:24px 0 40px}
    @media(min-width:840px){.hero{padding:36px 0 64px}}
    .hero-grid{display:grid;grid-template-columns:1fr;gap:32px;align-items:center}
    @media(min-width:900px){.hero-grid{grid-template-columns:1.1fr 1fr;gap:64px}}

    .pill{display:inline-flex;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--border);padding:7px 14px 7px 12px;border-radius:999px;font-size:12.5px;font-weight:700;letter-spacing:.3px;text-transform:uppercase;margin-bottom:18px;color:var(--text-2);box-shadow:0 1px 2px rgba(15,23,42,.04)}
    .pill .live-dot{width:8px;height:8px;border-radius:50%;background:var(--warn);box-shadow:0 0 0 0 rgba(220,38,38,.55);animation:pulseDot 1.6s infinite}
    .pill strong{color:var(--text);font-weight:800;letter-spacing:.4px}

    h1{font-size:36px;font-weight:900;line-height:1.06;letter-spacing:-1px;color:var(--text);margin-bottom:18px}
    @media(min-width:600px){h1{font-size:46px}}
    @media(min-width:1000px){h1{font-size:54px;letter-spacing:-1.4px}}
    h1 .underline{display:inline;background:linear-gradient(180deg,transparent 65%,#bbf7d0 65%);padding:0 4px;border-radius:3px}

    .lead{font-size:17px;color:var(--text-2);margin-bottom:26px;line-height:1.5;max-width:560px}
    @media(min-width:840px){.lead{font-size:18px}}

    .outcome-pills{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 24px}
    .outcome-pills .op{display:inline-flex;align-items:center;gap:7px;background:var(--surface);border:1px solid var(--border);color:var(--text);font-size:13.5px;font-weight:700;padding:8px 14px;border-radius:999px;letter-spacing:.1px}
    .outcome-pills .op .em{font-size:15px}

    /* CTA */
    .cta-stack{display:flex;flex-direction:column;gap:10px;margin-bottom:18px}
    @media(min-width:520px){.cta-stack{flex-direction:row;align-items:center;gap:18px}}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;background:var(--accent);color:#fff;border:0;border-radius:13px;padding:18px 28px;font:inherit;font-weight:800;font-size:17px;cursor:pointer;transition:background .15s,transform .1s,box-shadow .2s;text-decoration:none;text-align:center;box-shadow:0 10px 28px rgba(12,170,79,.35);letter-spacing:.1px;position:relative}
    .btn:hover{background:var(--accent-dark);box-shadow:0 14px 32px rgba(12,170,79,.42);transform:translateY(-1px)}
    .btn:active{transform:scale(.98)}
    .btn-large{padding:20px 32px;font-size:18px}
    .btn-arrow{display:inline-block;transition:transform .2s}
    .btn:hover .btn-arrow{transform:translateX(4px)}
    .cta-meta{font-size:13.5px;color:var(--text-2);font-weight:600;display:inline-flex;align-items:center;gap:6px}
    .cta-meta strong{color:var(--text);font-weight:700}

    .trust-row{display:flex;flex-wrap:wrap;gap:14px 18px;margin-top:8px;color:var(--text-2);font-size:13px;align-items:center;font-weight:600}
    .trust-row .item{display:inline-flex;align-items:center;gap:6px}
    .ch-flag{width:18px;height:14px;border-radius:2px;background:#dc2626;position:relative;display:inline-block;flex-shrink:0;box-shadow:inset 0 0 0 1px rgba(0,0,0,.05)}
    .ch-flag::before,.ch-flag::after{content:"";position:absolute;background:#fff}
    .ch-flag::before{left:7px;top:3px;width:4px;height:8px}
    .ch-flag::after{left:4px;top:6px;width:10px;height:2px}

    /* Hero visual: photo + floating badges */
    .hero-vis{position:relative;max-width:520px;margin:0 auto;width:100%}
    .hero-vis .photo-frame{position:relative;border-radius:24px;overflow:hidden;box-shadow:0 30px 60px -15px rgba(15,23,42,.25),0 8px 18px rgba(15,23,42,.06);transform:rotate(-2deg);transition:transform .4s ease}
    .hero-vis .photo-frame:hover{transform:rotate(0)}
    .hero-vis .photo-frame img{width:100%;height:auto;display:block}
    .hero-vis .photo-frame::after{content:"";position:absolute;inset:0;background:linear-gradient(170deg,transparent 60%,rgba(0,0,0,.06));pointer-events:none}

    .hero-vis .badge{position:absolute;background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:11px 14px;display:flex;align-items:center;gap:10px;box-shadow:0 12px 30px rgba(15,23,42,.14),0 4px 10px rgba(15,23,42,.05);font-weight:700;font-size:14px;color:var(--text);animation:floatY 3.6s ease-in-out infinite}
    .hero-vis .badge .ico{flex-shrink:0;width:34px;height:34px;border-radius:10px;background:var(--accent-soft);color:var(--accent);display:inline-flex;align-items:center;justify-content:center;font-size:18px}
    .hero-vis .badge .copy{line-height:1.2}
    .hero-vis .badge .copy small{display:block;color:var(--text-3);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;margin-top:1px}

    .hero-vis .b1{top:6%;left:-4%;animation-delay:0s;transform:rotate(-3deg)}
    .hero-vis .b2{top:34%;right:-6%;animation-delay:.8s;transform:rotate(2deg)}
    .hero-vis .b3{bottom:6%;left:-2%;animation-delay:1.6s;transform:rotate(-1deg)}
    @keyframes floatY{0%,100%{transform:translateY(0) rotate(var(--r,0deg))}50%{transform:translateY(-6px) rotate(var(--r,0deg))}}
    @media(max-width:600px){
      .hero-vis .b1{left:-8px;top:8px}
      .hero-vis .b2{right:-8px}
      .hero-vis .b3{left:-8px}
      .hero-vis .badge{font-size:13px;padding:9px 12px}
      .hero-vis .badge .ico{width:30px;height:30px;font-size:16px}
    }

    /* Section base */
    section.sec{padding:64px 0}
    @media(min-width:840px){section.sec{padding:88px 0}}
    .sec-eyebrow{display:block;text-align:center;color:var(--accent);font-size:12.5px;font-weight:800;letter-spacing:1.6px;text-transform:uppercase;margin-bottom:10px}
    .sec-h{font-size:30px;font-weight:900;text-align:center;line-height:1.14;color:var(--text);margin-bottom:14px;letter-spacing:-.6px}
    @media(min-width:840px){.sec-h{font-size:40px;letter-spacing:-1px}}
    .sec-sub{text-align:center;color:var(--text-2);font-size:16.5px;margin:0 auto 40px;max-width:620px;line-height:1.55}

    /* Pain mirror */
    .pain{background:var(--surface)}
    .pain-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;max-width:760px;margin:0 auto}
    @media(min-width:760px){.pain-grid{grid-template-columns:repeat(4,1fr);gap:16px}}
    .pain-card{background:var(--surface-2);border:1px solid var(--border);border-radius:16px;padding:20px 16px;text-align:center;transition:transform .2s,border-color .2s}
    .pain-card:hover{transform:translateY(-3px);border-color:var(--accent)}
    .pain-card .em{font-size:34px;display:block;margin-bottom:10px;line-height:1}
    .pain-card .lbl{font-size:14.5px;font-weight:700;color:var(--text);letter-spacing:-.1px;line-height:1.3}
    .pain-note{text-align:center;margin-top:30px;font-size:16px;font-weight:700;color:var(--text);max-width:560px;margin-inline:auto}
    .pain-note span{color:var(--accent)}

    /* Value */
    .value{background:var(--surface-2)}
    .value-cards{display:grid;grid-template-columns:1fr;gap:18px;max-width:980px;margin:0 auto}
    @media(min-width:760px){.value-cards{grid-template-columns:repeat(3,1fr);gap:22px}}
    .vc{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:28px 24px;position:relative;transition:transform .2s,box-shadow .2s}
    .vc:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(15,23,42,.08)}
    .vc-num{position:absolute;top:18px;right:22px;font-size:46px;font-weight:900;line-height:1;color:var(--accent-soft);letter-spacing:-2px}
    .vc-ico{width:48px;height:48px;border-radius:13px;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;margin-bottom:18px;box-shadow:0 6px 14px rgba(12,170,79,.32)}
    .vc-ico svg{width:24px;height:24px}
    .vc h3{font-size:19px;font-weight:800;letter-spacing:-.3px;color:var(--text);margin-bottom:8px;line-height:1.25}
    .vc p{font-size:15px;color:var(--text-2);line-height:1.55}

    /* Proof */
    .proof{background:var(--surface)}
    .proof-grid{display:grid;grid-template-columns:1fr;gap:14px;max-width:980px;margin:0 auto 40px}
    @media(min-width:600px){.proof-grid{grid-template-columns:repeat(3,1fr)}}
    .proof-grid img{width:100%;height:auto;display:block;border-radius:18px;box-shadow:0 12px 30px rgba(15,23,42,.1);transition:transform .3s}
    .proof-grid img:hover{transform:scale(1.02)}
    .testimonial{background:var(--surface-2);border-radius:20px;padding:26px;max-width:780px;margin:0 auto;position:relative;border:1px solid var(--border)}
    .testimonial::before{content:"”";position:absolute;top:-2px;left:18px;font-size:80px;color:var(--accent);font-family:Georgia,serif;line-height:1;font-weight:700;opacity:.5}
    .testimonial p{font-size:16.5px;line-height:1.65;color:var(--text);margin:0 0 14px;padding-left:32px;font-weight:500}
    .testimonial cite{display:flex;align-items:center;gap:12px;padding-left:32px;font-style:normal;color:var(--text-2);font-size:14px;font-weight:600}
    .testimonial .avatar{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-dark));display:inline-flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:13px;flex-shrink:0;box-shadow:0 4px 10px rgba(12,170,79,.32)}

    /* Final CTA */
    .final{background:linear-gradient(180deg,var(--text) 0%,#1a2235 100%);color:#fff;padding:80px 0;text-align:center;position:relative;overflow:hidden}
    .final::before{content:"";position:absolute;top:-50%;left:-20%;width:140%;height:200%;background:radial-gradient(ellipse at center,rgba(12,170,79,.18),transparent 50%);pointer-events:none}
    .final .wrap{position:relative}
    .final .date-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.06);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.1);padding:8px 16px;border-radius:999px;font-size:12.5px;font-weight:800;color:#86efac;letter-spacing:1.4px;text-transform:uppercase;margin-bottom:18px}
    .final .date-eyebrow .dot{width:8px;height:8px;border-radius:50%;background:#86efac;animation:pulseDot 1.6s infinite}
    .final h2{font-size:38px;font-weight:900;line-height:1.05;letter-spacing:-1.2px;margin-bottom:16px;color:#fff}
    @media(min-width:840px){.final h2{font-size:54px}}
    .final .sub{font-size:17px;color:#cbd5e1;line-height:1.55;max-width:540px;margin:0 auto 30px}
    .final .btn-wrap{max-width:480px;margin:0 auto}
    .final .btn{font-size:18px;padding:22px 32px}
    .final .scarcity{margin-top:18px;font-size:14px;color:#86efac;font-weight:700;display:flex;align-items:center;justify-content:center;gap:6px}
    .final .trust-row{justify-content:center;color:#94a3b8;margin-top:24px}
    .final .trust-row .item{color:#cbd5e1}

    footer{padding:30px 18px;text-align:center;color:var(--text-3);font-size:13px;background:var(--bg);border-top:1px solid var(--border)}
    footer .copy{margin-bottom:6px;color:var(--text-2);font-weight:600}
    footer a{color:var(--text-3);margin:0 8px;text-decoration:underline}

    /* Modal */
    .modal-overlay{position:fixed;inset:0;background:rgba(10,15,28,.78);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:none;align-items:flex-start;justify-content:center;z-index:9999;padding:20px;overflow-y:auto}
    .modal-overlay.open{display:flex;animation:fadeIn .2s}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    .modal{background:var(--surface);border-radius:22px;width:100%;max-width:440px;padding:0;position:relative;margin:24px auto;box-shadow:0 30px 80px rgba(0,0,0,.5);animation:modalIn .3s cubic-bezier(.22,1,.36,1);overflow:hidden}
    @keyframes modalIn{from{opacity:0;transform:translateY(20px) scale(.96)}to{opacity:1;transform:none}}
    .modal-head{background:var(--text);color:#fff;padding:24px 26px;position:relative;overflow:hidden}
    .modal-head::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 90% 0%,rgba(12,170,79,.4),transparent 60%);pointer-events:none}
    .modal-close{position:absolute;top:12px;right:12px;background:rgba(255,255,255,.1);border:0;font-size:16px;cursor:pointer;color:#fff;line-height:1;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .15s;z-index:2}
    .modal-close:hover{background:rgba(255,255,255,.2)}
    .modal-head .pill-mini{display:inline-flex;align-items:center;gap:6px;background:rgba(12,170,79,.18);border:1px solid rgba(12,170,79,.4);color:#86efac;padding:5px 11px;border-radius:999px;font-size:11.5px;font-weight:700;margin-bottom:12px;letter-spacing:.4px;text-transform:uppercase;position:relative}
    .modal-head .pill-mini::before{content:"";width:6px;height:6px;border-radius:50%;background:#86efac;animation:pulseDot 1.6s infinite}
    .modal-head h3{font-size:22px;font-weight:800;line-height:1.2;margin:0 0 4px;letter-spacing:-.4px;position:relative}
    .modal-head p.lead2{font-size:14px;color:#cbd5e1;line-height:1.45;margin:0;position:relative}

    .modal-body{padding:22px 26px 26px}
    form.optin{display:flex;flex-direction:column;gap:11px}
    form.optin .field input[type=text],
    form.optin .field input[type=email]{width:100%;padding:13px 16px;font:inherit;font-size:15.5px;border:1.5px solid var(--border);border-radius:11px;background:var(--surface);color:var(--text);transition:border-color .15s,box-shadow .15s}
    form.optin .field input:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(12,170,79,.15)}
    .phone-row{display:flex;gap:0}
    .phone-prefix{display:flex;align-items:center;gap:6px;background:#f1f5f9;border:1.5px solid var(--border);border-right:0;border-radius:11px 0 0 11px;padding:0 12px;font-weight:700;font-size:14.5px;color:var(--text);user-select:none;flex-shrink:0}
    .ch-flag-mini{width:18px;height:14px;border-radius:2px;background:#dc2626;position:relative;display:inline-block;box-shadow:inset 0 0 0 1px rgba(0,0,0,.05)}
    .ch-flag-mini::before,.ch-flag-mini::after{content:"";position:absolute;background:#fff}
    .ch-flag-mini::before{left:7px;top:3px;width:4px;height:8px}
    .ch-flag-mini::after{left:4px;top:6px;width:10px;height:2px}
    .phone-row input[type=tel]{flex:1;padding:13px 16px;font:inherit;font-size:15.5px;border:1.5px solid var(--border);border-radius:0 11px 11px 0;background:var(--surface);color:var(--text)}
    .phone-row input[type=tel]:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(12,170,79,.15)}
    form.optin label.tos{display:flex;align-items:flex-start;gap:9px;font-size:12.5px;color:var(--text-2);padding:4px 2px;line-height:1.5;font-weight:500;margin-bottom:0}
    form.optin label.tos input[type=checkbox]{width:18px;height:18px;flex-shrink:0;margin-top:1px;accent-color:var(--accent);cursor:pointer}
    form.optin label.tos a{color:var(--accent);text-decoration:underline;font-weight:600}
    .err{color:#b91c1c;font-size:13px;text-align:center;margin-top:4px;min-height:18px;font-weight:600}
    .modal .btn{width:100%}
    .modal-trust{display:flex;align-items:center;justify-content:center;gap:14px;margin-top:14px;color:var(--text-3);font-size:11.5px;font-weight:600}
    .modal-trust .item{display:flex;align-items:center;gap:5px}
  </style>
</head>
<body>
  <div class="topbar"><span class="pulse"></span> <span><strong>Live am Dienstag, 12.05.2026 · 18:00 Uhr</strong> · Online</span></div>

  <header><img src="/images/logo.png" alt="Fit on Time" /></header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="wrap">
        <div class="hero-grid">
          <div>
            <span class="pill"><span class="live-dot"></span> Gratis Live-Workshop · <strong>12. Mai 2026</strong></span>
            <h1>Endlich verstehen, warum dein Körper <span class="underline">Fett festhält</span>.</h1>
            <p class="lead">In 60 Minuten zeige ich dir, warum bei Frauen über 35 nichts mehr funktioniert, und was du wirklich tun musst, damit dein Körper aufhört, gegen dich zu arbeiten.</p>

            <div class="outcome-pills">
              <span class="op"><span class="em">🔥</span> Fettverbrennung an</span>
              <span class="op"><span class="em">💧</span> Wasser raus</span>
              <span class="op"><span class="em">⚡</span> Energie zurück</span>
            </div>

            <div class="cta-stack">
              <button class="btn btn-large" type="button" onclick="openModal('hero')">Jetzt Platz sichern <span class="btn-arrow">→</span></button>
              <span class="cta-meta">📅 <strong>Dienstag · 18:00</strong> · Online</span>
            </div>

            <div class="trust-row">
              <span class="item"><span class="ch-flag" aria-hidden="true"></span> Aus der Schweiz</span>
              <span class="item">⭐ 3.000+ begleitete Frauen</span>
              <span class="item">🔒 100% anonym</span>
            </div>
          </div>

          <div>
            <div class="hero-vis">
              <div class="photo-frame">
                <img src="/images/transformations/t1.jpg" alt="Fit on Time Transformation" loading="eager" />
              </div>
              <div class="badge b1" style="--r:-3deg">
                <div class="ico">🔥</div>
                <div class="copy">−14 kg<small>in 5 Monaten</small></div>
              </div>
              <div class="badge b2" style="--r:2deg">
                <div class="ico">⚡</div>
                <div class="copy">Endlich Energie<small>nach 4 Wochen</small></div>
              </div>
              <div class="badge b3" style="--r:-1deg">
                <div class="ico">✅</div>
                <div class="copy">Echte Frau, echtes Ergebnis<small>Fit on Time Schweiz</small></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pain Mirror -->
    <section class="sec pain">
      <div class="wrap">
        <span class="sec-eyebrow">Erkennst du dich?</span>
        <h2 class="sec-h">Du machst alles richtig.<br/>Nichts ändert sich.</h2>

        <div class="pain-grid">
          <div class="pain-card">
            <span class="em">🔋</span>
            <span class="lbl">Müde, obwohl du schläfst</span>
          </div>
