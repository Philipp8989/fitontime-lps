---
// DSGVO-konformer Cookie-Banner  -  LP Machine (v2)
// Meta Pixel + Hyros NUR nach Consent.
// Verbesserungen v2: event_id, sendBeacon, noscript-Fallback, consent-Key pro Kunde
export interface Props {
  metaPixelId?: string;
  hyrosPh?: string;
  impressumUrl: string;
  datenschutzUrl: string;
  consentKey?: string;
}
const {
  metaPixelId = '',
  hyrosPh = '',
  impressumUrl,
  datenschutzUrl,
  consentKey = 'lp_consent',
} = Astro.props;
---
<div id="cc-banner" class="cc-banner" hidden>
  <div class="cc-inner">
    <div class="cc-text">
      <h3>Cookies & Tracking</h3>
      <p>
        Wir verwenden Cookies und Tracking-Tools (Meta, Hyros), um unsere Angebote zu verbessern und
        relevante Werbung auszuspielen. Du kannst selbst entscheiden, was du erlaubst.
        Mehr Infos in unserer <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutzerklärung</a>.
      </p>
    </div>
    <div class="cc-actions">
      <button type="button" class="cc-btn cc-ghost" data-cc="essential">Nur Notwendige</button>
      <button type="button" class="cc-btn cc-primary" data-cc="all">Alle akzeptieren</button>
    </div>
    <div class="cc-links">
      <a href={impressumUrl} target="_blank" rel="noopener">Impressum</a>
      <span>·</span>
      <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutz</a>
    </div>
  </div>
</div>

{/* Persistente Legal-Bar: Impressum + Datenschutz IMMER sichtbar (DSGVO / § 5 TMG).
    Versteckt sich nur, solange der Cookie-Consent-Banner selbst offen ist (hat die Links bereits). */}
<div id="lp-legal-bar" class="lp-legal-bar" aria-label="Rechtliche Hinweise">
  <a href={impressumUrl} target="_blank" rel="noopener">Impressum</a>
  <span aria-hidden="true">·</span>
  <a href={datenschutzUrl} target="_blank" rel="noopener">Datenschutz</a>
</div>

{/* noscript-Fallback: feuert PageView ohne JS (DSGVO: nur wenn Consent vorliegt, daher minimal) */}
{metaPixelId && (
  <noscript>
    <img height="1" width="1" style="display:none"
      src={`https://www.facebook.com/tr?id=${metaPixelId}&ev=PageView&noscript=1`}
      alt="" />
  </noscript>
)}

<style is:global>
  .cc-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 99999;
    background: rgba(10, 10, 10, 0.97);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    color: #ffffff;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    animation: cc-up .35s ease-out;
  }
  @keyframes cc-up { from { transform: translateY(100%); } to { transform: translateY(0); } }
  .cc-inner {
    max-width: 980px;
    margin: 0 auto;
    padding: 20px 20px 16px;
    display: grid;
    gap: 14px;
  }
  .cc-text h3 { font-size: 15px; font-weight: 700; margin-bottom: 6px; color: #fff; }
  .cc-text p { font-size: 13px; line-height: 1.55; color: #999999; }
  .cc-text a { color: #FF8534; text-decoration: underline; }
  .cc-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .cc-btn {
    flex: 1 1 auto;
    min-width: 140px;
    padding: 12px 18px;
    border-radius: 10px;
    font: 700 14px/1 'Inter', system-ui, sans-serif;
    cursor: pointer;
    border: 0;
    transition: transform .15s, opacity .15s, background .15s;
  }
  .cc-btn:active { transform: scale(.98); }
  .cc-primary { background: #E8630A; color: #fff; }
  .cc-primary:hover { background: #FF8534; }
  .cc-ghost { background: transparent; color: #ffffff; border: 1px solid rgba(255, 255, 255, 0.18); }
  .cc-ghost:hover { border-color: rgba(255, 255, 255, 0.32); }
  .cc-links { font-size: 11px; color: #666; text-align: center; display: flex; gap: 8px; justify-content: center; }
  .cc-links a { color: #666; text-decoration: none; }
  .cc-links a:hover { color: #999; }
  @media (min-width: 720px) {
    .cc-inner { grid-template-columns: 1fr auto; align-items: center; padding: 22px 28px 18px; }
    .cc-text { grid-column: 1 / 2; }
    .cc-actions { grid-column: 2 / 3; flex-wrap: nowrap; }
    .cc-btn { min-width: 160px; flex: 0 0 auto; }
    .cc-links { grid-column: 1 / -1; margin-top: 4px; }
  }

  /* DSGVO Legal-Bar: persistent, dezent, unten zentriert.
     Liegt unter dem Cookie-Consent-Banner (z-index 99999) und versteckt sich,
     solange der Banner offen ist (Banner zeigt die Links bereits). */
  .lp-legal-bar {
    position: fixed;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 6px 14px;
    background: rgba(10, 10, 10, 0.72);
    backdrop-filter: saturate(140%) blur(8px);
    -webkit-backdrop-filter: saturate(140%) blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    font: 500 11px/1 'Inter', system-ui, -apple-system, sans-serif;
    color: #aaa;
    white-space: nowrap;
    pointer-events: auto;
  }
  .lp-legal-bar a { color: #ddd; text-decoration: none; }
  .lp-legal-bar a:hover { color: #fff; text-decoration: underline; }
  .lp-legal-bar span { color: #666; }
  /* Wenn Cookie-Consent-Banner aktiv ist (kein [hidden]): Legal-Bar ausblenden */
  #cc-banner:not([hidden]) ~ .lp-legal-bar { display: none; }
</style>

<script is:inline define:vars={{ metaPixelId, hyrosPh, consentKey }}>
  (function () {
    var KEY = consentKey;
    var banner = document.getElementById('cc-banner');
    var current = null;
    try { current = localStorage.getItem(KEY); } catch (e) {}

    // Event-ID Generator für Meta-Deduplizierung
    function eid() {
      return Date.now() + '-' + Math.random().toString(36).slice(2, 10);
    }

    function loadMetaPixel() {
      if (!metaPixelId || window.fbq) return;
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
      n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s);}(window,
      document,'script','https://connect.facebook.net/en_US/fbevents.js');
      window.fbq('init', metaPixelId);
      window.fbq('track', 'PageView', {}, { eventID: eid() });
    }

    function loadHyros() {
      if (!hyrosPh) return;
      var s = document.createElement('script');
      s.type = 'text/javascript';
      s.async = true;
      s.src = 'https://t.hyros.com/v1/lst/universal-script?ph=' + hyrosPh;
      document.head.appendChild(s);
    }

    function applyConsent(level) {
      try { localStorage.setItem(KEY, level); } catch (e) {}
      if (banner) banner.hidden = true;
      if (level === 'all') {
        loadMetaPixel();
        loadHyros();
      }
    }

    if (current === 'all') {
      loadMetaPixel();
      loadHyros();
    } else if (current !== 'essential') {
      if (banner) banner.hidden = false;
    }

    document.querySelectorAll('[data-cc]').forEach(function (el) {
      el.addEventListener('click', function () {
        applyConsent(el.getAttribute('data-cc'));
      });
    });

    // Globale Tracking-Helfer auf window für inline-Scripts
    window.__lp = {
      eid: eid,
      // Meta-Event mit event_id feuern
      meta: function(eventName, params) {
        var id = eid();
        if (typeof fbq === 'function') {
          fbq('track', eventName, params || {}, { eventID: id });
        }
        return id;
      },
      // Dashboard-Event per sendBeacon (navigations-sicher)
      track: function(event, data, funnel, funnelName) {
        var sid = sessionStorage.getItem('lp_sid');
        if (!sid) { sid = crypto.randomUUID(); sessionStorage.setItem('lp_sid', sid); }
        var payload = JSON.stringify(Object.assign({
          event: event,
          sessionId: sid,
          funnel: funnel || '',
          funnelName: funnelName || '',
          timestamp: new Date().toISOString(),
        }, data || {}));
        var sent = navigator.sendBeacon('/api/track', new Blob([payload], { type: 'application/json' }));
        if (!sent) {
          fetch('/api/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: payload,
            keepalive: true,
          }).catch(function(){});
        }
      }
    };
  })();
</script>
